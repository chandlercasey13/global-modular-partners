---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const deliver = [
  {
    title: 'Modular Clinics',
    text: 'Primary and specialty care shells delivered with clinical adjacencies, infection control, and utility rough-ins coordinated for rapid commissioning.',
  },
  {
    title: 'Telemedicine Centers',
    text: 'Technology-forward modules with acoustic treatment, network redundancy, and provider workflows that mirror brick-and-mortar standards.',
  },
  {
    title: 'Pediatric Facilities',
    text: 'Family-centered layouts, durable finishes, and wayfinding tuned for young patients—deployed where communities need capacity fastest.',
  },
  {
    title: 'Emergency Response Units',
    text: 'Rapidly deployable clinical infrastructure for surge events, with logistics packages aligned to field operations and local regulations.',
  },
  {
    title: 'Laboratory Modules',
    text: 'Controlled environments for diagnostics and support labs with mechanical coordination for exhaust, filtration, and biosafety considerations.',
  },
  {
    title: 'Administrative Centers',
    text: 'Back-office and command spaces that scale with clinical footprints—so operations, records, and coordination stay adjacent to care.',
  },
];

const value = [
  {
    title: '50+ Healthcare Facilities Delivered',
    text: 'A growing portfolio of modular medical assets deployed with partners who understand clinical operations—not just square footage.',
  },
  {
    title: '15 Countries Served',
    text: 'International experience adapting modules to local codes, climate, and supply chains while preserving clinical performance.',
  },
  {
    title: 'Rapid Deployment',
    text: 'Factory production and disciplined site work compress timelines so communities gain capacity when it matters most.',
  },
  {
    title: 'Community Impact',
    text: 'Facilities designed to serve underserved populations with dignity, access, and continuity of care.',
  },
];
---

<Layout
  title="Healthcare"
  description="Modular medical facilities through our partnership with Hospitals Without Borders."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hc-hero">
    <div class="hc-hero__pad">
      <div class="hc-hero__inner">
        <div class="hc-hero__content">
          <nav class="hc-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="hc-breadcrumb__sep">/</span>
            <a href="/departments">Departments</a>
            <span class="hc-breadcrumb__sep">/</span>
            <span>Healthcare</span>
          </nav>
          <h1 class="hc-hero__title">Healthcare Facilities<br />Without Boundaries</h1>
          <p class="hc-hero__sub">Rapidly deployable modular medical facilities delivered through our partnership with Hospitals Without Borders.</p>
          <div class="hc-hero__actions">
            <a href="/contact" class="mnc-btn mnc-btn--dark">
              Start a Project
              <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
            </a>
            <a href="/services" class="mnc-btn mnc-btn--stroke">
              Our Services
              <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="hc-overview section-gap">
    <div class="mnc-container">
      <span class="section-tag">Overview</span>
      <h2 class="section-title hc-overview__title">Service Overview</h2>
      <p class="hc-overview__lead">
        Through our partnership with <strong>Hospitals Without Borders (HWB)</strong>, we deliver modular medical facilities that expand access to care. From clinics and pediatric units to emergency response and telemedicine, we combine rapid deployment with customization so each module meets clinical workflows, infection prevention, and local requirements.
      </p>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="hc-deliver section-gap">
    <div class="mnc-container">
      <span class="section-tag">Capabilities</span>
      <h2 class="section-title">What We <span class="section-span">Deliver</span></h2>
      <div class="hc-deliver__grid">
        <div class="hc-deliver__list">
          {deliver.map((item) => (
            <div class="hc-deliver__item">
              <h3 class="hc-deliver__item-title">{item.title}</h3>
              <p class="hc-deliver__item-text">{item.text}</p>
            </div>
          ))}
        </div>
        <aside class="hc-deliver__sidebar">
          <div class="hc-stat-card">
            <p class="hc-stat-card__big">50+</p>
            <p class="hc-stat-card__label">Healthcare facilities</p>
            <div class="hc-stat-card__row">
              <div class="hc-stat-card__cell">
                <p class="hc-stat-card__num">15</p>
                <p class="hc-stat-card__sub">Countries</p>
              </div>
              <div class="hc-stat-card__divider"></div>
              <div class="hc-stat-card__cell">
                <p class="hc-stat-card__num">HWB</p>
                <p class="hc-stat-card__sub">Partner</p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Value -->
  <section class="hc-value section-gap">
    <div class="mnc-container">
      <span class="section-tag">Impact</span>
      <h2 class="section-title">Value We Create</h2>
      <div class="hc-value__grid">
        {value.map((item) => (
          <div class="hc-value__card">
            <h3 class="hc-value__card-title">{item.title}</h3>
            <p class="hc-value__card-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="hc-strip">
    <div class="mnc-container">
      <div class="hc-strip__grid">
        <div class="hc-strip__item">
          <span class="hc-strip__num">50+</span>
          <span class="hc-strip__txt">Facilities delivered worldwide</span>
        </div>
        <div class="hc-strip__item">
          <span class="hc-strip__num">15</span>
          <span class="hc-strip__txt">Countries with active programs</span>
        </div>
        <div class="hc-strip__item">
          <span class="hc-strip__num">Fast</span>
          <span class="hc-strip__txt">Rapid deployment when timelines are critical</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hc-cta section-gap">
    <div class="mnc-container hc-cta__inner">
      <h2 class="hc-cta__title">Care infrastructure that meets the moment</h2>
      <p class="hc-cta__text">
        Partner with us to design, fabricate, and deliver modular healthcare spaces that expand capacity with clinical rigor and humanitarian intent.
      </p>
      <a href="/contact" class="mnc-btn mnc-btn--dark hc-cta__btn">
        Partner with Us
        <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Container & Section Utilities ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  .section-tag {
    display: inline-block;
    border: 1px solid var(--amber);
    border-radius: 4px;
    padding: 4px 16px;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--amber-dark);
    margin-bottom: 20px;
  }

  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin: 0 0 24px;
  }

  .section-span {
    color: var(--amber);
  }

  /* ── Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
    line-height: 1.4;
  }

  .mnc-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border-color: var(--amber);
    font-weight: 700;
  }

  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }

  .mnc-btn--stroke:hover {
    border-color: #fff;
  }

  .mnc-btn--outline {
    background: transparent;
    color: var(--dark-text);
    border: 1px solid var(--medium-gray);
  }

  .mnc-btn--outline:hover {
    border-color: var(--dark-text);
  }

  /* ── Hero ── */
  .hc-hero {
    padding: 16px;
  }

  .hc-hero__pad {
    width: 100%;
  }

  .hc-hero__inner {
    height: 560px;
    border-radius: 8px;
    background: linear-gradient(160deg, var(--navy-light) 0%, var(--navy-dark) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }

  .hc-hero__content {
    padding: 80px 1.5rem 48px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px));
    width: 100%;
  }

  .hc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 24px;
  }

  .hc-breadcrumb a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.15s;
  }

  .hc-breadcrumb a:hover {
    color: #fff;
  }

  .hc-breadcrumb__sep {
    opacity: 0.4;
  }

  .hc-hero__title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 16px;
  }

  .hc-hero__sub {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 32px;
    max-width: 540px;
  }

  .hc-hero__sub strong {
    color: #fff;
    font-weight: 600;
  }

  .hc-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ── Overview ── */
  .hc-overview {
    background: #fff;
  }

  .hc-overview__title {
    max-width: 600px;
  }

  .hc-overview__lead {
    font-size: 18px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
    max-width: 780px;
  }

  .hc-overview__lead strong {
    color: var(--navy);
    font-weight: 700;
  }

  /* ── What We Deliver ── */
  .hc-deliver {
    background: var(--off-white);
  }

  .hc-deliver__grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 48px;
    margin-top: 40px;
    align-items: start;
  }

  .hc-deliver__list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .hc-deliver__item {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--medium-gray);
  }

  .hc-deliver__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .hc-deliver__item-title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .hc-deliver__item-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
  }

  .hc-deliver__sidebar {
    position: sticky;
    top: 100px;
  }

  /* ── Stat Card (sidebar) ── */
  .hc-stat-card {
    background: linear-gradient(160deg, var(--navy-light) 0%, var(--navy-dark) 100%);
    color: #fff;
    border-radius: 8px;
    padding: 32px 28px;
  }

  .hc-stat-card__big {
    font-family: var(--font-secondary);
    font-size: clamp(48px, 7vw, 64px);
    font-weight: 700;
    line-height: 1;
    margin: 0 0 4px;
  }

  .hc-stat-card__label {
    margin: 0 0 28px;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.4;
  }

  .hc-stat-card__row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .hc-stat-card__cell {
    flex: 1;
  }

  .hc-stat-card__num {
    font-family: var(--font-secondary);
    font-weight: 700;
    font-size: 28px;
    margin: 0;
    color: var(--amber);
  }

  .hc-stat-card__sub {
    margin: 4px 0 0;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
  }

  .hc-stat-card__divider {
    width: 1px;
    align-self: stretch;
    background: rgba(255, 255, 255, 0.15);
    min-height: 44px;
  }

  /* ── Value Section ── */
  .hc-value {
    background: #fff;
  }

  .hc-value__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 16px;
  }

  .hc-value__card {
    background: var(--off-white);
    border-radius: 8px;
    padding: 32px 28px;
  }

  .hc-value__card-title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .hc-value__card-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
  }

  /* ── Stats Strip ── */
  .hc-strip {
    background: var(--navy);
    padding: 60px 0;
  }

  .hc-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    text-align: center;
  }

  .hc-strip__item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hc-strip__num {
    font-family: var(--font-secondary);
    font-size: 36px;
    font-weight: 700;
    color: var(--amber);
    line-height: 1.1;
  }

  .hc-strip__txt {
    font-size: 15px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.68);
  }

  /* ── CTA ── */
  .hc-cta {
    background: var(--navy);
  }

  .hc-cta__inner {
    text-align: center;
    max-width: 680px;
  }

  .hc-cta__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 500;
    color: #fff;
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .hc-cta__text {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 36px;
  }

  .hc-cta__btn.mnc-btn--dark {
    background: var(--amber);
    color: var(--navy-dark);
  }

  .hc-cta__btn.mnc-btn--dark:hover {
    background: #c88d2a;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hc-deliver__grid {
      grid-template-columns: 1fr;
    }

    .hc-deliver__sidebar {
      position: static;
      max-width: 360px;
    }

    .hc-strip__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 640px) {
    .section-gap {
      padding: 60px 0;
    }

    .hc-value__grid {
      grid-template-columns: 1fr;
    }

    .hc-hero__content {
      padding: 60px 1.5rem 32px;
    }

    .hc-hero__inner {
      height: 480px;
    }
  }
</style>
