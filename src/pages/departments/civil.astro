---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const deliver = [
  {
    title: 'Bridge Construction',
    text: 'Structural spans delivered with geotechnical coordination, traffic management plans, and inspection regimes suited to public infrastructure owners.',
  },
  {
    title: 'Utility Installations',
    text: 'Water, sewer, power, and communications corridors installed with as-built documentation and minimized service interruptions.',
  },
  {
    title: 'Road & Highway',
    text: 'Grading, paving, and drainage executed to spec—with sequencing that keeps corridors safer for motorists and crews.',
  },
  {
    title: 'Commercial Foundations',
    text: 'Deep and shallow foundation systems aligned with structural loads, soils reports, and modular or traditional superstructure tie-ins.',
  },
  {
    title: 'Site Development',
    text: 'Mass earthwork, erosion control, and site logistics that prepare pads for vertical construction or industrial operations.',
  },
  {
    title: 'Environmental Remediation',
    text: 'Controlled handling of impacted soils and materials with compliance pathways that protect workers, neighbors, and timelines.',
  },
];

const value = [
  {
    title: 'National Reach',
    text: 'Civil capacity deployed across regions with crews and partners who understand local conditions, agencies, and haul routes.',
  },
  {
    title: 'Full-Service Capability',
    text: 'Single-threaded delivery from early civil through turnover—reducing handoffs between earthwork, utilities, and structures.',
  },
  {
    title: 'Safety Record',
    text: 'Job hazard analysis, daily briefings, and visible leadership that keep heavy civil environments predictable.',
  },
  {
    title: 'Regulatory Compliance',
    text: 'Permitting, inspections, and environmental controls managed as part of the baseline schedule—not as afterthoughts.',
  },
];
---

<Layout
  title="Civil Construction"
  description="Infrastructure and civil construction through Agbayani Construction."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="cv-hero">
    <div class="cv-hero__pad">
      <div class="cv-hero__inner">
        <div class="cv-hero__content">
          <nav class="cv-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="cv-breadcrumb__sep">/</span>
            <a href="/departments">Departments</a>
            <span class="cv-breadcrumb__sep">/</span>
            <span>Civil</span>
          </nav>
          <h1 class="cv-hero__title">Civil Construction<br />&amp; Infrastructure</h1>
          <p class="cv-hero__sub">Large-scale infrastructure and site development projects delivered through our partner Agbayani Construction.</p>
          <div class="cv-hero__actions">
            <a href="/contact" class="mnc-btn mnc-btn--dark">
              Start a Project
              <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
            </a>
            <a href="/services" class="mnc-btn mnc-btn--stroke">
              Our Services
              <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="cv-overview section-gap">
    <div class="mnc-container">
      <span class="section-tag">Overview</span>
      <h2 class="section-title cv-overview__title">Service Overview</h2>
      <p class="cv-overview__lead">
        Civil construction at GMP is delivered through <strong>Agbayani Construction</strong>, our subsidiary focused on infrastructure and heavy civil work. From bridges and roadways to utilities, foundations, and site development, we mobilize national resources with the field leadership and compliance rigor owners expect on public and private programs.
      </p>
    </div>
  </section>

  <!-- Subsidiary Banner -->
  <section class="cv-subsidiary">
    <div class="mnc-container">
      <div class="cv-subsidiary__card">
        <span class="cv-subsidiary__label">Subsidiary</span>
        <p class="cv-subsidiary__name">Agbayani Construction</p>
        <p class="cv-subsidiary__desc">National civil execution &bull; Integrated with GMP modular and program teams</p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="cv-deliver section-gap">
    <div class="mnc-container">
      <span class="section-tag">Capabilities</span>
      <h2 class="section-title">What We <span class="section-span">Deliver</span></h2>
      <div class="cv-deliver__grid">
        <div class="cv-deliver__list">
          {deliver.map((item) => (
            <div class="cv-deliver__item">
              <h3 class="cv-deliver__item-title">{item.title}</h3>
              <p class="cv-deliver__item-text">{item.text}</p>
            </div>
          ))}
        </div>
        <aside class="cv-deliver__sidebar">
          <div class="cv-deliver__img" aria-hidden="true"></div>
          <div class="cv-deliver__checklist">
            <ul>
              <li>DOT &amp; municipal coordination</li>
              <li>Utility conflict matrices</li>
              <li>SWPPP &amp; erosion control</li>
              <li>QA/QC test &amp; inspection logs</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Value -->
  <section class="cv-value section-gap">
    <div class="mnc-container">
      <span class="section-tag">Outcomes</span>
      <h2 class="section-title">Value We Create</h2>
      <div class="cv-value__grid">
        {value.map((item) => (
          <div class="cv-value__card">
            <h3 class="cv-value__card-title">{item.title}</h3>
            <p class="cv-value__card-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="cv-strip">
    <div class="mnc-container">
      <div class="cv-strip__grid">
        <div class="cv-strip__item">
          <span class="cv-strip__key">National</span>
          <span class="cv-strip__val">Multi-region civil teams</span>
        </div>
        <div class="cv-strip__item">
          <span class="cv-strip__key">Full-service</span>
          <span class="cv-strip__val">Earthwork through vertical-ready pads</span>
        </div>
        <div class="cv-strip__item">
          <span class="cv-strip__key">Safety</span>
          <span class="cv-strip__val">Leadership-led field culture</span>
        </div>
        <div class="cv-strip__item">
          <span class="cv-strip__key">Compliance</span>
          <span class="cv-strip__val">Permits, inspections, documentation</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cv-cta section-gap">
    <div class="mnc-container cv-cta__inner">
      <h2 class="cv-cta__title">Groundwork that holds up the rest of the job</h2>
      <p class="cv-cta__text">
        When civil, utilities, and structures move in sequence, you avoid costly rework. Talk to us about integrated delivery for your next infrastructure or development project.
      </p>
      <a href="/contact" class="mnc-btn mnc-btn--dark cv-cta__btn">
        Start Your Project
        <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Container & Section Utilities ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  .section-tag {
    display: inline-block;
    border: 1px solid var(--amber);
    border-radius: 4px;
    padding: 4px 16px;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--amber-dark);
    margin-bottom: 20px;
  }

  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin: 0 0 24px;
  }

  .section-span {
    color: var(--amber);
  }

  /* ── Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
    line-height: 1.4;
  }

  .mnc-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border-color: var(--amber);
    font-weight: 700;
  }

  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }

  .mnc-btn--stroke:hover {
    border-color: #fff;
  }

  .mnc-btn--outline {
    background: transparent;
    color: var(--dark-text);
    border: 1px solid var(--medium-gray);
  }

  .mnc-btn--outline:hover {
    border-color: var(--dark-text);
  }

  /* ── Hero ── */
  .cv-hero {
    padding: 16px;
  }

  .cv-hero__pad {
    width: 100%;
  }

  .cv-hero__inner {
    height: 560px;
    border-radius: 8px;
    background: linear-gradient(160deg, var(--navy-light) 0%, var(--navy-dark) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }

  .cv-hero__content {
    padding: 80px 1.5rem 48px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px));
    width: 100%;
  }

  .cv-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 24px;
  }

  .cv-breadcrumb a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.15s;
  }

  .cv-breadcrumb a:hover {
    color: #fff;
  }

  .cv-breadcrumb__sep {
    opacity: 0.4;
  }

  .cv-hero__title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 16px;
  }

  .cv-hero__sub {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 32px;
    max-width: 540px;
  }

  .cv-hero__sub strong {
    color: #fff;
    font-weight: 600;
  }

  .cv-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ── Overview ── */
  .cv-overview {
    background: #fff;
  }

  .cv-overview__title {
    max-width: 600px;
  }

  .cv-overview__lead {
    font-size: 18px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
    max-width: 780px;
  }

  .cv-overview__lead strong {
    color: var(--navy);
    font-weight: 700;
  }

  /* ── Subsidiary Banner ── */
  .cv-subsidiary {
    background: var(--off-white);
    padding: 48px 0;
  }

  .cv-subsidiary__card {
    border-left: 4px solid var(--amber);
    padding: 28px 32px;
    background: #fff;
    border-radius: 0 8px 8px 0;
  }

  .cv-subsidiary__label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 8px;
  }

  .cv-subsidiary__name {
    font-family: var(--font-secondary);
    font-size: 24px;
    font-weight: 600;
    color: var(--navy);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .cv-subsidiary__desc {
    margin: 0;
    font-size: 15px;
    color: var(--text-gray);
    line-height: 1.5;
  }

  /* ── What We Deliver ── */
  .cv-deliver {
    background: #fff;
  }

  .cv-deliver__grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    margin-top: 40px;
    align-items: start;
  }

  .cv-deliver__list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .cv-deliver__item {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--medium-gray);
  }

  .cv-deliver__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .cv-deliver__item-title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .cv-deliver__item-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
  }

  .cv-deliver__sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cv-deliver__img {
    min-height: 200px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--navy-light) 0%, var(--navy-dark) 100%);
  }

  .cv-deliver__checklist {
    background: var(--off-white);
    border-radius: 8px;
    padding: 24px;
  }

  .cv-deliver__checklist ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cv-deliver__checklist li {
    position: relative;
    padding-left: 22px;
    font-size: 15px;
    color: var(--text-gray);
    line-height: 1.5;
  }

  .cv-deliver__checklist li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--amber);
  }

  /* ── Value Section ── */
  .cv-value {
    background: var(--off-white);
  }

  .cv-value__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 16px;
  }

  .cv-value__card {
    background: #fff;
    border-radius: 8px;
    padding: 32px 28px;
  }

  .cv-value__card-title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .cv-value__card-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
  }

  /* ── Stats Strip ── */
  .cv-strip {
    background: var(--navy);
    padding: 60px 0;
  }

  .cv-strip__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .cv-strip__item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cv-strip__key {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--amber);
    line-height: 1.3;
  }

  .cv-strip__val {
    font-size: 15px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.68);
  }

  /* ── CTA ── */
  .cv-cta {
    background: var(--navy);
  }

  .cv-cta__inner {
    text-align: center;
    max-width: 680px;
  }

  .cv-cta__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 500;
    color: #fff;
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .cv-cta__text {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 36px;
  }

  .cv-cta__btn.mnc-btn--dark {
    background: var(--amber);
    color: var(--navy-dark);
  }

  .cv-cta__btn.mnc-btn--dark:hover {
    background: #c88d2a;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .cv-deliver__grid {
      grid-template-columns: 1fr;
    }

    .cv-deliver__sidebar {
      position: static;
      max-width: 360px;
    }

    .cv-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .section-gap {
      padding: 60px 0;
    }

    .cv-value__grid {
      grid-template-columns: 1fr;
    }

    .cv-strip__grid {
      grid-template-columns: 1fr;
    }

    .cv-hero__content {
      padding: 60px 1.5rem 32px;
    }

    .cv-hero__inner {
      height: 480px;
    }
  }
</style>
