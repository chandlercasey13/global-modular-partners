---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const deliver = [
  {
    title: 'DoD Contract Management',
    text: 'Structured governance for defense and federal programs—requirements traceability, change control, and stakeholder alignment across the contract lifecycle.',
  },
  {
    title: 'Federal Project Compliance',
    text: 'Documentation, reporting, and process rigor aligned with federal acquisition and construction standards so deliverables pass scrutiny.',
  },
  {
    title: 'Security Clearance Coordination',
    text: 'Sequencing of cleared personnel, site access, and subcontractor compliance to protect sensitive environments without slowing delivery.',
  },
  {
    title: 'Rapid Deployment Planning',
    text: 'Compressed schedules with parallel workstreams, early procurement, and logistics playbooks built for fast mobilization.',
  },
  {
    title: 'Risk Assessment & Mitigation',
    text: 'Identification of schedule, cost, and operational risks with mitigations tracked to owners and decision milestones.',
  },
  {
    title: 'Quality Assurance Programs',
    text: 'Inspection and test plans, hold points, and digital records that prove workmanship and spec conformance at turnover.',
  },
];

const value = [
  {
    title: 'On-Time Delivery',
    text: 'Milestone-driven planning and field coordination keep critical paths visible and actionable through closeout.',
  },
  {
    title: 'Budget Adherence',
    text: 'Forecasting, earned value discipline, and scope control protect funding lines while preserving mission outcomes.',
  },
  {
    title: 'Full Compliance',
    text: 'Federal, safety, and contractual requirements embedded in workflows—not bolted on at the end.',
  },
  {
    title: 'Risk Mitigation',
    text: 'Early signals, contingency planning, and cross-functional reviews reduce surprises during execution.',
  },
  {
    title: 'Transparent Reporting',
    text: 'Executive-ready dashboards and written status so sponsors see progress, blockers, and decisions clearly.',
  },
];

const tools = ['Procore', 'Microsoft Project', 'BIM 360', 'PlanGrid', 'AutoCAD', 'Primavera P6'];
---

<Layout
  title="Project Management"
  description="Expert project delivery with DoD and military compliance and proven methodology."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="pm-hero">
    <div class="pm-hero__pad">
      <div class="pm-hero__inner">
        <div class="pm-hero__content">
          <nav class="pm-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="pm-breadcrumb__sep">/</span>
            <a href="/#departments">Departments</a>
            <span class="pm-breadcrumb__sep">/</span>
            <span>Project Management</span>
          </nav>
          <h1 class="pm-hero__h1">End-to-End<br />Project Management</h1>
          <p class="pm-hero__sub">Expert delivery from pre-construction through close-out, with full DoD compliance and proven methodology.</p>
          <div class="pm-hero__btns">
            <a href="/services" class="mnc-btn mnc-btn--dark">
              View Our Work
              <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
            </a>
            <a href="/services" class="mnc-btn mnc-btn--stroke">
              Our Services
              <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="pm-overview section-gap">
    <div class="mnc-container">
      <span class="section-tag">Overview</span>
      <h2 class="section-title">Service Overview</h2>
      <p class="pm-overview__lead">
        GMP's project management department plans, directs, and controls complex construction programs with disciplined communication, quality assurance, and
        documentation. We bring extensive Department of Defense and federal experience—so schedules, compliance, and mission readiness stay in lockstep from
        kickoff through turnover.
      </p>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="pm-deliver section-gap">
    <div class="mnc-container">
      <span class="section-tag">Capabilities</span>
      <h2 class="section-title">What We Deliver</h2>
      <div class="pm-deliver__grid">
        <div class="pm-deliver__list">
          {deliver.map((item) => (
            <div class="pm-deliver__item">
              <h3 class="pm-deliver__item-title">{item.title}</h3>
              <p class="pm-deliver__item-text">{item.text}</p>
            </div>
          ))}
        </div>
        <aside class="pm-deliver__sidebar">
          <div class="pm-statboard">
            <div class="pm-statboard__item">
              <span class="pm-statboard__num">DoD</span>
              <span class="pm-statboard__lbl">Federal program fluency</span>
            </div>
            <div class="pm-statboard__item">
              <span class="pm-statboard__num">QA</span>
              <span class="pm-statboard__lbl">Documented conformance</span>
            </div>
            <div class="pm-statboard__item">
              <span class="pm-statboard__num">PMO</span>
              <span class="pm-statboard__lbl">Single source of truth</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Value -->
  <section class="pm-value section-gap">
    <div class="mnc-container">
      <span class="section-tag">Outcomes</span>
      <h2 class="section-title">Value We Create</h2>
      <div class="pm-value__grid">
        {value.map((item) => (
          <div class="pm-value__card">
            <h3 class="pm-value__card-title">{item.title}</h3>
            <p class="pm-value__card-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="pm-stats">
    <div class="mnc-container">
      <div class="pm-stats__grid">
        <div class="pm-stats__item">
          <span class="pm-stats__num">360°</span>
          <span class="pm-stats__label">Schedule & cost visibility</span>
        </div>
        <div class="pm-stats__item">
          <span class="pm-stats__num">Fed</span>
          <span class="pm-stats__label">Compliance-first workflows</span>
        </div>
        <div class="pm-stats__item">
          <span class="pm-stats__num">RACI</span>
          <span class="pm-stats__label">Clear ownership & escalation</span>
        </div>
        <div class="pm-stats__item">
          <span class="pm-stats__num">ROI</span>
          <span class="pm-stats__label">Fewer rework cycles</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section class="pm-tools section-gap">
    <div class="mnc-container">
      <span class="section-tag">Platforms</span>
      <h2 class="section-title">Tools & Platforms</h2>
      <p class="pm-tools__desc">
        We meet teams where they work—common construction and program platforms integrated into reporting rhythms you can audit.
      </p>
      <div class="pm-tools__row">
        {tools.map((name) => (
          <span class="pm-tool-pill">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Container & Shared ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin: 0 0 24px;
  }

  /* ── Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
    line-height: 1.4;
  }

  .mnc-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border: 1px solid var(--amber);
    font-weight: 700;
  }

  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background: transparent;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .mnc-btn--stroke:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  /* ── Hero ── */
  .pm-hero {
    padding: 16px;
  }

  .pm-hero__inner {
    background: linear-gradient(145deg, var(--navy) 0%, var(--navy-dark) 100%);
    border-radius: 8px;
    height: 560px;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }

  .pm-hero__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(224, 161, 53, 0.1) 0%, transparent 55%);
    pointer-events: none;
  }

  .pm-hero__content {
    position: relative;
    padding: 80px 1.5rem 48px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px));
    width: 100%;
  }

  .pm-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 24px;
  }

  .pm-breadcrumb a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .pm-breadcrumb a:hover {
    color: var(--amber);
  }

  .pm-breadcrumb__sep {
    opacity: 0.4;
  }

  .pm-hero__h1 {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 16px;
    max-width: 680px;
  }

  .pm-hero__sub {
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 32px;
    max-width: 520px;
  }

  .pm-hero__btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ── Overview ── */
  .pm-overview {
    background: #fff;
  }

  .pm-overview__lead {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
    max-width: 820px;
  }

  /* ── What We Deliver ── */
  .pm-deliver {
    background: var(--off-white);
  }

  .pm-deliver__grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 48px;
    margin-top: 40px;
    align-items: start;
  }

  .pm-deliver__list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pm-deliver__item-title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .pm-deliver__item-text {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-gray);
  }

  .pm-deliver__sidebar {
    position: sticky;
    top: 100px;
  }

  .pm-statboard {
    background: #fff;
    border-radius: 8px;
    border: 1px solid var(--medium-gray);
    overflow: hidden;
  }

  .pm-statboard__item {
    padding: 24px;
    border-bottom: 1px solid var(--medium-gray);
  }

  .pm-statboard__item:last-child {
    border-bottom: none;
  }

  .pm-statboard__num {
    display: block;
    font-family: var(--font-secondary);
    font-weight: 800;
    font-size: 24px;
    color: var(--navy);
    letter-spacing: 0.02em;
    margin-bottom: 4px;
  }

  .pm-statboard__lbl {
    font-size: 14px;
    color: var(--text-gray);
    line-height: 1.45;
  }

  /* ── Value ── */
  .pm-value {
    background: #fff;
  }

  .pm-value__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 16px;
  }

  .pm-value__card {
    background: var(--off-white);
    border-radius: 8px;
    padding: 28px 24px;
  }

  .pm-value__card-title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .pm-value__card-text {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
  }

  /* ── Stats Strip ── */
  .pm-stats {
    background: var(--navy);
    padding: 60px 0;
  }

  .pm-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }

  .pm-stats__num {
    display: block;
    font-family: var(--font-secondary);
    font-size: 36px;
    font-weight: 700;
    color: var(--amber);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .pm-stats__label {
    font-size: 14px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Tools ── */
  .pm-tools {
    background: var(--off-white);
  }

  .pm-tools__desc {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-gray);
    max-width: 600px;
    margin: 0 0 28px;
  }

  .pm-tools__row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .pm-tool-pill {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--navy);
    background: #fff;
    border: 1px solid var(--medium-gray);
    border-radius: 100px;
    transition: border-color 0.2s, color 0.2s;
  }

  .pm-tool-pill:hover {
    border-color: var(--amber);
    color: var(--amber);
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .pm-deliver__grid {
      grid-template-columns: 1fr;
    }

    .pm-deliver__sidebar {
      position: static;
    }

    .pm-value__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .section-gap {
      padding: 64px 0;
    }

    .pm-hero__inner {
      height: 480px;
    }

    .pm-hero__content {
      padding: 60px 1.5rem 32px;
    }

    .pm-stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .pm-value__grid {
      grid-template-columns: 1fr;
    }

    .pm-stats__grid {
      grid-template-columns: 1fr;
    }

    .pm-stats {
      padding: 40px 0;
    }

    .pm-hero__btns {
      flex-direction: column;
    }
  }
</style>
