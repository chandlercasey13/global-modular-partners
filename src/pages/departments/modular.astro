---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const deliver = [
  {
    title: 'Volumetric Module Fabrication',
    text: 'Complete room-scale units built in factory-controlled conditions using welded steel tubes and beams (HSS) connected with special connectors for superior structural integrity.',
  },
  {
    title: 'FrameCAD Light Gauge Framing',
    text: 'Precision-cut light gauge stud walls using FrameCAD technology for consistent dimensional accuracy and rapid assembly.',
  },
  {
    title: 'Integrated MEP Systems',
    text: 'Rough mechanical, electrical, and plumbing installed in-factory alongside HVAC, ensuring coordinated systems before modules leave the production line.',
  },
  {
    title: 'Multi-Manufacturer Coordination',
    text: 'GMP works with multiple manufacturers across the country, selecting the right partners based on project location, budget, feasibility, and logistics.',
  },
  {
    title: 'Complete Interior Finishing',
    text: 'Factory-installed insulation, interior walls, doors, windows, paint, cabinets, fixtures, and optional furniture — modules arrive site-ready.',
  },
  {
    title: 'Exterior Cladding & Protection',
    text: 'Exterior cladding applied in factory, followed by shrink-wrap protection for transport and on-site storage until installation.',
  },
];

const value = [
  {
    title: '30–50% Faster Delivery',
    text: 'Parallel factory production and site work compress overall duration so you occupy sooner and reduce carrying costs.',
  },
  {
    title: 'Superior Quality Control',
    text: 'Factory-controlled process with repeatable inspections ensures exceptional construction quality that meets or exceeds site-built standards.',
  },
  {
    title: 'Reduced Material Waste',
    text: 'Controlled inventory management and recycling in the factory environment eliminates waste compared to traditional on-site construction.',
  },
  {
    title: 'Weather-Independent',
    text: '60–90% of construction completed inside a factory, eliminating weather delays and protecting materials during the build process.',
  },
  {
    title: 'Minimal Site Disruption',
    text: 'Shortened on-site duration limits noise, traffic, and safety exposure for neighbors and ongoing operations.',
  },
];

const projects = [
  { title: 'Commercial Office', location: 'San Francisco, CA', text: 'Core-and-shell modular office with high-performance envelope and fast tenant fit-out.' },
  { title: 'Residential Complex', location: 'Austin, TX', text: 'Large-scale housing delivered with repeatable modules and coordinated vertical transportation.' },
  { title: 'Educational Facility', location: 'Denver, CO', text: 'Campus expansion with classrooms and support spaces installed during active school terms.' },
  { title: 'Retail Center', location: 'Phoenix, AZ', text: 'Mixed-use retail and service bays assembled for speed to revenue and phased openings.' },
];
---

<Layout
  title="Modular Construction"
  description="Innovative off-site building solutions for commercial, residential, and industrial applications."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="mod-hero">
    <div class="mod-hero__pad">
      <div class="mod-hero__inner">
        <div class="mod-hero__content">
          <nav class="mod-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="mod-breadcrumb__sep">/</span>
            <a href="/#departments">Departments</a>
            <span class="mod-breadcrumb__sep">/</span>
            <span>Modular Construction</span>
          </nav>
          <h1 class="mod-hero__h1">Modular Construction<br />Built for Scale</h1>
          <p class="mod-hero__sub">Precision-engineered off-site building solutions for commercial, residential, and industrial projects worldwide.</p>
          <div class="mod-hero__btns">
            <a href="/contact" class="mnc-btn mnc-btn--dark">
              Start a Project
              <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
            </a>
            <a href="/services" class="mnc-btn mnc-btn--stroke">
              Our Services
              <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="mod-overview section-gap">
    <div class="mnc-container">
      <span class="section-tag">Overview</span>
      <h2 class="section-title mod-overview__title">Service Overview</h2>
      <p class="mod-overview__lead">
        GMP works with multiple manufacturers across the country and selects the right ones based on project location, budget, feasibility, logistics, and more. Our modular structures are made from welded steel tubes and beams (HSS), connected using special connectors for superior strength. 60–90% of construction is completed inside factory-controlled settings, then modules are transported to the site and assembled into complete, high-performing structures.
      </p>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="mod-deliver section-gap">
    <div class="mnc-container">
      <span class="section-tag">Capabilities</span>
      <h2 class="section-title">What We <span class="section-span">Deliver</span></h2>
      <div class="mod-deliver__grid">
        <div class="mod-deliver__list">
          {deliver.map((item) => (
            <div class="mod-deliver__item">
              <h3 class="mod-deliver__item-title">{item.title}</h3>
              <p class="mod-deliver__item-text">{item.text}</p>
            </div>
          ))}
        </div>
        <aside class="mod-deliver__sidebar">
          <div class="mod-featured-stat">
            <span class="mod-featured-stat__eyebrow">Featured Program</span>
            <p class="mod-featured-stat__num">28</p>
            <p class="mod-featured-stat__label">Day ADU Delivery</p>
            <p class="mod-featured-stat__desc">
              Our 28-Day ADU program pairs factory production with disciplined site logistics so homeowners and developers get permitted, livable units on an
              aggressive calendar.
            </p>
          </div>
          <div class="mod-dotgrid" aria-hidden="true"></div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Value -->
  <section class="mod-value section-gap">
    <div class="mnc-container">
      <span class="section-tag">Value</span>
      <h2 class="section-title">Value We Create</h2>
      <div class="mod-value__grid">
        {value.map((item) => (
          <div class="mod-value__card">
            <h3 class="mod-value__card-title">{item.title}</h3>
            <p class="mod-value__card-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="mod-stats">
    <div class="mnc-container">
      <div class="mod-stats__grid">
        <div class="mod-stats__item">
          <span class="mod-stats__num">50%</span>
          <span class="mod-stats__label">Faster delivery vs. traditional</span>
        </div>
        <div class="mod-stats__item">
          <span class="mod-stats__num">28</span>
          <span class="mod-stats__label">Day ADU program</span>
        </div>
        <div class="mod-stats__item">
          <span class="mod-stats__num">100%</span>
          <span class="mod-stats__label">Code-aligned factory QC</span>
        </div>
        <div class="mod-stats__item">
          <span class="mod-stats__num">Low</span>
          <span class="mod-stats__label">On-site disruption profile</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="mod-projects section-gap">
    <div class="mnc-container">
      <span class="section-tag">Projects</span>
      <h2 class="section-title">Representative Projects</h2>
      <div class="mod-projects__grid">
        {projects.map((p) => (
          <article class="mod-project-card">
            <div class="mod-project-card__thumb" aria-hidden="true"></div>
            <div class="mod-project-card__body">
              <span class="mod-project-card__loc">{p.location}</span>
              <h3 class="mod-project-card__title">{p.title}</h3>
              <p class="mod-project-card__text">{p.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mod-cta section-gap">
    <div class="mnc-container">
      <div class="mod-cta__inner">
        <h2 class="mod-cta__heading">Scale certainty without sacrificing design</h2>
        <p class="mod-cta__sub">
          From first sketch to final inspection, we align manufacturing, logistics, and field teams so your modular project lands on time and on budget.
        </p>
        <div class="mod-cta__line"></div>
        <a href="/contact" class="mnc-btn mnc-btn--dark">
          Start Your Modular Project
          <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg>
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Container & Shared ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  .section-tag {
    display: inline-block;
    border: 1px solid var(--amber);
    border-radius: 4px;
    padding: 4px 16px;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--amber-dark);
    margin-bottom: 20px;
  }

  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin: 0 0 24px;
  }

  .section-span {
    color: var(--amber);
  }

  /* ── Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
    line-height: 1.4;
  }

  .mnc-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border: 1px solid var(--amber);
    font-weight: 700;
  }

  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background: transparent;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .mnc-btn--stroke:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  /* ── Hero ── */
  .mod-hero {
    padding: 16px;
  }

  .mod-hero__inner {
    background: linear-gradient(145deg, var(--navy) 0%, var(--navy-dark) 100%);
    border-radius: 8px;
    height: 560px;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }

  .mod-hero__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(224, 161, 53, 0.1) 0%, transparent 55%);
    pointer-events: none;
  }

  .mod-hero__content {
    position: relative;
    padding: 80px 1.5rem 48px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px));
    width: 100%;
  }

  .mod-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 24px;
  }

  .mod-breadcrumb a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .mod-breadcrumb a:hover {
    color: var(--amber);
  }

  .mod-breadcrumb__sep {
    opacity: 0.4;
  }

  .mod-hero__h1 {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 16px;
    max-width: 680px;
  }

  .mod-hero__sub {
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 32px;
    max-width: 520px;
  }

  .mod-hero__btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ── Overview ── */
  .mod-overview {
    background: #fff;
  }

  .mod-overview__title {
    max-width: 820px;
  }

  .mod-overview__lead {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
    max-width: 820px;
  }

  /* ── What We Deliver ── */
  .mod-deliver {
    background: var(--off-white);
  }

  .mod-deliver__grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 48px;
    margin-top: 40px;
    align-items: start;
  }

  .mod-deliver__list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .mod-deliver__item-title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .mod-deliver__item-text {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-gray);
  }

  .mod-deliver__sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 100px;
  }

  .mod-featured-stat {
    background: linear-gradient(145deg, var(--navy) 0%, var(--navy-dark) 100%);
    border-radius: 8px;
    padding: 32px 28px;
    color: #fff;
  }

  .mod-featured-stat__eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 12px;
  }

  .mod-featured-stat__num {
    font-family: var(--font-secondary);
    font-size: clamp(48px, 8vw, 68px);
    font-weight: 800;
    line-height: 1;
    margin: 0;
    color: #fff;
  }

  .mod-featured-stat__label {
    font-family: var(--font-secondary);
    font-weight: 600;
    font-size: 18px;
    margin: 6px 0 16px;
    color: rgba(255, 255, 255, 0.9);
  }

  .mod-featured-stat__desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
  }

  .mod-dotgrid {
    min-height: 180px;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--medium-gray);
    background-image: radial-gradient(circle at 1px 1px, rgba(224, 161, 53, 0.12) 1px, transparent 0);
    background-size: 20px 20px;
  }

  /* ── Value ── */
  .mod-value {
    background: #fff;
  }

  .mod-value__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 16px;
  }

  .mod-value__card {
    background: var(--off-white);
    border-radius: 8px;
    padding: 28px 24px;
  }

  .mod-value__card-title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .mod-value__card-text {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
  }

  /* ── Stats Strip ── */
  .mod-stats {
    background: var(--navy);
    padding: 60px 0;
  }

  .mod-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }

  .mod-stats__num {
    display: block;
    font-family: var(--font-secondary);
    font-size: 36px;
    font-weight: 700;
    color: var(--amber);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .mod-stats__label {
    font-size: 14px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Projects ── */
  .mod-projects {
    background: var(--off-white);
  }

  .mod-projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 32px;
  }

  .mod-project-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .mod-project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(36, 55, 85, 0.12);
  }

  .mod-project-card__thumb {
    height: 160px;
    background: linear-gradient(120deg, var(--navy-light) 0%, var(--navy-dark) 100%);
  }

  .mod-project-card__body {
    padding: 24px;
  }

  .mod-project-card__loc {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber);
  }

  .mod-project-card__title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 8px 0 10px;
    line-height: 1.3;
  }

  .mod-project-card__text {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-gray);
  }

  /* ── CTA ── */
  .mod-cta {
    background: var(--navy);
  }

  .mod-cta__inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .mod-cta__heading {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .mod-cta__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 28px;
  }

  .mod-cta__line {
    width: 48px;
    height: 3px;
    background: var(--amber);
    border-radius: 2px;
    margin: 0 auto 28px;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .mod-deliver__grid {
      grid-template-columns: 1fr;
    }

    .mod-deliver__sidebar {
      position: static;
    }

    .mod-value__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .section-gap {
      padding: 64px 0;
    }

    .mod-hero__inner {
      height: 480px;
    }

    .mod-hero__content {
      padding: 60px 1.5rem 32px;
    }

    .mod-stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .mod-projects__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .mod-value__grid {
      grid-template-columns: 1fr;
    }

    .mod-stats__grid {
      grid-template-columns: 1fr;
    }

    .mod-stats {
      padding: 40px 0;
    }

    .mod-hero__btns {
      flex-direction: column;
    }
  }
</style>
