---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const capabilities = [
  {
    title: 'Military Construction (MILCON)',
    text: 'Purpose-built facilities meeting UFC/UFGS standards—barracks, maintenance bays, operations centers, and support infrastructure delivered to Unified Facilities Criteria.',
  },
  {
    title: 'Security Clearance Programs',
    text: 'Facility and personnel clearance coordination for classified environments, including SCIF construction, SAP spaces, and secure compartmented access controls.',
  },
  {
    title: 'Anti-Terrorism / Force Protection (AT/FP)',
    text: 'Blast-resistant design integration, progressive collapse mitigation, and setback-compliant site planning per DoD Minimum Antiterrorism Standards.',
  },
  {
    title: 'Past Performance Documentation',
    text: 'CPARS-ready records, past performance narrative development, and reference coordination that strengthen competitive federal proposals.',
  },
  {
    title: 'Contingency Construction',
    text: 'Rapid-deploy structures for forward operating bases, expeditionary medical facilities, and contingency basing needs with compressed mobilization timelines.',
  },
  {
    title: 'Base Operations Support',
    text: 'Operations and maintenance, sustainment planning, and life-cycle facility management that keep installations mission-capable year over year.',
  },
];

const value = [
  {
    title: 'Mission Readiness',
    text: 'Facilities delivered operational and compliant on day one—tested, commissioned, and ready to support the warfighter.',
  },
  {
    title: 'Security Compliance',
    text: 'SCIF, SAP, and classified space requirements met without schedule impact through early integration of ICD 705 and security engineering.',
  },
  {
    title: 'Federal Acquisition Fluency',
    text: 'FAR/DFARS, Davis-Bacon, Buy American, and trade agreement fluency embedded across every contract and subcontract tier.',
  },
  {
    title: 'Past Performance Record',
    text: 'Documented contract success with Exceptional and Very Good CPARS ratings supporting competitive proposals and task order awards.',
  },
  {
    title: 'Rapid Mobilization',
    text: 'Expeditionary capability from notice-to-proceed to beneficial occupancy—logistics, labor, and material pipelines pre-positioned for speed.',
  },
];
---

<Layout
  title="DoD / Military"
  description="Mission-critical facilities and infrastructure for the Department of Defense, delivered with compliance, security, and precision."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="dod-hero">
    <div class="dod-hero__pad">
      <div class="dod-hero__inner">
        <div class="dod-hero__content">
          <nav class="dod-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="dod-breadcrumb__sep">/</span>
            <a href="/#departments">Departments</a>
            <span class="dod-breadcrumb__sep">/</span>
            <span>DoD / Military</span>
          </nav>
          <h1 class="dod-hero__h1">DoD & Military<br /><span class="hero-span">Construction</span></h1>
          <p class="dod-hero__sub">Mission-critical facilities and infrastructure delivered with the compliance, security, and precision that defense programs demand.</p>
          <div class="dod-hero__btns">
            <a href="/services" class="mnc-btn mnc-btn--dark">
              View Our Work
              <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
            </a>
            <a href="/services" class="mnc-btn mnc-btn--stroke">
              Our Services
              <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="dod-overview section-gap">
    <div class="mnc-container">
      <span class="section-tag">Overview</span>
      <h2 class="section-title">Department Overview</h2>
      <p class="dod-overview__lead">
        GMP's DoD/Military department delivers federal construction with a compliance-first approach built for the scrutiny defense programs demand. Our cleared personnel, UFC-aligned processes, and OCONUS/CONUS delivery experience mean facilities arrive mission-ready—with the documentation, security controls, and past performance record that keep programs on contract and on schedule.
      </p>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="dod-deliver section-gap">
    <div class="mnc-container">
      <span class="section-tag">Capabilities</span>
      <h2 class="section-title">What We Deliver</h2>
      <div class="dod-deliver__grid">
        <div class="dod-deliver__list">
          {capabilities.map((item) => (
            <div class="dod-deliver__item">
              <h3 class="dod-deliver__item-title">{item.title}</h3>
              <p class="dod-deliver__item-text">{item.text}</p>
            </div>
          ))}
        </div>
        <aside class="dod-deliver__sidebar">
          <div class="dod-statboard">
            <div class="dod-statboard__item">
              <span class="dod-statboard__num">SECRET</span>
              <span class="dod-statboard__lbl">Clearance level</span>
            </div>
            <div class="dod-statboard__item">
              <span class="dod-statboard__num">UFC</span>
              <span class="dod-statboard__lbl">Design standards</span>
            </div>
            <div class="dod-statboard__item">
              <span class="dod-statboard__num">CPARS</span>
              <span class="dod-statboard__lbl">Performance tracking</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Value -->
  <section class="dod-value section-gap">
    <div class="mnc-container">
      <span class="section-tag">Outcomes</span>
      <h2 class="section-title">Value We Create</h2>
      <div class="dod-value__grid">
        {value.map((item) => (
          <div class="dod-value__card">
            <h3 class="dod-value__card-title">{item.title}</h3>
            <p class="dod-value__card-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="dod-stats">
    <div class="mnc-container">
      <div class="dod-stats__grid">
        <div class="dod-stats__item">
          <span class="dod-stats__num">SCIF</span>
          <span class="dod-stats__label">Secure facility delivery</span>
        </div>
        <div class="dod-stats__item">
          <span class="dod-stats__num">FAR</span>
          <span class="dod-stats__label">Acquisition compliance</span>
        </div>
        <div class="dod-stats__item">
          <span class="dod-stats__num">AT/FP</span>
          <span class="dod-stats__label">Force protection</span>
        </div>
        <div class="dod-stats__item">
          <span class="dod-stats__num">NTP→BOD</span>
          <span class="dod-stats__label">Fast mobilization</span>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Container & Shared ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin: 0 0 24px;
  }

  /* ── Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
    line-height: 1.4;
  }

  .mnc-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border: 1px solid var(--amber);
    font-weight: 700;
  }

  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background: transparent;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .mnc-btn--stroke:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  /* ── Hero ── */
  .dod-hero {
    padding: 16px;
  }

  .dod-hero__inner {
    background: linear-gradient(145deg, var(--navy) 0%, var(--navy-dark) 100%);
    border-radius: 8px;
    height: 490px;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }

  .dod-hero__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(224, 161, 53, 0.1) 0%, transparent 55%);
    pointer-events: none;
  }

  .dod-hero__content {
    position: relative;
    padding: 80px 1.5rem 36px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px));
    width: 100%;
  }

  .dod-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 24px;
  }

  .dod-breadcrumb a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .dod-breadcrumb a:hover {
    color: var(--amber);
  }

  .dod-breadcrumb__sep {
    opacity: 0.4;
  }

  .dod-hero__h1 {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 16px;
    max-width: 680px;
  }
  .hero-span { color: rgba(255,255,255,.5); }

  .dod-hero__sub {
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 32px;
    max-width: 520px;
  }

  .dod-hero__btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ── Overview ── */
  .dod-overview {
    background: #fff;
  }

  .dod-overview__lead {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
    max-width: 820px;
  }

  /* ── Capabilities ── */
  .dod-deliver {
    background: var(--off-white);
  }

  .dod-deliver__grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 48px;
    margin-top: 40px;
    align-items: start;
  }

  .dod-deliver__list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .dod-deliver__item-title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .dod-deliver__item-text {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-gray);
  }

  .dod-deliver__sidebar {
    position: sticky;
    top: 100px;
  }

  .dod-statboard {
    background: #fff;
    border-radius: 8px;
    border: 1px solid var(--medium-gray);
    overflow: hidden;
  }

  .dod-statboard__item {
    padding: 24px;
    border-bottom: 1px solid var(--medium-gray);
  }

  .dod-statboard__item:last-child {
    border-bottom: none;
  }

  .dod-statboard__num {
    display: block;
    font-family: var(--font-secondary);
    font-weight: 800;
    font-size: 24px;
    color: var(--navy);
    letter-spacing: 0.02em;
    margin-bottom: 4px;
  }

  .dod-statboard__lbl {
    font-size: 14px;
    color: var(--text-gray);
    line-height: 1.45;
  }

  /* ── Value ── */
  .dod-value {
    background: #fff;
  }

  .dod-value__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 16px;
  }

  .dod-value__card {
    background: var(--off-white);
    border-radius: 8px;
    padding: 28px 24px;
  }

  .dod-value__card-title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .dod-value__card-text {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
  }

  /* ── Stats Strip ── */
  .dod-stats {
    background: var(--navy);
    padding: 60px 0;
  }

  .dod-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }

  .dod-stats__num {
    display: block;
    font-family: var(--font-secondary);
    font-size: 36px;
    font-weight: 700;
    color: var(--amber);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .dod-stats__label {
    font-size: 14px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .dod-deliver__grid {
      grid-template-columns: 1fr;
    }

    .dod-deliver__sidebar {
      position: static;
    }

    .dod-value__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .section-gap {
      padding: 64px 0;
    }

    .dod-hero__inner {
      height: 400px;
    }

    .dod-hero__content {
      padding: 60px 1.5rem 32px;
    }

    .dod-stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .dod-value__grid {
      grid-template-columns: 1fr;
    }

    .dod-stats__grid {
      grid-template-columns: 1fr;
    }

    .dod-stats {
      padding: 40px 0;
    }

    .dod-hero__btns {
      flex-direction: column;
    }
  }
</style>
