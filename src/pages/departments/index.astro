---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Departments"
  description="Five specialized divisions delivering precision across modular construction, defense, healthcare, civil infrastructure, and project management."
>
  <Header slot="header" />

  <!-- ════════ HERO ════════ -->
  <section class="dp-hero">
    <div class="dp-hero__content">
      <h1 class="dp-hero__h1">Specialized<br/>Operational<br/>Departments</h1>
      <p class="dp-hero__sub">Five core divisions driving modular excellence — from construction and project management to defense, healthcare, and civil infrastructure.</p>
    </div>
  </section>

  <!-- ════════ 01. MODULAR CONSTRUCTION ════════ -->
  <section class="dp-sec dp-sec--white" id="modular">
    <div class="mnc">
      <span class="dp-tag">Division 01</span>
      <h2 class="dp-sec__title">Modular Construction</h2>
      <p class="dp-sec__desc">
        Our Modular Construction division delivers efficiency through precision-engineered off-site fabrication. By shifting 90% of the build process to controlled factory environments, we eliminate weather delays and ensure traceability within tolerances. This division also serves as the technical heart of our operations, advancing scalable structures from single-unit components to complex multi-story complexes.
      </p>

      <div class="dp-mod__cards">
        <div class="dp-mod__card fade-up">
          <h4 class="dp-mod__card-title">Assembly Process</h4>
          <p class="dp-mod__card-desc">Full integration of structural framing, MEP rough-in, insulation, and interior finish — coordinated in a single factory pass for consistency at scale.</p>
        </div>
        <div class="dp-mod__card dp-mod__card--accent fade-up">
          <h4 class="dp-mod__card-title">Speed to Market</h4>
          <p class="dp-mod__card-desc">30–50% faster than conventional methods. Parallel factory production and site preparation compress delivery timelines dramatically.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 02. PROJECT MANAGEMENT ════════ -->
  <section class="dp-sec dp-sec--off" id="project-management">
    <div class="mnc">
      <div class="dp-split fade-up">
        <div class="dp-split__img">
          <img src="/images/showcase/west-interior.jpg" alt="Project Management" loading="lazy" />
        </div>
        <div class="dp-split__text">
          <span class="dp-tag">Division 02</span>
          <h2 class="dp-sec__title">Project Management</h2>
          <p class="dp-sec__desc">
            Authority in management is maintained through rigorous oversight and data-driven systems. Our Project Management office utilizes advanced BIM, Building Information Modeling, and ERP systems to synchronize all phases of construction with on-site assembly. We provide a singular point of accountability for the entire project lifecycle, from initial pre-construction planning to final occupancy optimization.
          </p>
          <ul class="dp-bullets">
            <li>BIM Level 2 integration for real-time conflict resolution</li>
            <li>Global supply chain automation and logistics management</li>
            <li>Comprehensive risk mitigation and compliance auditing</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 03. DOD & MILITARY ════════ -->
  <section class="dp-sec dp-sec--navy" id="dod-military">
    <div class="mnc">
      <div class="dp-dod fade-up">
        <div class="dp-dod__text">
          <span class="dp-tag dp-tag--light">Division 03</span>
          <h2 class="dp-sec__title dp-sec__title--white">DoD & Military<br/>Infrastructure</h2>
          <p class="dp-sec__desc dp-sec__desc--light">
            Global Modular Partners is a primary contractor for rapid-deployment military facilities. Our Military department specializes in MILCON (Military Construction), Barracks, Administrative Facilities, Maintenance Barracks, and tactical operations planning. Our record includes projects certified by Defense Logistics Agency (DLA) and AT/FP (Anti-Terrorism/Force Protection), mandated by service, national, and international standards and force protection.
          </p>
          <div class="dp-dod__accent-card">
            <h4 class="dp-dod__accent-title">Security & Compliance</h4>
            <p class="dp-dod__accent-desc">Full SCIF/SAP clearance capability. Unified Facilities Criteria compliance embedded from concept through construction and commissioning.</p>
          </div>
        </div>
        <div class="dp-dod__img">
          <img src="/images/showcase/ri-defense.jpg" alt="Military infrastructure" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 04. HEALTHCARE ════════ -->
  <section class="dp-sec dp-sec--white" id="healthcare">
    <div class="mnc">
      <span class="dp-tag">Division 04</span>
      <h2 class="dp-sec__title">Healthcare Systems</h2>

      <div class="dp-hc fade-up">
        <div class="dp-hc__left">
          <p class="dp-sec__desc">
            Our Med-Tech team delivers specialized modules for high-acuity medical environments, providing rapid deployment for hospitals, diagnostic labs, and outpatient clinics without compromising existing facility operations.
          </p>
          <div class="dp-hc__images">
            <img src="/images/showcase/hwb-clinic-interior.jpeg" alt="Healthcare interior" loading="lazy" />
            <img src="/images/showcase/hwb-modular-pediatric.jpeg" alt="Pediatric facility" loading="lazy" />
          </div>
        </div>
        <div class="dp-hc__right">
          <div class="dp-hc__watermark" aria-hidden="true">HC-74</div>
          <div class="dp-hc__feature">
            <h4 class="dp-hc__feature-title">Medical-Grade Engineering</h4>
            <ul class="dp-bullets dp-bullets--compact">
              <li>HEPA filtration systems</li>
              <li>Clinical adjacency coordination</li>
              <li>Infection control compliance</li>
            </ul>
          </div>
          <div class="dp-hc__feature">
            <h4 class="dp-hc__feature-title">Load-Jetting & Handling</h4>
            <ul class="dp-bullets dp-bullets--compact">
              <li>Oversized module transport logistics</li>
              <li>Crane coordination & staging</li>
              <li>Site integration protocols</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 05. CIVIL CONSTRUCTION ════════ -->
  <section class="dp-sec dp-sec--off" id="civil">
    <div class="mnc">
      <div class="dp-civil fade-up">
        <div class="dp-civil__img">
          <img src="/images/showcase/ri-civil-compound.jpg" alt="Civil construction" loading="lazy" />
          <img src="/images/showcase/atcco-aerial.jpg" alt="Aerial view" loading="lazy" />
        </div>
        <div class="dp-civil__text">
          <span class="dp-tag">Division 05</span>
          <h2 class="dp-sec__title">Civil Construction</h2>
          <p class="dp-sec__desc">
            Bridging the gap between modular upper-structures and traditional civil infrastructure, our Civil Construction department manages earthwork, utility integration, and foundation engineering. We provide the institutional base upon which our modular installations are permanently or semi-permanently affixed, operating in difficult terrain and complex urban environments using modern stabilization and geotechnical analysis for site stability and longevity.
          </p>
          <div class="dp-civil__stats">
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">25+</span>
              <span class="dp-civil__stat-label">Civil projects</span>
            </div>
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">500+</span>
              <span class="dp-civil__stat-label">Completed modules</span>
            </div>
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">Zero</span>
              <span class="dp-civil__stat-label">Safety incidents</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  html { scroll-behavior: smooth; }
  .mnc { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }

  .dp-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .dp-tag::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .dp-tag--hero { color: rgba(255,255,255,.6); }
  .dp-tag--hero::before { background: var(--amber); }
  .dp-tag--light { color: rgba(255,255,255,.4); }
  .dp-tag--light::before { background: var(--amber); }

  /* ═══ HERO ═══ */
  .dp-hero {
    position: relative;
    height: 480px;
    overflow: hidden;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .dp-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .dp-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
  }

  .dp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20,40,75,.35) 0%, rgba(20,40,75,.8) 100%);
    z-index: 1;
  }

  .dp-hero__lines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .dp-hero__lv {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: rgba(255,255,255,.05);
    transform: scaleY(0);
    transform-origin: top;
    animation: dpLineV 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .dp-hero__lv--1 { left: 55%; animation-delay: 0.1s; }
  .dp-hero__lv--2 { left: 72%; animation-delay: 0.4s; }
  .dp-hero__lv--3 { left: 90%; animation-delay: 0.7s; }
  .dp-hero__lh {
    position: absolute;
    height: 1px;
    left: 0; right: 0;
    background: rgba(255,255,255,.05);
    transform: scaleX(0);
    transform-origin: left;
    animation: dpLineH 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .dp-hero__lh--1 { top: 35%; animation-delay: 0.5s; }
  .dp-hero__lh--2 { top: 70%; animation-delay: 0.8s; }
  @keyframes dpLineV { to { transform: scaleY(1); } }
  @keyframes dpLineH { to { transform: scaleX(1); } }

  .dp-hero__content {
    position: relative;
    z-index: 3;
    max-width: 1240px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .dp-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: -2px;
    margin: 0 0 20px;
  }

  .dp-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,.5);
    max-width: 520px;
    margin: 0;
  }

  /* ═══ SECTIONS ═══ */
  .dp-sec {
    padding: 100px 0;
    scroll-margin-top: 100px;
  }
  .dp-sec--white { background: var(--white); }
  .dp-sec--off { background: var(--off-white); }
  .dp-sec--navy { background: var(--navy); }

  .dp-sec__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--dark-text);
    margin-bottom: 20px;
  }
  .dp-sec__title--white { color: var(--white); }

  .dp-sec__desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-gray);
    max-width: 720px;
    margin-bottom: 0;
  }
  .dp-sec__desc--light { color: rgba(255,255,255,.55); }

  /* ═══ 01. MODULAR ═══ */
  .dp-mod__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .dp-mod__card {
    padding: 32px 28px;
    border: 1px solid rgba(0,0,0,.08);
    background: var(--off-white);
    transition: box-shadow 0.3s ease;
  }

  .dp-mod__card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,.06);
  }

  .dp-mod__card--accent {
    background: var(--amber);
    border-color: var(--amber);
  }

  .dp-mod__card-title {
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 8px;
  }

  .dp-mod__card--accent .dp-mod__card-title {
    color: var(--navy);
  }

  .dp-mod__card-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-gray);
    margin: 0;
  }

  .dp-mod__card--accent .dp-mod__card-desc {
    color: rgba(30,58,102,.7);
  }

  /* ═══ 02. PM — SPLIT LAYOUT ═══ */
  .dp-split {
    display: grid;
    grid-template-columns: 0.45fr 0.55fr;
    gap: 48px;
    align-items: center;
  }

  .dp-split__img {
    position: relative;
    overflow: hidden;
    border-radius: 0;
  }

  .dp-split__img img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .dp-bullets {
    list-style: none;
    padding: 0;
    margin: 20px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dp-bullets li {
    position: relative;
    padding-left: 20px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-gray);
  }

  .dp-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--amber);
  }

  .dp-bullets--compact { margin: 12px 0 0; gap: 6px; }
  .dp-bullets--compact li { font-size: 13px; }

  /* ═══ 03. DOD ═══ */
  .dp-dod {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .dp-dod__img {
    overflow: hidden;
    border-radius: 0;
  }

  .dp-dod__img img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .dp-dod__accent-card {
    margin-top: 28px;
    padding: 20px 24px;
    background: rgba(224,161,53,.08);
    border-left: 3px solid var(--amber);
  }

  .dp-dod__accent-title {
    font-family: var(--font-secondary);
    font-size: 14px;
    font-weight: 700;
    color: var(--amber);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .dp-dod__accent-desc {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,.5);
    margin: 0;
  }

  /* ═══ 04. HEALTHCARE ═══ */
  .dp-hc {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-top: 32px;
    align-items: start;
  }

  .dp-hc__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 28px;
  }

  .dp-hc__images img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .dp-hc__right {
    position: relative;
  }

  .dp-hc__watermark {
    font-family: var(--font-secondary);
    font-size: clamp(60px, 10vw, 120px);
    font-weight: 900;
    color: rgba(0,0,0,.04);
    line-height: 1;
    margin-bottom: 24px;
    letter-spacing: -2px;
  }

  .dp-hc__feature {
    padding: 24px 0;
    border-top: 1px solid rgba(0,0,0,.08);
  }

  .dp-hc__feature:last-child {
    border-bottom: 1px solid rgba(0,0,0,.08);
  }

  .dp-hc__feature-title {
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 4px;
  }

  /* ═══ 05. CIVIL ═══ */
  .dp-civil {
    display: grid;
    grid-template-columns: 0.45fr 0.55fr;
    gap: 48px;
    align-items: start;
  }

  .dp-civil__img {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .dp-civil__img img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .dp-civil__img img:first-child {
    aspect-ratio: 16 / 10;
  }

  .dp-civil__img img:last-child {
    aspect-ratio: 16 / 9;
  }

  .dp-civil__stats {
    display: flex;
    gap: 40px;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(0,0,0,.08);
  }

  .dp-civil__stat-num {
    font-family: var(--font-secondary);
    font-size: 28px;
    font-weight: 900;
    color: var(--dark-text);
    display: block;
    line-height: 1;
  }

  .dp-civil__stat-label {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-gray);
    display: block;
    margin-top: 4px;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .dp-mod__cards { grid-template-columns: 1fr; }

    .dp-split,
    .dp-dod,
    .dp-hc,
    .dp-civil {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .dp-dod__img { order: -1; }
  }

  @media (max-width: 768px) {
    .dp-hero { height: 380px; }

    .dp-sec { padding: 64px 0; }

    .dp-hc__images { grid-template-columns: 1fr; }

    .dp-civil__stats { flex-direction: column; gap: 20px; }
  }
</style>
