---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageCTA from '../../components/PageCTA.astro';
---

<Layout
  title="Departments"
  description="Five specialized divisions delivering precision across modular construction, defense, healthcare, civil infrastructure, and project management."
>
  <Header slot="header" />

  <!-- ════════ HERO ════════ -->
  <section class="dp-hero">
    <div class="dp-hero__panel">
      <canvas id="departments-hero-3d" class="dp-hero__canvas" aria-hidden="true"></canvas>
      <span class="dp-hero__canvas-tag" aria-hidden="true">Five Divisions · One Core</span>
      <div class="dp-hero__content">
        <h1 class="dp-hero__h1">Operational<br/>Departments</h1>
        <p class="dp-hero__sub">Five core divisions driving modular excellence — from construction and project management to defense, healthcare, and civil infrastructure.</p>
      </div>
    </div>
  </section>

  <!-- ════════ 01. MODULAR CONSTRUCTION ════════ -->
  <section class="dp-sec dp-sec--white dp-strip" id="modular">
    <div class="dp-mod__wrap">
      <div class="dp-mod__split">
        <div class="dp-mod__intro fade-up">
          <span class="dp-tag">Division 01</span>
          <h2 class="dp-sec__title">Modular Construction</h2>
          <p class="dp-sec__desc">
            Our Modular Construction division delivers efficiency through precision-engineered off-site fabrication. By shifting 90% of the build process to controlled factory environments, we eliminate weather delays and ensure traceability within tolerances. This division also serves as the technical heart of our operations, advancing scalable structures from single-unit components to complex multi-story complexes.
          </p>
          <p class="dp-sec__desc">
            Every module ships with documented QA checkpoints, coordinated logistics for oversized loads, and field teams trained to integrate factory-built volumes with site conditions. That combination shortens commissioning cycles, reduces rework, and gives owners predictable occupancy dates across education, hospitality, workforce housing, and commercial programs.
          </p>
        </div>
        <div class="dp-mod__bento-col fade-up">
          <div class="dp-bento dp-bento--mod" aria-label="Modular construction imagery">
            <div class="dp-bento__cell">
              <img src="/images/showcase/ri-factory-production.jpg" alt="Factory module production floor" loading="lazy" />
            </div>
            <div class="dp-bento__cell">
              <img src="/images/showcase/ri-modular-residential.png" alt="Modular residential volumes" loading="lazy" />
            </div>
            <div class="dp-bento__cell">
              <img src="/images/showcase/west-crane.jpg" alt="On-site module setting" loading="lazy" />
            </div>
            <div class="dp-bento__cell">
              <img src="/images/showcase/ri-steel-frame-aerial.png" alt="Steel frame modular assembly aerial" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 02. PROJECT MANAGEMENT ════════ -->
  <section class="dp-sec dp-sec--off dp-strip dp-strip--split" id="project-management">
    <div class="dp-split">
      <div class="dp-split__img-col">
        <div class="dp-bento dp-bento--tri fade-up" aria-label="Project management imagery">
          <div class="dp-bento__cell">
            <img src="/images/showcase/west-interior.jpg" alt="Coordinated interior and program management" loading="lazy" />
          </div>
          <div class="dp-bento__cell">
            <img src="/images/showcase/ri-library-pavilion.png" alt="Modular pavilion delivery" loading="lazy" />
          </div>
          <div class="dp-bento__cell">
            <img src="/images/showcase/ri-factory-production.jpg" alt="Factory production aligned to schedule" loading="lazy" />
          </div>
        </div>
      </div>
      <div class="dp-split__text-col fade-up">
        <div class="dp-split__text-inner">
          <span class="dp-tag">Division 02</span>
          <h2 class="dp-sec__title">Project Management</h2>
          <p class="dp-sec__desc">
            Authority in management is maintained through rigorous oversight and data-driven systems. Our Project Management office utilizes advanced BIM, Building Information Modeling, and ERP systems to synchronize all phases of construction with on-site assembly. We provide a singular point of accountability for the entire project lifecycle, from initial pre-construction planning to final occupancy optimization.
          </p>
          <p class="dp-sec__desc">
            Stakeholders receive transparent reporting on schedule, cost, and quality metrics, with change control that ties decisions back to contract documents and design intent. We align trade partners, inspectors, and owner representatives on a single program calendar so factory production, site readiness, and commissioning stay in lockstep from mobilization through turnover.
          </p>
          <ul class="dp-bullets">
            <li>BIM Level 2 integration for real-time conflict resolution</li>
            <li>Global supply chain automation and logistics management</li>
            <li>Comprehensive risk mitigation and compliance auditing</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 03. DOD & MILITARY ════════ -->
  <section class="dp-sec dp-sec--white dp-strip dp-strip--split" id="dod-military">
    <div class="dp-dod">
      <div class="dp-dod__text-col fade-up">
        <div class="dp-dod__text-inner">
          <span class="dp-tag">Division 03</span>
          <h2 class="dp-sec__title">DoD & Military<br/>Infrastructure</h2>
          <p class="dp-sec__desc">
            Global Modular Partners is a primary contractor for rapid-deployment military facilities. Our Military department specializes in MILCON (Military Construction), Barracks, Administrative Facilities, Maintenance Barracks, and tactical operations planning. Our record includes projects certified by Defense Logistics Agency (DLA) and AT/FP (Anti-Terrorism/Force Protection), mandated by service, national, and international standards and force protection.
          </p>
          <p class="dp-sec__desc">
            We plan for constrained sites, expeditionary logistics, and layered security from day one—coordinating with government technical monitors, fire protection engineers, and communications specialists so modules arrive ready for utilities, access control, and operational use. Lessons learned from each deployment feed back into our standard details and training programs for the next mobilization.
          </p>
          <div class="dp-dod__accent-card">
            <h4 class="dp-dod__accent-title">Security & Compliance</h4>
            <p class="dp-dod__accent-desc">Full SCIF/SAP clearance capability. Unified Facilities Criteria compliance embedded from concept through construction and commissioning.</p>
          </div>
        </div>
      </div>
      <div class="dp-dod__img-col">
        <div class="dp-bento dp-bento--tri fade-up" aria-label="Defense and military infrastructure">
          <div class="dp-bento__cell">
            <img src="/images/showcase/ri-defense-base.png" alt="Forward operations modular compound" loading="lazy" />
          </div>
          <div class="dp-bento__cell">
            <img src="/images/showcase/ri-military-shelter-truck.png" alt="Expeditionary modular shelter" loading="lazy" />
          </div>
          <div class="dp-bento__cell">
            <img src="/images/showcase/ri-un-modules-crane.png" alt="Module crane deployment" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 04. HEALTHCARE ════════ -->
  <section class="dp-sec dp-sec--off dp-strip dp-strip--split" id="healthcare">
    <div class="dp-hc">
      <div class="dp-hc__text-col fade-up">
        <div class="dp-hc__text-inner">
          <span class="dp-tag">Division 04</span>
          <h2 class="dp-sec__title">Healthcare Systems</h2>
          <p class="dp-sec__desc">
            Our Med-Tech team delivers specialized modules for high-acuity medical environments, providing rapid deployment for hospitals, diagnostic labs, and outpatient clinics without compromising existing facility operations.
          </p>
          <p class="dp-sec__desc">
            We coordinate with clinical staff on adjacencies, mechanical redundancy, and life-safety pathways before fabrication begins, then sequence delivery to minimize disruption to active departments. Acoustic isolation, resilient flooring options, and modular headwalls allow facilities to expand capacity or reconfigure wings as census and service lines evolve.
          </p>
          <div class="dp-bento dp-bento--hc fade-up" aria-label="Healthcare modular facilities">
            <div class="dp-bento__cell">
              <img src="/images/showcase/hwb-clinic-interior.jpeg" alt="Healthcare clinic interior" loading="lazy" />
            </div>
            <div class="dp-bento__cell">
              <img src="/images/showcase/hwb-modular-pediatric.jpeg" alt="Pediatric modular facility" loading="lazy" />
            </div>
            <div class="dp-bento__cell">
              <img src="/images/showcase/ri-medical-lab.jpg" alt="Medical laboratory module" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
      <div class="dp-hc__side-col fade-up">
        <div class="dp-hc__side-inner">
          <div class="dp-hc__watermark" aria-hidden="true">HC-74</div>
          <div class="dp-hc__feature">
            <h4 class="dp-hc__feature-title">Medical-Grade Engineering</h4>
            <ul class="dp-bullets dp-bullets--compact">
              <li>HEPA filtration systems</li>
              <li>Clinical adjacency coordination</li>
              <li>Infection control compliance</li>
            </ul>
          </div>
          <div class="dp-hc__feature">
            <h4 class="dp-hc__feature-title">Load-Jetting & Handling</h4>
            <ul class="dp-bullets dp-bullets--compact">
              <li>Oversized module transport logistics</li>
              <li>Crane coordination & staging</li>
              <li>Site integration protocols</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 05. CIVIL CONSTRUCTION ════════ -->
  <section class="dp-sec dp-sec--white dp-strip dp-strip--split" id="civil">
    <div class="dp-civil">
      <div class="dp-civil__img-col">
        <div class="dp-bento dp-bento--tri fade-up" aria-label="Civil construction and site works">
          <div class="dp-bento__cell">
            <img src="/images/showcase/ri-civil-compound-aerial.png" alt="Civil compound and modular campus aerial" loading="lazy" />
          </div>
          <div class="dp-bento__cell">
            <img src="/images/showcase/atcco-aerial.jpg" alt="Civil infrastructure aerial" loading="lazy" />
          </div>
          <div class="dp-bento__cell">
            <img src="/images/showcase/ri-steel-frame-aerial.png" alt="Steel frame and civil works" loading="lazy" />
          </div>
        </div>
      </div>
      <div class="dp-civil__text-col fade-up">
        <div class="dp-civil__text-inner">
          <span class="dp-tag">Division 05</span>
          <h2 class="dp-sec__title">Civil Construction</h2>
          <p class="dp-sec__desc">
            Bridging the gap between modular upper-structures and traditional civil infrastructure, our Civil Construction department manages earthwork, utility integration, and foundation engineering. We provide the institutional base upon which our modular installations are permanently or semi-permanently affixed, operating in difficult terrain and complex urban environments using modern stabilization and geotechnical analysis for site stability and longevity.
          </p>
          <p class="dp-sec__desc">
            Our crews handle stormwater management, paving and curbs, and tie-ins to municipal water and sewer where required, always with clear handoffs to the modular set crew. That end-to-end ownership reduces interface risk, keeps warranties aligned, and protects the long-term performance of both the civil shell and the modules it supports.
          </p>
          <div class="dp-civil__stats">
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">25+</span>
              <span class="dp-civil__stat-label">Civil projects</span>
            </div>
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">500+</span>
              <span class="dp-civil__stat-label">Completed modules</span>
            </div>
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">Zero</span>
              <span class="dp-civil__stat-label">Safety incidents</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PageCTA
    eyebrow="Zoom out"
    title="The departments are only<br/>half the story."
    image="/images/showcase/ri-commercial-building.png"
    links={[
      { label: 'About GMP', href: '/about' },
      { label: 'Our Projects', href: '/projects' },
    ]}
  />

  <script>
    // ───────────────────────────────────────────────────────────────
    // DEPARTMENTS — hero 3D: "Five Divisions · One Core"
    // A central vertical spine with five modular units orbiting around
    // it at fixed angular spacing. Each module carries a subtle accent
    // colour cue for its division. The ring rotates slowly; each
    // module also bobs slightly on its own phase.
    // ───────────────────────────────────────────────────────────────
    import * as THREE from 'three';

    const canvas = document.getElementById('departments-hero-3d') as HTMLCanvasElement | null;
    if (canvas) {
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
      camera.position.set(7.4, 4.4, 9.6);
      camera.lookAt(0, 0.8, 0);

      // Shared wireframe materials (homepage style)
      const occluderMat = new THREE.MeshBasicMaterial({
        colorWrite: false,
        depthWrite: true,
        depthTest: true,
        side: THREE.DoubleSide,
        polygonOffset: true,
        polygonOffsetFactor: 1,
        polygonOffsetUnits: 1,
      });
      const lineMat = new THREE.LineBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0.92,
        depthTest: true,
        depthWrite: false,
        polygonOffset: true,
        polygonOffsetFactor: -1,
        polygonOffsetUnits: -1,
      });
      function wire(geometry: THREE.BufferGeometry): THREE.Group {
        const g = new THREE.Group();
        const shell = new THREE.Mesh(geometry, occluderMat);
        shell.renderOrder = 0;
        const edges = new THREE.LineSegments(
          new THREE.EdgesGeometry(geometry, 1),
          lineMat,
        );
        edges.renderOrder = 1;
        g.add(shell);
        g.add(edges);
        return g;
      }

      // Central spine: tall column + disc cap
      const spineG = new THREE.Group();
      const spine = wire(new THREE.CylinderGeometry(0.22, 0.22, 4.4, 24));
      spine.position.y = 1.8;
      spineG.add(spine);
      const spineAccentBands = [0.6, 1.8, 3.0];
      spineAccentBands.forEach((y) => {
        const band = wire(new THREE.CylinderGeometry(0.235, 0.235, 0.04, 24));
        band.position.y = y;
        spineG.add(band);
      });
      const cap = wire(new THREE.CylinderGeometry(0.38, 0.38, 0.16, 24));
      cap.position.y = 4.08;
      spineG.add(cap);
      const capAccent = wire(new THREE.CylinderGeometry(0.4, 0.4, 0.05, 24));
      capAccent.position.y = 4.18;
      spineG.add(capAccent);
      const base = wire(new THREE.CylinderGeometry(1.2, 1.2, 0.18, 32));
      base.position.y = -0.41;
      spineG.add(base);
      const baseAccent = wire(new THREE.CylinderGeometry(1.25, 1.25, 0.04, 32));
      baseAccent.position.y = -0.31;
      spineG.add(baseAccent);
      scene.add(spineG);

      // Build a single division module
      function makeModule() {
        const g = new THREE.Group();
        const w = 1.6, h = 1.0, d = 0.9;
        const body = wire(new THREE.BoxGeometry(w, h, d));
        g.add(body);
        const belt = wire(new THREE.BoxGeometry(w + 0.02, 0.04, d + 0.02));
        belt.position.y = -h / 2 + h * 0.4;
        g.add(belt);
        // Top cap
        const topCap = wire(new THREE.BoxGeometry(w + 0.02, 0.06, d + 0.02));
        topCap.position.y = h / 2 + 0.03;
        g.add(topCap);
        // Top rim
        const topStripe = wire(new THREE.BoxGeometry(w + 0.04, 0.03, d + 0.04));
        topStripe.position.y = h / 2 + 0.08;
        g.add(topStripe);
        // Vertical ribs front/back
        for (let side = -1; side <= 1; side += 2) {
          for (let i = 1; i <= 3; i++) {
            const t = i / 4;
            const rib = wire(new THREE.BoxGeometry(0.02, h * 0.78, 0.025));
            rib.position.set(-w / 2 + t * w, 0, side * (d / 2 + 0.001));
            g.add(rib);
          }
        }
        // Corner posts
        [[-1, -1], [1, -1], [-1, 1], [1, 1]].forEach(([sx, sz]) => {
          const post = wire(new THREE.BoxGeometry(0.08, h + 0.1, 0.08));
          post.position.set(sx * (w / 2), 0, sz * (d / 2));
          g.add(post);
        });
        return g;
      }

      const ring = new THREE.Group();
      scene.add(ring);

      const modules: { group: THREE.Group; phase: number }[] = [];
      const radius = 2.35;
      for (let i = 0; i < 5; i++) {
        const angle = (i / 5) * Math.PI * 2;
        const m = makeModule();
        m.position.set(Math.cos(angle) * radius, 1.1, Math.sin(angle) * radius);
        m.rotation.y = -angle + Math.PI / 2;
        ring.add(m);
        modules.push({ group: m, phase: i * 1.25 });
      }

      // Light connectors from spine to each module (white wireframe tubes)
      modules.forEach((m) => {
        const barGeo = new THREE.CylinderGeometry(0.025, 0.025, radius - 0.9, 8);
        const bar = new THREE.LineSegments(new THREE.EdgesGeometry(barGeo, 1), lineMat);
        bar.position.copy(m.group.position);
        bar.position.y = 1.1;
        const dir = m.group.position.clone().setY(0).normalize();
        const quat = new THREE.Quaternion().setFromUnitVectors(
          new THREE.Vector3(0, 1, 0),
          new THREE.Vector3(dir.x, 0, dir.z),
        );
        bar.quaternion.copy(quat);
        const mid = m.group.position.clone().multiplyScalar(0.5);
        bar.position.set(mid.x, 1.1, mid.z);
        ring.add(bar);
      });

      function resize() {
        if (!canvas) return;
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;
        if (w === 0 || h === 0) return;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }
      resize();
      const ro = new ResizeObserver(resize);
      ro.observe(canvas);
      window.addEventListener('resize', resize);

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let paused = false;
      const io = new IntersectionObserver((entries) => {
        paused = !entries[0].isIntersecting;
      }, { threshold: 0.01 });
      io.observe(canvas);

      let t0 = performance.now();
      function tick(now: number) {
        const dt = (now - t0) / 1000;
        t0 = now;
        if (!paused) {
          if (!reduced) {
            ring.rotation.y += dt * 0.15;
            spineG.rotation.y -= dt * 0.08;
            const tSec = now * 0.001;
            modules.forEach((m) => {
              m.group.position.y = 1.1 + Math.sin(tSec + m.phase) * 0.08;
            });
          }
          renderer.render(scene, camera);
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  </script>

  <Footer slot="footer" />
</Layout>

<style>
  html { scroll-behavior: smooth; }

  /* Match homepage: hero / UI chrome = Barlow; section h2s = secondary (same as .section-title) */
  .dp-hc__feature-title,
  .dp-dod__accent-title {
    font-family: var(--font-primary);
  }

  /* Match homepage / services strips */
  .dp-strip {
    --strip-edge-gutter: max(1.5rem, calc((100vw - 1440px) / 2 + 1.5rem));
    --strip-inner-gap: 36px;
    scroll-margin-top: 100px;
  }

  .dp-strip--split {
    padding: 0;
  }

  .dp-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .dp-tag::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--ink);
    flex-shrink: 0;
  }
  .dp-sec__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.8vw, 48px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .dp-sec__desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
    max-width: none;
  }
  .dp-sec__desc + .dp-sec__desc {
    margin-top: 1rem;
  }

  /* ═══ HERO ═══ */
  .dp-hero {
    position: relative;
    background: #fff;
    padding: 0;
  }

  .dp-hero__panel {
    position: relative;
    height: 480px;
    overflow: hidden;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .dp-hero__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .dp-hero__content {
    position: relative;
    z-index: 3;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .dp-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: none;
    letter-spacing: -2px;
    margin: 0 0 20px;
  }

  .dp-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    max-width: 520px;
    margin: 0;
  }

  /* 3D hero accent — five modules orbiting a central spine */
  .dp-hero__canvas {
    position: absolute;
    top: 0;
    right: 0;
    width: clamp(360px, 58%, 780px);
    height: 100%;
    z-index: 2;
    pointer-events: none;
    display: block;
    touch-action: none;
    mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 100%);
  }
  .dp-hero__canvas-tag {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 4;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.55);
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(8, 16, 30, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  @media (max-width: 768px) {
    .dp-hero__canvas,
    .dp-hero__canvas-tag {
      display: none;
    }
  }

  /* ═══ SECTION SHELL ═══ */
  .dp-sec {
    padding: 0;
  }
  .dp-sec--white { background: var(--paper); }
  .dp-sec--off { background: var(--paper-2); }

  /* ═══ 01. MODULAR — text + bento (two columns) ═══ */
  .dp-mod__wrap {
    padding: 80px var(--strip-edge-gutter) 100px;
  }

  .dp-mod__split {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(260px, 0.95fr);
    gap: clamp(28px, 4vw, 48px);
    align-items: start;
  }

  .dp-mod__intro {
    max-width: 640px;
    min-width: 0;
  }

  .dp-mod__bento-col {
    min-width: 0;
  }

  /* ═══ BENTO IMAGE GRIDS (shared) ═══ */
  .dp-bento {
    width: 100%;
    min-height: 0;
  }

  .dp-bento__cell {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background: var(--line);
    min-height: 0;
  }

