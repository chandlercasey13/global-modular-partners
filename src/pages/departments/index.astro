---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

/* ── Modular data ── */
const deliver = [
  { title: 'Volumetric Module Fabrication', text: 'Complete room-scale units built in factory-controlled conditions using welded steel tubes and beams (HSS) connected with special connectors for superior structural integrity.' },
  { title: 'FrameCAD Light Gauge Framing', text: 'Precision-cut light gauge stud walls using FrameCAD technology for consistent dimensional accuracy and rapid assembly.' },
  { title: 'Integrated MEP Systems', text: 'Rough mechanical, electrical, and plumbing installed in-factory alongside HVAC, ensuring coordinated systems before modules leave the production line.' },
  { title: 'Multi-Manufacturer Coordination', text: 'GMP works with multiple manufacturers across the country, selecting the right partners based on project location, budget, feasibility, and logistics.' },
  { title: 'Complete Interior Finishing', text: 'Factory-installed insulation, interior walls, doors, windows, paint, cabinets, fixtures, and optional furniture — modules arrive site-ready.' },
  { title: 'Exterior Cladding & Protection', text: 'Exterior cladding applied in factory, followed by shrink-wrap protection for transport and on-site storage until installation.' },
];
const value = [
  { title: '30–50% Faster Delivery', text: 'Parallel factory production and site work compress overall duration so you occupy sooner and reduce carrying costs.' },
  { title: 'Superior Quality Control', text: 'Factory-controlled process with repeatable inspections ensures exceptional construction quality that meets or exceeds site-built standards.' },
  { title: 'Reduced Material Waste', text: 'Controlled inventory management and recycling in the factory environment eliminates waste compared to traditional on-site construction.' },
  { title: 'Weather-Independent', text: '60–90% of construction completed inside a factory, eliminating weather delays and protecting materials during the build process.' },
  { title: 'Minimal Site Disruption', text: 'Shortened on-site duration limits noise, traffic, and safety exposure for neighbors and ongoing operations.' },
];
const projects = [
  { title: 'Commercial Office', location: 'San Francisco, CA', text: 'Core-and-shell modular office with high-performance envelope and fast tenant fit-out.' },
  { title: 'Residential Complex', location: 'Austin, TX', text: 'Large-scale housing delivered with repeatable modules and coordinated vertical transportation.' },
  { title: 'Educational Facility', location: 'Denver, CO', text: 'Campus expansion with classrooms and support spaces installed during active school terms.' },
  { title: 'Retail Center', location: 'Phoenix, AZ', text: 'Mixed-use retail and service bays assembled for speed to revenue and phased openings.' },
];

/* ── PM data ── */
const capabilities = [
  { key: 'dod', title: 'DoD Contract Management', text: 'Structured governance for defense and federal programs' },
  { key: 'federal', title: 'Federal Project Compliance', text: 'Documentation, reporting, process rigor' },
  { key: 'security', title: 'Security Clearance Coordination', text: 'Sequencing cleared personnel and site access' },
  { key: 'rapid', title: 'Rapid Deployment Planning', text: 'Compressed schedules with parallel workstreams' },
  { key: 'risk', title: 'Risk Assessment & Mitigation', text: 'Schedule, cost, operational risk identification' },
  { key: 'qa', title: 'Quality Assurance Programs', text: 'Inspection, test plans, digital records' },
];
const valuesPrimary = [
  { key: 'ontime', title: 'On-Time Delivery', text: 'Milestone-driven planning and field coordination keep critical paths visible and actionable through closeout.' },
  { key: 'budget', title: 'Budget Adherence', text: 'Forecasting, earned value discipline, and scope control protect funding lines while preserving mission outcomes.' },
];
const valuesMore = [
  { key: 'compliance', title: 'Full Compliance', text: 'Federal, safety, and contractual requirements embedded in workflows—not bolted on at the end.' },
  { key: 'riskval', title: 'Risk Mitigation', text: 'Early signals, contingency planning, and cross-functional reviews reduce surprises during execution.' },
  { key: 'report', title: 'Transparent Reporting', text: 'Executive-ready dashboards and written status so sponsors see progress, blockers, and decisions clearly.' },
];
const pmStats = [
  { num: '360°', label: 'Schedule & cost visibility' },
  { num: 'Fed', label: 'Compliance-first' },
  { num: 'RACI', label: 'Clear ownership' },
  { num: 'ROI', label: 'Fewer rework cycles' },
];
const tools = ['Procore', 'Microsoft Project', 'BIM 360', 'PlanGrid', 'AutoCAD', 'Primavera P6'];
const cap = (k: string) => capabilities.find((c) => c.key === k)!;

/* ── Healthcare data ── */
const valueStatCards = [
  { title: '50+ Healthcare Facilities Delivered', text: 'A growing portfolio of modular medical assets deployed with partners who understand clinical operations—not just square footage.', stat: '50+', statLabel: 'Facilities worldwide' },
  { title: '15 Countries Served', text: 'International experience adapting modules to local codes, climate, and supply chains while preserving clinical performance.', stat: '15', statLabel: 'Countries' },
];
---

<Layout
  title="Departments"
  description="Five specialized divisions delivering precision across modular construction, defense, healthcare, civil infrastructure, and project management."
>
  <Header slot="header" />

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="dept-hero-wrap">
    <div class="dept-hero-inner">
      <div class="dept-hero-content">
        <nav class="dept-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="dept-breadcrumb__sep">/</span>
          <span>Departments</span>
        </nav>
        <h1 class="dept-hero-title">Our Departments</h1>
        <p class="dept-hero-sub">
          Five specialized divisions delivering precision across modular construction, defense, healthcare, civil infrastructure, and project management.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 1. MODULAR CONSTRUCTION ═══════════════ -->
  <div class="dept-section-header" id="modular">
    <div class="mnc-container">
      <span class="section-tag">Department</span>
      <h2 class="section-title">Modular Construction</h2>
      <p class="dept-section-sub">Precision-engineered off-site building solutions for commercial, residential, and industrial projects worldwide.</p>
    </div>
  </div>

  <section class="mod-bento-section">
    <div class="mnc-container">
      <div class="mod-row mod-row--2 fade-up">
        <div class="mod-card mod-card--lg">
          <div class="mod-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 21h18M3 7v14m6-14v14m6-14v14m6-14v14M4 7h16l-8-4L4 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <h3 class="mod-card__title">{deliver[0].title}</h3>
          <p class="mod-card__desc">{deliver[0].text}</p>
          <a href="/contact" class="mod-card__link">Discuss volumetric scope <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        </div>
        <div class="mod-card mod-card--lg mod-card--navy">
          <div class="mod-card__icon mod-card__icon--light">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 3v18m9-9H3m6.5-6.5L12 3l2.5 2.5M6.5 17.5 12 21l5.5-3.5M3 12l2.5-5.5M21 12l-2.5-5.5M3 12l2.5 5.5M21 12l-2.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <h3 class="mod-card__title">{deliver[1].title}</h3>
          <p class="mod-card__desc">{deliver[1].text}</p>
          <a href="/contact" class="mod-card__link mod-card__link--light">FrameCAD &amp; framing <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        </div>
      </div>

      <div class="mod-row mod-row--3 fade-up">
        <div class="mod-card mod-card--sm">
          <div class="mod-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <h3 class="mod-card__title">{deliver[2].title}</h3>
          <p class="mod-card__desc">{deliver[2].text}</p>
          <a href="/contact" class="mod-card__link">Coordinate MEP <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        </div>
        <div class="mod-card mod-card--md">
          <div class="mod-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm16 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <h3 class="mod-card__title">{deliver[3].title}</h3>
          <p class="mod-card__desc">{deliver[3].text}</p>
          <a href="/contact" class="mod-card__link">Partner with GMP <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        </div>
        <div class="mod-card mod-card--img" aria-hidden="true">
          <div class="mod-card__gradient"></div>
        </div>
      </div>

      <div class="mod-row mod-row--2 fade-up">
        <div class="mod-card mod-card--img mod-card--img-tall" aria-hidden="true">
          <div class="mod-card__gradient mod-card__gradient--tall"></div>
        </div>
        <div class="mod-card mod-card--lg">
          <div class="mod-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /><path d="M9 22V12h6v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <h3 class="mod-card__title">{deliver[4].title}</h3>
          <p class="mod-card__desc">{deliver[4].text}</p>
          <a href="/contact" class="mod-card__link">Interior packages <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        </div>
      </div>

      <div class="mod-row mod-row--3eq fade-up">
        <div class="mod-card mod-card--md mod-card--navy">
          <div class="mod-card__icon mod-card__icon--light">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <h3 class="mod-card__title">{deliver[5].title}</h3>
          <p class="mod-card__desc">{deliver[5].text}</p>
          <a href="/contact" class="mod-card__link mod-card__link--light">Cladding &amp; logistics <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg></a>
        </div>
        <div class="mod-card mod-card--value">
          <h3 class="mod-card__title">{value[0].title}</h3>
          <p class="mod-card__desc">{value[0].text}</p>
        </div>
        <div class="mod-card mod-card--value">
          <h3 class="mod-card__title">{value[1].title}</h3>
          <p class="mod-card__desc">{value[1].text}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mod-adu-section">
    <div class="mnc-container fade-up">
      <div class="mod-adu-callout">
        <div class="mod-adu-callout__content">
          <span class="mod-adu-callout__eyebrow">Featured program</span>
          <p class="mod-adu-callout__num">28</p>
          <p class="mod-adu-callout__label">Day ADU delivery</p>
          <p class="mod-adu-callout__desc">
            Our 28-Day ADU program pairs factory production with disciplined site logistics so homeowners and developers get permitted, livable units on an aggressive calendar.
          </p>
          <a href="/contact" class="mod-card__link mod-card__link--light mod-adu-callout__link">
            Ask about the ADU program
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </a>
        </div>
        <div class="mod-adu-callout__accent" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <section class="stats-strip">
    <div class="mnc-container">
      <div class="stats-strip__grid stats-strip__grid--4">
        <div class="stats-strip__item">
          <span class="stats-strip__num">50%</span>
          <span class="stats-strip__label">Faster delivery vs. traditional</span>
        </div>
        <div class="stats-strip__item">
          <span class="stats-strip__num">28</span>
          <span class="stats-strip__label">Day ADU program</span>
        </div>
        <div class="stats-strip__item">
          <span class="stats-strip__num">100%</span>
          <span class="stats-strip__label">Code-aligned factory QC</span>
        </div>
        <div class="stats-strip__item">
          <span class="stats-strip__num">Low</span>
          <span class="stats-strip__label">On-site disruption profile</span>
        </div>
      </div>
    </div>
  </section>

  <section class="mod-projects section-gap">
    <div class="mnc-container">
      <span class="section-tag">Projects</span>
      <h2 class="section-title">Representative Projects</h2>
      <div class="mod-projects__grid">
        {projects.map((p) => (
          <article class="mod-project-card">
            <div class="mod-project-card__thumb" aria-hidden="true"></div>
            <div class="mod-project-card__body">
              <span class="mod-project-card__loc">{p.location}</span>
              <h3 class="mod-project-card__title">{p.title}</h3>
              <p class="mod-project-card__text">{p.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ 2. PROJECT MANAGEMENT ═══════════════ -->
  <div class="dept-section-header" id="project-management">
    <div class="mnc-container">
      <span class="section-tag">Department</span>
      <h2 class="section-title">Project Management</h2>
      <p class="dept-section-sub">Expert delivery from pre-construction through close-out, with full DoD compliance and proven methodology.</p>
    </div>
  </div>

  <section class="pm-bento">
    <div class="mnc-container pm-bento__container">
      <div class="pm-bento__grid">
        <article class="pm-card pm-card--white pm-card--dod">
          <div class="pm-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 3h8l4 4v14a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
              <path d="M14 3v4h4M9 12h6M9 16h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            </svg>
          </div>
          <h3 class="pm-card__title">{cap('dod').title}</h3>
          <p class="pm-card__text">{cap('dod').text}</p>
        </article>

        <article class="pm-card pm-card--navy pm-card--federal">
          <div class="pm-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 5H5v4M15 5h4v4M5 15v4h4M19 15v4h-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              <rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="2"></rect>
            </svg>
          </div>
          <h3 class="pm-card__title">{cap('federal').title}</h3>
          <p class="pm-card__text">{cap('federal').text}</p>
        </article>

        <article class="pm-card pm-card--white pm-card--security">
          <div class="pm-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 3l7 4v6c0 5-3 9-7 10-4-1-7-5-7-10V7l7-4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="pm-card__title">{cap('security').title}</h3>
          <p class="pm-card__text">{cap('security').text}</p>
        </article>

        <article class="pm-card pm-card--white pm-card--rapid">
          <div class="pm-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M13 2L4 14h7l-1 8 10-14h-7l0-6z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="pm-card__title">{cap('rapid').title}</h3>
          <p class="pm-card__text">{cap('rapid').text}</p>
        </article>

        <div class="pm-card pm-card--placeholder pm-card--ph-img" aria-hidden="true"></div>

        <div class="pm-card pm-card--placeholder pm-card--ph-tall" aria-hidden="true"></div>

        <article class="pm-card pm-card--white pm-card--risk">
          <div class="pm-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 9v4M12 17h.01M10.3 3.6L2 20h20L13.7 3.6a1 1 0 0 0-1.8 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="pm-card__title">{cap('risk').title}</h3>
          <p class="pm-card__text">{cap('risk').text}</p>
        </article>

        <article class="pm-card pm-card--navy pm-card--qa">
          <div class="pm-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
              <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"></rect>
            </svg>
          </div>
          <h3 class="pm-card__title">{cap('qa').title}</h3>
          <p class="pm-card__text">{cap('qa').text}</p>
        </article>

        {valuesPrimary.map((v) => (
          <article class:list={['pm-card', 'pm-card--white', v.key === 'ontime' ? 'pm-card--val-ontime' : 'pm-card--val-budget']}>
            <div class="pm-card__icon" aria-hidden="true">
              {v.key === 'ontime' ? (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle>
                  <path d="M12 7v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                </svg>
              ) : (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle>
                  <path d="M8 14c1.5 2 6.5 2 8 0M9 10h.01M15 10h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                </svg>
              )}
            </div>
            <h3 class="pm-card__title">{v.title}</h3>
            <p class="pm-card__text">{v.text}</p>
          </article>
        ))}

        {valuesMore.map((v) => (
          <article class="pm-card pm-card--white pm-card--val-extra">
            <div class="pm-card__icon" aria-hidden="true">
              {v.key === 'compliance' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 3l7 4v5c0 4-2.5 7-7 9-4.5-2-7-5-7-9V7l7-4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
                  <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                </svg>
              )}
              {v.key === 'riskval' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 16l4-6 4 3 4-8 4 11H4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
                </svg>
              )}
              {v.key === 'report' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 19V5a1 1 0 0 1 1-1h10l4 4v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
                  <path d="M8 11h8M8 15h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                </svg>
              )}
            </div>
            <h3 class="pm-card__title">{v.title}</h3>
            <p class="pm-card__text">{v.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="stats-strip">
    <div class="mnc-container">
      <div class="stats-strip__grid stats-strip__grid--4">
        {pmStats.map((s) => (
          <div class="stats-strip__item">
            <span class="stats-strip__num">{s.num}</span>
            <span class="stats-strip__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pm-tools section-gap">
    <div class="mnc-container">
      <span class="section-tag">Platforms</span>
      <h2 class="section-title">Tools &amp; Platforms</h2>
      <p class="pm-tools__desc">
        We meet teams where they work—common construction and program platforms integrated into reporting rhythms you can audit.
      </p>
      <div class="pm-tools__pills">
        {tools.map((name) => (
          <span class="pm-tool-pill">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ 3. DOD / MILITARY ═══════════════ -->
  <div class="dept-section-header" id="dod-military">
    <div class="mnc-container">
      <span class="section-tag">Department</span>
      <h2 class="section-title">DoD / Military</h2>
      <p class="dept-section-sub">Mission-critical facilities and infrastructure delivered with the compliance, security, and precision that defense programs demand.</p>
    </div>
  </div>

  <section class="dod-bento">
    <div class="mnc-container dod-bento__inner">
      <div class="dod-bento__grid">
        <article class="dod-card dod-card--white dod-card--area-milcon">
          <div class="dod-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
