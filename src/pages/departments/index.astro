---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Departments"
  description="Five specialized divisions delivering precision across modular construction, defense, healthcare, civil infrastructure, and project management."
>
  <Header slot="header" />

  <!-- ════════ HERO ════════ -->
  <section class="dp-hero">
    <div class="dp-hero__panel">
      <div class="dp-hero__content">
        <h1 class="dp-hero__h1">Operational<br/>Departments</h1>
        <p class="dp-hero__sub">Five core divisions driving modular excellence — from construction and project management to defense, healthcare, and civil infrastructure.</p>
      </div>
    </div>
  </section>

  <!-- ════════ 01. MODULAR CONSTRUCTION ════════ -->
  <section class="dp-sec dp-sec--white dp-strip" id="modular">
    <div class="dp-mod__wrap">
      <div class="dp-mod__intro">
        <span class="dp-tag">Division 01</span>
        <h2 class="dp-sec__title">Modular Construction</h2>
        <p class="dp-sec__desc">
          Our Modular Construction division delivers efficiency through precision-engineered off-site fabrication. By shifting 90% of the build process to controlled factory environments, we eliminate weather delays and ensure traceability within tolerances. This division also serves as the technical heart of our operations, advancing scalable structures from single-unit components to complex multi-story complexes.
        </p>
        <p class="dp-sec__desc">
          Every module ships with documented QA checkpoints, coordinated logistics for oversized loads, and field teams trained to integrate factory-built volumes with site conditions. That combination shortens commissioning cycles, reduces rework, and gives owners predictable occupancy dates across education, hospitality, workforce housing, and commercial programs.
        </p>
      </div>
      <div class="dp-mod__cards">
        <div class="dp-mod__card fade-up">
          <h4 class="dp-mod__card-title">Assembly Process</h4>
          <p class="dp-mod__card-desc">Full integration of structural framing, MEP rough-in, insulation, and interior finish — coordinated in a single factory pass for consistency at scale.</p>
        </div>
        <div class="dp-mod__card dp-mod__card--accent fade-up">
          <h4 class="dp-mod__card-title">Speed to Market</h4>
          <p class="dp-mod__card-desc">30–50% faster than conventional methods. Parallel factory production and site preparation compress delivery timelines dramatically.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 02. PROJECT MANAGEMENT ════════ -->
  <section class="dp-sec dp-sec--off dp-strip dp-strip--split" id="project-management">
    <div class="dp-split">
      <div class="dp-split__img-col">
        <img src="/images/showcase/west-interior.jpg" alt="Project Management" class="dp-split__img" loading="lazy" />
      </div>
      <div class="dp-split__text-col fade-up">
        <div class="dp-split__text-inner">
          <span class="dp-tag">Division 02</span>
          <h2 class="dp-sec__title">Project Management</h2>
          <p class="dp-sec__desc">
            Authority in management is maintained through rigorous oversight and data-driven systems. Our Project Management office utilizes advanced BIM, Building Information Modeling, and ERP systems to synchronize all phases of construction with on-site assembly. We provide a singular point of accountability for the entire project lifecycle, from initial pre-construction planning to final occupancy optimization.
          </p>
          <p class="dp-sec__desc">
            Stakeholders receive transparent reporting on schedule, cost, and quality metrics, with change control that ties decisions back to contract documents and design intent. We align trade partners, inspectors, and owner representatives on a single program calendar so factory production, site readiness, and commissioning stay in lockstep from mobilization through turnover.
          </p>
          <ul class="dp-bullets">
            <li>BIM Level 2 integration for real-time conflict resolution</li>
            <li>Global supply chain automation and logistics management</li>
            <li>Comprehensive risk mitigation and compliance auditing</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 03. DOD & MILITARY ════════ -->
  <section class="dp-sec dp-sec--white dp-strip dp-strip--split" id="dod-military">
    <div class="dp-dod">
      <div class="dp-dod__text-col fade-up">
        <div class="dp-dod__text-inner">
          <span class="dp-tag">Division 03</span>
          <h2 class="dp-sec__title">DoD & Military<br/>Infrastructure</h2>
          <p class="dp-sec__desc">
            Global Modular Partners is a primary contractor for rapid-deployment military facilities. Our Military department specializes in MILCON (Military Construction), Barracks, Administrative Facilities, Maintenance Barracks, and tactical operations planning. Our record includes projects certified by Defense Logistics Agency (DLA) and AT/FP (Anti-Terrorism/Force Protection), mandated by service, national, and international standards and force protection.
          </p>
          <p class="dp-sec__desc">
            We plan for constrained sites, expeditionary logistics, and layered security from day one—coordinating with government technical monitors, fire protection engineers, and communications specialists so modules arrive ready for utilities, access control, and operational use. Lessons learned from each deployment feed back into our standard details and training programs for the next mobilization.
          </p>
          <div class="dp-dod__accent-card">
            <h4 class="dp-dod__accent-title">Security & Compliance</h4>
            <p class="dp-dod__accent-desc">Full SCIF/SAP clearance capability. Unified Facilities Criteria compliance embedded from concept through construction and commissioning.</p>
          </div>
        </div>
      </div>
      <div class="dp-dod__img-col">
        <img src="/images/showcase/ri-defense-base.png" alt="Military infrastructure" class="dp-dod__img" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ════════ 04. HEALTHCARE ════════ -->
  <section class="dp-sec dp-sec--off dp-strip dp-strip--split" id="healthcare">
    <div class="dp-hc">
      <div class="dp-hc__text-col fade-up">
        <div class="dp-hc__text-inner">
          <span class="dp-tag">Division 04</span>
          <h2 class="dp-sec__title">Healthcare Systems</h2>
          <p class="dp-sec__desc">
            Our Med-Tech team delivers specialized modules for high-acuity medical environments, providing rapid deployment for hospitals, diagnostic labs, and outpatient clinics without compromising existing facility operations.
          </p>
          <p class="dp-sec__desc">
            We coordinate with clinical staff on adjacencies, mechanical redundancy, and life-safety pathways before fabrication begins, then sequence delivery to minimize disruption to active departments. Acoustic isolation, resilient flooring options, and modular headwalls allow facilities to expand capacity or reconfigure wings as census and service lines evolve.
          </p>
          <div class="dp-hc__images">
            <img src="/images/showcase/hwb-clinic-interior.jpeg" alt="Healthcare interior" loading="lazy" />
            <img src="/images/showcase/hwb-modular-pediatric.jpeg" alt="Pediatric facility" loading="lazy" />
          </div>
        </div>
      </div>
      <div class="dp-hc__side-col fade-up">
        <div class="dp-hc__side-inner">
          <div class="dp-hc__watermark" aria-hidden="true">HC-74</div>
          <div class="dp-hc__feature">
            <h4 class="dp-hc__feature-title">Medical-Grade Engineering</h4>
            <ul class="dp-bullets dp-bullets--compact">
              <li>HEPA filtration systems</li>
              <li>Clinical adjacency coordination</li>
              <li>Infection control compliance</li>
            </ul>
          </div>
          <div class="dp-hc__feature">
            <h4 class="dp-hc__feature-title">Load-Jetting & Handling</h4>
            <ul class="dp-bullets dp-bullets--compact">
              <li>Oversized module transport logistics</li>
              <li>Crane coordination & staging</li>
              <li>Site integration protocols</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 05. CIVIL CONSTRUCTION ════════ -->
  <section class="dp-sec dp-sec--white dp-strip dp-strip--split" id="civil">
    <div class="dp-civil">
      <div class="dp-civil__img-col">
        <img src="/images/showcase/ri-civil-compound-aerial.png" alt="Civil construction" class="dp-civil__img" loading="lazy" />
        <img src="/images/showcase/atcco-aerial.jpg" alt="Aerial view" class="dp-civil__img" loading="lazy" />
      </div>
      <div class="dp-civil__text-col fade-up">
        <div class="dp-civil__text-inner">
          <span class="dp-tag">Division 05</span>
          <h2 class="dp-sec__title">Civil Construction</h2>
          <p class="dp-sec__desc">
            Bridging the gap between modular upper-structures and traditional civil infrastructure, our Civil Construction department manages earthwork, utility integration, and foundation engineering. We provide the institutional base upon which our modular installations are permanently or semi-permanently affixed, operating in difficult terrain and complex urban environments using modern stabilization and geotechnical analysis for site stability and longevity.
          </p>
          <p class="dp-sec__desc">
            Our crews handle stormwater management, paving and curbs, and tie-ins to municipal water and sewer where required, always with clear handoffs to the modular set crew. That end-to-end ownership reduces interface risk, keeps warranties aligned, and protects the long-term performance of both the civil shell and the modules it supports.
          </p>
          <div class="dp-civil__stats">
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">25+</span>
              <span class="dp-civil__stat-label">Civil projects</span>
            </div>
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">500+</span>
              <span class="dp-civil__stat-label">Completed modules</span>
            </div>
            <div class="dp-civil__stat">
              <span class="dp-civil__stat-num">Zero</span>
              <span class="dp-civil__stat-label">Safety incidents</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  html { scroll-behavior: smooth; }

  /* Match homepage: hero / UI chrome = Barlow; section h2s = secondary (same as .section-title) */
  .dp-mod__card-title,
  .dp-hc__feature-title,
  .dp-dod__accent-title {
    font-family: var(--font-primary);
  }

  /* Match homepage / services strips */
  .dp-strip {
    --strip-edge-gutter: max(1.5rem, calc((100vw - 1440px) / 2 + 1.5rem));
    --strip-inner-gap: 36px;
    scroll-margin-top: 100px;
  }

  .dp-strip--split {
    padding: 0;
  }

  .dp-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .dp-tag::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--ink);
    flex-shrink: 0;
  }
  .dp-sec__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.8vw, 48px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .dp-sec__desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
    max-width: none;
  }
  .dp-sec__desc + .dp-sec__desc {
    margin-top: 1rem;
  }

  /* ═══ HERO (white inset frame + rounded navy panel) ═══ */
  .dp-hero {
    position: relative;
    background: #fff;
    padding: clamp(6px, 0.6vw, 10px);
  }

  .dp-hero__panel {
    position: relative;
    height: 480px;
    overflow: hidden;
    border-radius: clamp(14px, 1.6vw, 22px);
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .dp-hero__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .dp-hero__content {
    position: relative;
    z-index: 3;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .dp-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: none;
    letter-spacing: -2px;
    margin: 0 0 20px;
  }

  .dp-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    max-width: 520px;
    margin: 0;
  }

  /* ═══ SECTION SHELL ═══ */
  .dp-sec {
    padding: 0;
  }
  .dp-sec--white { background: var(--paper); }
  .dp-sec--off { background: var(--paper-2); }

  /* ═══ 01. MODULAR (intro + cards, full-bleed gutters) ═══ */
  .dp-mod__wrap {
    padding: 80px var(--strip-edge-gutter) 100px;
  }

  .dp-mod__intro {
    max-width: 680px;
  }

  .dp-mod__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .dp-mod__card {
    padding: 2rem 1.75rem;
    border: 1px solid var(--line);
    background: var(--paper);
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
    border-radius: var(--radius-xl);
  }

  .dp-mod__card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: #d6d6d1;
  }

  .dp-mod__card--accent {
    background: var(--ink);
    border-color: var(--ink);
  }

  .dp-mod__card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .dp-mod__card--accent .dp-mod__card-title {
    color: var(--on-ink);
  }

  .dp-mod__card-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  .dp-mod__card--accent .dp-mod__card-desc {
    color: var(--on-ink-muted);
  }

  /* ═══ 02. PM — image left, text right (like .netmap / services default) ═══ */
  .dp-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  .dp-split__img-col {
    position: relative;
    overflow: hidden;
    padding-top: 48px;
    padding-bottom: 48px;
    padding-left: var(--strip-edge-gutter);
    padding-right: var(--strip-inner-gap);
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .dp-split__img {
    width: 100%;
    flex: 1;
    min-height: 0;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-xl);
  }

  .dp-split__text-col {
    display: flex;
    align-items: center;
    padding-right: var(--strip-edge-gutter);
    padding-left: 0;
    min-width: 0;
  }

  .dp-split__text-inner {
    padding: 48px 0 48px var(--strip-inner-gap);
    max-width: 680px;
    width: 100%;
  }

  .dp-bullets {
    list-style: none;
    padding: 0;
    margin: 20px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dp-bullets li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--muted);
  }

  .dp-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 0;
    background: var(--ink);
  }

  .dp-bullets--compact { margin: 12px 0 0; gap: 6px; }
  .dp-bullets--compact li { font-size: 0.9rem; }

  /* ═══ 03. DOD — text left, image right (like .hp-about) ═══ */
  .dp-dod {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  .dp-dod__text-col {
    display: flex;
    align-items: center;
    padding-left: var(--strip-edge-gutter);
    padding-right: 0;
    min-width: 0;
  }

  .dp-dod__text-inner {
    padding: 48px var(--strip-inner-gap) 48px 0;
    max-width: 680px;
  }

  .dp-dod__img-col {
    position: relative;
    overflow: hidden;
    padding-top: 48px;
    padding-bottom: 48px;
    padding-left: var(--strip-inner-gap);
    padding-right: var(--strip-edge-gutter);
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .dp-dod__img {
    width: 100%;
    flex: 1;
    min-height: 0;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-xl);
  }

  .dp-dod__accent-card {
    margin-top: 1.75rem;
    padding: 1.5rem 1.75rem;
    background: var(--ink);
    color: var(--on-ink);
    border-left: none;
    border-radius: var(--radius-xl);
  }

  .dp-dod__accent-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--on-ink);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }

  .dp-dod__accent-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--on-ink-muted);
    margin: 0;
  }

  /* ═══ 04. HEALTHCARE ═══ */
  .dp-hc {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 560px;
  }

  .dp-hc__text-col {
    display: flex;
    align-items: flex-start;
    padding: 48px 0 48px var(--strip-edge-gutter);
    padding-right: var(--strip-inner-gap);
    min-width: 0;
  }

  .dp-hc__text-inner {
    padding: 0;
    max-width: 680px;
    width: 100%;
  }

  .dp-hc__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 28px;
  }

  .dp-hc__images img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-xl);
  }

  .dp-hc__side-col {
    display: flex;
    align-items: flex-start;
    padding: 48px var(--strip-edge-gutter) 48px 0;
    min-width: 0;
  }

  .dp-hc__side-inner {
    width: 100%;
    max-width: 420px;
  }

  .dp-hc__watermark {
    font-family: var(--font-mono);
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 400;
    color: var(--line);
    line-height: 1;
    margin-bottom: 1.5rem;
    letter-spacing: 0;
  }

  .dp-hc__feature {
    padding: 1.5rem 0;
    border-top: 1px solid var(--line);
  }

  .dp-hc__feature:last-child {
    border-bottom: 1px solid var(--line);
  }

  .dp-hc__feature-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  /* ═══ 05. CIVIL — images left, text right ═══ */
  .dp-civil {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  .dp-civil__img-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 48px;
    padding-bottom: 48px;
    padding-left: var(--strip-edge-gutter);
    padding-right: var(--strip-inner-gap);
    min-height: 0;
    justify-content: center;
  }

  .dp-civil__img {
    width: 100%;
    display: block;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  .dp-civil__img:first-child {
    aspect-ratio: 16 / 10;
  }

  .dp-civil__img:last-child {
    aspect-ratio: 16 / 9;
  }

  .dp-civil__text-col {
    display: flex;
    align-items: center;
    padding-right: var(--strip-edge-gutter);
    padding-left: 0;
    min-width: 0;
  }

  .dp-civil__text-inner {
    padding: 48px 0 48px var(--strip-inner-gap);
    max-width: 680px;
    width: 100%;
  }

  .dp-civil__stats {
    display: flex;
    gap: 2.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .dp-civil__stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    display: block;
    line-height: 1;
  }

  .dp-civil__stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-top: 0.5rem;
  }

  @media (min-width: 901px) {
    .dp-split,
    .dp-dod,
    .dp-civil {
      height: 620px;
      min-height: 620px;
      max-height: 620px;
      overflow: hidden;
    }

    .dp-split__text-col,
    .dp-dod__text-col,
    .dp-civil__text-col {
      align-items: stretch;
      overflow: hidden;
    }

    .dp-split__text-inner,
    .dp-dod__text-inner,
    .dp-civil__text-inner {
      display: flex;
      flex-direction: column;
      height: 100%;
      min-height: 0;
      padding-top: 48px;
      padding-bottom: 48px;
    }

    .dp-split__text-inner .dp-bullets {
      margin-top: auto;
      padding-top: 20px;
    }

    .dp-dod__text-inner .dp-dod__accent-card {
      margin-top: auto;
    }

    .dp-civil__text-inner .dp-civil__stats {
      margin-top: auto;
    }

    .dp-split__img-col,
    .dp-dod__img-col {
      min-height: 0;
    }
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .dp-mod__cards { grid-template-columns: 1fr; }

    .dp-split,
    .dp-dod,
    .dp-hc,
    .dp-civil {
      grid-template-columns: 1fr;
      min-height: auto;
      height: auto;
      max-height: none;
      overflow: visible;
    }

    .dp-split__img-col,
    .dp-dod__img-col,
    .dp-civil__img-col {
      padding: 28px 1.5rem;
      order: -1;
      height: auto;
    }

    .dp-split__img,
    .dp-dod__img {
      flex: none;
      aspect-ratio: 4 / 3;
      min-height: 200px;
    }

    .dp-split__text-col,
    .dp-dod__text-col,
    .dp-hc__text-col,
    .dp-hc__side-col,
    .dp-civil__text-col {
      padding-left: 0;
      padding-right: 0;
    }

    .dp-split__text-inner,
    .dp-dod__text-inner,
    .dp-hc__text-col {
      padding: 40px 32px 0;
    }

    .dp-hc__text-inner,
    .dp-civil__text-inner {
      padding: 0;
      max-width: none;
    }

