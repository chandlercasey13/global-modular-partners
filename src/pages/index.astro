<style>
  /* ════════════════════════════════════════════
     MNC-faithful Homepage — GMP color scheme
     ════════════════════════════════════════════ */

  /* ── Shared layout tokens ── */
  .mnc-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 64px 0;
  }

  /* ── Section Tag (pill) ── */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--text-gray);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .section-tag--dark {
    color: rgba(255,255,255,.6);
  }
  .section-tag--dark::before {
    background: var(--amber);
  }

  /* ── Section Title ── */
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0;
  }

  .section-span {
    color: var(--amber);
  }

  /* ── MNC Button style ── */
  .mnc-btn {
    display: inline-flex;
    padding: 16px;
    border: 1px solid var(--navy);
    border-radius: 4px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s, border-color 0.3s, color 0.3s;
  }

  .mnc-btn__wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mnc-btn__icon {
    width: 20px;
    height: 20px;
    flex: none;
    display: flex;
    align-items: center;
  }
  .mnc-btn__icon svg {
    width: 100%;
    height: 100%;
  }

  .mnc-btn--dark {
    background-color: var(--amber);
    border-color: var(--amber);
    color: var(--navy);
    font-weight: 700;
  }
  .mnc-btn--dark:hover {
    background-color: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background-color: transparent;
    border-color: rgba(255,255,255,.4);
    color: var(--white);
  }
  .mnc-btn--stroke:hover {
    border-color: var(--amber);
    color: var(--amber);
    background-color: rgba(224,161,53,.08);
  }

  .mnc-btn--light {
    background-color: var(--white);
    border-color: var(--white);
    color: var(--dark-text);
  }
  .mnc-btn--light:hover {
    background-color: var(--off-white);
    border-color: var(--off-white);
    color: var(--dark-text);
  }

  .mnc-btn--outline {
    background-color: transparent;
    border-color: var(--navy);
    color: var(--navy);
  }
  .mnc-btn--outline:hover {
    background-color: var(--navy);
    color: var(--white);
  }


  /* ════════ 1. BANNER ════════ */
  .banner {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    background-color: #fff;
    padding: 0;
    animation: bannerInset 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }
  .banner ~ section,
  .banner ~ footer,
  .banner ~ div {
    position: relative;
    z-index: 3;
  }

  @keyframes bannerInset {
    from { padding: 0; }
    to   { padding: clamp(6px, 0.6vw, 10px); }
  }

  .banner__pad {
    padding: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, var(--navy) 0%, var(--navy-dark) 100%);
    position: relative;
    overflow: hidden;
    border-radius: 0;
    animation: bannerRound 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }

  @keyframes bannerRound {
    from {
      border-radius: 0;
      min-height: 100vh;
    }
    to {
      border-radius: clamp(14px, 1.6vw, 22px);
      min-height: calc(100vh - clamp(12px, 1.2vw, 20px));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .banner, .banner__pad { animation: none; }
    .banner { padding: clamp(6px, 0.6vw, 10px); }
    .banner__pad {
      border-radius: clamp(14px, 1.6vw, 22px);
      min-height: calc(100vh - clamp(12px, 1.2vw, 20px));
    }
  }

  /* Hero animation timing — sync all hero entry animations to ~1.9s window
     (matches the bannerInset 0.3s delay + 1.6s duration). */
  .banner .fade-up {
    transition: opacity 1.35s cubic-bezier(0.22, 1, 0.36, 1), transform 1.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .banner__h1.fade-up        { transition-delay: 0.30s; }
  .banner__blurb-text.fade-up { transition-delay: 0.45s; }
  .banner__ctas.fade-up       { transition-delay: 0.55s; }

  .banner .slide-in-right {
    transition: opacity 1.4s cubic-bezier(0.22, 1, 0.36, 1), transform 1.4s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.40s;
  }

  .banner__tile.slide-in-up {
    transition: opacity 1.45s cubic-bezier(0.22, 1, 0.36, 1), transform 1.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .banner__inner {
    position: relative;
    z-index: 3;
    width: 100%;
    flex: 1;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: space-between;
  }

  .banner__split {
    position: relative;
    flex: 1;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    align-items: center;
    gap: clamp(24px, 3vw, 48px);
    padding-top: clamp(96px, 12vh, 148px);
    padding-bottom: clamp(20px, 2.2vh, 32px);
  }

  .banner__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 18px;
    max-width: 820px;
    padding-left: clamp(8px, 2vw, 28px);
  }

  .banner__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }


  .banner__h1 {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4.4vw, 62px);
    font-weight: 700;
    line-height: 1.08;
    color: var(--white);
    letter-spacing: -1.4px;
    text-transform: none;
    margin: 0;
  }
  .banner__h1-accent {
    color: var(--amber);
  }

  .banner__blurb-text {
    color: rgba(255,255,255,.72);
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.6;
    margin: 0;
    max-width: 640px;
  }

  .banner__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 22px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: background 0.25s, gap 0.25s, color 0.25s, border-color 0.25s;
  }
  .banner__cta--primary {
    padding: 8px 8px 8px 22px;
    background: var(--amber);
    color: #111;
  }
  .banner__cta--primary:hover {
    background: #f7d06b;
    gap: 14px;
  }
  .banner__cta--ghost {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }
  .banner__cta--ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #fff;
  }
  .banner__cta-icon {
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: #111;
    color: var(--amber);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .banner__visual {
    position: relative;
    width: 100%;
    height: clamp(340px, 48vh, 460px);
    overflow: visible;
  }

  @media (min-width: 769px) {
    .banner__visual {
      position: absolute;
      top: 60%;
      right: clamp(16px, 3vw, 60px);
      transform: translateY(-50%);
      width: calc(100% * 1 / 2.4 - 16px);
      height: clamp(420px, 78vh, 760px);
      max-height: calc(100vh - 240px);
    }
  }
  .banner__visual-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .banner__visual-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26, 42, 66, 0) 60%, rgba(17, 28, 48, 0.3) 100%);
    pointer-events: none;
  }

  .banner__visual--3d {
    background: transparent;
    border: none;
  }
  .banner__visual--3d canvas {
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
    touch-action: none;
  }
  .banner__visual--3d canvas:active {
    cursor: grabbing;
  }
  .banner__visual-tag {
    display: none;
  }

  .banner__tiles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding-bottom: 20px;
  }

  .banner__tile {
    position: relative;
    height: clamp(120px, 15vh, 160px);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .banner__tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .banner__tile-tag {
    position: absolute;
    left: 12px;
    bottom: 10px;
    font-family: var(--font-secondary);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
    padding: 5px 10px;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(6px);
  }

  .banner__tile--photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(12, 24, 48, 0.55) 0%, rgba(12, 24, 48, 0) 55%);
    pointer-events: none;
  }

  .banner__tile--3d {
    background: var(--navy-dark);
  }
  .banner__tile--3d canvas {
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
    touch-action: none;
  }
  .banner__tile--3d canvas:active {
    cursor: grabbing;
  }

  .banner__tile--stat {
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 8px;
    background: rgba(255, 255, 255, 0.04);
  }
  .banner__tile-big {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 600;
    line-height: 1;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .banner__tile-lbl {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }
  .banner__tile-chart {
    width: 100%;
    height: 32px;
    color: var(--amber);
    margin-top: auto;
  }
  .banner__tile-sub {
    font-size: 11px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.55);
    margin-top: auto;
  }

  .banner__bottom {
    flex-shrink: 0;
    padding-bottom: 32px;
    min-width: 0;
    width: 100%;
    pointer-events: auto;
  }

  .banner__partners {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: clamp(6px, 1vw, 16px);
    width: 100%;
    min-width: 0;
    overflow: hidden;
    padding: 22px clamp(16px, 2.5vw, 28px) 18px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.02) 0%,
      rgba(255, 255, 255, 0.006) 100%
    );
    backdrop-filter: blur(22px) saturate(100%);
    -webkit-backdrop-filter: blur(22px) saturate(100%);
    box-shadow: none;
  }

  .banner__partner {
    pointer-events: auto;
    flex: 1.22 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: clamp(30px, 4vw, 48px);
    filter: brightness(0) invert(1);
  }

  .banner__partner img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  /* Compact marks: narrower columns; other six get more width for larger artwork */
  .banner__partner[data-partner='EnTech Engineering'] {
    flex: 0.64 1 0;
  }

  .banner__partner[data-partner='EnTech Engineering'] {
    margin-inline: clamp(20px, 3.5vw, 44px);
  }

  .netmap__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    font-size: 14px;
    font-weight: 600;
