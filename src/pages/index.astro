  <script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline>
    (function initMap() {
      var mapEl = document.getElementById('network-map');
      if (!mapEl) return;
      if (typeof L === 'undefined') {
        setTimeout(initMap, 100);
        return;
      }

      var map = L.map(mapEl, {
        center: [25, -30],
        zoom: 2,
        zoomControl: true,
        scrollWheelZoom: false,
        attributionControl: false,
        minZoom: 2,
        maxZoom: 6,
        worldCopyJump: true,
      });

      // ESRI Dark Gray Canvas — English-only labels, served unlocalized.
      // Split into base (land/water) + reference (labels) so we can tint the
      // base blue without darkening the label readability.
      L.tileLayer(
        'https://server.arcgisonline.com/ArcGIS/rest/services/Canvas/World_Dark_Gray_Base/MapServer/tile/{z}/{y}/{x}',
        { maxZoom: 16, className: 'netmap-basetile' }
      ).addTo(map);
      L.tileLayer(
        'https://server.arcgisonline.com/ArcGIS/rest/services/Canvas/World_Dark_Gray_Reference/MapServer/tile/{z}/{y}/{x}',
        { maxZoom: 16, className: 'netmap-labeltile' }
      ).addTo(map);

      setTimeout(function () { map.invalidateSize(); }, 300);

      // type: 'office' (GMP), 'project' (active project site), 'partner' (partner facility)
      var locations = [
        // GMP offices
        { name: 'GMP Headquarters', loc: [37.8044, -122.2712], city: 'Oakland, CA', type: 'office' },
        { name: 'GMP Southern California', loc: [33.6846, -117.8265], city: 'Irvine, CA', type: 'office' },

        // North America project sites
        { name: 'Bay Area Projects', loc: [37.7749, -122.4194], city: 'San Francisco Bay Area, CA', type: 'project' },
        { name: 'Santa Ana Deployments', loc: [33.7455, -117.8677], city: 'Santa Ana, CA', type: 'project' },
        { name: 'New York Projects', loc: [40.7128, -74.0060], city: 'New York, NY', type: 'project' },
        { name: 'Guam Operations', loc: [13.4745, 144.7504], city: 'Hagåtña, Guam', type: 'project' },
        { name: 'Meridian Heights', loc: [31.8457, -102.3676], city: 'Odessa, TX', type: 'project' },

        // Europe / Mediterranean — RI Group footprint + HWB Europe
        { name: 'RI Group — Lecce', loc: [40.3515, 18.1750], city: 'Lecce, Italy', type: 'partner' },
        { name: 'RI Group — Rome Office', loc: [41.9028, 12.4964], city: 'Rome, Italy', type: 'partner' },
        { name: 'Istanbul Projects', loc: [41.0082, 28.9784], city: 'Istanbul, Türkiye', type: 'project' },

        // Middle East & Africa
        { name: 'EDIS International', loc: [31.9454, 35.9284], city: 'Amman, Jordan', type: 'partner' },
        { name: 'South Sudan Deployments', loc: [4.8594, 31.5713], city: 'Juba, South Sudan', type: 'project' },
      ];

      var pinColor = '#F0C645';
      var pinSize = 12;
      var pinIcon = L.divIcon({
        className: 'netmap-marker',
        html:
          '<span style="width:' + pinSize + 'px;height:' + pinSize + 'px;background:' + pinColor +
          ';border:2px solid #fff;border-radius:50%;display:block;' +
          'box-shadow:0 0 0 3px ' + pinColor + '33, 0 0 10px ' + pinColor + 'aa;"></span>',
        iconSize: [pinSize, pinSize],
        iconAnchor: [pinSize / 2, pinSize / 2],
      });

      locations.forEach(function (c) {
        L.marker(c.loc, { icon: pinIcon })
          .addTo(map)
          .bindPopup('<strong>' + c.name + '</strong><br/>' + c.city);
      });
    })();
  </script>

