  <script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"></script>
  <script is:inline>
    (function initMap() {
      var mapEl = document.getElementById('network-map');
      if (!mapEl) return;
      if (typeof L === 'undefined') {
        setTimeout(initMap, 100);
        return;
      }

      var map = L.map(mapEl, {
        center: [49.96, -2.46],
        zoom: 1.6,
        zoomControl: false,
        scrollWheelZoom: false,
        dragging: false,
        touchZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        tap: false,
        attributionControl: false,
        minZoom: 1,
        maxZoom: 6,
        worldCopyJump: true,
        preferCanvas: false,
      });

      // Ocean/land base colors are driven entirely by CSS so the map can
      // fade from white → navy together with the rest of the section as it
      // scrolls into view (see `.netmap.in-view` rules).

      function ensurePatternDefs() {
        var svg = mapEl.querySelector('.leaflet-overlay-pane svg');
        if (!svg) return null;
        if (!svg.querySelector('#gmp-blocks-defs')) {
          var ns = 'http://www.w3.org/2000/svg';
          var defs = document.createElementNS(ns, 'defs');
          defs.setAttribute('id', 'gmp-blocks-defs');
          defs.innerHTML =
            '<pattern id="gmp-blocks" x="0" y="0" width="22" height="18" patternUnits="userSpaceOnUse">' +
              '<rect x="1" y="1" width="19" height="15" fill="#F0C645" rx="2.5"/>' +
            '</pattern>';
          svg.insertBefore(defs, svg.firstChild);
        }
        return svg;
      }

      function applyPatternFill() {
        var svg = ensurePatternDefs();
        if (!svg) return;
        var paths = svg.querySelectorAll('path.netmap-land');
        for (var i = 0; i < paths.length; i++) {
          paths[i].setAttribute('fill', 'url(#gmp-blocks)');
          paths[i].setAttribute('fill-opacity', '1');
        }
      }

      // ─────────────────────────────────────────────────────────────
      // Scroll-trigger reveal: once the section scrolls into view, the
      // animation plays out on its own schedule (no scroll-linked
      // progress). Stages:
      //
      //   t = 0ms    → build-grid modules dismantle
      //   t = 250ms  → country blocks scale/fade in
      //   t = 1400ms → location pins fade in
      //   t = 2000ms → overlay text fades up into place
      // ─────────────────────────────────────────────────────────────
      var sectionEl = mapEl.closest('.netmap');
      var revealFired = false;

      function playNetmapReveal() {
        if (revealFired) return;
        revealFired = true;

        var root = document.documentElement.style;
        if (typeof window.startBuildDismantle === 'function') {
          window.startBuildDismantle();
        }
        setTimeout(function () { root.setProperty('--rv-blocks', '1'); },  250);
        setTimeout(function () { root.setProperty('--rv-pins',   '1'); }, 1400);
        setTimeout(function () { root.setProperty('--rv-text',   '1'); }, 2000);
      }

      if (sectionEl) {
        if ('IntersectionObserver' in window) {
          var netmapIO = new IntersectionObserver(function (entries) {
            for (var i = 0; i < entries.length; i++) {
              if (entries[i].isIntersecting) {
                playNetmapReveal();
                netmapIO.disconnect();
                break;
              }
            }
          }, { threshold: 0.35 });
          netmapIO.observe(sectionEl);
        } else {
          // Reduced-capability fallback: just play immediately.
          playNetmapReveal();
        }
      }

      // Fix polygons that wrap across the antimeridian (Russia, Fiji, etc.)
      // by shifting any negative longitudes into positive space when a ring
      // straddles ±180° — this prevents Leaflet from drawing a long horizontal
      // "seam" across the landmass.
      function fixRing(ring) {
        var hasFarEast = false, hasFarWest = false;
        for (var i = 0; i < ring.length; i++) {
          if (ring[i][0] > 90) hasFarEast = true;
          if (ring[i][0] < -90) hasFarWest = true;
        }
        if (hasFarEast && hasFarWest) {
          var out = new Array(ring.length);
          for (var j = 0; j < ring.length; j++) {
            var c = ring[j];
            out[j] = c[0] < 0 ? [c[0] + 360, c[1]] : [c[0], c[1]];
          }
          return out;
        }
        return ring;
      }
      function fixFeature(feat) {
        var g = feat && feat.geometry;
        if (!g) return feat;
        if (g.type === 'Polygon') {
          g.coordinates = g.coordinates.map(fixRing);
        } else if (g.type === 'MultiPolygon') {
          g.coordinates = g.coordinates.map(function (poly) {
            return poly.map(fixRing);
          });
        }
        return feat;
      }

      // Build the country layer from a 110m world topojson (~60KB).
      fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json')
        .then(function (r) { return r.json(); })
        .then(function (topo) {
          if (typeof topojson === 'undefined' || !topo || !topo.objects) return;
          var geo = topojson.feature(topo, topo.objects.countries);
          if (geo && geo.features) geo.features = geo.features.map(fixFeature);
          L.geoJSON(geo, {
            interactive: false,
            // Larger SVG padding prevents wide polygons (Russia, Antarctica)
            // from being clipped near the edges of the overlay pane.
            renderer: L.svg({ padding: 2 }),
            style: function () {
              return {
                fillColor: '#F0C645',
                color: 'rgba(140, 100, 28, 0.85)',
                weight: 0.6,
                opacity: 1,
                fillOpacity: 1,
                lineJoin: 'round',
                lineCap: 'round',
                className: 'netmap-land',
              };
            },
          }).addTo(map);
          applyPatternFill();
          renderLocationBlocks();
          map.on('zoomend moveend viewreset layeradd', applyPatternFill);
        })
        .catch(function () { /* silent — ocean still looks fine if offline */ });

      var refresh = function () { map.invalidateSize(); };
      setTimeout(refresh, 100);
      setTimeout(refresh, 400);
      setTimeout(refresh, 1000);
      window.addEventListener('resize', refresh);
      window.addEventListener('load', refresh);
      if (typeof ResizeObserver !== 'undefined') {
        var ro = new ResizeObserver(refresh);
        ro.observe(mapEl);
      }

      // type: 'office' (GMP), 'project' (active project site), 'partner' (partner facility)
      var locations = [
        // GMP offices
        { name: 'GMP Southern California', loc: [33.6846, -117.8265], city: 'Irvine, CA', type: 'office' },

        // North America project sites
        { name: 'Bay Area Projects', loc: [37.7749, -122.4194], city: 'San Francisco Bay Area, CA', type: 'project' },
        { name: 'Santa Ana Deployments', loc: [33.7455, -117.8677], city: 'Santa Ana, CA', type: 'project' },
        { name: 'New York Projects', loc: [40.7128, -74.0060], city: 'New York, NY', type: 'project' },
        { name: 'Guam Operations', loc: [13.4745, 144.7504], city: 'Hagåtña, Guam', type: 'project' },
        { name: 'Meridian Heights', loc: [31.8457, -102.3676], city: 'Odessa, TX', type: 'project' },

        // Europe / Mediterranean — RI Group footprint + HWB Europe
        { name: 'RI Group — Lecce', loc: [40.3515, 18.1750], city: 'Lecce, Italy', type: 'partner' },
        { name: 'RI Group — Rome Office', loc: [41.9028, 12.4964], city: 'Rome, Italy', type: 'partner' },
        { name: 'Istanbul Projects', loc: [41.0082, 28.9784], city: 'Istanbul, Türkiye', type: 'project' },

        // Middle East & Africa
        { name: 'EDIS International', loc: [31.9454, 35.9284], city: 'Amman, Jordan', type: 'partner' },
        { name: 'South Sudan Deployments', loc: [4.8594, 31.5713], city: 'Juba, South Sudan', type: 'project' },
      ];

      // Render each location as an amber cell that SNAPS to the same
      // 22×18 user-space grid the country pattern uses (rect at (1,1)
      // with 19×15 size, rx 2.5). The nearest grid cell to each lat/lng
      // gets filled in bright amber on top of the country grid, so
      // locations read as modules plugged into the continental grid.
      var LOC_COLOR = '#F0C645';
      var GRID_W = 22, GRID_H = 18;
      var CELL_W = 19, CELL_H = 15;
      var CELL_OFF_X = 1, CELL_OFF_Y = 1;

      function renderLocationBlocks() {
        var svg = mapEl.querySelector('.leaflet-overlay-pane svg');
        if (!svg) return;
        var ns = 'http://www.w3.org/2000/svg';
        var g = svg.querySelector('#gmp-loc-blocks');
        if (!g) {
          g = document.createElementNS(ns, 'g');
          g.setAttribute('id', 'gmp-loc-blocks');
        }
        // Always re-append so the group sits above country paths.
        svg.appendChild(g);
        while (g.firstChild) g.removeChild(g.firstChild);

        for (var k = 0; k < locations.length; k++) {
          var loc = locations[k];
          var p = map.latLngToLayerPoint(loc.loc);
          // Snap to the center of the nearest cell in the tiled pattern.
          var i = Math.round((p.x - (CELL_OFF_X + CELL_W / 2)) / GRID_W);
          var j = Math.round((p.y - (CELL_OFF_Y + CELL_H / 2)) / GRID_H);
          // Optional per-location grid offset: [colDelta, rowDelta],
          // positive = right / down in cell units.
          if (loc.offset) {
            i += loc.offset[0] | 0;
            j += loc.offset[1] | 0;
          }
          var rx = i * GRID_W + CELL_OFF_X;
          var ry = j * GRID_H + CELL_OFF_Y;

          // Halo: a slightly larger rect behind the solid cell that
          // pulses (scales + fades) infinitely, giving the block the
          // same "breathing" feel the old glowing dots had. Staggered
          // animation-delay keeps the group from pulsing in lockstep.
          var halo = document.createElementNS(ns, 'rect');
          halo.setAttribute('class', 'gmp-loc-halo netmap-marker');
          halo.setAttribute('x', String(rx));
          halo.setAttribute('y', String(ry));
          halo.setAttribute('width', String(CELL_W));
          halo.setAttribute('height', String(CELL_H));
          halo.setAttribute('rx', '2.5');
          halo.setAttribute('fill', LOC_COLOR);
          halo.style.animationDelay = (k * 0.18).toFixed(2) + 's';
          g.appendChild(halo);

          var rect = document.createElementNS(ns, 'rect');
          rect.setAttribute('class', 'gmp-loc-block netmap-marker');
          rect.setAttribute('x', String(rx));
          rect.setAttribute('y', String(ry));
          rect.setAttribute('width', String(CELL_W));
          rect.setAttribute('height', String(CELL_H));
          rect.setAttribute('rx', '2.5');
          rect.setAttribute('fill', LOC_COLOR);
          rect.style.animationDelay = (k * 0.18).toFixed(2) + 's';
          g.appendChild(rect);
        }
      }

      // Render (or re-render) after country paths exist and on any view
      // change. The map is locked, but we still hook these so the first
      // applyPatternFill → geoJSON add cycle always paints cells.
      map.on('zoomend moveend viewreset layeradd', renderLocationBlocks);

      // ── Modular "build" reveal animation ──
      var buildEl = document.getElementById('netmap-build');
      if (buildEl) {
        var cols = 18;
        var rows = 12;
        var wrapW = mapEl.clientWidth || 1200;
        if (wrapW < 700) { cols = 12; rows = 9; }
        buildEl.style.gridTemplateColumns = 'repeat(' + cols + ', 1fr)';
        buildEl.style.gridTemplateRows = 'repeat(' + rows + ', 1fr)';

        var total = cols * rows;
        var frag = document.createDocumentFragment();
        // Order cells by diagonal sweep + light randomness so it feels like
        // modules being dismantled from the top-left corner outward.
        for (var i = 0; i < total; i++) {
          var r = Math.floor(i / cols);
          var c = i % cols;
          var diag = (r + c) / (rows + cols);
          var jitter = Math.random() * 0.25;
          var delay = (diag * 1.4 + jitter).toFixed(2);
          var cell = document.createElement('span');
          cell.className = 'netmap__build__cell';
          cell.style.setProperty('--cell-delay', delay + 's');
          frag.appendChild(cell);
        }
        buildEl.appendChild(frag);

        // Exposed so the IntersectionObserver reveal trigger can fire the
        // dismantle when the section scrolls into view.
        window.startBuildDismantle = function () {
          map.invalidateSize();
          buildEl.classList.add('built');
          setTimeout(function () {
            buildEl.style.display = 'none';
          }, 2800);
        };
      }
    })();
  </script>

