  /* ════════ 3. GLOBAL NETWORK MAP ════════ */
  /* The section sits on the map's navy ocean color by default; the scroll
     stop only drives staged content reveals (country blocks, pins, text). */
  :root {
    --rv-blocks: 0;   /* block-country opacity/scale */
    --rv-pins:   0;   /* marker dots opacity */
    --rv-text:   0;   /* overlay text reveal */
  }

  .netmap .netmap__panel {
    background-color: transparent;
  }
  .netmap {
    background-color: #fff;
  }

  .netmap {
    position: relative;
    padding: 0;
    margin: 0;
  }

  .netmap__panel {
    position: relative;
    border-radius: 0;
    overflow: hidden;
    width: 100%;
    margin: 0 auto;
  }

  .netmap__img-col {
    width: 100%;
  }

  .netmap__map-wrap {
    position: relative;
    width: 100%;
    height: min(84vh, 820px);
    overflow: hidden;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .netmap__overlay {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 500;
    padding:
      clamp(56px, 6vw, 96px)
      clamp(24px, 3vw, 40px)
      clamp(10px, 1.2vw, 18px)
      var(--strip-edge-gutter, 1.5rem);
    pointer-events: none;
    background: linear-gradient(
      155deg,
      rgba(13, 28, 51, 0.32) 0%,
      rgba(13, 28, 51, 0.08) 48%,
      transparent 78%
    );
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: none;
  }

  .netmap__overlay > * {
    opacity: var(--rv-text, 0);
    transform: translateY(calc((1 - var(--rv-text, 0)) * 18px));
    transition:
      opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .netmap__overlay .netmap__overlay-tag,
  .netmap__overlay .section-tag.netmap__overlay-tag {
    margin: 0;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35), 0 0 20px rgba(0, 0, 0, 0.25);
  }
  .netmap__overlay .netmap__overlay-title,
  .netmap__overlay .section-title.netmap__overlay-title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: #fff !important;
    white-space: nowrap;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4), 0 8px 28px rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 900px) {
    .netmap__overlay {
      padding: 20px 18px;
      max-width: 90%;
    }
    .netmap__overlay-title {
      font-size: clamp(22px, 6vw, 32px);
    }
  }

  /* ── "Build" reveal: grid of modular blocks that dismantle to expose the map ── */
  .netmap__build {
    position: absolute;
    inset: 0;
    z-index: 450;
    display: grid;
    pointer-events: none;
    background: transparent;
  }
  .netmap__build__cell {
    background-color: var(--navy-dark);
    border: 1px solid rgba(255, 255, 255, 0.04);
    opacity: 1;
    transform: translateY(-6px) scale(1);
    transition:
      opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--cell-delay, 0s);
    will-change: opacity, transform;
  }
  .netmap__build.built .netmap__build__cell {
    opacity: 0;
    transform: translateY(-24px) scale(0.96);
  }

  @media (prefers-reduced-motion: reduce) {
    .netmap__build__cell {
      transition-duration: 0.2s !important;
      transition-delay: 0s !important;
      transform: none !important;
    }
  }

  .netmap__map-wrap :global(.leaflet-container) {
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
    border-radius: 0;
  }
  /* Country land layer drop-shadow for a lifted, blocky feel. */
  .netmap__map-wrap :global(.netmap-land) {
    filter: drop-shadow(0 1px 0 rgba(0, 0, 0, 0.35));
  }
  /* Markers float above the blocky land. */
  .netmap__map-wrap :global(.leaflet-marker-pane) { z-index: 610; }
  .netmap__map-wrap :global(.leaflet-popup-pane) { z-index: 700; }

  /* Country blocks: scale + fade in driven by --rv-blocks (0 → 1). */
  .netmap__map :global(#gmp-blocks rect) {
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(var(--rv-blocks, 0));
    opacity: var(--rv-blocks, 0);
    transition:
      transform 0.9s cubic-bezier(0.34, 1.4, 0.64, 1),
      opacity 0.7s ease-out;
  }

  /* Pins: fade in once blocks are mostly placed (driven by --rv-pins). */
  .netmap__map-wrap :global(.netmap-marker) {
    opacity: var(--rv-pins, 0);
    transition: opacity 0.7s ease-out;
  }

  /* Location cells breathe gently; the halo pulses outward like the
     glow the original dots had. Both use fill-opacity so the outer
     --rv-pins reveal opacity stays intact. */
  .netmap__map-wrap :global(.gmp-loc-block) {
    transform-box: fill-box;
    transform-origin: center;
    animation: gmpLocCore 1.8s ease-in-out infinite;
    will-change: fill-opacity, transform;
  }
  .netmap__map-wrap :global(.gmp-loc-halo) {
    transform-box: fill-box;
    transform-origin: center;
    animation: gmpLocHalo 1.8s ease-out infinite;
    will-change: transform, fill-opacity;
    pointer-events: none;
  }

  @keyframes gmpLocCore {
    0%, 100% { fill-opacity: 1;    transform: scale(1);    }
    50%      { fill-opacity: 0.6;  transform: scale(1.15); }
  }
  @keyframes gmpLocHalo {
    0%   { transform: scale(1);   fill-opacity: 0.9; }
    70%  { transform: scale(3.2); fill-opacity: 0;   }
    100% { transform: scale(3.2); fill-opacity: 0;   }
  }

  @media (prefers-reduced-motion: reduce) {
    .netmap__map-wrap :global(.gmp-loc-block),
    .netmap__map-wrap :global(.gmp-loc-halo) {
      animation: none !important;
    }
    .netmap__map-wrap :global(.gmp-loc-halo) { fill-opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .netmap__map :global(#gmp-blocks rect) {
      transform: none;
      opacity: 1;
    }
    .netmap__map-wrap :global(.netmap-marker) { opacity: 1; }
    .netmap__overlay > * { opacity: 1; transform: none; }
  }

