      }).addTo(map);

      setTimeout(function () { map.invalidateSize(); }, 300);

      var companies = [
        { name: 'GMP Headquarters', loc: [37.8044, -122.2712], city: 'Oakland, CA', type: 'hq' },
        { name: 'GMP Southern CA', loc: [33.6846, -117.8265], city: 'Irvine, CA', type: 'hq' },
