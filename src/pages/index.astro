  }

  .hp-work__title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: #111;
    margin: 0;
  }

  .hp-work__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 22px 10px 24px;
