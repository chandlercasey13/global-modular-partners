  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    const canvas = document.getElementById('hero-3d');
    if (canvas) {
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
      camera.position.set(12, 9, 14);

      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping = true;
      controls.dampingFactor = 0.05;
      controls.enablePan = false;
      controls.minDistance = 6;
      controls.maxDistance = 30;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.8;

      const edgeMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.6 });
      const ridgeMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.15 });

      const modules = [];
      const dropHeight = 15;

      function addModule(w, h, d, x, y, z, order) {
        const group = new THREE.Group();
        group.position.set(x, y + dropHeight, z);

        const geo = new THREE.BoxGeometry(w, h, d);
        const edges = new THREE.EdgesGeometry(geo);
        const line = new THREE.LineSegments(edges, edgeMat.clone());
        line.material.opacity = 0;
        group.add(line);

        const ridgeCount = Math.floor(w / 0.45);
        const ridgeGeo = new THREE.BufferGeometry();
        const verts = [];
        for (let i = 1; i < ridgeCount; i++) {
          const lx = -w / 2 + (w / ridgeCount) * i;
          verts.push(lx, -h / 2, d / 2, lx, h / 2, d / 2);
          verts.push(lx, -h / 2, -d / 2, lx, h / 2, -d / 2);
        }
        const sideCount = Math.floor(d / 0.45);
        for (let i = 1; i < sideCount; i++) {
          const lz = -d / 2 + (d / sideCount) * i;
          verts.push(-w / 2, -h / 2, lz, -w / 2, h / 2, lz);
          verts.push(w / 2, -h / 2, lz, w / 2, h / 2, lz);
        }
        ridgeGeo.setAttribute('position', new THREE.Float32BufferAttribute(verts, 3));
        const ridges = new THREE.LineSegments(ridgeGeo, ridgeMat.clone());
        ridges.material.opacity = 0;
        group.add(ridges);

        scene.add(group);
        modules.push({ group, targetY: y, delay: order * 0.3, started: false, done: false });
      }

      // Ground floor first (order 0–5)
      addModule(3, 1.3, 2, -5, 0.65, -3, 0);
      addModule(5, 1.2, 2.2, 0, 0.6, -4, 1);
      addModule(2.8, 1.3, 2, 4.5, 0.65, -2, 1);
      addModule(2.2, 1.2, 1.8, -4, 0.6, 2, 2);
      addModule(2.2, 1.2, 1.8, -1.5, 0.6, 2, 2);
      addModule(2.2, 1.2, 1.8, 1, 0.6, 2, 3);
      addModule(2, 1.3, 2, 5, 0.65, 2, 3);
      addModule(2.5, 1.1, 1.8, -1, 0.55, -1, 4);
      addModule(4, 1, 2.5, 2, 0.5, 0, 4);

      // Second floor (order 5–7)
      addModule(3, 1.3, 2, -5, 1.95, -3, 6);
      addModule(2.8, 1.3, 2, 4.5, 1.95, -2, 6);
      addModule(2, 1.3, 2, 5, 1.95, 2, 7);

      // Third floor (order 8–9)
      addModule(2, 0.8, 1.5, -5, 3, -3, 8);
      addModule(2, 1.3, 2, 5, 3.25, 2, 9);

      // Top piece (order 10)
      addModule(1.6, 0.6, 1.6, 5, 4.2, 2, 10);

      // Ground grid — appears immediately
      const gridMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.06 });
      const gridGeo = new THREE.BufferGeometry();
      const gv = [];
      for (let i = -8; i <= 8; i += 1) {
        gv.push(i, 0, -8, i, 0, 8);
        gv.push(-8, 0, i, 8, 0, i);
      }
      gridGeo.setAttribute('position', new THREE.Float32BufferAttribute(gv, 3));
      const grid = new THREE.LineSegments(gridGeo, gridMat);
      scene.add(grid);

      scene.position.y = 0;

      // Easing
      function easeOutCubic(t) {
        return 1 - Math.pow(1 - t, 3);
      }

      const buildDuration = 1.2;
      const startTime = performance.now() / 1000;

      function resize() {
        const parent = canvas.parentElement;
        if (!parent) return;
        const w = parent.clientWidth;
        const h = parent.clientHeight;
        renderer.setSize(w, h);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }

      resize();
      window.addEventListener('resize', resize);

      function animate() {
        requestAnimationFrame(animate);
        const now = performance.now() / 1000;
        const elapsed = now - startTime;

        for (const m of modules) {
          if (m.done) continue;
          const t = (elapsed - m.delay) / buildDuration;
          if (t <= 0) continue;
          m.started = true;
          const clamped = Math.min(t, 1);
          const ease = easeOutCubic(clamped);
          m.group.position.y = m.targetY + dropHeight * (1 - ease);
          m.group.children.forEach(child => {
            if (child.material) child.material.opacity = child.material === m.group.children[0].material ? 0.6 * ease : 0.15 * ease;
          });
          if (clamped >= 1) m.done = true;
        }

        controls.update();
        renderer.render(scene, camera);
      }
      animate();
    }
  </script>

