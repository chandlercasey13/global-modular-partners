    border-radius: clamp(12px, 1.4vw, 20px);
    background: var(--medium-gray);
  }

  .hp-about__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 700ms ease;
    pointer-events: none;
  }

  .hp-about__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .hp-about__dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
  }

  .hp-about__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(13, 28, 51, 0.22);
    border: 0;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease, width 0.25s ease;
  }

  .hp-about__dot:hover {
    background: rgba(13, 28, 51, 0.45);
  }

  .hp-about__dot.is-active {
    background: #0d1c33;
    width: 22px;
    border-radius: 999px;
  }

  .hp-about__dot:focus-visible {
    outline: 2px solid var(--turf-green, #0C7C59);
    outline-offset: 3px;
  }

  @media (max-width: 900px) {
    .hp-about__panel {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (min-width: 901px) {
    .netmap__panel {
      height: auto;
    }

    .netmap__link {
      margin-top: 32px;
    }
  }

  @media (max-width: 1024px) {
    .hp-about { padding: 44px var(--strip-edge-gutter) 72px; }
  }

  @media (max-width: 640px) {
    .hp-about { padding: 36px 1rem 56px; }
  }

  /* ════════ ABOUT MOSAIC ════════ */
