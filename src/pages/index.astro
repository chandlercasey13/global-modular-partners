        { name: 'EDIS USA', loc: [37.8044, -122.2712], city: 'Oakland, CA', type: 'subsidiary' },
        { name: 'EDIS International', loc: [31.9454, 35.9284], city: 'Amman, Jordan', type: 'subsidiary' },
      ];

      function makeDot(color, size) {
        return L.divIcon({
          className: 'netmap-marker',
          html: '<span style="width:' + size + 'px;height:' + size + 'px;background:' + color + ';border:2px solid #fff;border-radius:50%;display:block;box-shadow:0 0 8px ' + color + '88;"></span>',
          iconSize: [size, size],
          iconAnchor: [size / 2, size / 2],
        });
      }

      var hqIcon = makeDot('#2B4B7E', 14);
      var subIcon = makeDot('#4a8c3f', 12);

      companies.forEach(function (c) {
        var icon = c.type === 'hq' ? hqIcon : subIcon;
        L.marker(c.loc, { icon: icon })
          .addTo(map)
          .bindPopup('<strong>' + c.name + '</strong><br/>' + c.city);
