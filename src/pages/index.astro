---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const partners = [
  { name: 'West Modular', logo: '/images/partners/west-modular.svg' },
  { name: 'PROSET Construction', logo: '/images/partners/proset.svg' },
  { name: 'TRUE NORTH Compliance', logo: '/images/partners/true-north.svg' },
  { name: 'EnTech Engineering', logo: '/images/partners/entech.svg' },
  { name: 'Agbayani Construction', logo: '/images/partners/agbayani.svg' },
  { name: 'STREAM Logistics', logo: '/images/partners/stream-logistics.svg' },
];
---

<Layout title="Home">
  <Header slot="header" />

  <!-- ════════ 1. BANNER SECTION ════════ -->
  <section class="banner">
    <div class="banner__pad">
      <div class="banner__inner">
        <div class="banner__split">
          <div class="banner__content">
            <h1 class="banner__h1 fade-up">Building the future of <span class="banner__h1-accent">modular construction.</span></h1>
            <p class="banner__blurb-text fade-up">
              A singular alliance providing end-to-end modular solutions — engineering, fabrication, logistics, and deployment delivered as one coordinated program.
            </p>
            <div class="banner__ctas fade-up">
              <a href="/contact" class="banner__cta banner__cta--primary">
                <span>Get Started</span>
                <span class="banner__cta-icon">
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </a>
              <a href="/projects" class="banner__cta banner__cta--ghost">View Projects</a>
            </div>
          </div>
          <div class="banner__visual banner__visual--3d slide-in-right">
            <canvas id="hero-3d"></canvas>
            <span class="banner__visual-tag">Live Modular Build</span>
          </div>
        </div>

        <div class="banner__tiles">
          <div class="banner__tile banner__tile--stat slide-in-up" style="--delay: 0.15s">
            <span class="banner__tile-big">2,400+</span>
            <span class="banner__tile-lbl">Modules produced</span>
            <svg class="banner__tile-chart" viewBox="0 0 80 28" aria-hidden="true">
              <polyline points="0,22 12,18 24,20 36,12 48,14 60,6 72,9 80,3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="banner__tile banner__tile--photo slide-in-up" style="--delay: 0.25s">
            <img src="/images/showcase/ri-factory-production.jpg" alt="Factory module production" />
            <span class="banner__tile-tag">Fabrication</span>
          </div>
          <div class="banner__tile banner__tile--photo slide-in-up" style="--delay: 0.35s">
            <img src="/images/showcase/west-crane.jpg" alt="On-site deployment and setting" />
            <span class="banner__tile-tag">Deployment</span>
          </div>
          <div class="banner__tile banner__tile--stat slide-in-up" style="--delay: 0.45s">
            <span class="banner__tile-big">3</span>
            <span class="banner__tile-lbl">Continents served</span>
            <span class="banner__tile-sub">North America · Europe · Middle East</span>
          </div>
        </div>

        <div class="banner__bottom">
          <div class="banner__partners">
            {partners.map((p) => (
              <span class="banner__partner" data-partner={p.name}>
                <img src={p.logo} alt={p.name} loading="lazy" />
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    const canvas = document.getElementById('hero-3d');
    if (canvas) {
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 280);
      camera.position.set(-0.87505, 4.00014, 10.71888);

      const controls = new OrbitControls(camera, canvas);
      controls.enableZoom = false;
      controls.enableDamping = true;
      controls.dampingFactor = 0.05;
      controls.enablePan = true;
      controls.panSpeed = 0.55;
      controls.screenSpacePanning = true;
      controls.minDistance = 9;
      controls.maxDistance = 50;
      controls.minPolarAngle = Math.PI * 0.18;
      controls.maxPolarAngle = Math.PI * 0.52;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.8;
      let autoRotateResumeTimer = 0;
      controls.addEventListener('start', () => {
        window.clearTimeout(autoRotateResumeTimer);
        controls.autoRotate = false;
      });
      const fmtCam = (v) => Math.round(v * 1e5) / 1e5;
      function logHeroCameraState() {
        const p = camera.position;
        const t = controls.target;
        const dist = p.distanceTo(t);
        const state = {
          cameraPosition: { x: fmtCam(p.x), y: fmtCam(p.y), z: fmtCam(p.z) },
          controlsTarget: { x: fmtCam(t.x), y: fmtCam(t.y), z: fmtCam(t.z) },
          distance: fmtCam(dist),
          polarAngle: fmtCam(controls.getPolarAngle()),
          azimuthalAngle: fmtCam(controls.getAzimuthalAngle()),
          fov: camera.fov,
          near: camera.near,
          far: camera.far,
        };
        console.log('[hero-3d camera]', state);
        console.log(
          `[hero-3d copy/paste] camera.position.set(${fmtCam(p.x)}, ${fmtCam(p.y)}, ${fmtCam(p.z)});\n` +
            `controls.target.set(${fmtCam(t.x)}, ${fmtCam(t.y)}, ${fmtCam(t.z)});`
        );
      }

      controls.addEventListener('end', () => {
        logHeroCameraState();
        window.clearTimeout(autoRotateResumeTimer);
        autoRotateResumeTimer = window.setTimeout(() => {
          controls.autoRotate = true;
        }, 2200);
      });

      const modules = [];
      const dropHeight = 11;

      const towerX = -0.92;
      const towerZ = -0.08;
      const SEAM_HUG = 0.0022;
      const ADJ = 0.03;

      /** Axis-aligned cell (world space) from center + full dimensions. */
      function pushCell(cx, cy, cz, w, h, d, cells, tier) {
        const hx = w / 2;
        const hy = h / 2;
        const hz = d / 2;
        cells.push({
          x0: cx - hx,
          x1: cx + hx,
          y0: cy - hy,
          y1: cy + hy,
          z0: cz - hz,
          z1: cz + hz,
          tier,
        });
      }

      function iv2(a0, a1, b0, b1) {
        return Math.min(a1, b1) - Math.max(a0, b0) > ADJ;
      }

      function hasNeighborOnFace(c, boxes, face) {
        for (let i = 0; i < boxes.length; i++) {
          const o = boxes[i];
          if (o === c) continue;
          if (face === '+x' && Math.abs(c.x1 - o.x0) < ADJ && iv2(c.y0, c.y1, o.y0, o.y1) && iv2(c.z0, c.z1, o.z0, o.z1)) return true;
          if (face === '-x' && Math.abs(c.x0 - o.x1) < ADJ && iv2(c.y0, c.y1, o.y0, o.y1) && iv2(c.z0, c.z1, o.z0, o.z1)) return true;
          if (face === '+y' && Math.abs(c.y1 - o.y0) < ADJ && iv2(c.x0, c.x1, o.x0, o.x1) && iv2(c.z0, c.z1, o.z0, o.z1)) return true;
          if (face === '-y' && Math.abs(c.y0 - o.y1) < ADJ && iv2(c.x0, c.x1, o.x0, o.x1) && iv2(c.z0, c.z1, o.z0, o.z1)) return true;
          if (face === '+z' && Math.abs(c.z1 - o.z0) < ADJ && iv2(c.x0, c.x1, o.x0, o.x1) && iv2(c.y0, c.y1, o.y0, o.y1)) return true;
          if (face === '-z' && Math.abs(c.z0 - o.z1) < ADJ && iv2(c.x0, c.x1, o.x0, o.x1) && iv2(c.y0, c.y1, o.y0, o.y1)) return true;
        }
        return false;
      }

      function r(v) {
        return Math.round(v * 1e5) / 1e5;
      }

      function edgeKey(x1, y1, z1, x2, y2, z2) {
        const a = `${r(x1)},${r(y1)},${r(z1)}`;
        const b = `${r(x2)},${r(y2)},${r(z2)}`;
        return a < b ? `${a}|${b}` : `${b}|${a}`;
      }

      function addUniqueEdge(edgeMap, ax, ay, az, bx, by, bz) {
        const k = edgeKey(ax, ay, az, bx, by, bz);
        if (!edgeMap.has(k)) edgeMap.set(k, [ax, ay, az, bx, by, bz]);
      }

      function pushTri(pos, ax, ay, az, bx, by, bz, cx, cy, cz) {
        pos.push(ax, ay, az, bx, by, bz, cx, cy, cz);
      }

      /** Two triangles for one exposed quad (same faces as wireframe extraction). */
      function emitExposedFaceTriangles(c, face, positions) {
        const { x0, x1, y0, y1, z0, z1 } = c;
        if (face === '+x') {
          pushTri(positions, x1, y0, z0, x1, y1, z0, x1, y1, z1);
          pushTri(positions, x1, y0, z0, x1, y1, z1, x1, y0, z1);
        } else if (face === '-x') {
          pushTri(positions, x0, y0, z0, x0, y1, z1, x0, y1, z0);
          pushTri(positions, x0, y0, z0, x0, y0, z1, x0, y1, z1);
        } else if (face === '+y') {
          pushTri(positions, x0, y1, z0, x1, y1, z0, x1, y1, z1);
          pushTri(positions, x0, y1, z0, x1, y1, z1, x0, y1, z1);
        } else if (face === '-y') {
          pushTri(positions, x0, y0, z0, x1, y0, z1, x1, y0, z0);
          pushTri(positions, x0, y0, z0, x0, y0, z1, x1, y0, z1);
        } else if (face === '+z') {
          pushTri(positions, x0, y0, z1, x1, y0, z1, x1, y1, z1);
          pushTri(positions, x0, y0, z1, x1, y1, z1, x0, y1, z1);
        } else if (face === '-z') {
          pushTri(positions, x0, y0, z0, x1, y0, z0, x1, y1, z0);
          pushTri(positions, x0, y0, z0, x1, y1, z0, x0, y1, z0);
        }
      }

      /** Four perimeter edges of one face (only called when that face is exposed). */
      function emitExposedFaceEdges(c, face, edgeMap) {
        const { x0, x1, y0, y1, z0, z1 } = c;
        if (face === '+x') {
          addUniqueEdge(edgeMap, x1, y0, z0, x1, y1, z0);
          addUniqueEdge(edgeMap, x1, y1, z0, x1, y1, z1);
          addUniqueEdge(edgeMap, x1, y1, z1, x1, y0, z1);
          addUniqueEdge(edgeMap, x1, y0, z1, x1, y0, z0);
        } else if (face === '-x') {
          addUniqueEdge(edgeMap, x0, y0, z0, x0, y1, z0);
          addUniqueEdge(edgeMap, x0, y1, z0, x0, y1, z1);
          addUniqueEdge(edgeMap, x0, y1, z1, x0, y0, z1);
          addUniqueEdge(edgeMap, x0, y0, z1, x0, y0, z0);
        } else if (face === '+y') {
          addUniqueEdge(edgeMap, x0, y1, z0, x1, y1, z0);
          addUniqueEdge(edgeMap, x1, y1, z0, x1, y1, z1);
          addUniqueEdge(edgeMap, x1, y1, z1, x0, y1, z1);
          addUniqueEdge(edgeMap, x0, y1, z1, x0, y1, z0);
        } else if (face === '-y') {
          addUniqueEdge(edgeMap, x0, y0, z0, x1, y0, z0);
          addUniqueEdge(edgeMap, x1, y0, z0, x1, y0, z1);
          addUniqueEdge(edgeMap, x1, y0, z1, x0, y0, z1);
          addUniqueEdge(edgeMap, x0, y0, z1, x0, y0, z0);
        } else if (face === '+z') {
          addUniqueEdge(edgeMap, x0, y0, z1, x1, y0, z1);
          addUniqueEdge(edgeMap, x1, y0, z1, x1, y1, z1);
          addUniqueEdge(edgeMap, x1, y1, z1, x0, y1, z1);
          addUniqueEdge(edgeMap, x0, y1, z1, x0, y0, z1);
        } else if (face === '-z') {
          addUniqueEdge(edgeMap, x0, y0, z0, x1, y0, z0);
          addUniqueEdge(edgeMap, x1, y0, z0, x1, y1, z0);
          addUniqueEdge(edgeMap, x1, y1, z0, x0, y1, z0);
          addUniqueEdge(edgeMap, x0, y1, z0, x0, y0, z0);
        }
      }

      function addSliceGrid(cols, rows, modW, modD, modH, gapX, gapZ, floors, cells, yTopRef, tierRef) {
        const tier = tierRef.v;
        const hug = gapX === 0 && gapZ === 0 ? SEAM_HUG : 0;
        const pitchX = modW + gapX - hug;
        const pitchZ = modD + gapZ - hug;
        for (let f = 0; f < floors; f++) {
          yTopRef.v += modH / 2;
          const cy = yTopRef.v;
          for (let ix = 0; ix < cols; ix++) {
            for (let iz = 0; iz < rows; iz++) {
              const cx = towerX + (ix - (cols - 1) / 2) * pitchX;
              const cz = towerZ + (iz - (rows - 1) / 2) * pitchZ;
              pushCell(cx, cy, cz, modW, modH, modD, cells, tier);
            }
          }
          yTopRef.v += modH / 2;
        }
        tierRef.v += 1;
      }

      function addSpireCells(baseW, baseD, segmentH, segments, taper, cells, yTopRef, tierRef) {
        let w = baseW;
        let d = baseD;
        for (let s = 0; s < segments; s++) {
          const tier = tierRef.v;
          yTopRef.v += segmentH / 2;
          pushCell(towerX, yTopRef.v, towerZ, w, segmentH, d, cells, tier);
          yTopRef.v += segmentH / 2;
          w *= taper;
          d *= taper;
          tierRef.v += 1;
        }
      }

      /** Neighbor tests use full occupancy; only `subset` cells emit geometry (staggered build). */
      function buildExteriorWireframeGeometry(subset, allCells) {
        const faces = ['+x', '-x', '+y', '-y', '+z', '-z'];
        const edgeMap = new Map();
        for (let i = 0; i < subset.length; i++) {
          const c = subset[i];
          for (let fi = 0; fi < 6; fi++) {
            const face = faces[fi];
            if (!hasNeighborOnFace(c, allCells, face)) {
              emitExposedFaceEdges(c, face, edgeMap);
            }
          }
        }
        const verts = [];
        edgeMap.forEach((seg) => {
          verts.push(seg[0], seg[1], seg[2], seg[3], seg[4], seg[5]);
        });
        const geo = new THREE.BufferGeometry();
        geo.setAttribute('position', new THREE.Float32BufferAttribute(verts, 3));
        return geo;
      }

      function buildExteriorShellGeometry(subset, allCells) {
        const faces = ['+x', '-x', '+y', '-y', '+z', '-z'];
        const positions = [];
        for (let i = 0; i < subset.length; i++) {
          const c = subset[i];
          for (let fi = 0; fi < 6; fi++) {
            const face = faces[fi];
            if (!hasNeighborOnFace(c, allCells, face)) {
              emitExposedFaceTriangles(c, face, positions);
            }
          }
        }
        const geo = new THREE.BufferGeometry();
        geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
        geo.computeVertexNormals();
        return geo;
      }

      const cells = [];
      const yTopRef = { v: 0 };
      const tierRef = { v: 0 };
      addSliceGrid(6, 5, 0.52, 0.5, 0.3, 0, 0, 2, cells, yTopRef, tierRef);
      addSliceGrid(5, 5, 0.54, 0.52, 0.31, 0, 0, 3, cells, yTopRef, tierRef);
      addSliceGrid(5, 4, 0.55, 0.53, 0.32, 0, 0, 2, cells, yTopRef, tierRef);
      addSliceGrid(4, 4, 0.56, 0.54, 0.32, 0, 0, 4, cells, yTopRef, tierRef);
      addSliceGrid(3, 3, 0.58, 0.55, 0.33, 0, 0, 3, cells, yTopRef, tierRef);
      addSliceGrid(2, 2, 0.6, 0.57, 0.33, 0, 0, 4, cells, yTopRef, tierRef);
      addSliceGrid(1, 1, 0.52, 0.5, 0.32, 0, 0, 4, cells, yTopRef, tierRef);
      addSpireCells(0.27, 0.24, 0.29, 8, 0.87, cells, yTopRef, tierRef);

      let minY = Infinity;
      let maxY = -Infinity;
      let maxTier = 0;
      for (let i = 0; i < cells.length; i++) {
        const c = cells[i];
        minY = Math.min(minY, c.y0);
        maxY = Math.max(maxY, c.y1);
        maxTier = Math.max(maxTier, c.tier);
      }
      const pivotY = (minY + maxY) / 2;

      const tierStagger = 0.14;

      for (let tier = 0; tier <= maxTier; tier++) {
        const subset = [];
        for (let i = 0; i < cells.length; i++) {
          if (cells[i].tier === tier) subset.push(cells[i]);
        }
        if (subset.length === 0) continue;

        const worldGeo = buildExteriorWireframeGeometry(subset, cells);
        const wArr = worldGeo.getAttribute('position').array.slice();
        worldGeo.dispose();
        if (wArr.length < 6) continue;
        const local = new Float32Array(wArr.length);
        for (let i = 0; i < wArr.length; i += 3) {
          local[i] = wArr[i] - towerX;
          local[i + 1] = wArr[i + 1] - pivotY;
          local[i + 2] = wArr[i + 2] - towerZ;
        }
        const localGeo = new THREE.BufferGeometry();
        localGeo.setAttribute('position', new THREE.BufferAttribute(local, 3));

        const worldShell = buildExteriorShellGeometry(subset, cells);
        const sArr = worldShell.getAttribute('position').array.slice();
        worldShell.dispose();
        const shellLocal = new Float32Array(sArr.length);
        for (let i = 0; i < sArr.length; i += 3) {
          shellLocal[i] = sArr[i] - towerX;
          shellLocal[i + 1] = sArr[i + 1] - pivotY;
          shellLocal[i + 2] = sArr[i + 2] - towerZ;
        }
        const shellLocalGeo = new THREE.BufferGeometry();
        shellLocalGeo.setAttribute('position', new THREE.BufferAttribute(shellLocal, 3));
        shellLocalGeo.computeVertexNormals();

        const group = new THREE.Group();
        group.position.set(towerX, pivotY + dropHeight, towerZ);
        const shellMat = new THREE.MeshBasicMaterial({
          colorWrite: false,
          depthWrite: true,
          depthTest: true,
          side: THREE.DoubleSide,
          polygonOffset: true,
          polygonOffsetFactor: 1,
          polygonOffsetUnits: 1,
        });
        const shellMesh = new THREE.Mesh(shellLocalGeo, shellMat);
        shellMesh.userData.depthOccluder = true;
        shellMesh.renderOrder = 0;
        group.add(shellMesh);

        const edgeMat = new THREE.LineBasicMaterial({
          color: 0xffffff,
          transparent: true,
          opacity: 0,
          depthTest: true,
          depthWrite: false,
          polygonOffset: true,
          polygonOffsetFactor: -1,
          polygonOffsetUnits: -1,
        });
        const lines = new THREE.LineSegments(localGeo, edgeMat);
        lines.renderOrder = 1;
        group.add(lines);
        scene.add(group);
        modules.push({
          group,
          targetY: pivotY,
          delay: tier * tierStagger,
          started: false,
          done: false,
        });
      }

      scene.position.set(0, 0, 0);
      controls.target.set(towerX, 4.68, towerZ);

      // Easing
      function easeOutCubic(t) {
        return 1 - Math.pow(1 - t, 3);
      }

      const buildDuration = 0.85;
      const startTime = performance.now() / 1000;

      function resize() {
        const parent = canvas.parentElement;
        if (!parent) return;
        const w = parent.clientWidth;
        const h = parent.clientHeight;
        if (w === 0 || h === 0) return;
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }

      resize();
      window.addEventListener('resize', resize);
      if (typeof ResizeObserver !== 'undefined' && canvas.parentElement) {
        const ro = new ResizeObserver(() => resize());
        ro.observe(canvas.parentElement);
      }

      function animate() {
        requestAnimationFrame(animate);
        const now = performance.now() / 1000;
        const elapsed = now - startTime;

        for (const m of modules) {
          if (m.done) continue;
          const t = (elapsed - m.delay) / buildDuration;
          if (t <= 0) continue;
          m.started = true;
          const clamped = Math.min(t, 1);
          const ease = easeOutCubic(clamped);
          m.group.position.y = m.targetY + dropHeight * (1 - ease);
          m.group.children.forEach(child => {
            if (child.userData.depthOccluder) return;
            if (child.material) child.material.opacity = 0.6 * ease;
          });
          if (clamped >= 1) m.done = true;
        }

        controls.update();
        renderer.render(scene, camera);
      }
      animate();
    }
  </script>

  <!-- ════════ ABOUT MOSAIC ════════ -->
  <section class="hp-about">
    <div class="hp-about__panel">
      <div class="hp-about__head fade-up">
        <span class="hp-about__eyebrow">&bull; ABOUT GMP</span>
        <h2 class="hp-about__title">
          A modular construction partner<br/>
          built for <span class="hp-about__title-chip hp-about__title-chip--blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 4v8l5 3" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/><circle cx="12" cy="12" r="9" stroke="#fff" stroke-width="2.2"/></svg>
          </span> global delivery
          <span class="hp-about__title-script">and</span>
          <span class="hp-about__title-chip hp-about__title-chip--lime" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d="M9 18h6M10 21h4M12 3a6 6 0 0 0-4 10.5V16h8v-2.5A6 6 0 0 0 12 3Z" stroke="#1a2a42" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span> measurable outcomes
        </h2>
      </div>

      <div class="hp-about__grid">
        <!-- Left: blue hero stat card -->
        <article class="hp-m-card hp-m-card--hero slide-in-up">
          <div class="hp-m-card__hero-inner">
            <img src="/images/showcase/ri-modular-residential.png" alt="" class="hp-m-card__hero-bg" loading="lazy" aria-hidden="true" />
            <div class="hp-m-card__hero-tint"></div>
            <div class="hp-m-card__hero-top">
              <span class="hp-m-card__hero-brand">GMP<sup>&reg;</sup></span>
              <span class="hp-m-card__hero-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M4 20h16M6 20V10m6 10V4m6 16v-7" stroke="#1a2a42" stroke-width="2" stroke-linecap="round"/></svg>
              </span>
            </div>
            <div class="hp-m-card__hero-plate">
              <span class="hp-m-card__hero-big">40+</span>
              <p class="hp-m-card__hero-caption">Collaborating with leading modular engineering, steel, and healthcare partners worldwide.</p>
            </div>
          </div>
