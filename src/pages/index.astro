<script>
  // Puzzle animation
  const puzzleGrid = document.getElementById('puzzle-grid');
  const pieces = document.querySelectorAll<HTMLElement>('[data-puzzle]');

  if (puzzleGrid && pieces.length) {
    let placed = false;
    const puzzleObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !placed) {
          placed = true;
          pieces.forEach((piece, i) => {
            setTimeout(() => {
              piece.classList.add('is-placed');
            }, i * 150);
          });
          setTimeout(() => {
            puzzleGrid.classList.add('is-complete');
          }, pieces.length * 150 + 600);
        }
      });
    }, { threshold: 0.15 });

    puzzleObserver.observe(puzzleGrid);
  }
</script>

<style>
  /* ════════════════════════════════════════════
     MNC-faithful Homepage — GMP color scheme
     ════════════════════════════════════════════ */

  /* ── Shared layout tokens ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  /* ── Section Tag (pill) ── */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .section-tag--dark {
    color: rgba(255,255,255,.6);
  }
  .section-tag--dark::before {
    background: var(--amber);
  }

  /* ── Section Title ── */
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
  }

  .section-span {
    color: var(--amber);
