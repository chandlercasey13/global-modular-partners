  }
  .hp-work__cta:hover .hp-work__cta-dot svg {
    color: #111;
  }

  .hp-work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .hp-work-card {
    position: relative;
    background: #ebe8e2;
