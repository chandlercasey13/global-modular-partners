<script>
  // Puzzle animation
  const puzzleGrid = document.getElementById('puzzle-grid');
  const pieces = document.querySelectorAll<HTMLElement>('[data-puzzle]');

  if (puzzleGrid && pieces.length) {
    let placed = false;
    const puzzleObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !placed) {
          placed = true;
          pieces.forEach((piece, i) => {
            setTimeout(() => {
              piece.classList.add('is-placed');
            }, i * 150);
          });
          setTimeout(() => {
            puzzleGrid.classList.add('is-complete');
          }, pieces.length * 150 + 600);
        }
      });
    }, { threshold: 0.15 });

    puzzleObserver.observe(puzzleGrid);
  }
</script>

<style>
  /* ════════════════════════════════════════════
     MNC-faithful Homepage — GMP color scheme
     ════════════════════════════════════════════ */

  /* ── Shared layout tokens ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  /* ── Section Tag (pill) ── */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .section-tag--dark {
    color: rgba(255,255,255,.6);
  }
  .section-tag--dark::before {
    background: var(--amber);
  }

  /* ── Section Title ── */
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
  }

  .section-span {
    color: var(--amber);
  }

  /* ── MNC Button style ── */
  .mnc-btn {
    display: inline-flex;
    padding: 16px;
    border: 1px solid var(--navy);
    border-radius: 4px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s, border-color 0.3s, color 0.3s;
  }

  .mnc-btn__wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mnc-btn__icon {
    width: 20px;
    height: 20px;
    flex: none;
    display: flex;
    align-items: center;
  }
  .mnc-btn__icon svg {
    width: 100%;
    height: 100%;
  }

  .mnc-btn--dark {
    background-color: var(--amber);
    border-color: var(--amber);
    color: var(--navy);
    font-weight: 700;
  }
  .mnc-btn--dark:hover {
    background-color: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background-color: transparent;
    border-color: rgba(255,255,255,.4);
    color: var(--white);
  }
  .mnc-btn--stroke:hover {
    border-color: var(--amber);
    color: var(--amber);
    background-color: rgba(224,161,53,.08);
  }

  .mnc-btn--light {
    background-color: var(--white);
    border-color: var(--white);
    color: var(--dark-text);
  }
  .mnc-btn--light:hover {
    background-color: var(--off-white);
    border-color: var(--off-white);
    color: var(--dark-text);
  }

  .mnc-btn--outline {
    background-color: transparent;
    border-color: var(--navy);
    color: var(--navy);
  }
  .mnc-btn--outline:hover {
    background-color: var(--navy);
    color: var(--white);
  }


  /* ════════ 1. BANNER ════════ */
  .banner {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    background-color: var(--off-white);
  }
  .banner ~ section,
  .banner ~ footer,
  .banner ~ div {
    position: relative;
    z-index: 3;
  }

  .banner__pad {
    padding: 0;
    height: 100vh;
    min-height: 700px;
  }

  .banner__inner {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: linear-gradient(180deg, var(--navy) 0%, var(--navy-dark) 100%);
  }

  .banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,42,66,.85) 0%, rgba(26,42,66,.3) 40%, transparent 70%);
    z-index: 1;
  }

  .banner__3d {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .banner__3d canvas {
    width: 100% !important;
    height: 100% !important;
  }

  .banner__content {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
    pointer-events: none;
  }
  .banner__content * {
    pointer-events: auto;
  }

  .banner__container {
    max-width: 700px;
    padding-bottom: 100px;
  }

  .banner__line {
    height: 1px;
    width: 100%;
    background: rgba(255,255,255,.12);
    margin: 20px 0;
  }

  .banner__tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--white);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 8px;
    backdrop-filter: blur(8px);
    background: rgba(224,161,53,.12);
    border: 1px solid rgba(224,161,53,.3);
    margin-bottom: 24px;
  }

  .banner__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(224,161,53,.6);
  }

  .banner__h1 {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 500;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 20px;
  }

  .banner__sub {
    color: var(--medium-gray);
    font-size: 18px;
    line-height: 1.6;
    max-width: 620px;
    margin-bottom: 32px;
  }

  .banner__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }


  /* ════════ 2. DETAILS ════════ */
  .details {
    background-color: var(--white);
  }

  .details__head {
    margin-bottom: 32px;
  }

  .details__title {
    max-width: 900px;
    margin-bottom: 24px;
  }

  .details__body {
    max-width: 780px;
    margin-bottom: 56px;
    font-size: 18px;
    line-height: 1.75;
    color: var(--text-gray);
  }

  .details__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
    margin-bottom: 80px;
  }

  .details__stat {
    background-color: var(--off-white);
    border-radius: 8px;
    padding: 24px;
    text-align: center;
    border-top: 3px solid var(--amber);
  }

  .details__stat-val {
    display: block;
    font-family: var(--font-secondary);
    font-size: 30px;
    font-weight: 600;
    color: var(--amber-dark);
    margin-bottom: 4px;
  }

  .details__stat-label {
    font-size: 16px;
    color: var(--text-gray);
  }

  .details__partners {
    text-align: center;
  }

  .details__partners-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-gray);
    margin-bottom: 24px;
  }

  .details__marquee-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .details__marquee {
    display: flex;
    gap: 64px;
    animation: marquee 35s linear infinite;
    width: max-content;
  }

  .details__partner {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    opacity: 0.5;
    filter: grayscale(100%);
    transition: opacity 0.3s, filter 0.3s;
  }

  .details__partner:hover {
    opacity: 1;
    filter: grayscale(0%);
  }

  .details__partner img {
    height: 100%;
    width: auto;
    max-width: 160px;
    object-fit: contain;
  }


  /* ════════ 3. OFFER — Puzzle Grid ════════ */
  .offer {
    background-color: var(--navy);
    padding-bottom: 100px;
  }

  .offer__head {
    padding-bottom: 64px;
  }

  .offer__head .section-tag {
    margin-bottom: 24px;
  }

  .offer__title {
    color: var(--white);
    max-width: 900px;
  }

  /* ── Puzzle grid ── */
  .puzzle {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    position: relative;
  }

  .puzzle__piece {
    position: relative;
    overflow: visible;
    opacity: 0;
    transition: transform 0.9s cubic-bezier(.22,1,.36,1), opacity 0.7s ease;
  }

  .puzzle__piece--0 { transform: translate(-60px, -60px) rotate(-3deg); }
  .puzzle__piece--1 { transform: translate(60px, -60px) rotate(3deg); }
  .puzzle__piece--2 { transform: translate(-60px, 60px) rotate(3deg); }
  .puzzle__piece--3 { transform: translate(60px, 60px) rotate(-3deg); }

  .puzzle__piece.is-placed {
    opacity: 1;
    transform: translate(0, 0) rotate(0deg);
  }

  /* Staggered delays */
  .puzzle__piece--0 { transition-delay: 0s; }
  .puzzle__piece--1 { transition-delay: 0.15s; }
  .puzzle__piece--2 { transition-delay: 0.3s; }
  .puzzle__piece--3 { transition-delay: 0.45s; }

  /* ── Puzzle tab connectors (decorative interlocking nubs) ── */
  .puzzle__tab-h,
  .puzzle__tab-v {
    position: absolute;
    z-index: 3;
    border-radius: 50%;
    pointer-events: none;
  }

  /* Horizontal tab: sits on the right edge of left-column pieces */
  .puzzle__piece--0 .puzzle__tab-h,
  .puzzle__piece--2 .puzzle__tab-h {
    width: 28px;
    height: 28px;
    background: var(--amber);
    right: -14px;
    top: 50%;
    transform: translateY(-50%);
    box-shadow: 0 0 0 4px var(--navy), 0 2px 8px rgba(0,0,0,.3);
  }

  /* Horizontal tab: sits on the left edge of right-column pieces (indent) */
  .puzzle__piece--1 .puzzle__tab-h,
  .puzzle__piece--3 .puzzle__tab-h {
    width: 28px;
    height: 28px;
    background: var(--navy);
    border: 3px solid var(--amber);
    left: -14px;
    top: 50%;
    transform: translateY(-50%);
    box-shadow: 0 2px 8px rgba(0,0,0,.2);
  }

  /* Vertical tab: sits on the bottom edge of top-row pieces */
  .puzzle__piece--0 .puzzle__tab-v,
  .puzzle__piece--1 .puzzle__tab-v {
    width: 28px;
    height: 28px;
    background: var(--amber);
    bottom: -14px;
    left: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 4px var(--navy), 0 2px 8px rgba(0,0,0,.3);
  }

  /* Vertical tab: sits on the top edge of bottom-row pieces (indent) */
  .puzzle__piece--2 .puzzle__tab-v,
  .puzzle__piece--3 .puzzle__tab-v {
    width: 28px;
    height: 28px;
    background: var(--navy);
    border: 3px solid var(--amber);
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    box-shadow: 0 2px 8px rgba(0,0,0,.2);
  }

  /* ── Card inner ── */
  .puzzle__inner {
    position: relative;
    z-index: 1;
    padding: 40px;
    border-radius: 8px;
    height: 100%;
    display: flex;
    flex-direction: column;
    min-height: 340px;
    border: 1px solid rgba(255,255,255,.06);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .puzzle__piece:hover .puzzle__inner {
    border-color: rgba(224,161,53,.2);
    box-shadow: 0 8px 32px rgba(0,0,0,.2);
  }

  .puzzle__piece--0 .puzzle__inner {
    background: var(--off-white);
    border-radius: 8px 0 0 0;
  }
  .puzzle__piece--1 .puzzle__inner {
    background: var(--white);
    border-radius: 0 8px 0 0;
  }
  .puzzle__piece--2 .puzzle__inner {
    background: var(--white);
    border-radius: 0 0 0 8px;
  }
  .puzzle__piece--3 .puzzle__inner {
    background: var(--off-white);
    border-radius: 0 0 8px 0;
  }

  .puzzle__num {
    display: inline-block;
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    color: var(--white);
    background: var(--navy);
    border-radius: 4px;
    padding: 4px 10px;
    margin-bottom: 20px;
    width: fit-content;
  }

  .puzzle__title {
    font-family: var(--font-secondary);
    font-size: clamp(22px, 2.2vw, 28px);
    font-weight: 600;
    color: var(--dark-text);
    margin-bottom: 10px;
    line-height: 1.25;
  }

  .puzzle__desc {
    font-size: 15px;
    color: var(--text-gray);
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
  }

  .puzzle__bullets {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }

  .puzzle__bullet {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .puzzle__bullet-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
  }

  .puzzle__bullet-text {
    font-size: 14px;
    font-weight: 500;
    color: var(--dark-text);
    opacity: 0.7;
  }

  .puzzle__companies {
    margin-bottom: 24px;
    padding-top: 16px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .puzzle__companies-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-gray);
    opacity: 0.5;
    margin-bottom: 10px;
  }

  .puzzle__companies-logos {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .puzzle__company-logo {
    height: 22px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.45);
    transition: filter 0.25s ease;
  }

  .puzzle__piece:hover .puzzle__company-logo {
    filter: grayscale(0) opacity(0.85);
  }

  /* Landing "snap" pop */
  @keyframes puzzle-snap {
    0% { transform: scale(1); }
    40% { transform: scale(1.015); }
    100% { transform: scale(1); }
  }

  .puzzle__piece.is-placed {
    animation: puzzle-snap 0.4s ease forwards;
    animation-delay: inherit;
  }

  /* Connector glow pulse after all pieces land */
  @keyframes tab-glow {
    0%   { box-shadow: 0 0 0 4px var(--navy), 0 0 0 rgba(224,161,53,0); }
    50%  { box-shadow: 0 0 0 4px var(--navy), 0 0 16px rgba(224,161,53,.5); }
    100% { box-shadow: 0 0 0 4px var(--navy), 0 0 0 rgba(224,161,53,0); }
  }

  .puzzle.is-complete .puzzle__piece--0 .puzzle__tab-h,
  .puzzle.is-complete .puzzle__piece--2 .puzzle__tab-h,
  .puzzle.is-complete .puzzle__piece--0 .puzzle__tab-v,
  .puzzle.is-complete .puzzle__piece--1 .puzzle__tab-v {
    animation: tab-glow 1.5s ease 0.6s 1;
  }


  /* ════════ 4. REACH ════════ */
  .reach { background-color: var(--white); }
  .reach__head { text-align: center; margin-bottom: 32px; }
  .reach__title { text-align: center; max-width: 900px; margin: 0 auto 64px; }
  .reach__bento { display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: 250px 250px; gap: 20px; }
  .bento { border-radius: 8px; padding: 24px; display: flex; flex-direction: column; justify-content: flex-end; overflow: hidden; position: relative; }
  .bento--dark { background: linear-gradient(145deg, var(--navy) 0%, var(--navy-dark) 100%); }
  .bento--light { background-color: var(--white); border: 1px solid var(--medium-gray); }
  .bento--img { padding: 0; }
  .bento__gradient { width: 100%; height: 100%; background: linear-gradient(135deg, var(--navy-light) 0%, var(--navy) 50%, var(--navy-dark) 100%); border-radius: 8px; }
  .bento__gradient--alt { background: linear-gradient(225deg, var(--navy-light) 0%, var(--navy-dark) 100%); }
  .bento__gradient--wide { background: linear-gradient(90deg, var(--navy-dark) 0%, var(--navy-light) 50%, var(--navy) 100%); }
  .bento__val { font-family: var(--font-secondary); font-size: clamp(28px, 3vw, 36px); font-weight: 700; color: var(--white); line-height: 1; margin-bottom: 4px; }
  .bento__val--dark { color: var(--dark-text); }
  .bento__label { font-size: 16px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
  .bento__label--dark { color: var(--dark-text); }
  .bento__sub { font-size: 14px; color: rgba(255,255,255,.45); }
  .bento__sub--dark { color: var(--text-gray); }
  .bento--r1c1 { grid-column: 1; grid-row: 1; }
  .bento--r1c2 { grid-column: 2; grid-row: 1; }
  .bento--r1c3 { grid-column: 3; grid-row: 1; }
  .bento--r1c4 { grid-column: 4; grid-row: 1; }
  .bento--r2c1 { grid-column: 1 / span 2; grid-row: 2; }
  .bento--r2c3 { grid-column: 3; grid-row: 2; }
  .bento--r2c4 { grid-column: 4; grid-row: 2; }

  /* ════════ 5. CREDENTIALS ════════ */
  .credentials { background-color: var(--white); }
  .credentials__head { margin-bottom: 32px; }
  .credentials__title { max-width: 900px; margin-bottom: 48px; }
  .credentials__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px; }
  .credentials__card { background: var(--off-white); border-radius: 8px; padding: 28px 24px; border-top: 3px solid var(--amber); }
  .credentials__badge { display: inline-block; font-family: var(--font-secondary); font-size: 13px; font-weight: 800; letter-spacing: 1px; color: var(--navy); background: linear-gradient(145deg, rgba(224,161,53,.15), rgba(36,55,85,.06)); border: 1px solid rgba(224,161,53,.25); border-radius: 6px; padding: 6px 12px; margin-bottom: 14px; }
  .credentials__card-title { font-family: var(--font-secondary); font-size: 18px; font-weight: 600; color: var(--dark-text); margin-bottom: 8px; }
  .credentials__card-desc { font-size: 15px; line-height: 1.55; color: var(--text-gray); margin: 0; }
  .credentials__cta { text-align: center; }
  @media (max-width: 960px) { .credentials__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .credentials__grid { grid-template-columns: 1fr; } }


  /* ════════ 7. OUR WORK ════════ */
  .work {
    background: var(--off-white);
  }

  .work__head {
    margin-bottom: 32px;
  }

  .work__title {
    max-width: 900px;
    margin-bottom: 48px;
  }

  .work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .work__card {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: block;
    text-decoration: none;
  }

  .work__card--wide {
    grid-column: span 2;
    aspect-ratio: 16 / 9;
  }

  .work__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .work__card:hover .work__img {
    transform: scale(1.04);
  }

  .work__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(12, 24, 48, 0.85) 0%, rgba(12, 24, 48, 0.3) 40%, transparent 65%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    transition: background 0.35s ease;
  }

  .work__card:hover .work__overlay {
    background: linear-gradient(0deg, rgba(12, 24, 48, 0.9) 0%, rgba(12, 24, 48, 0.4) 50%, transparent 70%);
  }

  .work__tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 6px;
  }

  .work__card-title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: #fff;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .work__card-sub {
    font-size: 14px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease;
  }

  .work__card:hover .work__card-sub {
    max-height: 80px;
    opacity: 1;
  }

  @media (max-width: 768px) {
    .work__grid {
      grid-template-columns: 1fr;
    }

    .work__card--wide {
      grid-column: span 1;
      aspect-ratio: 16 / 9;
    }

    .work__card {
      aspect-ratio: 16 / 10;
    }

    .work__card-sub {
      max-height: none;
      opacity: 1;
    }
  }


  /* ════════ RESPONSIVE ════════ */
  @media (max-width: 1024px) {
    .details__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .puzzle__inner {
      padding: 32px;
      min-height: 300px;
    }

    .reach__bento {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }

    .bento--r1c1 { grid-column: 1; grid-row: 1; }
    .bento--r1c2 { grid-column: 2; grid-row: 1; }
    .bento--r1c3 { grid-column: 1; grid-row: 2; }
    .bento--r1c4 { grid-column: 2; grid-row: 2; }
    .bento--r2c1 { grid-column: 1 / span 2; grid-row: 3; }
    .bento--r2c3 { grid-column: 1; grid-row: 4; }
    .bento--r2c4 { grid-column: 2; grid-row: 4; }
  }

  @media (max-width: 768px) {
    .section-gap {
      padding: 64px 0;
    }

    .banner__container {
      max-width: 100%;
      padding-bottom: 40px;
    }

    .banner__h1 {
      font-size: clamp(28px, 7vw, 42px);
    }

    .details__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .puzzle {
      grid-template-columns: 1fr;
    }

    .puzzle__piece--0 .puzzle__inner,
    .puzzle__piece--1 .puzzle__inner,
    .puzzle__piece--2 .puzzle__inner,
    .puzzle__piece--3 .puzzle__inner {
      border-radius: 8px;
    }

    .puzzle__piece--0 { transform: translate(0, -40px); }
    .puzzle__piece--1 { transform: translate(0, -40px); }
    .puzzle__piece--2 { transform: translate(0, 40px); }
