---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const partners = [
  { name: 'West Modular', logo: '/images/partners/west-og.png' },
  { name: 'PROSET Construction', logo: '/images/partners/proset-footer.png' },
  { name: 'TRUE NORTH Compliance', logo: '/images/partners/true-north.svg' },
  { name: 'EnTech Engineering', logo: '/images/partners/entech.svg' },
  { name: 'Agbayani Construction', logo: '/images/partners/agbayani-real.png' },
  { name: 'STREAM Logistics', logo: '/images/partners/stream-dark.png' },
  { name: 'ATCCO Construction', logo: '/images/partners/atcco-big.png' },
  { name: 'Petra Air Conditioning', logo: '/images/partners/petra-eng.png' },
  { name: 'Petra Aluminum', logo: '/images/partners/petralu-logo.jpg' },
  { name: 'Abstract Architecture', logo: '/images/partners/abstract-arch.jpg' },
];

---

<Layout title="Home">
  <Header slot="header" />

  <!-- ════════ 1. BANNER SECTION ════════ -->
  <section class="banner">
    <div class="banner__pad">
      <div class="banner__inner">
        <div class="banner__3d">
          <canvas id="hero-3d"></canvas>
        </div>
        <div class="banner__overlay"></div>
        <div class="banner__content">
          <div class="banner__top"></div>
          <div class="banner__center">
            <h1 class="banner__h1 fade-up">Your Global<br/>Partner in <span class="banner__h1-accent">Modular<br/>Excellence.</span></h1>
            <div class="banner__blurb fade-up">
              <span class="banner__blurb-line"></span>
              <p class="banner__blurb-text">
                A singular alliance providing end-to-end modular solutions for the world's most complex architectural demands. Precision engineered. Globally deployed.
              </p>
            </div>
          </div>
          <div class="banner__bottom">
            <div class="banner__stats fade-up">
              <div class="banner__stat">
                <span class="banner__stat-label">Load Bearing Cap</span>
                <span class="banner__stat-value">14,200 KN</span>
              </div>
              <div class="banner__stat-divider"></div>
              <div class="banner__stat">
                <span class="banner__stat-label">Precision Tolerance</span>
                <span class="banner__stat-value">&pm; 0.05 MM</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    const canvas = document.getElementById('hero-3d');
    if (canvas) {
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
      camera.position.set(12, 9, 14);

      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping = true;
      controls.dampingFactor = 0.05;
      controls.enablePan = false;
      controls.minDistance = 6;
      controls.maxDistance = 30;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.8;

      const edgeMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.6 });
      const ridgeMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.15 });

      const modules = [];
      const dropHeight = 15;

      function addModule(w, h, d, x, y, z, order) {
        const group = new THREE.Group();
        group.position.set(x, y + dropHeight, z);

        const geo = new THREE.BoxGeometry(w, h, d);
        const edges = new THREE.EdgesGeometry(geo);
        const line = new THREE.LineSegments(edges, edgeMat.clone());
        line.material.opacity = 0;
        group.add(line);

        const ridgeCount = Math.floor(w / 0.45);
        const ridgeGeo = new THREE.BufferGeometry();
        const verts = [];
        for (let i = 1; i < ridgeCount; i++) {
          const lx = -w / 2 + (w / ridgeCount) * i;
          verts.push(lx, -h / 2, d / 2, lx, h / 2, d / 2);
          verts.push(lx, -h / 2, -d / 2, lx, h / 2, -d / 2);
        }
        const sideCount = Math.floor(d / 0.45);
        for (let i = 1; i < sideCount; i++) {
          const lz = -d / 2 + (d / sideCount) * i;
          verts.push(-w / 2, -h / 2, lz, -w / 2, h / 2, lz);
          verts.push(w / 2, -h / 2, lz, w / 2, h / 2, lz);
        }
        ridgeGeo.setAttribute('position', new THREE.Float32BufferAttribute(verts, 3));
        const ridges = new THREE.LineSegments(ridgeGeo, ridgeMat.clone());
        ridges.material.opacity = 0;
        group.add(ridges);

        scene.add(group);
        modules.push({ group, targetY: y, delay: order * 0.3, started: false, done: false });
      }

      // Ground floor first (order 0–5)
      addModule(3, 1.3, 2, -5, 0.65, -3, 0);
      addModule(5, 1.2, 2.2, 0, 0.6, -4, 1);
      addModule(2.8, 1.3, 2, 4.5, 0.65, -2, 1);
      addModule(2.2, 1.2, 1.8, -4, 0.6, 2, 2);
      addModule(2.2, 1.2, 1.8, -1.5, 0.6, 2, 2);
      addModule(2.2, 1.2, 1.8, 1, 0.6, 2, 3);
      addModule(2, 1.3, 2, 5, 0.65, 2, 3);
      addModule(2.5, 1.1, 1.8, -1, 0.55, -1, 4);
      addModule(4, 1, 2.5, 2, 0.5, 0, 4);

      // Second floor (order 5–7)
      addModule(3, 1.3, 2, -5, 1.95, -3, 6);
      addModule(2.8, 1.3, 2, 4.5, 1.95, -2, 6);
      addModule(2, 1.3, 2, 5, 1.95, 2, 7);

      // Third floor (order 8–9)
      addModule(2, 0.8, 1.5, -5, 3, -3, 8);
      addModule(2, 1.3, 2, 5, 3.25, 2, 9);

      // Top piece (order 10)
      addModule(1.6, 0.6, 1.6, 5, 4.2, 2, 10);

      // Ground grid — appears immediately
      const gridMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.06 });
      const gridGeo = new THREE.BufferGeometry();
      const gv = [];
      for (let i = -8; i <= 8; i += 1) {
        gv.push(i, 0, -8, i, 0, 8);
        gv.push(-8, 0, i, 8, 0, i);
      }
      gridGeo.setAttribute('position', new THREE.Float32BufferAttribute(gv, 3));
      const grid = new THREE.LineSegments(gridGeo, gridMat);
      scene.add(grid);

      scene.position.set(0, 0, 0);
      controls.target.set(0, 2, 0);

      // Easing
      function easeOutCubic(t) {
        return 1 - Math.pow(1 - t, 3);
      }

      const buildDuration = 1.2;
      const startTime = performance.now() / 1000;

      function resize() {
        const parent = canvas.parentElement;
        if (!parent) return;
        const w = parent.clientWidth;
        const h = parent.clientHeight;
        renderer.setSize(w, h);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }

      resize();
      window.addEventListener('resize', resize);

      function animate() {
        requestAnimationFrame(animate);
        const now = performance.now() / 1000;
        const elapsed = now - startTime;

        for (const m of modules) {
          if (m.done) continue;
          const t = (elapsed - m.delay) / buildDuration;
          if (t <= 0) continue;
          m.started = true;
          const clamped = Math.min(t, 1);
          const ease = easeOutCubic(clamped);
          m.group.position.y = m.targetY + dropHeight * (1 - ease);
          m.group.children.forEach(child => {
            if (child.material) child.material.opacity = child.material === m.group.children[0].material ? 0.6 * ease : 0.15 * ease;
          });
          if (clamped >= 1) m.done = true;
        }

        controls.update();
        renderer.render(scene, camera);
      }
      animate();
    }
  </script>

  <!-- ════════ 2. ADVANTAGE SECTION ════════ -->
  <section class="advantage section-gap">
    <div class="mnc-container">
      <div class="advantage__top fade-up">
        <h2 class="section-title advantage__title">
          The End-to-End Advantage:<br/><span class="section-span">A Total Solution.</span>
        </h2>
        <p class="advantage__desc">
          We eliminate the fragmentation of traditional construction. By integrating engineering, procurement, fabrication, and global logistics into a single workflow, we provide a seamless partnership that guarantees architectural integrity and speed-to-market.
        </p>
      </div>

      <div class="advantage__cards">
        <div class="advantage__card fade-up">
          <svg class="advantage__icon" viewBox="0 0 40 40" fill="none"><path d="M20 4l2.5 8H31l-7 5 2.5 8-7-5-7 5 2.5-8-7-5h8.5L20 4z" stroke="var(--amber-dark)" stroke-width="1.5" fill="none"/><path d="M8 36h24M12 36V24h16v12" stroke="var(--amber-dark)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <h3 class="advantage__card-title">Precision Engineering</h3>
          <p class="advantage__card-desc">Advanced BIM modeling and structural analysis ensure every module exceeds international seismic and environmental standards.</p>
        </div>
        <div class="advantage__card fade-up">
          <svg class="advantage__icon" viewBox="0 0 40 40" fill="none"><rect x="6" y="20" width="12" height="14" rx="1" stroke="var(--amber-dark)" stroke-width="1.5"/><rect x="22" y="14" width="12" height="20" rx="1" stroke="var(--amber-dark)" stroke-width="1.5"/><path d="M10 16h4M10 12h4M26 10h4" stroke="var(--amber-dark)" stroke-width="1.5" stroke-linecap="round"/><rect x="14" y="6" width="12" height="28" rx="1" stroke="var(--amber-dark)" stroke-width="1.5"/></svg>
          <h3 class="advantage__card-title">Modular Fabrication</h3>
          <p class="advantage__card-desc">Proprietary steel-frame systems manufactured in controlled environments for unrivaled quality consistency and waste reduction.</p>
        </div>
        <div class="advantage__card advantage__card--accent fade-up">
          <svg class="advantage__icon" viewBox="0 0 40 40" fill="none"><rect x="4" y="22" width="14" height="10" rx="2" stroke="var(--amber-dark)" stroke-width="1.5"/><circle cx="8" cy="35" r="2" stroke="var(--amber-dark)" stroke-width="1.5"/><circle cx="14" cy="35" r="2" stroke="var(--amber-dark)" stroke-width="1.5"/><path d="M18 27h8l4-8H22" stroke="var(--amber-dark)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="27" cy="35" r="2" stroke="var(--amber-dark)" stroke-width="1.5"/><path d="M20 8l4 4M24 8l-4 4M22 4v4" stroke="var(--amber-dark)" stroke-width="1.5" stroke-linecap="round"/></svg>
          <h3 class="advantage__card-title">Integrated Logistics</h3>
          <p class="advantage__card-desc">Global supply chain management and specialized transport networks delivering turnkey components to any site worldwide.</p>
        </div>
      </div>

      <div class="details__partners fade-up">
        <span class="details__partners-label">Trade Partners</span>
        <div class="details__marquee-track">
          <div class="details__marquee">
            {partners.map((p) => <span class="details__partner"><img src={p.logo} alt={p.name} loading="lazy" /></span>)}
            {partners.map((p) => <span class="details__partner"><img src={p.logo} alt={p.name} loading="lazy" /></span>)}
            {partners.map((p) => <span class="details__partner"><img src={p.logo} alt={p.name} loading="lazy" /></span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 3. GLOBAL NETWORK MAP ════════ -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css" />
  <section class="netmap section-gap">
    <div class="mnc-container">
      <div class="netmap__layout fade-up">
        <div class="netmap__left">
          <h2 class="section-title netmap__title">Our Integrated<br/>Global Network.</h2>

          <div class="netmap__hubs">
            <div class="netmap__hub">
              <span class="netmap__hub-line"></span>
              <div>
                <h4 class="netmap__hub-title">Agbayani Construction</h4>
                <p class="netmap__hub-desc">Civil &amp; modular general contracting. Headquartered in Daly City, CA with operations across the Bay Area.</p>
              </div>
            </div>
            <div class="netmap__hub">
              <span class="netmap__hub-line"></span>
              <div>
                <h4 class="netmap__hub-title">RI Group USA</h4>
                <p class="netmap__hub-desc">International modular construction and manufacturing. Parent company based in Lecce, Italy with global project delivery.</p>
              </div>
            </div>
            <div class="netmap__hub">
              <span class="netmap__hub-line"></span>
              <div>
                <h4 class="netmap__hub-title">Hospitals Without Borders</h4>
                <p class="netmap__hub-desc">Deployable modular medical infrastructure. HQ in Oakland, CA with European operations in Rome, Italy.</p>
              </div>
            </div>
            <div class="netmap__hub">
              <span class="netmap__hub-line"></span>
              <div>
                <h4 class="netmap__hub-title">EDIS USA</h4>
                <p class="netmap__hub-desc">Early warning systems and disaster preparedness technology for emergency management agencies.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="netmap__right">
          <div class="netmap__badge">
            <span class="netmap__badge-dot"></span>
            Active Hubs: 8 Locations
          </div>
          <div id="network-map" class="netmap__map"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import L from 'https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet-src.esm.js';

    const mapEl = document.getElementById('network-map');
    if (mapEl) {
      const map = L.map(mapEl, {
        center: [30, 20],
        zoom: 2,
        zoomControl: true,
        scrollWheelZoom: false,
        attributionControl: false,
        minZoom: 2,
        maxZoom: 6,
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        subdomains: 'abcd',
      }).addTo(map);

      const companies = [
        { name: 'GMP Headquarters', loc: [37.8044, -122.2712], city: 'Oakland, CA', type: 'hq' },
        { name: 'GMP Southern CA', loc: [33.6846, -117.8265], city: 'Irvine, CA', type: 'hq' },
        { name: 'Agbayani Construction', loc: [37.6879, -122.4702], city: 'Daly City, CA', type: 'subsidiary' },
        { name: 'RI Group (R.I. Group S.p.A.)', loc: [40.2834, 18.0107], city: 'Lecce, Italy', type: 'subsidiary' },
        { name: 'Hospitals Without Borders', loc: [37.8044, -122.2712], city: 'Oakland, CA', type: 'subsidiary' },
        { name: 'HWB Europe', loc: [41.9028, 12.4964], city: 'Rome, Italy', type: 'subsidiary' },
        { name: 'EDIS USA', loc: [37.8044, -122.2712], city: 'Oakland, CA', type: 'subsidiary' },
        { name: 'EDIS International', loc: [31.9454, 35.9284], city: 'Amman, Jordan', type: 'subsidiary' },
      ];

      function makeDot(color: string, size: number) {
        return L.divIcon({
          className: 'netmap-marker',
          html: `<span style="
            width:${size}px;height:${size}px;
            background:${color};
            border:2px solid #fff;
            border-radius:50%;
            display:block;
            box-shadow:0 0 8px ${color}88;
          "></span>`,
          iconSize: [size, size],
          iconAnchor: [size/2, size/2],
        });
      }

      const hqIcon = makeDot('#2B4B7E', 14);
      const subIcon = makeDot('#4a8c3f', 12);

      companies.forEach(c => {
        const icon = c.type === 'hq' ? hqIcon : subIcon;
        L.marker(c.loc, { icon })
          .addTo(map)
          .bindPopup(`<strong>${c.name}</strong><br/>${c.city}`);
      });

      const legendEl = document.createElement('div');
      legendEl.className = 'netmap-legend';
      legendEl.innerHTML = `
        <div class="netmap-legend__row"><span class="netmap-legend__dot" style="background:#2B4B7E"></span> GMP Offices</div>
        <div class="netmap-legend__row"><span class="netmap-legend__dot" style="background:#4a8c3f"></span> Subsidiaries</div>
      `;
      mapEl.appendChild(legendEl);
    }
  </script>

  <!-- ════════ 4. AUTHORITY SECTION ════════ -->
  <section class="authority">
    <div class="authority__inner">
      <div class="authority__left fade-up">
        <h2 class="authority__title">The Authority in<br/>Steel Engineering.</h2>
        <p class="authority__desc">
          Our structural systems are designed for extreme longevity and performance. We utilize high-tensile steel and proprietary joinery that sets the global benchmark for modular stability.
        </p>
        <div class="authority__stats">
          <div class="authority__stat">
            <span class="authority__stat-num">120+</span>
            <span class="authority__stat-label">Project Certifications</span>
          </div>
          <div class="authority__stat">
            <span class="authority__stat-num">0.5mm</span>
            <span class="authority__stat-label">Fabrication Tolerance</span>
          </div>
          <div class="authority__stat">
            <span class="authority__stat-num">60%</span>
            <span class="authority__stat-label">Faster Deployment</span>
          </div>
          <div class="authority__stat">
            <span class="authority__stat-num">100%</span>
            <span class="authority__stat-label">Recyclable Steel</span>
          </div>
        </div>
      </div>
      <div class="authority__right fade-up">
        <div class="authority__img-wrap">
          <img src="/images/showcase/ri-modular-units.jpg" alt="Precision modular steel assembly" class="authority__img" loading="lazy" />
        </div>
        <div class="authority__cert">
          <span class="authority__cert-title">Certified Mastery</span>
          <span class="authority__cert-sub">ISO 9001:2015 Approved</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 5. OUR WORK & REACH SECTION ════════ -->
  <section class="reach section-gap">
    <div class="mnc-container">
      <div class="reach__head fade-up">
        <span class="section-tag">Our Work</span>
      </div>
      <h2 class="section-title reach__title fade-up">
        Delivering modular solutions <span class="section-span">across sectors and borders.</span>
      </h2>

      <div class="reach__grid">
        <a href="/departments#modular" class="reach__card fade-up">
          <img src="/images/showcase/west-blvd-render.jpg" alt="West Boulevard modular residential" class="reach__card-img" loading="lazy" />
          <div class="reach__card-overlay">
            <span class="reach__card-tag">Modular</span>
            <span class="reach__card-title">West Blvd Residential</span>
          </div>
        </a>
        <a href="/departments#healthcare" class="reach__card fade-up">
          <img src="/images/showcase/hwb-modular-pediatric.jpeg" alt="HWB modular pediatric clinic" class="reach__card-img" loading="lazy" />
          <div class="reach__card-overlay">
            <span class="reach__card-tag">Healthcare</span>
            <span class="reach__card-title">Pediatric Clinic</span>
          </div>
        </a>
        <a href="/departments#civil" class="reach__card fade-up">
          <img src="/images/showcase/ri-defense.jpg" alt="RI Group defense compound" class="reach__card-img" loading="lazy" />
          <div class="reach__card-overlay">
            <span class="reach__card-tag">Defense</span>
            <span class="reach__card-title">Military Compound</span>
          </div>
        </a>
        <a href="/departments#modular" class="reach__card fade-up">
          <img src="/images/showcase/west-factory.jpg" alt="West Modular factory floor" class="reach__card-img" loading="lazy" />
          <div class="reach__card-overlay">
            <span class="reach__card-tag">Manufacturing</span>
            <span class="reach__card-title">Factory Production</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>


<style>
  /* ════════════════════════════════════════════
     MNC-faithful Homepage — GMP color scheme
     ════════════════════════════════════════════ */

  /* ── Shared layout tokens ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  /* ── Section Tag (pill) ── */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .section-tag--dark {
    color: rgba(255,255,255,.6);
  }
  .section-tag--dark::before {
    background: var(--amber);
  }

  /* ── Section Title ── */
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
  }

  .section-span {
    color: var(--amber);
  }

  /* ── MNC Button style ── */
  .mnc-btn {
    display: inline-flex;
    padding: 16px;
    border: 1px solid var(--navy);
    border-radius: 4px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s, border-color 0.3s, color 0.3s;
  }

  .mnc-btn__wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mnc-btn__icon {
    width: 20px;
    height: 20px;
    flex: none;
    display: flex;
    align-items: center;
  }
  .mnc-btn__icon svg {
    width: 100%;
    height: 100%;
  }

  .mnc-btn--dark {
    background-color: var(--amber);
    border-color: var(--amber);
    color: var(--navy);
    font-weight: 700;
  }
  .mnc-btn--dark:hover {
    background-color: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--stroke {
    background-color: transparent;
    border-color: rgba(255,255,255,.4);
    color: var(--white);
  }
  .mnc-btn--stroke:hover {
    border-color: var(--amber);
    color: var(--amber);
    background-color: rgba(224,161,53,.08);
  }

  .mnc-btn--light {
    background-color: var(--white);
    border-color: var(--white);
    color: var(--dark-text);
  }
  .mnc-btn--light:hover {
    background-color: var(--off-white);
    border-color: var(--off-white);
    color: var(--dark-text);
  }

  .mnc-btn--outline {
    background-color: transparent;
    border-color: var(--navy);
    color: var(--navy);
  }
  .mnc-btn--outline:hover {
    background-color: var(--navy);
    color: var(--white);
  }


