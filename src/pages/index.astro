  <script is:inline>
    (function initCapsTabs() {
      var AUTO_INTERVAL = 5000;
      var sections = document.querySelectorAll('.hp-caps');
      for (var s = 0; s < sections.length; s++) {
        (function (section) {
          var tabs = section.querySelectorAll('.hp-caps__tab');
          var slides = section.querySelectorAll('.hp-caps__slide');
          if (!tabs.length || !slides.length) return;

          var current = 0;
          var timer = null;
          var isPaused = false;
          var inView = false;

          function activate(index) {
            current = index;
            for (var i = 0; i < tabs.length; i++) {
              var isActive = i === index;
              tabs[i].classList.toggle('is-active', isActive);
              tabs[i].setAttribute('aria-selected', isActive ? 'true' : 'false');
            }
            for (var j = 0; j < slides.length; j++) {
              var isOn = j === index;
              slides[j].classList.toggle('is-active', isOn);
              if (isOn) {
                slides[j].removeAttribute('hidden');
              } else {
                slides[j].setAttribute('hidden', '');
              }
            }
          }

          function next() {
            activate((current + 1) % tabs.length);
          }

          function start() {
            if (timer || isPaused || !inView) return;
            timer = setInterval(next, AUTO_INTERVAL);
          }

          function stop() {
            if (timer) {
              clearInterval(timer);
              timer = null;
            }
          }

          function restart() {
            stop();
            start();
          }

          for (var k = 0; k < tabs.length; k++) {
            (function (idx) {
              tabs[idx].addEventListener('click', function () {
                activate(idx);
                restart();
              });
            })(k);
          }

          section.addEventListener('mouseenter', function () { isPaused = true; stop(); });
          section.addEventListener('mouseleave', function () { isPaused = false; start(); });
          section.addEventListener('focusin', function () { isPaused = true; stop(); });
          section.addEventListener('focusout', function () { isPaused = false; start(); });

          if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(function (entries) {
              for (var e = 0; e < entries.length; e++) {
                inView = entries[e].isIntersecting;
                if (inView) start(); else stop();
              }
            }, { threshold: 0.25 });
            io.observe(section);
          } else {
            inView = true;
            start();
          }
        })(sections[s]);
      }
    })();
  </script>

