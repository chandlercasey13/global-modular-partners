---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    num: '01',
    title: 'Consulting',
    image: '/images/showcase/ri-factory-panorama.jpg',
    description:
      'We partner with stakeholders early to evaluate feasibility, define scope, and align modular strategies with project goals — from site analysis and code review to budgeting and schedule planning.',
    bullets: ['Feasibility analysis', 'Site evaluation & code review', 'Budget modeling & schedule planning', 'Entitlements & permitting strategy'],
  },
  {
    num: '02',
    title: 'Development & New Construction',
    image: '/images/showcase/west-blvd-render.jpg',
    description:
      'Full-cycle design-build delivery for modular structures — residential, commercial, healthcare, and government. We coordinate architecture, engineering, and BIM from concept through factory production.',
    bullets: ['Architectural design & BIM coordination', 'Structural & MEP engineering', 'Factory production management', 'Shop drawings & design-assist'],
  },
  {
    num: '03',
    title: 'Procurement',
    image: '/images/showcase/west-factory.jpg',
    description:
      'Leveraging our global alliance network to source materials, modules, and specialized systems at scale — ensuring quality, compliance, and cost efficiency across every supply chain.',
    bullets: ['Material sourcing & vendor management', 'Module fabrication oversight', 'Supply chain logistics', 'Quality assurance & compliance'],
  },
  {
    num: '04',
    title: 'Installation',
    image: '/images/showcase/west-crane.jpg',
    description:
      'Turnkey on-site assembly of modular units — from foundation tie-in and craning to utility connections, finishing, and inspections. We manage every phase of field execution.',
    bullets: ['Module transport coordination', 'Craning & setting', 'Utility connections & finishing', 'Inspections & agency approvals'],
  },
  {
    num: '05',
    title: 'Project Management',
    image: '/images/showcase/hwb-ri-factory-visit.jpeg',
    description:
      'Dedicated program management that keeps scope, schedule, and budget aligned across all stakeholders — from pre-construction through turnover and closeout.',
    bullets: ['Schedule & milestone tracking', 'Stakeholder coordination', 'Risk management & reporting', 'Documentation & closeout'],
  },
  {
    num: '06',
    title: 'Support & Maintenance',
    image: '/images/showcase/ri-medical-shelter.jpg',
    description:
      'Post-occupancy support including warranty administration, preventive maintenance programs, and lifecycle planning to protect your investment long-term.',
    bullets: ['Warranty administration', 'Preventive maintenance programs', 'Facility lifecycle planning', 'Emergency response & rapid deployment'],
  },
];

const values = [
  {
    title: '30–50% Faster',
    body: 'Construction occurs simultaneously with site work, compressing schedules by 30–50% versus traditional methods.',
  },
  {
    title: 'Superior Quality',
    body: 'Factory-controlled manufacturing ensures exceptional construction quality with repeatable precision.',
  },
  {
    title: 'Greener Building',
    body: 'Less material waste, greater flexibility for reuse, and reduced carbon emissions from construction.',
  },
  {
    title: 'Safer Construction',
    body: 'Indoor factory environment reduces risks of accidents and related liabilities for workers.',
  },
  {
    title: 'Cost Efficient',
    body: 'Reduced material waste, less site overhead, and fewer weather delays lower overall project costs.',
  },
];

const faqs = [
  {
    q: 'What types of modular buildings can you construct?',
    a: 'We deliver healthcare, administrative, housing, training, and specialty facilities—configured for government, commercial, and institutional programs. Scope ranges from single modules to multi-building campuses.',
  },
  {
    q: 'Do you handle government/DoD projects?',
    a: 'Yes. We align with federal requirements, security considerations, and documentation expectations typical of DoD and agency work, working alongside your contracting officers and A/E teams.',
  },
  {
    q: 'How long does a typical modular project take?',
    a: 'Timelines depend on scope, site readiness, and approvals. Parallel factory production and site work often compress schedules significantly versus stick-built delivery; we provide a phased plan after discovery.',
  },
  {
    q: 'Do you offer warranties on completed projects?',
    a: 'We stand behind our work with structured warranty and support options. Specific terms are defined per contract and asset class.',
  },
  {
    q: 'Can you work with existing architects and engineers?',
    a: 'Absolutely. We integrate with your design partners—supporting BIM coordination, design-assist, and design-build models to keep a single thread from concept through turnover.',
  },
];
---

<Layout
  title="Services"
  description="Multipurpose modular construction services: consulting, design-build, procurement, installation, support, and emergency deployment."
>
  <Header slot="header" />

  <!-- Hero Banner -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <span>Services</span>
        </nav>
        <h1 class="hero-title fade-up">Our Multipurpose<br />Construction Solutions</h1>
        <p class="hero-sub fade-up">
          We craft customized, forward-thinking modular solutions that tackle challenges, inspire
          innovation, and turn your vision into reality.
        </p>
      </div>
    </div>
  </section>

  <!-- Service Sections -->
  {services.map((s, i) => (
    <section id={i === 0 ? 'services' : undefined} class:list={['section-gap', 'svc-block', { 'svc-block--alt': i % 2 === 1 }]}>
      <div class="mnc-container">
        <div class:list={['svc-block__grid', 'fade-up', { 'svc-block__grid--reverse': i % 2 === 1 }]}>
          <div class="svc-block__image">
            <img src={s.image} alt={s.title} loading="lazy" />
          </div>
          <div class="svc-block__content">
            <span class="svc-block__num">{s.num}</span>
            <h2 class="svc-block__title">{s.title}</h2>
            <p class="svc-block__desc">{s.description}</p>
            <ul class="svc-block__bullets">
              {s.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- FAQ Section -->
  <section class="section-gap svc-faq-section">
    <div class="mnc-container">
      <div class="faq-header fade-up">
        <span class="section-tag">FAQ</span>
        <h2 class="section-title">Questions we hear often <span class="section-span">answered clearly</span></h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item fade-up" name="gmp-faq">
            <summary class="faq-item__summary">
              <span class="faq-item__q">{item.q}</span>
              <span class="faq-item__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq-item__answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Shared MNC tokens ── */
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin-bottom: 20px;
  }
  .section-span { color: var(--amber); }
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px;
    border: 1px solid var(--navy);
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .mnc-btn--dark { background: var(--amber); border-color: var(--amber); color: var(--navy); font-weight: 700; }
  .mnc-btn--dark:hover { background: var(--amber-dark); border-color: var(--amber-dark); color: var(--white); box-shadow: 0 4px 16px rgba(224,161,53,.35); }
  .mnc-btn--outline { background: transparent; color: var(--navy); }
  .mnc-btn--outline:hover { background: var(--navy); color: var(--white); }
  .mnc-btn--stroke { background: transparent; border-color: rgba(255,255,255,.4); color: var(--white); }
  .mnc-btn--stroke:hover { border-color: var(--amber); color: var(--amber); background: rgba(224,161,53,.08); }
  .mnc-btn__icon { display: flex; width: 20px; height: 20px; }
  .mnc-btn__icon svg { width: 100%; height: 100%; }

  /* ── Hero Banner ── */
  .hero-wrap { padding: 16px; }
  .hero-inner {
    height: 490px;
    border-radius: 8px;
    background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }
  .hero-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 1; padding: 80px 1.5rem 36px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,.5);
    margin-bottom: 20px;
  }
  .breadcrumb a { color: rgba(255,255,255,.5); }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-wrap .section-tag { color: rgba(255,255,255,.6); }
  .hero-wrap .section-tag::before { background: var(--amber); }
  .hero-title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--white);
    max-width: 700px;
    margin-bottom: 16px;
  }
  .hero-sub {
    color: rgba(255,255,255,.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 32px;
  }

  /* ── Service Sections ── */
  .svc-block { background: var(--white); }
  .svc-block--alt { background: var(--off-white); }

  .svc-block__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .svc-block__grid--reverse .svc-block__image {
    order: 2;
  }
  .svc-block__grid--reverse .svc-block__content {
    order: 1;
  }

  .svc-block__image {
    border-radius: 8px;
    overflow: hidden;
  }
  .svc-block__image img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }

  .svc-block__num {
    display: inline-block;
    font-family: var(--font-secondary);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--amber);
    margin-bottom: 12px;
  }
  .svc-block__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 600;
    line-height: 1.2;
    color: var(--dark-text);
    margin-bottom: 16px;
  }
  .svc-block__desc {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-gray);
    margin-bottom: 24px;
  }
  .svc-block__bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 28px;
  }
  .svc-block__bullets li {
    position: relative;
    padding-left: 20px;
    font-size: 15px;
    color: var(--dark-text);
    line-height: 1.6;
  }
  .svc-block__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--amber);
  }

  @media (max-width: 900px) {
    .svc-block__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .svc-block__grid--reverse .svc-block__image { order: 0; }
    .svc-block__grid--reverse .svc-block__content { order: 0; }
    .svc-block__image img { height: 280px; }
  }
  @media (max-width: 640px) {
    .svc-block__bullets { grid-template-columns: 1fr; }
    .svc-block__image img { height: 220px; }
  }

  /* ── FAQ Section ── */
  .svc-faq-section { background: var(--white); }
  .faq-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 48px;
  }
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .faq-item {
    background: var(--white);
    border: 1px solid #dedede;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .faq-item:hover { border-color: var(--navy); }
  .faq-item[open] {
    border-color: var(--navy);
    box-shadow: 0 4px 16px rgba(36,55,85,.08);
  }
  .faq-item__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-secondary);
    font-weight: 600;
    font-size: 16px;
    color: var(--dark-text);
  }
  .faq-item__summary::-webkit-details-marker { display: none; }
  .faq-item__q { flex: 1; text-align: left; line-height: 1.4; }
  .faq-item__icon {
    width: 32px;
    height: 32px;
    border-radius: 4px;
    background: var(--off-white);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    flex-shrink: 0;
    transition: transform 0.3s ease, background 0.25s ease;
  }
  .faq-item[open] .faq-item__icon {
    transform: rotate(180deg);
    background: rgba(224,161,53,.15);
  }
  .faq-item__answer { padding: 0 24px 18px; }
  .faq-item__answer p {
    margin: 0;
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-gray);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .section-gap { padding: 60px 0; }
    .hero-inner { height: 400px; }
    .hero-content { padding: 60px 1.5rem 24px; }
  }
</style>
