---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    q: 'What types of modular buildings can you construct?',
    a: 'We deliver healthcare, administrative, housing, training, and specialty facilities—configured for government, commercial, and institutional programs. Scope ranges from single modules to multi-building campuses.',
  },
  {
    q: 'Do you handle government/DoD projects?',
    a: 'Yes. We align with federal requirements, security considerations, and documentation expectations typical of DoD and agency work, working alongside your contracting officers and A/E teams.',
  },
  {
    q: 'How long does a typical modular project take?',
    a: 'Timelines depend on scope, site readiness, and approvals. Parallel factory production and site work often compress schedules significantly versus stick-built delivery; we provide a phased plan after discovery.',
  },
  {
    q: 'Do you offer warranties on completed projects?',
    a: 'We stand behind our work with structured warranty and support options. Specific terms are defined per contract and asset class.',
  },
  {
    q: 'Can you work with existing architects and engineers?',
    a: 'Absolutely. We integrate with your design partners—supporting BIM coordination, design-assist, and design-build models to keep a single thread from concept through turnover.',
  },
];
---

<Layout
  title="Services"
  description="Multipurpose modular construction services: consulting, design-build, procurement, installation, support, and emergency deployment."
>
  <Header slot="header" />

  <!-- Hero Banner -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-lines" aria-hidden="true">
        <div class="hero-lines__v hero-lines__v--1"></div>
        <div class="hero-lines__v hero-lines__v--2"></div>
        <div class="hero-lines__v hero-lines__v--3"></div>
        <div class="hero-lines__v hero-lines__v--4"></div>
        <div class="hero-lines__v hero-lines__v--5"></div>
        <div class="hero-lines__v hero-lines__v--6"></div>
        <div class="hero-lines__h hero-lines__h--1"></div>
        <div class="hero-lines__h hero-lines__h--2"></div>
        <div class="hero-lines__h hero-lines__h--3"></div>
        <div class="hero-lines__h hero-lines__h--4"></div>
        <div class="hero-lines__h hero-lines__h--5"></div>
        <div class="hero-lines__h hero-lines__h--6"></div>
        <div class="hero-lines__h hero-lines__h--7"></div>
        <div class="hero-lines__h hero-lines__h--8"></div>
      </div>
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <span>Services</span>
        </nav>
        <h1 class="hero-title fade-up">Integrated Modular<br />Construction Services</h1>
        <p class="hero-sub fade-up">
          From early-stage consulting through final installation, we manage the full lifecycle of modular construction — delivering precision-built facilities on schedule and within budget.
        </p>
      </div>
    </div>
  </section>

  <!-- Bento Services Grid -->
  <section class="section-gap svc-bento-section">
    <div class="mnc-container">
      <!-- Row 1: Two large cards -->
      <div class="svc-row svc-row--2">
        <div class="svc-card svc-card--lg fade-up">
          <div class="svc-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 21h18M3 7v14m6-14v14m6-14v14m6-14v14M4 7h16l-8-4L4 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="svc-card__title">Consulting & Feasibility</h3>
          <p class="svc-card__desc">
            We step in early to assess viability, map site conditions, review applicable codes, and develop modular strategies that align with your program goals and budget constraints.
          </p>
          <ul class="svc-card__points">
            <li>Site Analysis & Code Assessment</li>
            <li>Budget Modeling</li>
            <li>Permitting Strategy</li>
          </ul>
          <a href="/contact" class="svc-card__link">
            Start a Conversation
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="svc-card svc-card--lg svc-card--navy fade-up">
          <div class="svc-card__icon svc-card__icon--light">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 3v18m9-9H3m6.5-6.5L12 3l2.5 2.5M6.5 17.5 12 21l5.5-3.5M3 12l2.5-5.5M21 12l-2.5-5.5M3 12l2.5 5.5M21 12l-2.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="svc-card__title">Design-Build Delivery</h3>
          <p class="svc-card__desc">
            Unified design-to-fabrication workflows — from architectural concepts and structural engineering through BIM coordination and factory production oversight.
          </p>
          <ul class="svc-card__points svc-card__points--light">
            <li>Architecture & Engineering</li>
            <li>BIM Coordination</li>
            <li>Factory Production Management</li>
          </ul>
          <a href="/departments#modular" class="svc-card__link svc-card__link--light">
            View Modular Division
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <!-- Row 2: Three cards (sm, md, image) -->
      <div class="svc-row svc-row--3">
        <div class="svc-card svc-card--sm fade-up">
          <div class="svc-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m-6 9 2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="svc-card__title">Project Management</h3>
          <p class="svc-card__desc">
            Dedicated oversight across scope, schedule, and budget — from pre-construction planning through final turnover and closeout documentation.
          </p>
          <a href="/departments#project-management" class="svc-card__link">
            PM Division
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="svc-card svc-card--md fade-up">
          <div class="svc-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M13 16V6a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1ZM13 8h5l3 3v5a1 1 0 0 1-1 1h-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <h3 class="svc-card__title">Procurement & Supply Chain</h3>
          <p class="svc-card__desc">
            Our alliance network spans manufacturers across multiple continents. We source materials, coordinate module fabrication, and manage oversized transport logistics to keep production moving.
          </p>
          <ul class="svc-card__points">
            <li>Vendor Management</li>
            <li>Quality Compliance</li>
            <li>Transport Logistics</li>
          </ul>
        </div>

        <div class="svc-card svc-card--img fade-up">
          <img src="/images/showcase/west-crane.jpg" alt="Modular installation on site" loading="lazy" />
        </div>
      </div>

      <!-- Row 3: Two cards (image, lg) -->
      <div class="svc-row svc-row--2">
        <div class="svc-card svc-card--img svc-card--img-tall fade-up">
          <img src="/images/showcase/ri-factory-panorama.jpg" alt="Factory floor production" loading="lazy" />
        </div>

        <div class="svc-card svc-card--lg fade-up">
          <div class="svc-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 1 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="svc-card__title">Installation & Field Execution</h3>
          <p class="svc-card__desc">
            Turnkey on-site assembly — from foundation connections and crane operations to utility tie-ins, interior finishing, and agency inspections. We coordinate every phase of physical deployment.
          </p>
          <ul class="svc-card__points">
            <li>Module Transport & Craning</li>
            <li>Utility Connections</li>
            <li>Inspections & Approvals</li>
          </ul>
          <a href="/contact" class="svc-card__link">
            Discuss Your Project
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <!-- Row 4: Three cards -->
      <div class="svc-row svc-row--3">
        <div class="svc-card svc-card--md svc-card--navy fade-up">
          <div class="svc-card__icon svc-card__icon--light">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="svc-card__title">Healthcare Deployment</h3>
          <p class="svc-card__desc">
            Rapid-deployment medical facilities through our Hospitals Without Borders partnership — modular clinics, telemedicine centers, and emergency response units.
          </p>
          <a href="/departments#healthcare" class="svc-card__link svc-card__link--light">
            Healthcare Division
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="svc-card svc-card--sm fade-up">
          <div class="svc-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="svc-card__title">Post-Occupancy Support</h3>
          <p class="svc-card__desc">
            Warranty administration, scheduled maintenance, and lifecycle planning to protect your investment well beyond handover.
          </p>
        </div>

        <div class="svc-card svc-card--sm fade-up">
          <div class="svc-card__icon">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="svc-card__title">Civil Infrastructure</h3>
          <p class="svc-card__desc">
            Grading, utilities, roadwork, and site development through our Agbayani Construction subsidiary — integrated with our modular delivery pipeline.
          </p>
          <a href="/departments#civil" class="svc-card__link">
            Civil Division
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props -->
  <section class="section-gap svc-value-section">
    <div class="mnc-container">
      <div class="svc-value-header fade-up">
        <span class="section-tag">The Modular Advantage</span>
        <h2 class="section-title">Built Different, <span class="section-span">Delivered Better</span></h2>
      </div>
      <div class="svc-value-grid fade-up">
        <div class="svc-val">
          <span class="svc-val__stat">30–50%</span>
          <span class="svc-val__label">Faster Than Traditional</span>
          <p class="svc-val__desc">Factory production runs parallel with site preparation, compressing delivery timelines dramatically.</p>
        </div>
        <div class="svc-val">
          <span class="svc-val__stat">90%+</span>
          <span class="svc-val__label">Factory-Controlled Quality</span>
          <p class="svc-val__desc">Climate-controlled manufacturing environments eliminate weather delays and deliver repeatable precision.</p>
        </div>
        <div class="svc-val">
          <span class="svc-val__stat">60%</span>
          <span class="svc-val__label">Less Material Waste</span>
          <p class="svc-val__desc">Standardized factory processes, recyclable offcuts, and optimized material ordering reduce waste at every stage.</p>
        </div>
        <div class="svc-val">
          <span class="svc-val__stat">Safer</span>
          <span class="svc-val__label">Controlled Work Environment</span>
          <p class="svc-val__desc">Indoor manufacturing reduces on-site hazards, weather exposure, and accident-related liabilities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section-gap svc-faq-section">
    <div class="mnc-container">
      <div class="faq-header fade-up">
        <span class="section-tag">FAQ</span>
        <h2 class="section-title">Questions we hear often <span class="section-span">answered clearly</span></h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item fade-up" name="gmp-faq">
            <summary class="faq-item__summary">
              <span class="faq-item__q">{item.q}</span>
              <span class="faq-item__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq-item__answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Shared MNC tokens ── */
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin-bottom: 20px;
  }
  .section-span { color: var(--amber); }

  /* ── Hero Banner ── */
  .hero-wrap { padding: 0; }
  .hero-inner {
    height: 510px;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }
  .hero-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%);
    pointer-events: none;
  }
  /* Hero grid lines */
  .hero-lines {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-lines__v {
    position: absolute;
    top: 25%;
    bottom: 0;
    width: 1px;
    background: rgba(255,255,255,.06);
    transform: scaleY(0);
    transform-origin: top;
    animation: lineRevealV 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  /* Right-side verticals */
  .hero-lines__v--1 { left: 54%; animation-delay: 0.1s; }
  .hero-lines__v--2 { left: 70%; animation-delay: 0.4s; }
  .hero-lines__v--3 { left: 90%; animation-delay: 0.7s; }
  .hero-lines__v--4 { left: 62%; animation-delay: 1.0s; }
  /* Left-side verticals */
  .hero-lines__v--5 { left: 3%; animation-delay: 0.25s; }
  .hero-lines__v--6 { left: 8%; animation-delay: 0.55s; }

  .hero-lines__h {
    position: absolute;
    height: 1px;
    background: rgba(255,255,255,.06);
    transform: scaleX(0);
    animation: lineRevealH 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  /* Left-side horizontals — edge to content margin */
  .hero-lines__h--1 { top: 5%; left: 0; right: 0; transform-origin: left; animation-delay: 0.35s; }
  .hero-lines__h--2 { top: 38%; left: 0; right: 88%; transform-origin: right; animation-delay: 0.75s; }
  .hero-lines__h--3 { top: 65%; left: 0; right: 88%; transform-origin: left; animation-delay: 1.05s; }
  .hero-lines__h--4 { top: 88%; left: 0; right: 88%; transform-origin: right; animation-delay: 1.3s; }
  /* Right-side horizontals — content margin to edge */
  .hero-lines__h--5 { display: none; }
  .hero-lines__h--6 { top: 38%; left: 50%; right: 0; transform-origin: left; animation-delay: 1.15s; }
  .hero-lines__h--7 { top: 65%; left: 52%; right: 0; transform-origin: right; animation-delay: 0.6s; }
  .hero-lines__h--8 { top: 88%; left: 52%; right: 0; transform-origin: left; animation-delay: 1.4s; }

  @keyframes lineRevealV {
    0%   { transform: scaleY(0); opacity: 0; }
    60%  { transform: scaleY(1); opacity: 1; }
    75%  { transform: scaleY(1); opacity: .35; }
    100% { transform: scaleY(1); opacity: 1; }
  }
  @keyframes lineRevealH {
    0%   { transform: scaleX(0); opacity: 0; }
    60%  { transform: scaleX(1); opacity: 1; }
    75%  { transform: scaleX(1); opacity: .35; }
    100% { transform: scaleX(1); opacity: 1; }
  }

  .hero-content { position: relative; z-index: 1; padding: 80px 1.5rem 60px max(1.5rem, calc(50vw - 620px + 1.5rem)); width: 100%; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,.5);
    margin-bottom: 20px;
  }
  .breadcrumb a { color: rgba(255,255,255,.5); }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-wrap .section-tag { color: rgba(255,255,255,.6); }
  .hero-wrap .section-tag::before { background: var(--amber); }
  .hero-title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--white);
    max-width: 700px;
    margin-bottom: 16px;
  }
  .hero-sub {
    color: rgba(255,255,255,.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 32px;
  }

  /* ── Bento Services Section ── */
  .svc-bento-section {
    background: transparent;
    position: relative;
    z-index: 2;
    margin-top: -50px;
    padding-top: 0;
  }
  .svc-bento-section::before {
    content: '';
    position: absolute;
    top: 80px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--off-white);
    z-index: -1;
  }

  /* Rows */
  .svc-row {
    display: grid;
    gap: 20px;
    margin-bottom: 20px;
  }
  .svc-row--2 { grid-template-columns: 1fr 1fr; }
  .svc-row--3 { grid-template-columns: 1fr 1.4fr 0.8fr; }
  .svc-row:last-child { margin-bottom: 0; }

  /* Card base */
  .svc-card {
    background: var(--white);
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 8px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, border-color 0.3s ease, opacity 0.7s ease, transform 0.7s ease;
  }
  .svc-row .svc-card.fade-up:nth-child(1) { transition-delay: 0s; }
  .svc-row .svc-card.fade-up:nth-child(2) { transition-delay: 0.12s; }
  .svc-row .svc-card.fade-up:nth-child(3) { transition-delay: 0.24s; }
  .svc-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,.07);
    border-color: rgba(0,0,0,.1);
  }

  /* Navy variant */
  .svc-card--navy {
    background: linear-gradient(155deg, var(--navy) 0%, var(--navy-dark) 100%);
    border-color: transparent;
    color: var(--white);
  }
  .svc-card--navy:hover {
    box-shadow: 0 8px 32px rgba(30,58,102,.25);
  }
  .svc-card--navy .svc-card__title { color: var(--white); }
  .svc-card--navy .svc-card__desc { color: rgba(255,255,255,.65); }

  /* Image card */
  .svc-card--img {
    padding: 0;
    overflow: hidden;
    min-height: 240px;
    border: none;
  }
  .svc-card--img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .svc-card--img:hover img { transform: scale(1.04); }
  .svc-card--img-tall { min-height: 380px; }

  /* Icon */
  .svc-card__icon {
    width: 48px;
    height: 48px;
    border: 1px solid rgba(0,0,0,.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber-dark);
    margin-bottom: 24px;
    flex-shrink: 0;
  }
  .svc-card__icon--light {
