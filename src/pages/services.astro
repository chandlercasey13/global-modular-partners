---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageCTA from '../components/PageCTA.astro';

const competencies = [
  {
    tag: 'Consulting',
    tagSuffix: 'Strategy + Feasibility',
    title: 'Consulting.',
    titleSub: 'Strategy before scope.',
    desc: 'Advisory work at the earliest stages of a project — feasibility analysis, regulatory and code review, site assessment, and total-cost-of-ownership modeling. We help owners, agencies, and developers decide whether modular is the right delivery method before a single drawing is issued.',
    desc2: 'Our consultants bring practitioner experience across federal, healthcare, and civil sectors, translating ambiguous program requirements into defensible scopes, schedules, and budgets that downstream teams can execute against.',
    pills: ['Feasibility Studies', 'Code & Compliance', 'TCO Modeling', 'Delivery Planning'],
    img: '/images/showcase/west-blvd-render.jpg',
    layout: 'text-left',
  },
  {
    tag: 'Project Management',
    tagSuffix: 'Integrated Delivery',
    title: 'Project Management.',
    titleSub: 'One schedule, one source.',
    desc: 'End-to-end coordination across design, manufacturing, logistics, and installation under a single point of accountability. Every milestone, submittal, and budget line is tracked against a unified critical path — replacing the fragmented handoffs of traditional construction.',
    desc2: 'We orchestrate multi-partner delivery across continents, aligning factories, freight forwarders, and site crews so modules arrive sequenced, inspected, and ready to install.',
    pills: ['Single Point of Contact', 'Critical Path Scheduling', 'Multi-Partner Coordination', 'Owner Reporting'],
    img: '/images/showcase/ri-civil-compound-aerial.png',
    layout: 'text-right',
  },
  {
    tag: 'Development',
    tagSuffix: 'Design + Build',
    title: 'Development.',
    titleSub: 'Designed and built as one package.',
    desc: 'Design-build execution delivered as a single integrated package — architecture, structural engineering, MEP, BIM coordination, and custom module fabrication handled in-house and through our vetted manufacturing partners.',
    desc2: 'From purpose-built healthcare suites to secure DoD compounds, we translate program requirements into manufactured modules engineered to snap into their foundations on the first lift.',
    pills: ['Design-Build', 'BIM Coordination', 'Factory Fabrication', 'On-Site Assembly'],
    img: '/images/showcase/ri-factory-panorama.jpg',
    layout: 'text-left',
  },
  {
    tag: 'Support & Maintenance',
    tagSuffix: 'Lifecycle Service',
    title: 'Support & Maintenance.',
    titleSub: 'Uptime across the lifecycle.',
    desc: 'Post-occupancy support that protects uptime across the full lifecycle. Scheduled inspections, warranty service, retrofit upgrades, and rapid-response on-site repair keep modules performing for decades after initial deployment.',
    desc2: 'For mission-critical facilities — military, medical, civic — we maintain documented service records and staged spare-parts logistics, deployable anywhere in our operating footprint.',
    pills: ['Preventive Maintenance', 'Warranty Service', 'Retrofits & Upgrades', 'Rapid Response'],
    img: '/images/showcase/ri-un-modules-crane.png',
    layout: 'text-right',
  },
];

const protocols = [
  { num: '01', title: 'Architectural Audit', desc: 'Verification of design intent against fabrication capacity, material availability, and structural code.' },
  { num: '02', title: 'BIM Co-Synthesis', desc: 'Full model MEP clashes and fit-for-purpose validation for building information modeling.' },
  { num: '03', title: 'Modular ESG Analog', desc: 'Measurement of full material sustainability with corrections applied before production begins.' },
];

---

<Layout
  title="Services"
  description="Multipurpose modular construction services: consulting, design-build, procurement, installation, support, and emergency deployment."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="sv-hero">
    <div class="sv-hero__panel">
      <div class="mnc-container sv-hero__inner">
        <div class="sv-hero__content">
          <h1 class="sv-hero__h1">Engineering the Future<br/><span class="sv-hero__h1-sub">of Construction.</span></h1>
          <p class="sv-hero__sub">Multipurpose modular construction services — from consulting and design-build to procurement, installation, and emergency deployment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ OUR APPROACH ════════ -->
  <section class="sv-advantage" id="our-approach">
    <div class="mnc-container">
      <div class="sv-sec-head fade-up">
        <span class="section-tag">Our Approach</span>
      </div>
      <div class="sv-advantage__top fade-up">
        <h2 class="sv-advantage__title">
          Four services.<br/><span class="sv-advantage__span">One coordinated delivery model.</span>
        </h2>
        <p class="sv-advantage__desc">
          Consulting, project management, development, and lifecycle support all run through a single integrated framework — one team, one schedule, and one point of accountability from the first feasibility call through long-term service.
        </p>
      </div>

      <div class="sv-advantage__cards">
        <div class="sv-advantage__card">
          <div class="sv-advantage__card-media">
            <span class="sv-advantage__card-num">01</span>
            <img src="/images/showcase/ri-civil-compound.jpg" alt="Integrated modular compound" class="sv-advantage__card-img" loading="lazy" />
          </div>
          <div class="sv-advantage__card-body">
            <h3 class="sv-advantage__card-title">
              Single point of accountability.
              <span class="sv-advantage__card-title-sub">One team across every phase.</span>
            </h3>
            <p class="sv-advantage__card-desc">One team carries every decision across consulting, design, fabrication, and installation — no dropped context between firms, no scope gaps between contracts.</p>
          </div>
        </div>
        <div class="sv-advantage__card">
          <div class="sv-advantage__card-media">
            <span class="sv-advantage__card-num">02</span>
            <img src="/images/showcase/ri-factory-production.jpg" alt="Factory-grade modular production" class="sv-advantage__card-img" loading="lazy" />
          </div>
          <div class="sv-advantage__card-body">
            <h3 class="sv-advantage__card-title">
              Factory-grade precision.
              <span class="sv-advantage__card-title-sub">Tolerances you can measure.</span>
            </h3>
            <p class="sv-advantage__card-desc">Every module is engineered for controlled assembly — tighter tolerances, measurable QA, and documented chain-of-custody from factory floor through installation and service.</p>
          </div>
        </div>
        <div class="sv-advantage__card">
          <div class="sv-advantage__card-media">
            <span class="sv-advantage__card-num">03</span>
            <img src="/images/showcase/ri-un-ship-logistics.png" alt="Global modular logistics" class="sv-advantage__card-img" loading="lazy" />
          </div>
          <div class="sv-advantage__card-body">
            <h3 class="sv-advantage__card-title">
              Global delivery network.
              <span class="sv-advantage__card-title-sub">Three continents, one standard.</span>
            </h3>
            <p class="sv-advantage__card-desc">A vetted base of 40+ manufacturing and engineering partners across three continents stages work close to demand — without loosening the standards set upstream.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 2. COMPETENCY SECTIONS ════════ -->
  {competencies.map((comp, i) => (
    <section
      class:list={[
        'sv-comp',
        comp.layout === 'text-right' && 'sv-comp--reverse',
        i % 2 === 0 && 'sv-comp--band-muted',
      ]}
    >
      <div class="sv-comp__grid">
          <div class="sv-comp__img-col">
            <img src={comp.img} alt={comp.title} class="sv-comp__img" loading="lazy" />
          </div>
          <div class="sv-comp__text-col fade-up">
            <div class="sv-comp__text-inner">
              <div class="sv-comp__tag-row">
                <span class="sv-comp__tag">{comp.tag}</span>
                <span class="sv-comp__tag-suffix">{comp.tagSuffix}</span>
              </div>
              <h2 class="sv-comp__title">
                {comp.title}<br/><span class="sv-comp__title-sub">{comp.titleSub}</span>
              </h2>
              <p class="sv-comp__desc">{comp.desc}</p>
              {comp.desc2 && <p class="sv-comp__desc">{comp.desc2}</p>}
              <div class="sv-comp__pills">
                {comp.pills.map((pill: string) => (
                  <span class="sv-comp__pill">{pill}</span>
                ))}
              </div>
            </div>
          </div>
      </div>
    </section>
  ))}

  <!-- ════════ 3. PROTOCOL ════════ -->
  <section class="sv-protocol">
    <div class="sv-protocol__layout fade-up">
      <div class="sv-protocol__left">
        <div class="sv-protocol__text-inner">
          <span class="section-tag">Protocol</span>
          <h2 class="sv-protocol__title">A Rigid Protocol.<br/><span class="sv-protocol__title-sub">For Perfection.</span></h2>
          <p class="sv-protocol__sub">
            Every build is held to a 3-phase pre-fabrication audit and strict final QA process.
          </p>

          <div class="sv-protocol__steps">
            {protocols.map((p) => (
              <div class="sv-protocol__step">
                <span class="sv-protocol__num">{p.num}</span>
                <div>
                  <h4 class="sv-protocol__step-title">{p.title}</h4>
                  <p class="sv-protocol__step-desc">{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="sv-protocol__right">
        <div class="sv-protocol__img-wrap">
          <img src="/images/showcase/petra-project3.jpg" alt="Welding precision" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <PageCTA
    eyebrow="See the work"
    title="This is what these services<br/>look like in the field."
    image="/images/showcase/ri-un-modules-crane.png"
    links={[
      { label: 'Browse Projects', href: '/projects' },
      { label: 'Meet the Partners', href: '/partners' },
    ]}
  />

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1440px; margin: 0 auto; padding: 0 1.5rem; }

  .sv-sec-head {
    margin-bottom: 20px;
  }

  /* section-tag styled globally (aeline mono-dot) */

  /* ═══ OUR PROCESS (aeline) ═══ */
  .sv-advantage {
    background-color: var(--paper);
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }

  .sv-advantage__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 56px;
  }

  .sv-advantage__title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #0d1c33;
    margin: 0;
  }

  .sv-advantage__span {
    color: var(--muted);
    font-weight: 400;
  }

  .sv-advantage__desc {
    font-size: var(--fs-lg);
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
    max-width: 34rem;
  }

  .sv-advantage__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .sv-advantage__card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    transition:
      transform 0.4s cubic-bezier(.2, .8, .2, 1),
      box-shadow 0.4s ease,
      border-color 0.4s ease;
  }

  .sv-advantage__card:hover {
    transform: translateY(-3px);
    border-color: rgba(0, 0, 0, 0.12);
    box-shadow: 0 12px 32px -8px rgba(0, 0, 0, 0.12);
  }

  .sv-advantage__card-media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--paper-2, #f3f1ec);
  }

  .sv-advantage__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s cubic-bezier(.2,.8,.2,1);
  }

  .sv-advantage__card:hover .sv-advantage__card-img {
    transform: scale(1.04);
  }

  .sv-advantage__card-num {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--ink);
    background: rgba(255, 255, 255, 0.92);
    padding: 6px 10px;
    border-radius: 999px;
    text-transform: uppercase;
    backdrop-filter: blur(4px);
  }

  .sv-advantage__card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px 26px 28px;
    flex: 1;
  }

  .sv-advantage__card-title {
    font-family: var(--font-secondary);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: #0d1c33;
    line-height: 1.3;
    margin: 0;
  }

  .sv-advantage__card-title-sub {
    display: block;
    color: var(--muted);
    font-weight: 400;
    margin-top: 2px;
  }

  .sv-advantage__card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  @media (max-width: 768px) {
    .sv-advantage__top {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .sv-advantage__cards {
      grid-template-columns: 1fr;
    }
  }

  /* ═══ 1. HERO ═══ */
  .sv-hero {
    position: relative;
    background: #fff;
    padding: 0;
  }

  .sv-hero__panel {
    position: relative;
    height: 480px;
    overflow: hidden;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .sv-hero__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
  }

  .sv-hero__inner {
    height: 100%;
  }

  .sv-hero__content {
    position: relative;
    padding: 120px 0 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    z-index: 2;
  }

  .sv-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: none;
    letter-spacing: -2px;
    margin-bottom: 20px;
  }

  .sv-hero__h1-sub {
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
  }

  .sv-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,.5);
    max-width: 520px;
    margin: 0;
  }

  /* ═══ 2. COMPETENCY (aeline) — alternating paper / soft bands ═══ */
  .sv-comp {
    background-color: var(--paper);
    --strip-edge-gutter: max(1.5rem, calc((100vw - 1440px) / 2 + 1.5rem));
    --strip-inner-gap: 48px;
  }

  .sv-comp--band-muted {
    background-color: var(--paper-2);
  }

  .sv-comp__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  .sv-comp--reverse .sv-comp__img-col { order: 2; }
  .sv-comp--reverse .sv-comp__text-col { order: 1; }

  /* Default: image left, text right (same gutters as .netmap) */
  .sv-comp:not(.sv-comp--reverse) .sv-comp__img-col {
    position: relative;
    overflow: hidden;
    padding-top: 48px;
    padding-bottom: 48px;
    padding-left: var(--strip-edge-gutter);
    padding-right: var(--strip-inner-gap);
  }

  .sv-comp:not(.sv-comp--reverse) .sv-comp__text-col {
    display: flex;
    align-items: center;
    background: transparent;
    padding-right: var(--strip-edge-gutter);
    padding-left: 0;
  }

  .sv-comp:not(.sv-comp--reverse) .sv-comp__text-inner {
    padding: 48px 0 48px var(--strip-inner-gap);
    max-width: 680px;
    width: 100%;
  }

  /* Reverse: text left, image right (same gutters as .hp-about) */
  .sv-comp--reverse .sv-comp__text-col {
    display: flex;
    align-items: center;
    background: transparent;
    padding-left: var(--strip-edge-gutter);
    padding-right: 0;
  }

  .sv-comp--reverse .sv-comp__text-inner {
    padding: 48px var(--strip-inner-gap) 48px 0;
    max-width: 680px;
  }

  .sv-comp--reverse .sv-comp__img-col {
    position: relative;
    overflow: hidden;
    padding-top: 48px;
    padding-bottom: 48px;
    padding-left: var(--strip-inner-gap);
    padding-right: var(--strip-edge-gutter);
  }

  .sv-comp__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-xl);
  }

  .sv-comp__tag-row {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .sv-comp__tag-row::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--ink);
    flex-shrink: 0;
  }

  .sv-comp__tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .sv-comp__tag-suffix {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .sv-comp__title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: #0d1c33;
    margin: 0 0 18px;
  }

  .sv-comp__title-sub {
    color: var(--muted);
    font-weight: 400;
  }

  .sv-comp__desc {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0 0 16px;
  }

  .sv-comp__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 28px;
  }

  .sv-comp__pill {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-transform: none;
    padding: 8px 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    color: var(--ink);
    background: var(--paper);
  }

  @media (min-width: 901px) {
    .sv-comp__grid {
      height: 620px;
      min-height: 620px;
      max-height: 620px;
      overflow: hidden;
    }

    .sv-comp__text-col {
      min-height: 0;
      overflow: hidden;
      align-items: stretch;
    }

    .sv-comp__text-inner {
      display: flex;
      flex-direction: column;
      height: 100%;
      min-height: 0;
      padding-top: 48px;
      padding-bottom: 48px;
    }

    .sv-comp__pills {
      margin-top: auto;
      padding-top: 28px;
    }

    .sv-comp__img-col {
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .sv-comp__img {
      flex: 1;
      min-height: 0;
    }
  }

  /* ═══ 3. PROTOCOL (aeline dark rounded panel) ═══ */
  .sv-protocol {
    background: var(--ink);
    color: var(--on-ink);
    padding: 0;
    --strip-edge-gutter: max(1.5rem, calc((100vw - 1440px) / 2 + 1.5rem));
    --strip-inner-gap: 48px;
  }

  .sv-protocol__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 560px;
  }

  .sv-protocol .section-tag {
    color: var(--on-ink);
    margin-bottom: 28px;
  }
  .sv-protocol .section-tag::before {
    background-color: var(--accent);
  }

  .sv-protocol__left {
    display: flex;
    align-items: center;
    padding-left: var(--strip-edge-gutter);
    min-width: 0;
  }

  .sv-protocol__text-inner {
    max-width: 680px;
    padding: 48px var(--strip-inner-gap) 48px 0;
    width: 100%;
  }

  .sv-protocol__title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--on-ink);
    margin: 0 0 18px;
  }

  .sv-protocol__title-sub {
    color: var(--on-ink-muted);
    font-weight: 400;
  }

  .sv-protocol__sub {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--on-ink-muted);
    margin: 0 0 32px;
  }

  .sv-protocol__steps {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .sv-protocol__step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .sv-protocol__num {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--accent);
    flex-shrink: 0;
    line-height: 1.4;
    padding-top: 2px;
  }

  .sv-protocol__step-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--on-ink);
    margin-bottom: 4px;
  }

  .sv-protocol__step-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--on-ink-muted);
    margin: 0;
  }

  .sv-protocol__right {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    padding: 48px var(--strip-edge-gutter) 48px var(--strip-inner-gap);
  }

  .sv-protocol__img-wrap {
    position: relative;
    flex: 1;
    min-height: 280px;
    overflow: hidden;
    border-radius: var(--radius-xl);
  }

  .sv-protocol__img-wrap img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 901px) {
    .sv-protocol__img-wrap {
      min-height: 0;
    }

    .sv-protocol__img-wrap img {
      min-height: 0;
    }
  }

  /* ═══ 4. STANDARDS ═══ */
  .sv-standards {
    background: var(--off-white);
    padding: 64px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .sv-standards__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
  }

  .sv-standards__title {
    font-family: var(--font-secondary);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-gray);
    white-space: nowrap;
