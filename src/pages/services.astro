---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const competencies = [
  {
    tag: 'architecture',
    tagSuffix: 'Structural + Civil',
    title: 'Structural Engineering',
    desc: 'Multi-system structural analysis from seismic performance to lateral load factors — advancing safety, efficiency, and regulatory compliance.',
    desc2: 'Projects under review across government and commercial sectors supporting Federal and international infrastructure.',
    pills: ['Service/Verticals', 'AISC Steel', 'Reinforced Concrete'],
    img: '/images/showcase/ri-factory-panorama.jpg',
    layout: 'text-left',
  },
  {
    tag: 'Supply Chain Operations',
    tagSuffix: 'Import + Logistics',
    title: 'Supply Chain Integration',
    desc: 'End-to-end integration from international procurement to last mile delivery. Our proprietary coordination system manages logistics for streamlining cost efficiency.',
    pills: ['Multi-Vendor OFFSEC', '<=45% Cycle Time'],
    img: '/images/showcase/ri-un-ship-logistics.png',
    layout: 'text-right',
  },
  {
    tag: 'Fabrication',
    tagSuffix: 'Custom + Scalable',
    title: 'Custom Module Synthesis',
    desc: 'Purpose-built for each brief — we configure custom and standardized modules spanning commercial, healthcare, defense, and institutional applications with factory-level precision and consistency.',
    pills: ['Custom Build-Out', 'Lab Assemblies'],
    img: '/images/showcase/ri-commercial-building.png',
    layout: 'text-left',
  },
];

const protocols = [
  { num: '01', title: 'Architectural Audit', desc: 'Verification of design intent against fabrication capacity, material availability, and structural code.' },
  { num: '02', title: 'BIM Co-Synthesis', desc: 'Full model MEP clashes and fit-for-purpose validation for building information modeling.' },
  { num: '03', title: 'Modular ESG Analog', desc: 'Measurement of full material sustainability with corrections applied before production begins.' },
];

const standards = [
  { icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`, title: 'ISO 9001:2015' },
  { icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 12c0 4.97 3.038 9.227 7.354 11.016.34.141.652.213.966.236.033.002.065.003.098.004L12 23.25l.582.006c.033-.001.065-.002.098-.004.314-.023.626-.095.966-.236C17.962 21.227 21 16.97 21 12c0-1.047-.134-2.063-.382-3.016z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`, title: 'AISC Certified' },
  { icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`, title: 'IBC Compliant' },
  { icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M3 21h18M3 7v14m6-14v14m6-14v14m6-14v14M4 7h16l-8-4L4 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`, title: 'OSHA Aligned' },
];
---

<Layout
  title="Services"
  description="Multipurpose modular construction services: consulting, design-build, procurement, installation, support, and emergency deployment."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="sv-hero">
    <div class="sv-hero__content">
      <h1 class="sv-hero__h1">Engineering the<br/>Future of Construction.</h1>
      <p class="sv-hero__sub">Multipurpose modular construction services — from consulting and design-build to procurement, installation, and emergency deployment.</p>
    </div>
  </section>

  <!-- ════════ 2. CORE COMPETENCIES INTRO ════════ -->
  <section class="sv-intro">
    <div class="mnc-container">
      <div class="sv-intro__inner fade-up">
        <h2 class="sv-intro__title">Core Competencies</h2>
        <p class="sv-intro__desc">
          Our modular systems integration gives us a structural, fabrication, and management capacity that can't just be outsourced — it's engineered, compliant, and field-validated at global scale.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ 3. COMPETENCY SECTIONS ════════ -->
  {competencies.map((comp, i) => (
    <section class={`sv-comp ${comp.layout === 'text-right' ? 'sv-comp--reverse' : ''}`}>
      <div class="sv-comp__img-col">
        <img src={comp.img} alt={comp.title} class="sv-comp__img" loading="lazy" />
      </div>
      <div class="sv-comp__text-col fade-up">
        <div class="sv-comp__text-inner">
          <div class="sv-comp__tag-row">
            <span class="sv-comp__tag">{comp.tag}</span>
            <span class="sv-comp__tag-suffix">{comp.tagSuffix}</span>
          </div>
          <h2 class="sv-comp__title">{comp.title}</h2>
          <p class="sv-comp__desc">{comp.desc}</p>
          {comp.desc2 && <p class="sv-comp__desc">{comp.desc2}</p>}
          <div class="sv-comp__pills">
            {comp.pills.map((pill: string) => (
              <span class="sv-comp__pill">{pill}</span>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ════════ 4. PROTOCOL ════════ -->
  <section class="sv-protocol">
    <div class="mnc-container">
      <div class="sv-protocol__layout fade-up">
        <div class="sv-protocol__left">
          <h2 class="sv-protocol__title">A Rigid Protocol<br/>for Perfection</h2>
          <p class="sv-protocol__sub">
            Every build is held to a 3-phase pre-fabrication audit and strict final QA process.
          </p>

          <div class="sv-protocol__steps">
            {protocols.map((p) => (
              <div class="sv-protocol__step">
                <span class="sv-protocol__num">{p.num}</span>
                <div>
                  <h4 class="sv-protocol__step-title">{p.title}</h4>
                  <p class="sv-protocol__step-desc">{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="sv-protocol__right">
          <div class="sv-protocol__img-wrap">
            <img src="/images/showcase/petra-project3.jpg" alt="Welding precision" loading="lazy" />
            <div class="sv-protocol__stat-badge">
              <span class="sv-protocol__stat-num">98.4%</span>
              <span class="sv-protocol__stat-label">First-pass inspection rate</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1440px; margin: 0 auto; padding: 0 1.5rem; }

  /* ═══ 1. HERO ═══ */
  .sv-hero {
    position: relative;
    height: 480px;
    overflow: hidden;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .sv-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
  }

  .sv-hero__content {
    position: relative;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .sv-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: -2px;
    margin-bottom: 20px;
  }

  .sv-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,.5);
    max-width: 520px;
    margin: 0;
  }

  /* ═══ 2. INTRO ═══ */
  .sv-intro {
    background: var(--white);
    padding: 100px 0;
    border-bottom: 1px solid rgba(0,0,0,.06);
  }

  .sv-intro__inner {
    max-width: 800px;
  }

  .sv-intro__title {
    font-family: var(--font-secondary);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-gray);
    margin-bottom: 24px;
  }

  .sv-intro__desc {
    font-family: var(--font-secondary);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    line-height: 1.5;
    color: var(--dark-text);
    margin: 0;
  }

  /* ═══ 3. COMPETENCY SECTIONS ═══ */
  .sv-comp {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 520px;
  }

  .sv-comp--reverse .sv-comp__img-col { order: 2; }
  .sv-comp--reverse .sv-comp__text-col { order: 1; }

  .sv-comp__img-col {
    position: relative;
    overflow: hidden;
  }

  .sv-comp__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sv-comp__text-col {
    display: flex;
    align-items: center;
    background: var(--white);
  }

  .sv-comp--reverse .sv-comp__text-col {
    background: var(--navy);
  }

  .sv-comp__text-inner {
    padding: 60px 64px;
    max-width: 560px;
  }

  .sv-comp--reverse .sv-comp__text-inner {
    margin-left: auto;
  }

  .sv-comp__tag-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .sv-comp__tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--amber);
  }

  .sv-comp__tag-suffix {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-gray);
  }

  .sv-comp--reverse .sv-comp__tag-suffix {
    color: rgba(255,255,255,.35);
  }

  .sv-comp__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    line-height: 1.05;
    color: var(--dark-text);
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .sv-comp--reverse .sv-comp__title {
    color: var(--white);
  }

  .sv-comp__desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
    margin-bottom: 16px;
  }

  .sv-comp--reverse .sv-comp__desc {
    color: rgba(255,255,255,.55);
  }

  .sv-comp__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .sv-comp__pill {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid rgba(0,0,0,.12);
    color: var(--dark-text);
  }

  .sv-comp--reverse .sv-comp__pill {
    border-color: rgba(255,255,255,.15);
    color: rgba(255,255,255,.5);
  }

  /* ═══ 4. PROTOCOL ═══ */
  .sv-protocol {
    background: var(--off-white);
    padding: 100px 0;
  }

  .sv-protocol__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .sv-protocol__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--dark-text);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .sv-protocol__sub {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-gray);
    margin-bottom: 36px;
  }

  .sv-protocol__steps {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .sv-protocol__step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .sv-protocol__num {
    font-family: var(--font-secondary);
    font-size: 24px;
    font-weight: 900;
    color: var(--amber);
    flex-shrink: 0;
    line-height: 1.2;
  }

  .sv-protocol__step-title {
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 4px;
  }

  .sv-protocol__step-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-gray);
    margin: 0;
  }

  .sv-protocol__right {
    position: relative;
  }

  .sv-protocol__img-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 0;
  }

  .sv-protocol__img-wrap img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .sv-protocol__stat-badge {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background: var(--navy);
    padding: 20px 24px;
    border-radius: 8px;
    text-align: center;
    min-width: 140px;
  }

  .sv-protocol__stat-num {
    font-family: var(--font-secondary);
    font-size: 36px;
    font-weight: 900;
    color: var(--amber);
    display: block;
    line-height: 1;
  }

  .sv-protocol__stat-label {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
    display: block;
    margin-top: 6px;
  }

  /* ═══ 5. STANDARDS ═══ */
  .sv-standards {
    background: var(--navy-dark);
    padding: 64px 0;
  }

  .sv-standards__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
  }

  .sv-standards__title {
    font-family: var(--font-secondary);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,.35);
    white-space: nowrap;
    margin: 0;
  }

  .sv-standards__grid {
    display: flex;
    gap: 32px;
  }

  .sv-standards__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 6px;
    white-space: nowrap;
  }

  .sv-standards__icon {
    color: var(--amber);
    display: flex;
    align-items: center;
  }

  .sv-standards__name {
    font-family: var(--font-secondary);
    font-size: 14px;
    font-weight: 700;
    color: rgba(255,255,255,.7);
    letter-spacing: 0.5px;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .sv-comp {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .sv-comp--reverse .sv-comp__img-col { order: 1; }
    .sv-comp--reverse .sv-comp__text-col { order: 2; }

    .sv-comp__img-col { height: 300px; }

    .sv-comp__text-inner {
      padding: 48px 32px;
      max-width: none;
    }

    .sv-comp--reverse .sv-comp__text-inner {
      margin-left: 0;
    }

    .sv-protocol__layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .sv-standards__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .sv-standards__grid {
      flex-wrap: wrap;
    }
  }

  @media (max-width: 768px) {
    .sv-hero { height: 380px; }

    .sv-intro { padding: 64px 0; }

    .sv-protocol { padding: 64px 0; }

    .sv-comp__img-col { height: 240px; }

    .sv-comp__text-inner { padding: 36px 24px; }
  }
</style>
