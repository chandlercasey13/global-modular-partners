---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
  { title: 'Innovation', desc: 'Advancing modular methods and digital delivery.', icon: 'spark' },
  { title: 'Integrity', desc: 'Transparent partnerships and accountable execution.', icon: 'shield' },
  { title: 'Excellence', desc: 'Rigorous quality in design, manufacturing, and field work.', icon: 'star' },
  { title: 'Sustainability', desc: 'Responsible materials, efficiency, and lifecycle thinking.', icon: 'leaf' },
  { title: 'Compliance', desc: 'Meeting and exceeding regulatory and client standards.', icon: 'check' },
  { title: 'Impact', desc: 'Outcomes that strengthen communities and critical infrastructure.', icon: 'globe' },
] as const;

const subsidiaries = [
  {
    name: 'Agbayani Construction',
    blurb: 'General contracting across modular and civil construction programs.',
    bullets: ['Commercial & Residential Modular', 'Civil Infrastructure', 'Design-Build Services'],
    icon: 'build',
  },
  {
    name: 'RI Group USA',
    blurb: 'International modular construction expertise and manufacturing partnerships.',
    bullets: ['Modular Manufacturing', 'International Supply Chain', 'Quality Assurance'],
    icon: 'globe',
  },
  {
    name: 'EDIS USA',
    blurb: 'Emergency Disaster Information Systems for rapid deployment.',
    bullets: ['Emergency Response', 'Rapid Deployment Units', 'Disaster Recovery'],
    icon: 'alert',
  },
];

const leadership = [
  { name: 'Fuad Sweiss', role: 'Founder & CEO', bio: 'Founded GMP in 2019 to advance modular construction globally' },
];

const board = [
  { name: 'Robert Bilbeisi', role: 'Board Chairman', focus: 'International Development' },
  { name: 'Dr. Maria Carranza', role: 'Board Member', focus: 'Healthcare Systems' },
  { name: 'James Siri', role: 'Board Member', focus: 'Defense Contracting' },
  { name: 'Amb. Ahmed Bulgherini', role: 'Board Member', focus: 'International Relations' },
];

const timeline = [
  { year: '2019', event: 'GMP founded by Fuad Sweiss in the San Francisco Bay Area' },
  { year: '2020', event: 'Agbayani Construction partnership established' },
  { year: '2021', event: 'RI Group USA collaboration launched' },
  { year: '2022', event: 'Irvine, CA office opened for Southern California operations' },
  { year: '2023', event: 'HWB healthcare partnership initiated' },
  { year: '2024', event: 'Trade partner network expanded to 10+ firms' },
  { year: '2025', event: '28-Day ADU program introduced' },
];

const awards = [
  { year: '2017', title: 'Innovation Award' },
  { year: '2019', title: 'Sustainability Excellence' },
  { year: '2021', title: 'Top Construction Partner' },
  { year: '2023', title: 'Best Government Contractor' },
  { year: '2025', title: 'Industry Leader Recognition' },
];
---

<Layout
  title="About Us"
  description="Mission, subsidiaries, leadership, and history of Global Modular Partners — modular construction for government, healthcare, and commercial sectors."
>
  <Header slot="header" />

  <!-- Hero Banner -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <span>About Us</span>
        </nav>
        <h1 class="hero-title fade-up">Shaping the Future of<br />Global Construction</h1>
        <p class="hero-sub fade-up">
          Founded in 2019 by Fuad Sweiss to improve and perfect modular building technologies through global partnerships.
        </p>
        <div class="hero-actions fade-up">
          <a href="/contact" class="mnc-btn mnc-btn--dark">
            Start a Project
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg></span>
          </a>
          <a href="/services" class="mnc-btn mnc-btn--stroke">
            Our Services
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="section-gap about-mission">
    <div class="mnc-container">
      <div class="mission-header fade-up">
        <span class="section-tag">Our Purpose</span>
        <h2 class="section-title">Creating jobs and affordable housing <span class="section-span">through modular innovation worldwide</span></h2>
        <p class="mission-lead">
          GMP's mission is to create jobs in underserved areas and provide affordable housing worldwide — reducing project costs, delivering in shorter timeframes, reducing waste of materials, improving the quality of construction, reducing site disruption, improving worker safety, and minimizing carbon emissions from construction projects.
        </p>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value-card fade-up">
            <div class="value-card__icon" aria-hidden="true">
              {v.icon === 'spark' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M16 4l2 8 8 2-8 2-2 8-2-8-8-2 8-2 2-8z" />
                </svg>
              )}
              {v.icon === 'shield' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M16 4l10 4v8c0 6-4 11-10 12-6-1-10-6-10-12V8l10-4z" />
                </svg>
              )}
              {v.icon === 'star' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M16 6l3.5 7.5L28 15l-6 5.5L24 30l-8-4.5L8 30l2-9.5L4 15l8.5-1.5L16 6z" />
                </svg>
              )}
              {v.icon === 'leaf' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M6 26c8-2 14-8 16-16 0 8-6 14-14 16z" />
                  <path d="M6 26c4-10 12-14 20-14" />
                </svg>
              )}
              {v.icon === 'check' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M6 16l8 8 12-14" />
                </svg>
              )}
              {v.icon === 'globe' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <circle cx="16" cy="16" r="12" />
                  <path d="M4 16h24M16 4c3 4 3 20 0 24M16 4c-3 4-3 20 0 24" />
                </svg>
              )}
            </div>
            <h3 class="value-card__title">{v.title}</h3>
            <p class="value-card__desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Subsidiaries -->
  <section class="section-gap about-subs" id="subsidiaries">
    <div class="mnc-container">
      <div class="subs-header fade-up">
        <span class="section-tag">Portfolio</span>
        <h2 class="section-title">Subsidiaries &amp; partners <span class="section-span">integrated across every discipline</span></h2>
        <p class="subs-lead">Integrated capabilities across construction, manufacturing, emergency systems, and healthcare delivery.</p>
      </div>
      <div class="subs-grid">
        {subsidiaries.map((s) => (
          <article class="sub-card fade-up">
            <div class="sub-card__icon" aria-hidden="true">
              {s.icon === 'build' && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.75">
                  <rect x="6" y="22" width="36" height="20" rx="2" />
                  <path d="M10 22V14l14-8 14 8v8" />
                  <rect x="20" y="28" width="8" height="14" />
                </svg>
              )}
              {s.icon === 'globe' && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.75">
                  <circle cx="24" cy="24" r="18" />
                  <path d="M6 24h36M24 6c4 6 4 30 0 36M24 6c-4 6-4 30 0 36" />
                </svg>
              )}
              {s.icon === 'alert' && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M24 6L6 40h36L24 6z" />
                  <path d="M24 18v12M24 34h.01" stroke-linecap="round" />
                </svg>
              )}
            </div>
            <h3 class="sub-card__name">{s.name}</h3>
            <p class="sub-card__blurb">{s.blurb}</p>
            <ul class="sub-card__list">
              {s.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <article class="partner-card fade-up">
        <div class="partner-card__row">
          <span class="partner-card__badge">External Partner</span>
          <h3 class="partner-card__name">HWB — Hospitals Without Borders</h3>
        </div>
        <p class="partner-card__blurb">
          Humanitarian healthcare facilities, telemedicine, and rapid-deployment clinical infrastructure.
        </p>
        <ul class="partner-card__tags">
          <li>Healthcare Facilities</li>
          <li>Telemedicine</li>
          <li>Humanitarian</li>
        </ul>
      </article>
    </div>
  </section>

  <!-- Leadership -->
  <section class="section-gap about-leaders" id="leadership">
    <div class="mnc-container">
      <div class="leaders-header fade-up">
        <span class="section-tag">Team</span>
        <h2 class="section-title">Leadership <span class="section-span">guiding strategy and execution</span></h2>
        <p class="leaders-lead">Seasoned executives guiding strategy, operations, and financial performance.</p>
      </div>
      <div class="leaders-grid">
        {leadership.map((person) => (
          <article class="leader-card fade-up">
            <div class="leader-card__avatar" aria-hidden="true">
              <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="40" cy="28" r="14" />
                <path d="M12 72c0-15.5 12.5-28 28-28s28 12.5 28 28" />
              </svg>
            </div>
            <h3 class="leader-card__name">{person.name}</h3>
            <p class="leader-card__role">{person.role}</p>
            <p class="leader-card__bio">{person.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Board of Directors -->
  <section class="section-gap about-board" id="board">
    <div class="mnc-container">
      <div class="board-header fade-up">
        <span class="section-tag">Governance</span>
        <h2 class="section-title">Board of Directors <span class="section-span">providing strategic oversight</span></h2>
        <p class="board-lead">Strategic oversight spanning development, healthcare, defense, and international relations.</p>
      </div>
      <div class="board-grid">
        {board.map((member) => (
          <article class="board-card fade-up">
            <div class="board-card__initial" aria-hidden="true">{member.name.charAt(0)}</div>
            <h3 class="board-card__name">{member.name}</h3>
            <p class="board-card__role">{member.role}</p>
            <p class="board-card__focus">{member.focus}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section-gap about-timeline" id="history">
    <div class="mnc-container">
      <div class="timeline-header fade-up">
        <span class="section-tag">Heritage</span>
        <h2 class="section-title">Our timeline <span class="section-span">from founding to today</span></h2>
        <p class="timeline-lead">Key milestones from founding through today's programs and partnerships.</p>
      </div>
      <div class="timeline-track">
        {timeline.map((item, i) => (
          <div class:list={['timeline-item', 'fade-up', { 'timeline-item--right': i % 2 === 1 }]}>
            <div class="timeline-item__marker" aria-hidden="true" />
            <div class="timeline-item__panel">
              <span class="timeline-item__year">{item.year}</span>
              <p class="timeline-item__event">{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="section-gap about-awards">
    <div class="mnc-container">
      <div class="awards-rail fade-up" role="list">
        {awards.map((a) => (
          <div class="awards-item" role="listitem">
            <span class="awards-item__year">{a.year}</span>
            <span class="awards-item__divider" aria-hidden="true" />
            <span class="awards-item__title">{a.title}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-gap about-cta">
    <div class="mnc-container">
      <div class="cta-inner fade-up">
        <h2 class="cta-title">Partner with us</h2>
        <p class="cta-sub">
          Whether you are scaling modular capacity, supporting mission-critical facilities, or exploring new markets, our
          team is ready to align capabilities with your objectives.
        </p>
        <div class="cta-actions">
          <a href="/contact" class="mnc-btn mnc-btn--dark" style="background: var(--amber); border-color: var(--amber); color: var(--navy);">
            Start a Conversation
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg></span>
          </a>
          <a href="/services" class="mnc-btn mnc-btn--stroke">
            Explore Services
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg"><path d="M12.78 18.4s6.13-4.52 6.13-6.13S12.78 6.13 12.78 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/><path d="M5.62 18.4s6.13-4.52 6.13-6.13S5.62 6.13 5.62 6.13" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Shared MNC tokens ── */
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag {
    display: inline-block;
    border: 1px solid var(--amber);
    border-radius: 4px;
    padding: 4px 16px;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--amber-dark);
    margin-bottom: 20px;
  }
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin-bottom: 20px;
  }
  .section-span { color: var(--amber); }
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px;
    border: 1px solid var(--navy);
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .mnc-btn--dark { background: var(--amber); border-color: var(--amber); color: var(--navy); font-weight: 700; }
  .mnc-btn--dark:hover { background: var(--amber-dark); border-color: var(--amber-dark); color: var(--white); box-shadow: 0 4px 16px rgba(224,161,53,.35); }
  .mnc-btn--outline { background: transparent; color: var(--navy); }
  .mnc-btn--outline:hover { background: var(--navy); color: var(--white); }
  .mnc-btn--stroke { background: transparent; border-color: rgba(255,255,255,.4); color: var(--white); }
  .mnc-btn--stroke:hover { border-color: var(--amber); color: var(--amber); background: rgba(224,161,53,.08); }
  .mnc-btn__icon { display: flex; width: 20px; height: 20px; }
  .mnc-btn__icon svg { width: 100%; height: 100%; }

  /* ── Hero Banner ── */
  .hero-wrap { padding: 16px; }
  .hero-inner {
    height: 560px;
    border-radius: 8px;
    background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }
  .hero-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 1; padding: 120px 1.5rem 60px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,.5);
    margin-bottom: 20px;
  }
  .breadcrumb a { color: rgba(255,255,255,.5); }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-wrap .section-tag { border-color: var(--amber); color: var(--amber); }
  .hero-title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--white);
    max-width: 700px;
    margin-bottom: 16px;
  }
  .hero-sub {
    color: rgba(255,255,255,.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 32px;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ── Mission ── */
  .about-mission { background: var(--white); }
  .mission-header { max-width: 720px; margin-bottom: 48px; }
  .mission-lead {
    font-size: 18px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
  }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .value-card {
    background: var(--off-white);
    border-radius: 8px;
    padding: 24px;
  }
  .value-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background: linear-gradient(145deg, rgba(224,161,53,.12), rgba(36,55,85,.06));
    color: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .value-card__icon svg { width: 22px; height: 22px; }
  .value-card__title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin-bottom: 6px;
  }
  .value-card__desc {
    font-size: 15px;
    line-height: 1.55;
    color: var(--text-gray);
    margin: 0;
  }

  @media (max-width: 768px) {
    .values-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .values-grid { grid-template-columns: 1fr; }
  }

  /* ── Subsidiaries ── */
  .about-subs { background: var(--off-white); }
  .subs-header { max-width: 720px; margin-bottom: 48px; }
  .subs-lead {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-gray);
    margin: 0;
  }
  .subs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 20px;
  }
  .sub-card {
    background: var(--white);
    border-radius: 8px;
    padding: 32px 24px;
    border: 1px solid rgba(0,0,0,.04);
  }
  .sub-card__icon {
    width: 52px;
    height: 52px;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .sub-card__icon svg { width: 100%; height: 100%; }
  .sub-card__name {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin-bottom: 8px;
  }
  .sub-card__blurb {
    font-size: 15px;
    color: var(--text-gray);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .sub-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sub-card__list li {
    position: relative;
    padding: 5px 0 5px 20px;
    font-size: 14px;
    color: var(--dark-text);
  }
  .sub-card__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
  }

  .partner-card {
    background: var(--white);
    border-radius: 8px;
    padding: 32px 24px;
    border: 2px solid var(--amber);
  }
  .partner-card__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .partner-card__badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--navy);
    background: rgba(224,161,53,.2);
    padding: 4px 12px;
    border-radius: 4px;
  }
  .partner-card__name {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0;
  }
  .partner-card__blurb {
    font-size: 15px;
    color: var(--text-gray);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .partner-card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .partner-card__tags li {
    font-size: 13px;
    padding: 4px 14px;
    border: 1px solid var(--medium-gray);
    border-radius: 4px;
    color: var(--dark-text);
  }

  @media (max-width: 960px) {
    .subs-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .subs-grid { grid-template-columns: 1fr; }
  }

  /* ── Leadership ── */
  .about-leaders { background: var(--white); }
  .leaders-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 48px;
  }
  .leaders-lead {
