---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const articles = [
  {
    date: 'March 2026',
    category: 'Sustainability',
    title: 'The Road to Net-Zero: Modular Sustainability',
    excerpt:
      'How factory-controlled builds, material optimization, and logistics discipline stack up to measurable carbon reductions across the project lifecycle.',
    href: '#',
  },
  {
    date: 'Feb 2026',
    category: 'Government',
    title: 'DoD Procurement: What You Need to Know',
    excerpt:
      'A practical overview of requirements, small-business pathways, and documentation that primes and subs expect on defense-adjacent modular programs.',
    href: '#',
  },
  {
    date: 'Jan 2026',
    category: 'Partnership',
    title: 'HWB Partnership Expands Healthcare Reach',
    excerpt:
      'Modular clinics and humanitarian infrastructure gain momentum as GMP and Hospitals Without Borders align delivery models for underserved regions.',
    href: '#',
  },
  {
    date: 'Dec 2025',
    category: 'Innovation',
    title: '28-Day ADU: Revolutionizing Home Construction',
    excerpt:
      'Inside the program compressing design, permitting support, and factory build into a predictable timeline for accessory dwelling units.',
    href: '#',
  },
  {
    date: 'Nov 2025',
    category: 'Industry',
    title: 'Modular Construction Trends in 2026',
    excerpt:
      'From data-rich prefab to integrated MEP: the signals procurement teams and developers are watching in the year ahead.',
    href: '#',
  },
  {
    date: 'Oct 2025',
    category: 'DoD',
    title: 'SDVOSB Certification: What It Means for Contractors',
    excerpt:
      'Why SDVOSB status matters for set-asides, teaming, and compliance—and how to evaluate partners with verified credentials.',
    href: '#',
  },
];
---

<Layout
  title="News & Insights"
  description="Industry updates, company announcements, and expert analysis from Global Modular Partners."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <span>News & Insights</span>
        </nav>
        <h1 class="hero-title fade-up">Latest News &amp;<br />Industry Insights</h1>
        <p class="hero-sub fade-up">Stay informed with company updates, project milestones, and trends shaping the future of modular construction.</p>
        <div class="hero-actions fade-up">
          <a href="#articles" class="mnc-btn mnc-btn--dark">
            Latest articles
            <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
          </a>
          <a href="#subscribe" class="mnc-btn mnc-btn--stroke">
            Get updates
            <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- Articles -->
  <section id="articles" class="news-articles section-gap">
    <div class="mnc-container">
      <div class="news-articles__head">
        <span class="section-tag">Editorial</span>
        <h2 class="section-title">Selected perspectives <span class="section-span">for leaders in government and development</span></h2>
      </div>

      <div class="news-articles__grid">
        {articles.map((article) => (
          <article class="nc">
            <div class="nc__img">
              <div class="nc__img-shine" aria-hidden="true"></div>
              <span class="nc__date">{article.date}</span>
            </div>
            <div class="nc__body">
              <span class="nc__cat">{article.category}</span>
              <div class="nc__divider"></div>
              <h3 class="nc__title"><a href={article.href}>{article.title}</a></h3>
              <p class="nc__excerpt">{article.excerpt}</p>
              <a href={article.href} class="nc__more">Read more &rarr;</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Subscribe -->
  <section id="subscribe" class="news-subscribe section-gap">
    <div class="mnc-container">
      <div class="news-subscribe__panel">
        <div class="news-subscribe__left">
          <h2 class="section-title" style="font-size:clamp(24px,3vw,36px);">Subscribe for insights</h2>
          <p class="news-subscribe__desc">
            Receive quarterly industry briefs, program announcements, and compliance-relevant
            updates. Tell us your sector—we'll tailor what you see.
          </p>
        </div>
        <div class="news-subscribe__right">
          <a href="/contact" class="mnc-btn mnc-btn--dark">
            <span class="mnc-btn__wrap">
              <span>Subscribe via contact</span>
              <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
            </span>
          </a>
          <p class="news-subscribe__note">
            Prefer email? Use the contact form and mention "newsletter" in your message.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Hero ── */
  .hero-wrap { padding: 0; }
  .hero-inner {
    height: 560px;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }
  .hero-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 120px 1.5rem 60px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px));
    width: 100%;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,.5);
    margin-bottom: 20px;
  }
  .breadcrumb a {
    color: rgba(255,255,255,.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-wrap .section-tag { color: rgba(255,255,255,.6); }
  .hero-wrap .section-tag::before { background: var(--amber); }
  .hero-title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--white);
    max-width: 700px;
    margin-bottom: 16px;
  }
  .hero-sub {
    color: rgba(255,255,255,.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 32px;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ── MNC Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    font-family: var(--font-primary);
    font-size: 15px;
    font-weight: 600;
    border-radius: 4px;
    text-decoration: none;
    transition: all 200ms ease;
    cursor: pointer;
    border: 1px solid transparent;
    line-height: 1;
  }
  .mnc-btn__wrap {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .mnc-btn__icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
    transition: transform 200ms ease;
  }
  .mnc-btn__icon svg {
    width: 100%;
    height: 100%;
  }
  .mnc-btn:hover .mnc-btn__icon {
    transform: translateX(3px);
  }
  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border-color: var(--amber);
    font-weight: 700;
  }
  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }
  .mnc-btn--outline {
    background: transparent;
    border-color: var(--navy);
    color: var(--navy);
  }
  .mnc-btn--outline:hover {
    background: var(--navy);
    color: #fff;
  }
  .mnc-btn--stroke {
    background: transparent;
    border-color: rgba(255,255,255,.3);
    color: #fff;
  }
  .mnc-btn--stroke:hover {
    border-color: var(--amber);
    color: var(--amber);
  }

  /* ── Container & Section ── */
  .mnc-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .section-gap {
    padding: 100px 0;
  }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin-bottom: 0;
  }
  .section-span {
    color: var(--amber);
  }

  /* ── Articles Section ── */
  .news-articles {
    background: #fff;
  }
  .news-articles__head {
    text-align: center;
    margin-bottom: 64px;
  }
  .news-articles__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 1024px) {
    .news-articles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .news-articles__grid {
      grid-template-columns: 1fr;
    }
    .section-gap {
      padding: 64px 0;
    }
  }

  /* ── Article Card (nc) ── */
  .nc {
    display: flex;
    flex-direction: column;
    transition: transform 300ms ease, box-shadow 300ms ease;
  }
  .nc:hover {
    transform: translateY(-4px);
  }
  .nc__img {
    position: relative;
    height: 200px;
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 50%, var(--navy-light) 100%);
    border-radius: 0;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 16px;
  }
  .nc__img-shine {
    position: absolute;
    inset: -40%;
    background: radial-gradient(ellipse at 30% 25%, rgba(224,161,53,.2) 0%, transparent 55%);
  }
  .nc__date {
    position: relative;
    z-index: 1;
    font-size: 13px;
    color: rgba(255,255,255,.6);
  }
  .nc__body {
    position: relative;
    background: #fff;
    border: 1px solid #dedede;
    border-top: none;
    border-radius: 0;
    padding: 24px;
    margin-top: -16px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 12px;
  }
  .nc__cat {
    display: inline-block;
    width: fit-content;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--navy);
    background: var(--off-white);
    border-radius: 4px;
  }
  .nc__divider {
    border-top: 1px dashed #dedede;
  }
  .nc__title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--dark-text);
    margin: 0;
  }
  .nc__title a {
    color: inherit;
    text-decoration: none;
    transition: text-decoration-color 200ms ease;
  }
  .nc__title a:hover {
    text-decoration: underline;
    text-decoration-color: var(--amber);
    text-underline-offset: 3px;
    color: var(--dark-text);
  }
  .nc__excerpt {
    flex: 1;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
    margin: 0;
  }
  .nc__more {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--navy);
    transition: color 200ms ease;
  }
  .nc__more:hover {
    color: var(--amber);
  }

  /* ── Subscribe Section ── */
  .news-subscribe {
    background: var(--off-white);
  }
  .news-subscribe__panel {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
    background: #fff;
    border-radius: 8px;
    border: 1px solid #dedede;
    padding: 48px 56px;
    max-width: 960px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .hero-inner { height: 480px; }
    .hero-content { padding: 80px 1.5rem 40px; }
    .news-subscribe__panel {
      grid-template-columns: 1fr;
      padding: 32px 24px;
      gap: 32px;
    }
  }
  .news-subscribe__desc {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
    margin: 16px 0 0;
  }
  .news-subscribe__right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }
  .news-subscribe__note {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-gray);
    margin: 0;
    max-width: 280px;
  }
  @media (max-width: 768px) {
    .news-subscribe__right {
      align-items: stretch;
    }
    .news-subscribe__right .mnc-btn {
      justify-content: center;
    }
    .news-subscribe__note {
      max-width: none;
    }
  }
</style>
