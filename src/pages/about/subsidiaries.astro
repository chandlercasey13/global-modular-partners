---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const subsidiaries = [
  {
    name: 'Agbayani Construction',
    role: 'General Contractor',
    description: 'Full-service general contracting across modular and civil construction programs. Agbayani handles everything from site preparation and foundation work to final assembly and turnover, bringing decades of field experience to every GMP project.',
    capabilities: ['Commercial & Residential Modular', 'Civil Infrastructure', 'Design-Build Services', 'Site Preparation & Foundations', 'Government & DoD Projects'],
  },
  {
    name: 'RI Group USA',
    role: 'Manufacturing Partner',
    description: 'International modular construction expertise connecting GMP to advanced manufacturing facilities and global supply chains. RI Group brings European precision engineering and quality standards to the American modular market.',
    capabilities: ['Modular Manufacturing', 'International Supply Chain', 'Quality Assurance', 'HSS Steel Frame Systems', 'Factory Production Management'],
  },
  {
    name: 'EDIS',
    role: 'Early Warning & Preparedness',
    description: 'Early warning systems and disaster preparedness technology for emergency management agencies.',
    capabilities: ['Early Warning Systems', 'Disaster Preparedness', 'Emergency Management Technology', 'Risk Monitoring & Alerts', 'Agency-Ready Solutions'],
  },
];

const partner = {
  name: 'HWB — Hospitals Without Borders',
  description: 'Humanitarian healthcare facilities, telemedicine platforms, and rapid-deployment clinical infrastructure serving communities worldwide. Through our partnership with HWB, GMP extends modular construction into global health, delivering fully equipped clinics and hospitals to underserved regions.',
  focus: ['Healthcare Facilities', 'Telemedicine', 'Humanitarian Aid', 'Pediatric Clinics', 'Remote Diagnostics'],
};
---

<Layout
  title="Subsidiaries — About"
  description="GMP's subsidiary companies: Agbayani Construction, RI Group USA, and EDIS (early warning and disaster preparedness) — delivering integrated modular construction capabilities."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <a href="/about">About Us</a>
          <span class="breadcrumb__sep">/</span>
          <span>Subsidiaries</span>
        </nav>
        <h1 class="hero-title fade-up">Our Subsidiary<br />Companies</h1>
        <p class="hero-sub fade-up">Integrated capabilities across construction, manufacturing, emergency systems, and healthcare delivery.</p>
        <div class="hero-actions fade-up">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/about" class="mnc-btn mnc-btn--stroke">
            About Overview
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section-gap sub-overview">
    <div class="mnc-container">
      <div class="overview-header fade-up">
        <span class="section-tag">Portfolio</span>
        <h2 class="section-title">Companies working together <span class="section-span">across every discipline</span></h2>
      </div>
      <p class="overview-body fade-up">
        GMP's subsidiary network provides end-to-end coverage across the construction lifecycle. From general contracting and modular manufacturing to emergency response systems, each company brings specialized expertise that integrates seamlessly into a unified delivery model.
      </p>
    </div>
  </section>

  <!-- Subsidiary Cards -->
  <section class="section-gap sub-cards">
    <div class="mnc-container">
      <div class="sub-cards__header fade-up">
        <span class="section-tag">Subsidiaries</span>
        <h2 class="section-title">What we bring <span class="section-span">to the table</span></h2>
      </div>
      <div class="sub-cards__grid">
        {subsidiaries.map((s) => (
          <article class="sub-card fade-up">
            <span class="sub-card__role">{s.role}</span>
            <h3 class="sub-card__name">{s.name}</h3>
            <p class="sub-card__desc">{s.description}</p>
            <ul class="sub-card__list">
              {s.capabilities.map((c) => (
                <li>{c}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- External Partner -->
  <section class="section-gap sub-partner">
    <div class="mnc-container">
      <div class="partner-header fade-up">
        <span class="section-tag">External Partner</span>
        <h2 class="section-title">Healthcare through <span class="section-span">global partnerships</span></h2>
      </div>
      <article class="partner-card fade-up">
        <h3 class="partner-card__name">{partner.name}</h3>
        <p class="partner-card__desc">{partner.description}</p>
        <ul class="partner-card__tags">
          {partner.focus.map((f) => (
            <li>{f}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-gap sub-cta">
    <div class="mnc-container">
      <div class="cta-inner fade-up">
        <h2 class="cta-title">Explore our capabilities</h2>
        <p class="cta-sub">See how GMP's subsidiaries and partners deliver integrated construction, manufacturing, and emergency-preparedness solutions.</p>
        <div class="cta-actions">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/partners" class="mnc-btn mnc-btn--stroke">
            View Partners
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 2.5px; color: var(--amber); margin-bottom: 20px; padding: 0; border: none; border-radius: 0; }
  .section-tag::before { content: ''; display: inline-block; width: 24px; height: 2px; background: var(--amber); flex-shrink: 0; }
  .section-title { font-family: var(--font-secondary); font-size: clamp(32px, 4vw, 52px); line-height: 1.2; font-weight: 500; color: var(--dark-text); margin-bottom: 20px; }
  .section-span { color: var(--amber); }
  .mnc-btn { display: inline-flex; align-items: center; gap: 10px; padding: 16px; border: 1px solid var(--navy); border-radius: 4px; font-size: 16px; font-weight: 600; text-decoration: none; transition: all 0.25s ease; }
  .mnc-btn--dark { background: var(--amber); border-color: var(--amber); color: var(--navy); font-weight: 700; }
  .mnc-btn--dark:hover { background: var(--amber-dark); border-color: var(--amber-dark); color: var(--white); box-shadow: 0 4px 16px rgba(224,161,53,.35); }
  .mnc-btn--stroke { background: transparent; border-color: rgba(255,255,255,.4); color: var(--white); }
  .mnc-btn--stroke:hover { border-color: var(--amber); color: var(--amber); background: rgba(224,161,53,.08); }
  .mnc-btn__icon { display: flex; width: 20px; height: 20px; }
  .mnc-btn__icon svg { width: 100%; height: 100%; }

  /* Hero */
  .hero-wrap { padding: 16px; }
  .hero-inner { height: 560px; border-radius: 8px; background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); display: flex; align-items: flex-end; position: relative; overflow: hidden; }
  .hero-inner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%); pointer-events: none; }
  .hero-content { position: relative; z-index: 1; padding: 120px 1.5rem 60px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
  .breadcrumb a { color: rgba(255,255,255,.5); text-decoration: none; }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-title { font-family: var(--font-secondary); font-size: clamp(36px, 5vw, 56px); font-weight: 600; line-height: 1.15; color: var(--white); max-width: 700px; margin-bottom: 16px; }
  .hero-sub { color: rgba(255,255,255,.65); font-size: 18px; line-height: 1.7; max-width: 560px; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Overview */
  .sub-overview { background: var(--white); }
  .overview-header { max-width: 720px; margin-bottom: 24px; }
  .overview-body { font-size: 18px; line-height: 1.75; color: var(--text-gray); max-width: 800px; margin: 0; }

  /* Subsidiary Cards */
  .sub-cards { background: var(--off-white); }
  .sub-cards__header { max-width: 720px; margin-bottom: 48px; }
  .sub-cards__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .sub-card { background: var(--white); border-radius: 8px; padding: 32px 24px; border: 1px solid rgba(0,0,0,.04); }
  .sub-card__role { display: inline-block; font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--amber-dark); background: rgba(224,161,53,.12); padding: 4px 12px; border-radius: 4px; margin-bottom: 16px; }
  .sub-card__name { font-family: var(--font-secondary); font-size: 22px; font-weight: 600; color: var(--dark-text); margin-bottom: 12px; }
  .sub-card__desc { font-size: 15px; color: var(--text-gray); line-height: 1.65; margin-bottom: 20px; }
  .sub-card__list { list-style: none; padding: 0; margin: 0; }
  .sub-card__list li { position: relative; padding: 5px 0 5px 20px; font-size: 14px; color: var(--dark-text); }
  .sub-card__list li::before { content: ''; position: absolute; left: 0; top: 12px; width: 6px; height: 6px; border-radius: 50%; background: var(--amber); }

  /* External Partner */
  .sub-partner { background: var(--white); }
  .partner-header { max-width: 720px; margin-bottom: 32px; }
  .partner-card { background: var(--off-white); border-radius: 8px; padding: 40px 32px; border: 2px solid var(--amber); max-width: 800px; }
  .partner-card__name { font-family: var(--font-secondary); font-size: 22px; font-weight: 600; color: var(--dark-text); margin-bottom: 12px; }
  .partner-card__desc { font-size: 16px; color: var(--text-gray); line-height: 1.7; margin-bottom: 20px; }
  .partner-card__tags { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .partner-card__tags li { font-size: 13px; padding: 6px 14px; border: 1px solid var(--medium-gray); border-radius: 4px; color: var(--dark-text); }

  /* CTA */
  .sub-cta { background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); position: relative; overflow: hidden; }
  .sub-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 80% 20%, rgba(224,161,53,.1), transparent), radial-gradient(ellipse 60% 50% at 10% 90%, rgba(0,0,0,.12), transparent); pointer-events: none; }
  .cta-inner { position: relative; z-index: 1; text-align: center; max-width: 680px; margin: 0 auto; }
  .cta-title { font-family: var(--font-secondary); font-size: clamp(28px, 3.5vw, 44px); font-weight: 600; color: var(--white); margin-bottom: 16px; }
  .cta-sub { color: rgba(255,255,255,.65); font-size: 17px; line-height: 1.7; margin-bottom: 32px; }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

  @media (max-width: 960px) { .sub-cards__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .section-gap { padding: 60px 0; }
    .hero-inner { height: 480px; }
    .hero-content { padding: 80px 1.5rem 40px; }
  }
  @media (max-width: 640px) { .sub-cards__grid { grid-template-columns: 1fr; } }
</style>
