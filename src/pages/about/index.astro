---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const leadership = [
  { name: 'Fuad Sweiss', role: 'Founder & CEO', bio: 'Founded GMP in 2019 to advance modular construction globally' },
];

const board = [
  { name: 'Robert Bilbeisi', role: 'Board Chairman', focus: 'International Development' },
  { name: 'Dr. Maria Carranza', role: 'Board Member', focus: 'Healthcare Systems' },
  { name: 'James Siri', role: 'Board Member', focus: 'Defense Contracting' },
  { name: 'Amb. Ahmed Bulgherini', role: 'Board Member', focus: 'International Relations' },
];

const timeline = [
  { year: '2019', event: 'GMP founded by Fuad Sweiss in the San Francisco Bay Area' },
  { year: '2020', event: 'Agbayani Construction partnership established' },
  { year: '2021', event: 'RI Group USA collaboration launched' },
  { year: '2022', event: 'Irvine, CA office opened for Southern California operations' },
  { year: '2023', event: 'HWB healthcare partnership initiated' },
  { year: '2024', event: 'Trade partner network expanded to 10+ firms' },
  { year: '2025', event: '28-Day ADU program introduced' },
];
---

<Layout
  title="About Us"
  description="Mission, subsidiaries, leadership, and history of Global Modular Partners — modular construction for government, healthcare, and commercial sectors."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="ab-hero">
    <div class="ab-hero__inner">
      <div class="ab-hero__overlay"></div>
      <img src="/images/showcase/west-factory.jpg" alt="Factory floor" class="ab-hero__bg" />
      <div class="ab-hero__content">
        <span class="ab-hero__tag">Industrial Authority</span>
        <h1 class="ab-hero__h1">The Architectural<br/>Authority in<br/>Modular Engineering</h1>
        <p class="ab-hero__sub">
          Redefining the built environment of global infrastructure through precision modular assembly and partnership-driven engineering innovation.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ 2. LEGACY ════════ -->
  <section class="ab-legacy">
    <div class="mnc-container">
      <div class="ab-legacy__layout fade-up">
        <div class="ab-legacy__left">
          <span class="ab-tag">Heritage &amp; History</span>
          <h2 class="ab-legacy__title">A Legacy Forged in Precision.</h2>
          <p class="ab-legacy__body">
            For five years, Global Modular Partners has positioned itself as the definitive force in modern modular construction. What began as a specialized joint venture has evolved to become the global hub of modular engineering.
          </p>
          <p class="ab-legacy__body">
            Our legacy is defined by the refusal to compromise on standards or timelines. Where others see obstacles and delays, we see opportunity to innovate and outperform — selecting the right team for each project based on location, scope, and compliance requirements.
          </p>
          <div class="ab-legacy__stats">
            <div class="ab-legacy__stat">
              <span class="ab-legacy__stat-num">40+</span>
              <span class="ab-legacy__stat-label">Projects Delivered</span>
            </div>
            <div class="ab-legacy__stat">
              <span class="ab-legacy__stat-num">2.4k</span>
              <span class="ab-legacy__stat-label">Modular Units Produced</span>
            </div>
          </div>
        </div>
        <div class="ab-legacy__right">
          <div class="ab-legacy__img-wrap">
            <img src="/images/showcase/ri-modular-units.jpg" alt="Precision modular units" class="ab-legacy__img" loading="lazy" />
          </div>
          <div class="ab-legacy__badge">
            <span class="ab-legacy__badge-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </span>
            <div>
              <span class="ab-legacy__badge-title">The GMP Standard</span>
              <span class="ab-legacy__badge-sub">Our partners are selected through a rigorous vetting process to ensure the highest quality standards.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 3. LEADERSHIP & VISION ════════ -->
  <section class="ab-vision">
    <div class="mnc-container">
      <div class="ab-vision__head fade-up">
        <span class="ab-tag">Corporate Philosophy</span>
        <h2 class="ab-vision__title">Leadership &amp; Vision</h2>
        <p class="ab-vision__sub">
          Our executive team and board bring decades of experience in construction, engineering, defense, and international development, focused on mission-critical modular delivery.
        </p>
      </div>

      <div class="ab-vision__cards">
        <div class="ab-vision__card fade-up">
          <span class="ab-vision__card-num">01</span>
          <h3 class="ab-vision__card-title">Architectural Authority</h3>
          <p class="ab-vision__card-desc">Every project begins with advanced BIM coordination, structural analysis, and compliance-first design that exceeds international standards.</p>
        </div>
        <div class="ab-vision__card fade-up">
          <span class="ab-vision__card-num">02</span>
          <h3 class="ab-vision__card-title">Scalable Dominance</h3>
          <p class="ab-vision__card-desc">Our multi-manufacturer coordination model lets us scale from single-unit deployments to campus-scale programs without sacrificing precision.</p>
        </div>
        <div class="ab-vision__card fade-up">
          <span class="ab-vision__card-num">03</span>
          <h3 class="ab-vision__card-title">Global Citizenship</h3>
          <p class="ab-vision__card-desc">Through HWB and our international partners, we deliver modular medical and civil infrastructure to underserved communities worldwide.</p>
        </div>
      </div>

      <div class="ab-team">
        <div class="ab-team__header fade-up">
          <h3 class="ab-team__title">Executive Team &amp; Board</h3>
        </div>
        <div class="ab-team__grid">
          <div class="ab-team__member fade-up">
            <div class="ab-team__avatar"><span>FS</span></div>
            <div>
              <h4 class="ab-team__name">Fuad Sweiss</h4>
              <span class="ab-team__role">Founder & CEO</span>
              <p class="ab-team__bio">Founded GMP in 2019 to advance modular construction globally.</p>
            </div>
          </div>
          {board.map((m) => (
            <div class="ab-team__member fade-up">
              <div class="ab-team__avatar"><span>{m.name.charAt(0)}{m.name.split(' ')[1]?.charAt(0)}</span></div>
              <div>
                <h4 class="ab-team__name">{m.name}</h4>
                <span class="ab-team__role">{m.role}</span>
                <p class="ab-team__bio">{m.focus}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 4. FACILITY SHOWCASE ════════ -->
  <section class="ab-facility">
    <div class="ab-facility__inner">
      <img src="/images/showcase/ri-factory-panorama.jpg" alt="Manufacturing facility panorama" class="ab-facility__bg" loading="lazy" />
      <div class="ab-facility__overlay"></div>
      <div class="ab-facility__content fade-up">
        <h2 class="ab-facility__h2">500,000<br/>Sq. Ft.<br/>Facility</h2>
        <p class="ab-facility__desc">
          Combined manufacturing capacity across our partner network — automated production lines, quality labs, and staging areas delivering turnkey modular components at scale.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ 5. GLOBAL FOOTPRINT ════════ -->
  <section class="ab-footprint">
    <div class="mnc-container">
      <div class="ab-footprint__layout fade-up">
        <div class="ab-footprint__left">
          <span class="ab-tag">Our Presence</span>
          <h2 class="ab-footprint__title">Global Footprint</h2>

          <div class="ab-footprint__locs">
            <div class="ab-footprint__loc">
              <h4 class="ab-footprint__loc-title">Primary Command Center</h4>
              <p class="ab-footprint__loc-desc">Located in the heart of the San Francisco Bay Area, our headquarters direct the strategic allocation of our global engineering services.</p>
              <span class="ab-footprint__loc-addr">1630 San Pablo Ave, Oakland, CA 94612</span>
            </div>
            <div class="ab-footprint__loc">
              <h4 class="ab-footprint__loc-title">Regional Presence</h4>
              <p class="ab-footprint__loc-desc">Our West Modular and RI Group partners in San Diego, CA and Lecce, Italy drive manufacturing and international supply chain operations.</p>
              <span class="ab-footprint__loc-addr">San Diego, CA · Lecce, Italy · Amman, Jordan</span>
            </div>
          </div>
        </div>
        <div class="ab-footprint__right">
          <img src="/images/showcase/ri-permanent-building.jpg" alt="Modular building installation" class="ab-footprint__img" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 6. TIMELINE ════════ -->
  <section class="ab-timeline">
    <div class="mnc-container">
      <div class="ab-timeline__head fade-up">
        <span class="ab-tag">Milestones</span>
        <h2 class="ab-timeline__title">From Founding to Today</h2>
      </div>
      <div class="ab-timeline__track">
        {timeline.map((item) => (
          <div class="ab-timeline__item fade-up">
            <span class="ab-timeline__year">{item.year}</span>
            <span class="ab-timeline__dot"></span>
            <p class="ab-timeline__event">{item.event}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ 7. CTA ════════ -->
  <section class="ab-cta">
    <div class="mnc-container">
      <div class="ab-cta__inner fade-up">
        <h2 class="ab-cta__title">Explore our capabilities</h2>
        <p class="ab-cta__sub">From modular delivery and manufacturing partnerships to mission-critical programs.</p>
        <div class="ab-cta__actions">
          <a href="/services" class="ab-cta__btn ab-cta__btn--primary">View Our Work</a>
          <a href="/contact" class="ab-cta__btn ab-cta__btn--outline">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }

  .ab-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .ab-tag::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* ═══ 1. HERO ═══ */
  .ab-hero__inner {
    position: relative;
    height: 620px;
    overflow: hidden;
    background: var(--navy-dark);
  }

  .ab-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
  }

  .ab-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(30,58,102,.6) 0%, rgba(30,58,102,.9) 100%);
    z-index: 1;
  }

  .ab-hero__content {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ab-hero__tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
    margin-bottom: 20px;
  }

  .ab-hero__h1 {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.95;
    color: var(--white);
    letter-spacing: -1px;
    margin-bottom: 24px;
  }

  .ab-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,.5);
    max-width: 520px;
    margin: 0;
  }

  /* ═══ 2. LEGACY ═══ */
  .ab-legacy {
    background: var(--white);
    padding: 100px 0;
  }

  .ab-legacy__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .ab-legacy__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    font-style: italic;
    color: var(--dark-text);
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .ab-legacy__body {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-gray);
    margin-bottom: 16px;
  }

  .ab-legacy__stats {
    display: flex;
    gap: 48px;
    margin-top: 32px;
  }

  .ab-legacy__stat { display: flex; flex-direction: column; gap: 4px; }

  .ab-legacy__stat-num {
    font-family: var(--font-secondary);
    font-size: 40px;
    font-weight: 900;
    color: var(--dark-text);
    line-height: 1;
  }

  .ab-legacy__stat-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-gray);
  }

  .ab-legacy__right { position: relative; }

  .ab-legacy__img-wrap {
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .ab-legacy__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ab-legacy__badge {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    background: var(--navy);
    border-radius: 8px;
    padding: 20px;
    margin-top: -48px;
    margin-left: 24px;
    margin-right: 24px;
    position: relative;
    z-index: 2;
  }

  .ab-legacy__badge-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    color: var(--amber);
  }
  .ab-legacy__badge-icon svg { width: 100%; height: 100%; }

  .ab-legacy__badge-title {
    display: block;
    font-family: var(--font-secondary);
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }

  .ab-legacy__badge-sub {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255,255,255,.5);
  }

  /* ═══ 3. VISION ═══ */
  .ab-vision {
    background: var(--off-white);
    padding: 100px 0;
  }

  .ab-vision__head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 56px;
  }

  .ab-vision__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    font-style: italic;
    color: var(--dark-text);
    margin-bottom: 16px;
  }

  .ab-vision__sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
    margin: 0;
  }

  .ab-vision__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-bottom: 80px;
  }

  .ab-vision__card {
    padding: 40px 32px;
    background: var(--white);
    transition: box-shadow 0.3s ease;
  }
  .ab-vision__card:first-child { border-radius: 8px 0 0 8px; }
  .ab-vision__card:last-child { border-radius: 0 8px 8px 0; background: var(--navy); }
  .ab-vision__card:last-child .ab-vision__card-num { color: var(--amber); border-color: var(--amber); }
  .ab-vision__card:last-child .ab-vision__card-title { color: var(--white); }
  .ab-vision__card:last-child .ab-vision__card-desc { color: rgba(255,255,255,.55); }

  .ab-vision__card-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 700;
    color: var(--navy);
    border: 2px solid var(--navy);
    border-radius: 6px;
    margin-bottom: 24px;
  }

  .ab-vision__card-title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 12px;
  }

  .ab-vision__card-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-gray);
    margin: 0;
  }

  /* Team */
  .ab-team__header { margin-bottom: 32px; }

  .ab-team__title {
    font-family: var(--font-secondary);
    font-size: 24px;
    font-weight: 700;
    color: var(--dark-text);
  }

  .ab-team__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .ab-team__member {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--white);
    border-radius: 8px;
    padding: 24px;
    border: 1px solid rgba(0,0,0,.04);
  }

  .ab-team__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ab-team__name {
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 600;
    color: var(--dark-text);
    margin-bottom: 2px;
  }

  .ab-team__role {
    display: block;
    font-size: 12px;
    font-weight: 700;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .ab-team__bio {
    font-size: 13px;
    color: var(--text-gray);
    line-height: 1.5;
    margin: 0;
  }

  /* ═══ 4. FACILITY ═══ */
  .ab-facility__inner {
    position: relative;
    height: 500px;
    overflow: hidden;
  }

  .ab-facility__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ab-facility__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(30,58,102,.88) 0%, rgba(30,58,102,.4) 60%, transparent 100%);
    z-index: 1;
  }

  .ab-facility__content {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 480px;
    margin: 0;
    padding: 60px max(1.5rem, calc(50vw - 620px + 1.5rem));
  }

  .ab-facility__h2 {
    font-family: var(--font-secondary);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.95;
    color: var(--white);
    margin-bottom: 20px;
    font-style: italic;
  }

  .ab-facility__desc {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,.55);
    max-width: 400px;
    margin: 0;
  }

  /* ═══ 5. FOOTPRINT ═══ */
  .ab-footprint {
    background: var(--white);
    padding: 100px 0;
  }

  .ab-footprint__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .ab-footprint__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    font-style: italic;
    color: var(--dark-text);
    margin-bottom: 32px;
  }

  .ab-footprint__locs {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .ab-footprint__loc {
    padding-left: 16px;
    border-left: 3px solid var(--amber);
  }

  .ab-footprint__loc-title {
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 6px;
  }

  .ab-footprint__loc-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-gray);
    margin-bottom: 6px;
  }

  .ab-footprint__loc-addr {
    font-size: 12px;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: 0.5px;
  }

  .ab-footprint__right {
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .ab-footprint__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ═══ 6. TIMELINE ═══ */
  .ab-timeline {
    background: var(--off-white);
    padding: 100px 0;
  }

  .ab-timeline__head {
    text-align: center;
    margin-bottom: 56px;
  }

  .ab-timeline__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    font-style: italic;
    color: var(--dark-text);
    margin: 0;
  }

  .ab-timeline__track {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
  }

  .ab-timeline__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 1 140px;
    gap: 10px;
  }

  .ab-timeline__year {
    font-family: var(--font-secondary);
    font-size: 22px;
    font-weight: 900;
    color: var(--amber);
  }

  .ab-timeline__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--navy);
    box-shadow: 0 0 0 4px var(--off-white), 0 0 0 6px rgba(43,75,126,.2);
  }

  .ab-timeline__event {
    font-size: 13px;
    color: var(--dark-text);
    line-height: 1.45;
    margin: 0;
  }

  /* ═══ 7. CTA ═══ */
  .ab-cta {
    background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 50%, var(--navy-light) 100%);
    padding: 80px 0;
  }

  .ab-cta__inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .ab-cta__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }

  .ab-cta__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,.55);
    margin-bottom: 32px;
  }

  .ab-cta__actions {
    display: flex;
    gap: 12px;
