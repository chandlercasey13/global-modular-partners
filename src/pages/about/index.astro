---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const board = [
  { name: 'Robert Bilbeisi', role: 'Board Chairman', focus: 'International Development' },
  { name: 'Dr. Maria Carranza', role: 'Board Member', focus: 'Healthcare Systems' },
  { name: 'James Siri', role: 'Board Member', focus: 'Defense Contracting' },
  { name: 'Amb. Ahmed Bulgherini', role: 'Board Member', focus: 'International Relations' },
];

const timeline = [
  { year: '2019', event: 'GMP founded by Fuad Sweiss in the San Francisco Bay Area' },
  { year: '2020', event: 'Agbayani Construction partnership established' },
  { year: '2021', event: 'RI Group USA collaboration launched' },
  { year: '2022', event: 'Irvine, CA office opened for Southern California operations' },
  { year: '2023', event: 'HWB healthcare partnership initiated' },
  { year: '2024', event: 'Trade partner network expanded to 10+ firms' },
  { year: '2025', event: '28-Day ADU program introduced' },
];
---

<Layout
  title="About Us"
  description="Mission, subsidiaries, leadership, and history of Global Modular Partners — modular construction for government, healthcare, and commercial sectors."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO + MILESTONES ════════ -->
  <section class="ab-hero" aria-labelledby="ab-hero-heading">
    <div class="ab-hero__intro">
      <div class="ab-hero__intro-panel">
        <div class="ab-hero__intro-content fade-up">
          <h1 id="ab-hero-heading" class="ab-hero__h1">The Authority in<br/>Modular Engineering</h1>
          <p class="ab-hero__sub">
            Redefining the built environment of global infrastructure through precision modular assembly and partnership-driven engineering innovation.
          </p>
        </div>
      </div>
    </div>
    <div class="ab-hero__top">
      <div class="ab-hero__split mnc-container">
        <div class="ab-hero__split-left fade-up">
          <p class="ab-hero__split-eyebrow">Heritage &amp; History</p>
          <h2 class="ab-legacy__title">A Legacy Forged in Precision.</h2>
          <p class="ab-legacy__body">
            For five years, Global Modular Partners has positioned itself as the definitive force in modern modular construction. What began as a specialized joint venture has evolved to become the global hub of modular engineering.
          </p>
          <p class="ab-legacy__body">
            Our legacy is defined by the refusal to compromise on standards or timelines. Where others see obstacles and delays, we see opportunity to innovate and outperform — selecting the right team for each project based on location, scope, and compliance requirements.
          </p>
          <p class="ab-legacy__body">
            From Oakland and Irvine, we align Agbayani Construction, RI Group USA, Hospitals Without Borders, and EDIS USA around a single factory-to-field delivery chain. That network has delivered 40+ projects and 2,400+ modular units across three continents, with roughly 500,000 sq. ft. of combined partner manufacturing capacity.
          </p>
        </div>
        <div class="ab-hero__split-right fade-up">
          <img
            src="/images/showcase/ri-factory-production.jpg"
            alt="Modular manufacturing and steel frame assembly"
            class="ab-hero__photo"
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="ab-hero__timeline">
      <div class="mnc-container">
        <div class="ab-hero__timeline-scroll">
          <div class="ab-hero__timeline-row">
            <div class="ab-hero__timeline-line" aria-hidden="true"></div>
            {timeline.map((item) => (
              <div class="ab-hero__timeline-col fade-up">
                <span class="ab-hero__timeline-year">{item.year}</span>
                <span class="ab-hero__timeline-dot"></span>
                <p class="ab-hero__timeline-desc">{item.event}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 2. LEADERSHIP & VISION ════════ -->
  <section class="ab-vision">
    <div class="mnc-container">
      <div class="ab-vision__head fade-up">
        <span class="ab-tag">Corporate Philosophy</span>
        <h2 class="ab-vision__title">Leadership &amp; Vision</h2>
        <p class="ab-vision__sub">
          Our executive team and board bring decades of experience in construction, engineering, defense, and international development, focused on mission-critical modular delivery.
        </p>
      </div>

      <div class="ab-vision__cards">
        <div class="ab-vision__card fade-up">
          <span class="ab-vision__card-num">01</span>
          <h3 class="ab-vision__card-title">Architectural Authority</h3>
          <p class="ab-vision__card-desc">Every project begins with advanced BIM coordination, structural analysis, and compliance-first design that exceeds international standards.</p>
        </div>
        <div class="ab-vision__card fade-up">
          <span class="ab-vision__card-num">02</span>
          <h3 class="ab-vision__card-title">Scalable Dominance</h3>
          <p class="ab-vision__card-desc">Our multi-manufacturer coordination model lets us scale from single-unit deployments to campus-scale programs without sacrificing precision.</p>
        </div>
        <div class="ab-vision__card fade-up">
          <span class="ab-vision__card-num">03</span>
          <h3 class="ab-vision__card-title">Global Citizenship</h3>
          <p class="ab-vision__card-desc">Through HWB and our international partners, we deliver modular medical and civil infrastructure to underserved communities worldwide.</p>
        </div>
      </div>

      <div class="ab-team">
        <div class="ab-team__header fade-up">
          <h3 class="ab-team__title">Executive Team &amp; Board</h3>
        </div>
        <div class="ab-team__grid">
          <div class="ab-team__member fade-up">
            <div class="ab-team__avatar"><span>FS</span></div>
            <div>
              <h4 class="ab-team__name">Fuad Sweiss</h4>
              <span class="ab-team__role">Founder & CEO</span>
              <p class="ab-team__bio">Founded GMP in 2019 to advance modular construction globally.</p>
            </div>
          </div>
          {board.map((m) => (
            <div class="ab-team__member fade-up">
              <div class="ab-team__avatar"><span>{m.name.charAt(0)}{m.name.split(' ')[1]?.charAt(0)}</span></div>
              <div>
                <h4 class="ab-team__name">{m.name}</h4>
                <span class="ab-team__role">{m.role}</span>
                <p class="ab-team__bio">{m.focus}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1440px; margin: 0 auto; padding: 0 1.5rem; }

  .ab-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-bottom: 1rem;
  }
  .ab-tag::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--ink);
    flex-shrink: 0;
    border-radius: 0;
  }

  /* ═══ 1. HERO + MILESTONES ═══ */
  .ab-hero {
    position: relative;
    overflow: hidden;
  }

  /* Match homepage hero: white outer frame + rounded inner panel (no animation) */
  .ab-hero__intro {
    position: relative;
    background: #fff;
    padding: clamp(6px, 0.6vw, 10px);
  }

  .ab-hero__intro-panel {
    position: relative;
    height: 480px;
    overflow: hidden;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
    border-radius: clamp(14px, 1.6vw, 22px);
  }

  .ab-hero__intro-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
  }

  .ab-hero__intro-content {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .ab-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: none;
    letter-spacing: -2px;
    margin-bottom: 20px;
  }

  .ab-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    max-width: 520px;
    margin: 0;
  }

  .ab-hero__top {
    position: relative;
    z-index: 2;
    background: var(--paper);
    padding: clamp(48px, 8vw, 96px) 0 0;
  }

  .ab-hero__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 56px);
    align-items: center;
  }

  .ab-hero__split-left {
    min-width: 0;
    padding-bottom: clamp(20px, 3vw, 36px);
  }

  /* Label: Barlow + dash like .ab-tag; headline uses .ab-legacy__title (Sora italic) */
  .ab-hero__split-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .ab-hero__split-eyebrow::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--ink);
    flex-shrink: 0;
  }

  .ab-hero__split-left > .ab-legacy__title {
    margin-top: 0;
  }

  .ab-hero__split-left .ab-legacy__body:last-of-type {
    margin-bottom: 0;
  }

  .ab-hero__split-right {
    position: relative;
    min-width: 0;
  }

  .ab-hero__photo {
    display: block;
    width: 100%;
    border-radius: var(--radius-xl);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    box-shadow: var(--shadow-md);
    margin-bottom: clamp(-100px, -8vw, -48px);
  }

  .ab-hero__timeline {
    position: relative;
    z-index: 1;
    background: var(--paper);
    border-top: 1px solid var(--line);
    padding: clamp(80px, 11vw, 132px) 0 64px;
  }

  .ab-hero__timeline-scroll {
    overflow-x: auto;
    overflow-y: visible;
    -webkit-overflow-scrolling: touch;
    scrollbar-color: rgba(0, 0, 0, 0.22) transparent;
  }

  .ab-hero__timeline-row {
    display: flex;
    position: relative;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0;
    min-width: 100%;
    padding-top: 4px;
  }

  .ab-hero__timeline-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 2.45rem;
    height: 1px;
    background: var(--line);
    pointer-events: none;
  }

  .ab-hero__timeline-col {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 clamp(4px, 0.8vw, 10px);
  }

  .ab-hero__timeline-year {
    font-family: var(--font-mono);
    font-size: clamp(13px, 1.15vw, 16px);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    margin-bottom: 14px;
    line-height: 1.2;
    min-height: 1.2em;
  }

  .ab-hero__timeline-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ink);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    margin-bottom: 16px;
    box-shadow: 0 0 0 4px var(--paper);
  }

  .ab-hero__timeline-desc {
    font-size: clamp(11px, 0.85vw, 13px);
    line-height: 1.5;
    color: var(--muted);
    margin: 0;
    max-width: 13rem;
    hyphens: auto;
  }

  @media (max-width: 1100px) {
    .ab-hero__timeline-row {
      min-width: 880px;
    }
  }

  /* Hero split headline + body (classes reused from former legacy section) */
  .ab-legacy__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 600;
    font-style: normal;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .ab-legacy__body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  /* ═══ 2. VISION (aeline) ═══ */
  .ab-vision {
    background: var(--paper-2);
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(5rem, 10vw, 8rem);
  }

  .ab-vision__head {
    text-align: center;
    max-width: 52rem;
    margin: 0 auto 4rem;
  }

  .ab-vision__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.8vw, 52px);
    font-weight: 600;
    font-style: normal;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .ab-vision__sub {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  .ab-vision__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 5rem;
  }

  .ab-vision__card {
    padding: clamp(1.75rem, 3vw, 2.5rem);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .ab-vision__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: #d6d6d1;
  }
  .ab-vision__card:last-child {
    background: var(--ink);
    border-color: var(--ink);
  }
  .ab-vision__card:last-child .ab-vision__card-num {
    color: var(--on-ink);
    border-color: rgba(255,255,255,0.2);
  }
  .ab-vision__card:last-child .ab-vision__card-title { color: var(--on-ink); }
  .ab-vision__card:last-child .ab-vision__card-desc { color: var(--on-ink-muted); }

  .ab-vision__card-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
    background: var(--paper);
  }

  .ab-vision__card-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .ab-vision__card-desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  /* Team */
  .ab-team__header { margin-bottom: 2rem; }

  .ab-team__title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .ab-team__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .ab-team__member {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--paper);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    border: 1px solid var(--line);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .ab-team__member:hover {
    border-color: #d6d6d1;
    box-shadow: var(--shadow-sm);
  }

  .ab-team__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--on-ink);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ab-team__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .ab-team__role {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    margin-bottom: 0.5rem;
  }

  .ab-team__bio {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .ab-hero__split {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ab-vision__cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .ab-hero__intro {
      height: 380px;
    }

    .ab-hero__top {
      padding: 28px 0 0;
    }

    .ab-hero__photo {
      border-radius: 10px;
      aspect-ratio: 4 / 3;
    }

    .ab-hero__timeline {
      padding: 72px 0 48px;
    }

    .ab-vision {
      padding: 48px 0 64px;
    }

    .ab-team__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
