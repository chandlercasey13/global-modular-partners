---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const values = [
  { title: 'Innovation', desc: 'Advancing modular methods and digital delivery.', icon: 'spark' },
  { title: 'Integrity', desc: 'Transparent partnerships and accountable execution.', icon: 'shield' },
  { title: 'Excellence', desc: 'Rigorous quality in design, manufacturing, and field work.', icon: 'star' },
  { title: 'Sustainability', desc: 'Responsible materials, efficiency, and lifecycle thinking.', icon: 'leaf' },
  { title: 'Compliance', desc: 'Meeting and exceeding regulatory and client standards.', icon: 'check' },
  { title: 'Impact', desc: 'Outcomes that strengthen communities and critical infrastructure.', icon: 'globe' },
] as const;

const subsidiaries = [
  {
    name: 'Agbayani Construction',
    blurb: 'General contracting across modular and civil construction programs.',
    bullets: ['Commercial & Residential Modular', 'Civil Infrastructure', 'Design-Build Services'],
    logo: '/images/partners/agbayani.svg',
  },
  {
    name: 'RI Group USA',
    blurb: 'International modular construction expertise and manufacturing partnerships.',
    bullets: ['Modular Manufacturing', 'International Supply Chain', 'Quality Assurance'],
    logo: '/images/partners/ri-group.png',
  },
  {
    name: 'EDIS USA',
    blurb: 'Early warning systems and disaster preparedness technology for emergency management agencies.',
    bullets: ['Early Warning Systems', 'Disaster Preparedness', 'Emergency Management Technology'],
    logo: '/images/partners/edis.png',
  },
];

const goals = [
  'Reducing project costs',
  'Delivering projects in shorter timeframes',
  'Reducing waste of materials',
  'Improving the quality of construction',
  'Reducing site disruption and improving worker safety',
  'Minimizing carbon emissions from construction projects',
];

const leadership = [
  { name: 'Fuad Sweiss', role: 'Founder & CEO', bio: 'Founded GMP in 2019 with the objective of improving and perfecting modular building technologies by fostering long-lasting partnerships among developers, architects, engineers, contractors, suppliers, and modular manufacturers worldwide.' },
];

const board = [
  { name: 'Robert Bilbeisi', role: 'Board Chairman', focus: 'International Development' },
  { name: 'Dr. Maria Carranza', role: 'Board Member', focus: 'Healthcare Systems' },
  { name: 'James Siri', role: 'Board Member', focus: 'Defense Contracting' },
  { name: 'Amb. Ahmed Bulgherini', role: 'Board Member', focus: 'International Relations' },
];

const timeline = [
  { year: '2019', event: 'GMP founded by Fuad Sweiss in the San Francisco Bay Area' },
  { year: '2020', event: 'Agbayani Construction partnership established' },
  { year: '2021', event: 'RI Group USA collaboration launched' },
  { year: '2022', event: 'Irvine, CA office opened for Southern California operations' },
  { year: '2023', event: 'HWB healthcare partnership initiated' },
  { year: '2024', event: 'Trade partner network expanded to 10+ firms' },
  { year: '2025', event: '28-Day ADU program introduced' },
];

---

<Layout
  title="About Us"
  description="Mission, subsidiaries, leadership, and history of Global Modular Partners — modular construction for government, healthcare, and commercial sectors."
>
  <Header slot="header" />

  <!-- Hero Banner -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <span>About Us</span>
        </nav>
        <h1 class="hero-title fade-up">Improving & Perfecting<br /><span class="hero-span">Modular Building</span></h1>
        <p class="hero-sub fade-up">
          Founded in 2019 by Fuad Sweiss to foster long-lasting partnerships among developers, architects, engineers, contractors, suppliers, and modular manufacturers worldwide.
        </p>
      </div>
    </div>
  </section>

  <!-- Founder Story -->
  <section class="section-gap about-story" id="mission">
    <div class="mnc-container">
      <div class="story-grid fade-up">
        <div class="story-content">
          <span class="section-tag">Our Story</span>
          <h2 class="section-title">Founded to transform <span class="section-span">how the world builds</span></h2>
          <p class="story-body">
            Global Modular Partners, LLC (GMP) was founded by Fuad Sweiss in 2019, with the objective of improving and perfecting modular building technologies by fostering long-lasting partnerships among all stakeholders involved in modular projects — developers, architects, engineers, contractors, suppliers, and modular manufacturers in various countries.
          </p>
          <p class="story-body">
            In the process, we will create jobs in underserved areas and provide affordable housing to millions of people all over the world.
          </p>
        </div>
        <div class="story-image">
          <img src="/images/showcase/hwb-ri-factory-visit.jpeg" alt="GMP delegation at RI Group factory in Italy" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Goals -->
  <section class="section-gap about-goals">
    <div class="mnc-container">
      <div class="goals-header fade-up">
        <span class="section-tag">Our Goals</span>
        <h2 class="section-title">What we're working toward <span class="section-span">every day</span></h2>
      </div>
      <div class="goals-grid">
        {goals.map((g) => (
          <div class="goal-card fade-up">
            <span class="goal-card__check" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
            </span>
            <p class="goal-card__text">{g}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Modular -->
  <section class="section-gap about-why">
    <div class="mnc-container">
      <div class="why-grid fade-up">
        <div class="why-image">
          <img src="/images/showcase/west-factory.jpg" alt="West Modular manufacturing facility" loading="lazy" />
        </div>
        <div class="why-content">
          <span class="section-tag">Why Modular</span>
          <h2 class="section-title">The future of <span class="section-span">housing production</span></h2>
          <p class="why-body">
            The world population will exceed 10 billion in less than 20 years and the demand for housing will continue to grow. We have been utilizing the same archaic building methods for over a century — the only way to meet the demands of growing populations, diminishing resources, and climate change mandates is to modernize and automate traditional construction methods.
          </p>
          <p class="why-body why-body--highlight">
            Modular simply is the future of housing production.
          </p>
          <p class="why-body">
            GMP is uniquely positioned to perfect modular technologies by bringing the most talented and experienced professionals to work together. Our company headquarters is based in the San Francisco Bay Area — which has the highest number of modular projects completed to date. Our second office in Irvine, California serves the growing number of modular construction projects in Southern California.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-gap about-values">
    <div class="mnc-container">
      <div class="values-header fade-up">
        <span class="section-tag">Our Values</span>
        <h2 class="section-title">Principles that guide <span class="section-span">everything we do</span></h2>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value-card fade-up">
            <div class="value-card__icon" aria-hidden="true">
              {v.icon === 'spark' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M16 4l2 8 8 2-8 2-2 8-2-8-8-2 8-2 2-8z" />
                </svg>
              )}
              {v.icon === 'shield' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M16 4l10 4v8c0 6-4 11-10 12-6-1-10-6-10-12V8l10-4z" />
                </svg>
              )}
              {v.icon === 'star' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M16 6l3.5 7.5L28 15l-6 5.5L24 30l-8-4.5L8 30l2-9.5L4 15l8.5-1.5L16 6z" />
                </svg>
              )}
              {v.icon === 'leaf' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M6 26c8-2 14-8 16-16 0 8-6 14-14 16z" />
                  <path d="M6 26c4-10 12-14 20-14" />
                </svg>
              )}
              {v.icon === 'check' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <path d="M6 16l8 8 12-14" />
                </svg>
              )}
              {v.icon === 'globe' && (
                <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75">
                  <circle cx="16" cy="16" r="12" />
                  <path d="M4 16h24M16 4c3 4 3 20 0 24M16 4c-3 4-3 20 0 24" />
                </svg>
              )}
            </div>
            <h3 class="value-card__title">{v.title}</h3>
            <p class="value-card__desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Subsidiaries -->
  <section class="section-gap about-subs" id="subsidiaries">
    <div class="mnc-container">
      <div class="subs-header fade-up">
        <span class="section-tag">Portfolio</span>
        <h2 class="section-title">Subsidiaries &amp; partners <span class="section-span">integrated across every discipline</span></h2>
        <p class="subs-lead">Integrated capabilities across construction, manufacturing, emergency systems, and healthcare delivery.</p>
      </div>
      <div class="subs-grid">
        {subsidiaries.map((s) => (
          <article class="sub-card fade-up">
            <div class="sub-card__logo-wrap">
              <img src={s.logo} alt={`${s.name} logo`} class="sub-card__logo" loading="lazy" />
            </div>
            <h3 class="sub-card__name">{s.name}</h3>
            <p class="sub-card__blurb">{s.blurb}</p>
            <ul class="sub-card__list">
              {s.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <article class="partner-card fade-up">
        <div class="partner-card__header">
          <div class="partner-card__logo-wrap">
            <img src="/images/partners/hwb.svg" alt="Hospitals Without Borders logo" class="partner-card__logo" loading="lazy" />
          </div>
          <div class="partner-card__row">
            <span class="partner-card__badge">External Partner</span>
            <h3 class="partner-card__name">HWB — Hospitals Without Borders</h3>
          </div>
        </div>
        <p class="partner-card__blurb">
          Humanitarian healthcare facilities, telemedicine, and rapid-deployment clinical infrastructure.
        </p>
        <ul class="partner-card__tags">
          <li>Healthcare Facilities</li>
          <li>Telemedicine</li>
          <li>Humanitarian</li>
        </ul>
      </article>
    </div>
  </section>

  <!-- Leadership -->
  <section class="section-gap about-leaders" id="leadership">
    <div class="mnc-container">
      <div class="leaders-header fade-up">
        <span class="section-tag">Team</span>
        <h2 class="section-title">Leadership <span class="section-span">guiding strategy and execution</span></h2>
        <p class="leaders-lead">Seasoned executives guiding strategy, operations, and financial performance.</p>
      </div>
      <div class="leaders-grid">
        {leadership.map((person) => (
          <article class="leader-card fade-up">
            <div class="leader-card__avatar" aria-hidden="true">
              <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="40" cy="28" r="14" />
                <path d="M12 72c0-15.5 12.5-28 28-28s28 12.5 28 28" />
              </svg>
            </div>
            <h3 class="leader-card__name">{person.name}</h3>
            <p class="leader-card__role">{person.role}</p>
            <p class="leader-card__bio">{person.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Board of Directors -->
  <section class="section-gap about-board" id="board">
    <div class="mnc-container">
      <div class="board-header fade-up">
        <span class="section-tag">Governance</span>
        <h2 class="section-title">Board of Directors <span class="section-span">providing strategic oversight</span></h2>
        <p class="board-lead">Strategic oversight spanning development, healthcare, defense, and international relations.</p>
      </div>
      <div class="board-grid">
        {board.map((member) => (
          <article class="board-card fade-up">
            <div class="board-card__initial" aria-hidden="true">{member.name.charAt(0)}</div>
            <h3 class="board-card__name">{member.name}</h3>
            <p class="board-card__role">{member.role}</p>
            <p class="board-card__focus">{member.focus}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section-gap about-timeline" id="history">
    <div class="mnc-container">
      <div class="timeline-header fade-up">
        <span class="section-tag">Heritage</span>
        <h2 class="section-title">Our timeline <span class="section-span">from founding to today</span></h2>
        <p class="timeline-lead">Key milestones from founding through today's programs and partnerships.</p>
      </div>
      <div class="timeline-track">
        {timeline.map((item, i) => (
          <div class:list={['timeline-item', 'fade-up', { 'timeline-item--right': i % 2 === 1 }]}>
            <div class="timeline-item__marker" aria-hidden="true" />
            <div class="timeline-item__panel">
              <span class="timeline-item__year">{item.year}</span>
              <p class="timeline-item__event">{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <Footer slot="footer" />
</Layout>

<style>
  /* ── Shared MNC tokens ── */
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin-bottom: 20px;
  }
  .section-span { color: var(--amber); }
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px;
    border: 1px solid var(--navy);
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .mnc-btn--dark { background: var(--amber); border-color: var(--amber); color: var(--navy); font-weight: 700; }
  .mnc-btn--dark:hover { background: var(--amber-dark); border-color: var(--amber-dark); color: var(--white); box-shadow: 0 4px 16px rgba(224,161,53,.35); }
  .mnc-btn--outline { background: transparent; color: var(--navy); }
  .mnc-btn--outline:hover { background: var(--navy); color: var(--white); }
  .mnc-btn--stroke { background: transparent; border-color: rgba(255,255,255,.4); color: var(--white); }
  .mnc-btn--stroke:hover { border-color: var(--amber); color: var(--amber); background: rgba(224,161,53,.08); }
  .mnc-btn__icon { display: flex; width: 20px; height: 20px; }
  .mnc-btn__icon svg { width: 100%; height: 100%; }

  /* ── Hero Banner ── */
  .hero-wrap { padding: 16px; }
  .hero-inner {
    height: 490px;
    border-radius: 8px;
    background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }
  .hero-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 1; padding: 80px 1.5rem 36px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,.5);
    margin-bottom: 20px;
  }
  .breadcrumb a { color: rgba(255,255,255,.5); }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-wrap .section-tag { color: rgba(255,255,255,.6); }
  .hero-wrap .section-tag::before { background: var(--amber); }
  .hero-title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    line-height: 1.1;
    color: var(--white);
    max-width: 700px;
    margin-bottom: 16px;
  }
  .hero-span {
    color: rgba(255,255,255,.5);
  }
  .hero-sub {
    color: rgba(255,255,255,.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 32px;
  }

  /* ── Founder Story ── */
  .about-story { background: var(--white); }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .story-body {
    font-size: 17px;
    line-height: 1.8;
    color: var(--text-gray);
    margin: 0 0 16px;
  }
  .story-body:last-child { margin-bottom: 0; }
  .story-image {
    border-radius: 8px;
    overflow: hidden;
  }
  .story-image img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 900px) {
    .story-grid { grid-template-columns: 1fr; gap: 32px; }
    .story-image img { height: 280px; }
  }

  /* ── Goals ── */
  .about-goals { background: var(--off-white); }
  .goals-header { max-width: 720px; margin-bottom: 40px; }
  .goals-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .goal-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: var(--white);
    border-radius: 8px;
    padding: 20px 22px;
    border: 1px solid rgba(0,0,0,.04);
  }
  .goal-card__check {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(224,161,53,.12);
    color: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .goal-card__check svg { width: 14px; height: 14px; }
  .goal-card__text {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    color: var(--dark-text);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .goals-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .goals-grid { grid-template-columns: 1fr; }
  }

  /* ── Why Modular ── */
  .about-why { background: var(--white); }
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .why-image {
    border-radius: 8px;
    overflow: hidden;
  }
  .why-image img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }
  .why-body {
    font-size: 17px;
    line-height: 1.8;
    color: var(--text-gray);
    margin: 0 0 16px;
  }
  .why-body:last-child { margin-bottom: 0; }
  .why-body--highlight {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--navy);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .why-grid { grid-template-columns: 1fr; gap: 32px; }
    .why-image img { height: 280px; }
  }

  /* ── Values ── */
  .about-values { background: var(--off-white); }
  .values-header { max-width: 720px; margin-bottom: 40px; }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .value-card {
    background: var(--white);
    border-radius: 8px;
    padding: 24px;
  }
  .value-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background: linear-gradient(145deg, rgba(224,161,53,.12), rgba(36,55,85,.06));
    color: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .value-card__icon svg { width: 22px; height: 22px; }
  .value-card__title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 600;
    color: var(--dark-text);
    margin-bottom: 6px;
  }
  .value-card__desc {
    font-size: 15px;
    line-height: 1.55;
    color: var(--text-gray);
    margin: 0;
  }

  @media (max-width: 768px) {
    .values-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .values-grid { grid-template-columns: 1fr; }
  }

  /* ── Subsidiaries ── */
  .about-subs { background: var(--off-white); }
  .subs-header { max-width: 720px; margin-bottom: 48px; }
  .subs-lead {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-gray);
    margin: 0;
  }
  .subs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 20px;
  }
  .sub-card {
    background: var(--white);
    border-radius: 8px;
    padding: 0;
    border: 1px solid rgba(0,0,0,.04);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .sub-card__logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 20px;
    background: #f7f7f7;
    border-bottom: 1px solid #eee;
    min-height: 88px;
  }
  .sub-card__logo {
    max-height: 48px;
    max-width: 160px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .sub-card__name {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    color: var(--dark-text);
    margin: 0 0 8px;
    padding: 24px 24px 0;
  }
  .sub-card__blurb {
    font-size: 15px;
    color: var(--text-gray);
    line-height: 1.6;
    margin-bottom: 16px;
    padding: 0 24px;
  }
  .sub-card__list {
    list-style: none;
    padding: 0 24px 24px;
    margin: 0;
