---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const timeline = [
  { year: '2019', event: 'GMP founded by Fuad Sweiss in the San Francisco Bay Area with the objective of perfecting modular building technologies through global partnerships.' },
  { year: '2020', event: 'Agbayani Construction partnership established, expanding general contracting capabilities across modular and civil programs.' },
  { year: '2021', event: 'RI Group USA collaboration launched, connecting GMP to international modular manufacturing expertise and supply chains.' },
  { year: '2022', event: 'Second office opened in Irvine, California to serve the growing number of modular construction projects in Southern California.' },
  { year: '2023', event: 'Hospitals Without Borders healthcare partnership initiated, extending modular construction into global health and humanitarian response.' },
  { year: '2024', event: 'Trade partner network expanded to 10+ firms including West Modular, PROSET, EnTech, TRUE NORTH, STREAM, and more.' },
  { year: '2025', event: '28-Day ADU program introduced — rapid accessory dwelling unit delivery leveraging factory-built efficiency.' },
];

const milestones = [
  { title: 'Bay Area Headquarters', desc: 'Established in the region with the highest number of completed modular projects to date.' },
  { title: 'Southern California Expansion', desc: 'Irvine office opened to serve growing demand in the largest construction market in the state.' },
  { title: 'Global Health Partnership', desc: 'HWB collaboration brings modular medical facilities to underserved communities worldwide.' },
  { title: '10+ Trade Partner Network', desc: 'Integrated network of specialist firms covering manufacturing, logistics, engineering, and compliance.' },
  { title: '28-Day ADU Program', desc: 'Factory-built accessory dwelling units delivered and installed in under one month.' },
  { title: 'DoD & Military Programs', desc: 'Mission-critical modular facilities meeting federal compliance, security, and precision standards.' },
];
---

<Layout
  title="History — About"
  description="GMP's history from founding in 2019 through today's programs, partnerships, and milestones in modular construction."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <a href="/about">About Us</a>
          <span class="breadcrumb__sep">/</span>
          <span>History</span>
        </nav>
        <h1 class="hero-title fade-up">Our Story &<br />Key Milestones</h1>
        <p class="hero-sub fade-up">From founding in 2019 to a nationwide network of partners advancing modular construction.</p>
        <div class="hero-actions fade-up">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/about" class="mnc-btn mnc-btn--stroke">
            About Overview
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section-gap hist-overview">
    <div class="mnc-container">
      <div class="overview-header fade-up">
        <span class="section-tag">Heritage</span>
        <h2 class="section-title">Building momentum <span class="section-span">since day one</span></h2>
      </div>
      <p class="overview-body fade-up">
        GMP's journey began with a clear vision: modernize construction through modular innovation. In just a few years, we've grown from a single Bay Area office to a coast-to-coast network of partners, manufacturers, and specialists — delivering projects faster, greener, and smarter.
      </p>
    </div>
  </section>

  <!-- Interactive Timeline -->
  <section class="section-gap hist-timeline">
    <div class="mnc-container">
      <div class="timeline-header fade-up">
        <span class="section-tag">Timeline</span>
        <h2 class="section-title">Our path from <span class="section-span">founding to today</span></h2>
      </div>
      <div class="timeline-track">
        {timeline.map((item, i) => (
          <div class:list={['timeline-item', 'fade-up', { 'timeline-item--right': i % 2 === 1 }]}>
            <div class="timeline-item__marker" aria-hidden="true" />
            <div class="timeline-item__panel">
              <span class="timeline-item__year">{item.year}</span>
              <p class="timeline-item__event">{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Milestones -->
  <section class="section-gap hist-milestones">
    <div class="mnc-container">
      <div class="milestones-header fade-up">
        <span class="section-tag">Milestones</span>
        <h2 class="section-title">Achievements that <span class="section-span">define our growth</span></h2>
      </div>
      <div class="milestones-grid">
        {milestones.map((m) => (
          <div class="milestone-card fade-up">
            <h3 class="milestone-card__title">{m.title}</h3>
            <p class="milestone-card__desc">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-gap hist-cta">
    <div class="mnc-container">
      <div class="cta-inner fade-up">
        <h2 class="cta-title">View our portfolio</h2>
        <p class="cta-sub">See how GMP's growth, partnerships, and programs translate into modular capabilities today.</p>
        <div class="cta-actions">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/about/leadership" class="mnc-btn mnc-btn--stroke">
            Meet the Team
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 2.5px; color: var(--amber); margin-bottom: 20px; padding: 0; border: none; border-radius: 0; }
  .section-tag::before { content: ''; display: inline-block; width: 24px; height: 2px; background: var(--amber); flex-shrink: 0; }
  .section-title { font-family: var(--font-secondary); font-size: clamp(32px, 4vw, 52px); line-height: 1.2; font-weight: 500; color: var(--dark-text); margin-bottom: 20px; }
  .section-span { color: var(--amber); }
  .mnc-btn { display: inline-flex; align-items: center; gap: 10px; padding: 16px; border: 1px solid var(--navy); border-radius: 4px; font-size: 16px; font-weight: 600; text-decoration: none; transition: all 0.25s ease; }
  .mnc-btn--dark { background: var(--amber); border-color: var(--amber); color: var(--navy); font-weight: 700; }
  .mnc-btn--dark:hover { background: var(--amber-dark); border-color: var(--amber-dark); color: var(--white); box-shadow: 0 4px 16px rgba(224,161,53,.35); }
  .mnc-btn--stroke { background: transparent; border-color: rgba(255,255,255,.4); color: var(--white); }
  .mnc-btn--stroke:hover { border-color: var(--amber); color: var(--amber); background: rgba(224,161,53,.08); }
  .mnc-btn__icon { display: flex; width: 20px; height: 20px; }
  .mnc-btn__icon svg { width: 100%; height: 100%; }

  /* Hero */
  .hero-wrap { padding: 16px; }
  .hero-inner { height: 560px; border-radius: 8px; background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); display: flex; align-items: flex-end; position: relative; overflow: hidden; }
  .hero-inner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%); pointer-events: none; }
  .hero-content { position: relative; z-index: 1; padding: 120px 1.5rem 60px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
  .breadcrumb a { color: rgba(255,255,255,.5); text-decoration: none; }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-title { font-family: var(--font-secondary); font-size: clamp(36px, 5vw, 56px); font-weight: 600; line-height: 1.15; color: var(--white); max-width: 700px; margin-bottom: 16px; }
  .hero-sub { color: rgba(255,255,255,.65); font-size: 18px; line-height: 1.7; max-width: 560px; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Overview */
  .hist-overview { background: var(--white); }
  .overview-header { max-width: 720px; margin-bottom: 24px; }
  .overview-body { font-size: 18px; line-height: 1.75; color: var(--text-gray); max-width: 800px; margin: 0; }

  /* Timeline */
  .hist-timeline { background: var(--off-white); }
  .timeline-header { text-align: center; max-width: 720px; margin: 0 auto 48px; }
  .timeline-track { position: relative; max-width: 860px; margin: 0 auto; padding: 8px 0 16px; }
  .timeline-track::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 2px; background: var(--medium-gray); transform: translateX(-50%); }
  .timeline-item { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: center; margin-bottom: 32px; }
  .timeline-item__panel { grid-column: 1; justify-self: end; width: 100%; max-width: 360px; text-align: right; background: var(--white); border-radius: 8px; padding: 20px 24px; }
  .timeline-item--right .timeline-item__panel { grid-column: 2; justify-self: start; text-align: left; }
  .timeline-item__marker { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); z-index: 2; width: 14px; height: 14px; border-radius: 50%; background: var(--amber); box-shadow: 0 0 0 4px var(--off-white), 0 0 0 6px rgba(224,161,53,.35); }
  .timeline-item__year { display: block; font-family: var(--font-secondary); font-size: 22px; font-weight: 800; color: var(--amber); margin-bottom: 4px; }
  .timeline-item__event { margin: 0; color: var(--dark-text); font-size: 15px; line-height: 1.5; }

  /* Milestones */
  .hist-milestones { background: var(--white); }
  .milestones-header { max-width: 720px; margin-bottom: 48px; }
  .milestones-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .milestone-card { background: var(--off-white); border-radius: 8px; padding: 28px 24px; border-left: 3px solid var(--amber); }
  .milestone-card__title { font-family: var(--font-secondary); font-size: 18px; font-weight: 600; color: var(--dark-text); margin-bottom: 8px; }
  .milestone-card__desc { font-size: 15px; color: var(--text-gray); line-height: 1.55; margin: 0; }

  /* CTA */
  .hist-cta { background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); position: relative; overflow: hidden; }
  .hist-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 80% 20%, rgba(224,161,53,.1), transparent), radial-gradient(ellipse 60% 50% at 10% 90%, rgba(0,0,0,.12), transparent); pointer-events: none; }
  .cta-inner { position: relative; z-index: 1; text-align: center; max-width: 680px; margin: 0 auto; }
  .cta-title { font-family: var(--font-secondary); font-size: clamp(28px, 3.5vw, 44px); font-weight: 600; color: var(--white); margin-bottom: 16px; }
  .cta-sub { color: rgba(255,255,255,.65); font-size: 17px; line-height: 1.7; margin-bottom: 32px; }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

  @media (max-width: 960px) { .milestones-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .section-gap { padding: 60px 0; }
    .hero-inner { height: 480px; }
    .hero-content { padding: 80px 1.5rem 40px; }
    .timeline-track::before { left: 14px; transform: none; }
    .timeline-item, .timeline-item--right { grid-template-columns: 1fr; padding-left: 44px; margin-bottom: 20px; }
    .timeline-item .timeline-item__panel, .timeline-item--right .timeline-item__panel { grid-column: 1; justify-self: stretch; max-width: none; text-align: left; }
    .timeline-item__marker { left: 14px; }
  }
  @media (max-width: 640px) { .milestones-grid { grid-template-columns: 1fr; } }
</style>
