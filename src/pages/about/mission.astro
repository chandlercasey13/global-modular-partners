---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const values = [
  { title: 'Innovation', desc: 'Advancing modular methods and digital delivery to meet the demands of growing populations and diminishing resources.', icon: 'spark' },
  { title: 'Integrity', desc: 'Transparent partnerships and accountable execution across every stakeholder relationship.', icon: 'shield' },
  { title: 'Excellence', desc: 'Rigorous quality in design, manufacturing, and field work — meeting or exceeding site-built standards.', icon: 'star' },
  { title: 'Sustainability', desc: 'Responsible materials, factory efficiency, and lifecycle thinking that minimizes carbon emissions.', icon: 'leaf' },
  { title: 'Compliance', desc: 'Meeting and exceeding regulatory and client standards across federal, state, and local jurisdictions.', icon: 'check' },
  { title: 'Impact', desc: 'Outcomes that strengthen communities, create jobs in underserved areas, and provide affordable housing worldwide.', icon: 'globe' },
];

const goals = [
  'Reducing project costs through factory-controlled efficiency',
  'Delivering projects in shorter timeframes — 30% to 50% faster',
  'Reducing waste of materials through controlled inventory management',
  'Improving the quality of construction through repeatable precision',
  'Reducing site disruption and improving worker safety',
  'Minimizing carbon emissions from construction projects',
];
---

<Layout
  title="Mission & Values — About"
  description="GMP's mission to create jobs, provide affordable housing, and advance modular building technologies worldwide."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <a href="/about">About Us</a>
          <span class="breadcrumb__sep">/</span>
          <span>Mission & Values</span>
        </nav>
        <h1 class="hero-title fade-up">Our Mission &<br />Core Values</h1>
        <p class="hero-sub fade-up">Creating jobs and affordable housing through modular innovation — perfecting how the world builds.</p>
        <div class="hero-actions fade-up">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/about" class="mnc-btn mnc-btn--stroke">
            About Overview
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Statement -->
  <section class="section-gap mission-statement">
    <div class="mnc-container">
      <div class="mission-header fade-up">
        <span class="section-tag">Our Purpose</span>
        <h2 class="section-title">Why we exist <span class="section-span">and what drives us</span></h2>
      </div>
      <div class="mission-body fade-up">
        <p>
          Global Modular Partners was founded with the objective of improving and perfecting modular building technologies by fostering long-lasting partnerships among all stakeholders involved in modular projects — developers, architects, engineers, contractors, suppliers, and modular manufacturers in various countries.
        </p>
        <p>
          The world population will exceed 10 billion in less than 20 years and the demand for housing will continue to grow. We have been utilizing the same archaic building methods for over a century. The only way to meet the demands of growing populations, diminishing resources, and climate change mandates is to modernize and automate traditional construction methods. Modular simply is the future of housing production.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Goals -->
  <section class="section-gap mission-goals">
    <div class="mnc-container">
      <div class="goals-header fade-up">
        <span class="section-tag">Our Goals</span>
        <h2 class="section-title">What we're working <span class="section-span">to accomplish</span></h2>
      </div>
      <div class="goals-grid">
        {goals.map((goal, i) => (
          <div class="goal-item fade-up">
            <span class="goal-item__num">{String(i + 1).padStart(2, '0')}</span>
            <p class="goal-item__text">{goal}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="section-gap mission-values">
    <div class="mnc-container">
      <div class="values-header fade-up">
        <span class="section-tag">Core Values</span>
        <h2 class="section-title">Principles that guide <span class="section-span">every decision</span></h2>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value-card fade-up">
            <div class="value-card__icon" aria-hidden="true">
              {v.icon === 'spark' && (<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M16 4l2 8 8 2-8 2-2 8-2-8-8-2 8-2 2-8z" /></svg>)}
              {v.icon === 'shield' && (<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M16 4l10 4v8c0 6-4 11-10 12-6-1-10-6-10-12V8l10-4z" /></svg>)}
              {v.icon === 'star' && (<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M16 6l3.5 7.5L28 15l-6 5.5L24 30l-8-4.5L8 30l2-9.5L4 15l8.5-1.5L16 6z" /></svg>)}
              {v.icon === 'leaf' && (<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M6 26c8-2 14-8 16-16 0 8-6 14-14 16z" /><path d="M6 26c4-10 12-14 20-14" /></svg>)}
              {v.icon === 'check' && (<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M6 16l8 8 12-14" /></svg>)}
              {v.icon === 'globe' && (<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="16" cy="16" r="12" /><path d="M4 16h24M16 4c3 4 3 20 0 24M16 4c-3 4-3 20 0 24" /></svg>)}
            </div>
            <h3 class="value-card__title">{v.title}</h3>
            <p class="value-card__desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-gap mission-cta">
    <div class="mnc-container">
      <div class="cta-inner fade-up">
        <h2 class="cta-title">Discover our approach</h2>
        <p class="cta-sub">Learn how GMP's mission, goals, and values shape modular delivery from factory through field operations.</p>
        <div class="cta-actions">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/services" class="mnc-btn mnc-btn--stroke">
            Explore Services
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 2.5px; color: var(--amber); margin-bottom: 20px; padding: 0; border: none; border-radius: 0; }
  .section-tag::before { content: ''; display: inline-block; width: 24px; height: 2px; background: var(--amber); flex-shrink: 0; }
  .section-title { font-family: var(--font-secondary); font-size: clamp(32px, 4vw, 52px); line-height: 1.2; font-weight: 500; color: var(--dark-text); margin-bottom: 20px; }
  .section-span { color: var(--amber); }
  .mnc-btn { display: inline-flex; align-items: center; gap: 10px; padding: 16px; border: 1px solid var(--navy); border-radius: 4px; font-size: 16px; font-weight: 600; text-decoration: none; transition: all 0.25s ease; }
  .mnc-btn--dark { background: var(--amber); border-color: var(--amber); color: var(--navy); font-weight: 700; }
  .mnc-btn--dark:hover { background: var(--amber-dark); border-color: var(--amber-dark); color: var(--white); box-shadow: 0 4px 16px rgba(224,161,53,.35); }
  .mnc-btn--stroke { background: transparent; border-color: rgba(255,255,255,.4); color: var(--white); }
  .mnc-btn--stroke:hover { border-color: var(--amber); color: var(--amber); background: rgba(224,161,53,.08); }
  .mnc-btn__icon { display: flex; width: 20px; height: 20px; }
  .mnc-btn__icon svg { width: 100%; height: 100%; }

  /* Hero */
  .hero-wrap { padding: 16px; }
  .hero-inner { height: 560px; border-radius: 8px; background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); display: flex; align-items: flex-end; position: relative; overflow: hidden; }
  .hero-inner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%); pointer-events: none; }
  .hero-content { position: relative; z-index: 1; padding: 120px 1.5rem 60px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
  .breadcrumb a { color: rgba(255,255,255,.5); text-decoration: none; }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-title { font-family: var(--font-secondary); font-size: clamp(36px, 5vw, 56px); font-weight: 600; line-height: 1.15; color: var(--white); max-width: 700px; margin-bottom: 16px; }
  .hero-sub { color: rgba(255,255,255,.65); font-size: 18px; line-height: 1.7; max-width: 560px; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Mission Statement */
  .mission-statement { background: var(--white); }
  .mission-header { max-width: 720px; margin-bottom: 24px; }
  .mission-body { max-width: 800px; }
  .mission-body p { font-size: 18px; line-height: 1.75; color: var(--text-gray); margin: 0 0 20px; }
  .mission-body p:last-child { margin-bottom: 0; }

  /* Goals */
  .mission-goals { background: var(--off-white); }
  .goals-header { max-width: 720px; margin-bottom: 48px; }
  .goals-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .goal-item { display: flex; align-items: flex-start; gap: 16px; background: var(--white); border-radius: 8px; padding: 24px; }
  .goal-item__num { flex: none; font-family: var(--font-secondary); font-size: 28px; font-weight: 800; color: var(--amber); line-height: 1; }
  .goal-item__text { font-size: 16px; color: var(--dark-text); line-height: 1.55; margin: 0; }

  /* Core Values */
  .mission-values { background: var(--white); }
  .values-header { max-width: 720px; margin-bottom: 48px; }
  .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .value-card { background: var(--off-white); border-radius: 8px; padding: 24px; }
  .value-card__icon { width: 48px; height: 48px; border-radius: 8px; background: linear-gradient(145deg, rgba(224,161,53,.12), rgba(36,55,85,.06)); color: var(--amber); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
  .value-card__icon svg { width: 22px; height: 22px; }
  .value-card__title { font-family: var(--font-secondary); font-size: 18px; font-weight: 600; color: var(--dark-text); margin-bottom: 6px; }
  .value-card__desc { font-size: 15px; line-height: 1.55; color: var(--text-gray); margin: 0; }

  /* CTA */
  .mission-cta { background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); position: relative; overflow: hidden; }
  .mission-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 80% 20%, rgba(224,161,53,.1), transparent), radial-gradient(ellipse 60% 50% at 10% 90%, rgba(0,0,0,.12), transparent); pointer-events: none; }
  .cta-inner { position: relative; z-index: 1; text-align: center; max-width: 680px; margin: 0 auto; }
  .cta-title { font-family: var(--font-secondary); font-size: clamp(28px, 3.5vw, 44px); font-weight: 600; color: var(--white); margin-bottom: 16px; }
  .cta-sub { color: rgba(255,255,255,.65); font-size: 17px; line-height: 1.7; margin-bottom: 32px; }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

  @media (max-width: 768px) {
    .section-gap { padding: 60px 0; }
    .hero-inner { height: 480px; }
    .hero-content { padding: 80px 1.5rem 40px; }
    .values-grid { grid-template-columns: repeat(2, 1fr); }
    .goals-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) { .values-grid { grid-template-columns: 1fr; } }
</style>
