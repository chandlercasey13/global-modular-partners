---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const executives = [
  {
    name: 'Fuad Sweiss',
    role: 'Founder & CEO',
    bio: 'Founded GMP in 2019 with the objective of improving and perfecting modular building technologies by fostering long-lasting partnerships among developers, architects, engineers, contractors, suppliers, and modular manufacturers worldwide. Based in the San Francisco Bay Area, Fuad brings decades of construction and development expertise to every GMP initiative.',
  },
];

const board = [
  { name: 'Robert Bilbeisi', role: 'Board Chairman', focus: 'International Development', bio: 'Leads strategic direction and international expansion initiatives for GMP, drawing on extensive experience in cross-border development partnerships.' },
  { name: 'Dr. Maria Carranza', role: 'Board Member', focus: 'Healthcare Systems', bio: 'Guides GMP\'s healthcare division strategy, ensuring modular medical facilities meet the highest clinical and operational standards.' },
  { name: 'James Siri', role: 'Board Member', focus: 'Defense Contracting', bio: 'Provides oversight on government and DoD programs, ensuring compliance with federal acquisition requirements and security standards.' },
  { name: 'Amb. Ahmed Bulgherini', role: 'Board Member', focus: 'International Relations', bio: 'Advises on international partnerships and diplomatic relationships that support GMP\'s global modular construction mission.' },
];
---

<Layout
  title="Leadership — About"
  description="Meet GMP's executive team and Board of Directors guiding strategy, operations, and global modular construction partnerships."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb fade-up" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <a href="/about">About Us</a>
          <span class="breadcrumb__sep">/</span>
          <span>Leadership</span>
        </nav>
        <h1 class="hero-title fade-up">Leadership Behind<br />Our Mission</h1>
        <p class="hero-sub fade-up">Seasoned executives and board members guiding strategy, operations, and global partnerships.</p>
        <div class="hero-actions fade-up">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/about" class="mnc-btn mnc-btn--stroke">
            About Overview
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section-gap lead-overview">
    <div class="mnc-container">
      <div class="overview-header fade-up">
        <span class="section-tag">Our People</span>
        <h2 class="section-title">Experience and vision <span class="section-span">driving results</span></h2>
      </div>
      <p class="overview-body fade-up">
        GMP is led by construction industry veterans who bring deep expertise in modular manufacturing, project delivery, government contracting, and international development. Together, our leadership team ensures every project benefits from strategic oversight and operational excellence.
      </p>
    </div>
  </section>

  <!-- Executive Bios -->
  <section class="section-gap lead-execs">
    <div class="mnc-container">
      <div class="execs-header fade-up">
        <span class="section-tag">Executive Team</span>
        <h2 class="section-title">The people who <span class="section-span">lead our work</span></h2>
      </div>
      <div class="execs-grid">
        {executives.map((person) => (
          <article class="exec-card fade-up">
            <div class="exec-card__avatar" aria-hidden="true">
              <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="40" cy="28" r="14" />
                <path d="M12 72c0-15.5 12.5-28 28-28s28 12.5 28 28" />
              </svg>
            </div>
            <h3 class="exec-card__name">{person.name}</h3>
            <p class="exec-card__role">{person.role}</p>
            <p class="exec-card__bio">{person.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Board of Directors -->
  <section class="section-gap lead-board">
    <div class="mnc-container">
      <div class="board-header fade-up">
        <span class="section-tag">Governance</span>
        <h2 class="section-title">Board of Directors <span class="section-span">providing strategic oversight</span></h2>
      </div>
      <div class="board-grid">
        {board.map((member) => (
          <article class="board-card fade-up">
            <div class="board-card__initial" aria-hidden="true">{member.name.charAt(0)}</div>
            <h3 class="board-card__name">{member.name}</h3>
            <p class="board-card__role">{member.role}</p>
            <span class="board-card__focus">{member.focus}</span>
            <p class="board-card__bio">{member.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-gap lead-cta">
    <div class="mnc-container">
      <div class="cta-inner fade-up">
        <h2 class="cta-title">See our expertise</h2>
        <p class="cta-sub">Review how GMP's leadership and delivery model support modular programs across markets and sectors.</p>
        <div class="cta-actions">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            View Our Work
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
          <a href="/services" class="mnc-btn mnc-btn--stroke">
            Explore Services
            <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .section-gap { padding: 100px 0; }
  .section-tag { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 2.5px; color: var(--amber); margin-bottom: 20px; padding: 0; border: none; border-radius: 0; }
  .section-tag::before { content: ''; display: inline-block; width: 24px; height: 2px; background: var(--amber); flex-shrink: 0; }
  .section-title { font-family: var(--font-secondary); font-size: clamp(32px, 4vw, 52px); line-height: 1.2; font-weight: 500; color: var(--dark-text); margin-bottom: 20px; }
  .section-span { color: var(--amber); }
  .mnc-btn { display: inline-flex; align-items: center; gap: 10px; padding: 16px; border: 1px solid var(--navy); border-radius: 4px; font-size: 16px; font-weight: 600; text-decoration: none; transition: all 0.25s ease; }
  .mnc-btn--dark { background: var(--amber); border-color: var(--amber); color: var(--navy); font-weight: 700; }
  .mnc-btn--dark:hover { background: var(--amber-dark); border-color: var(--amber-dark); color: var(--white); box-shadow: 0 4px 16px rgba(224,161,53,.35); }
  .mnc-btn--stroke { background: transparent; border-color: rgba(255,255,255,.4); color: var(--white); }
  .mnc-btn--stroke:hover { border-color: var(--amber); color: var(--amber); background: rgba(224,161,53,.08); }
  .mnc-btn__icon { display: flex; width: 20px; height: 20px; }
  .mnc-btn__icon svg { width: 100%; height: 100%; }

  /* Hero */
  .hero-wrap { padding: 16px; }
  .hero-inner { height: 560px; border-radius: 8px; background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); display: flex; align-items: flex-end; position: relative; overflow: hidden; }
  .hero-inner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%); pointer-events: none; }
  .hero-content { position: relative; z-index: 1; padding: 120px 1.5rem 60px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
  .breadcrumb a { color: rgba(255,255,255,.5); text-decoration: none; }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-title { font-family: var(--font-secondary); font-size: clamp(36px, 5vw, 56px); font-weight: 600; line-height: 1.15; color: var(--white); max-width: 700px; margin-bottom: 16px; }
  .hero-sub { color: rgba(255,255,255,.65); font-size: 18px; line-height: 1.7; max-width: 560px; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Overview */
  .lead-overview { background: var(--white); }
  .overview-header { max-width: 720px; margin-bottom: 24px; }
  .overview-body { font-size: 18px; line-height: 1.75; color: var(--text-gray); max-width: 800px; margin: 0; }

  /* Executive Cards */
  .lead-execs { background: var(--off-white); }
  .execs-header { max-width: 720px; margin-bottom: 48px; }
  .execs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px; }
  .exec-card { background: var(--white); border-radius: 8px; padding: 40px 32px; text-align: center; }
  .exec-card__avatar { width: 96px; height: 96px; margin: 0 auto 20px; border-radius: 50%; background: var(--off-white); color: var(--text-gray); display: flex; align-items: center; justify-content: center; overflow: hidden; border: 2px solid rgba(224,161,53,.25); }
  .exec-card__avatar svg { width: 68px; height: 68px; }
  .exec-card__name { font-family: var(--font-secondary); font-size: 22px; font-weight: 600; color: var(--dark-text); margin-bottom: 4px; }
  .exec-card__role { font-weight: 600; color: var(--amber); font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; }
  .exec-card__bio { font-size: 15px; color: var(--text-gray); line-height: 1.65; margin: 0; }

  /* Board Cards */
  .lead-board { background: var(--white); }
  .board-header { max-width: 720px; margin-bottom: 48px; }
  .board-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .board-card { text-align: center; background: var(--off-white); border-radius: 8px; padding: 32px 20px; }
  .board-card__initial { width: 56px; height: 56px; margin: 0 auto 16px; border-radius: 50%; background: var(--navy); color: var(--white); font-family: var(--font-secondary); font-size: 22px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  .board-card__name { font-family: var(--font-secondary); font-size: 16px; font-weight: 600; color: var(--dark-text); margin-bottom: 4px; line-height: 1.3; }
  .board-card__role { font-weight: 600; color: var(--amber); font-size: 13px; margin-bottom: 8px; }
  .board-card__focus { display: inline-block; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; color: var(--navy); background: rgba(36,55,85,.08); padding: 4px 10px; border-radius: 4px; margin-bottom: 12px; }
  .board-card__bio { font-size: 14px; color: var(--text-gray); line-height: 1.55; margin: 0; }

  /* CTA */
  .lead-cta { background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%); position: relative; overflow: hidden; }
  .lead-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 80% 20%, rgba(224,161,53,.1), transparent), radial-gradient(ellipse 60% 50% at 10% 90%, rgba(0,0,0,.12), transparent); pointer-events: none; }
  .cta-inner { position: relative; z-index: 1; text-align: center; max-width: 680px; margin: 0 auto; }
  .cta-title { font-family: var(--font-secondary); font-size: clamp(28px, 3.5vw, 44px); font-weight: 600; color: var(--white); margin-bottom: 16px; }
  .cta-sub { color: rgba(255,255,255,.65); font-size: 17px; line-height: 1.7; margin-bottom: 32px; }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

  @media (max-width: 960px) { .board-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .section-gap { padding: 60px 0; }
    .hero-inner { height: 480px; }
    .hero-content { padding: 80px 1.5rem 40px; }
  }
  @media (max-width: 480px) { .board-grid { grid-template-columns: 1fr; } }
</style>
