---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const isoCards = [
  {
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'ISO 9001',
    subtitle: 'Quality Management',
    desc: 'The cornerstone of our structural integrity, ensuring every component meets manufacturing governance and construction product properties.',
  },
  {
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: 'ISO 14001',
    subtitle: 'Environmental Standards',
    desc: 'Zero-impact modular engineering meets sustainable manufacturing, waste reduction, and pollution prevention through our fully audited operational framework.',
  },
  {
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 12c0 4.97 3.038 9.227 7.354 11.016.34.141.652.213.966.236L12 23.25l.582.006c.314-.023.626-.095.966-.236C17.962 21.227 21 16.97 21 12c0-1.047-.134-2.063-.382-3.016z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'ISO 45001',
    subtitle: 'Safety Systems',
    desc: 'Our zero-harm mission is an operational health & safety practice for the framework for a clear, firm environment for our engineering and fabrication operations.',
  },
];

const safetyFeatures = [
  { title: 'Predictive Risk Assessment', desc: 'AI-driven simulations identify potential hazards in the fabrication sequence BEFORE THEY ENTER THE FIELD ENVIRONMENT.' },
  { title: 'Active Safety Monitoring', desc: 'Real-time monitoring systems and wearable safety tech provide instantaneous risk alerts on the immediate response activation.' },
  { title: 'Continuous Training Modules', desc: 'Quarterly certification updates for all technical staff ensuring comprehensive awareness and adherence of industrial awareness.' },
];

const esgCards = [
  { title: 'Environmental', desc: 'Carbon neutral manufacturing for scalable, 2030 through reduced waste generation and high-efficiency production lines.', img: '/images/showcase/ri-modular-units.jpg' },
  { title: 'Social', desc: 'Investing in local engineering talent and creating green-collar career pathways through community partnerships and equal opportunity recruitment.', img: '/images/showcase/hwb-ri-factory-visit.jpeg' },
  { title: 'Governance', desc: 'Transparent audit trails and board-level oversight. All compliance is documented using GAAP-based internal governance and procurement practices.', img: '' },
];

const patents = [
  { id: 'PAT 7124 S', title: 'Iso-Lock Rigid Framing', desc: 'A variable-torque interlocking system for modular structural steel assembly, designed for seismic zone Level IV specifications.' },
  { id: 'PAT 0044 In', title: 'ThermalBridge Decoupler', desc: 'Precision insulation break mechanism for modular walls and floors, delivering thermal break isolation for moisture and thermal bridging.' },
  { id: 'PAT 0012 Q', title: 'Rapid-Connect Electrical Bus', desc: 'Fast-mating modular electrical bus bar connectors allowing 0.07s connection under loaded-grounded conditions.' },
  { id: 'PAT 7124 Q', title: 'Dynamic Acoustic Barrier', desc: 'Multi-layer partition system incorporating dynamic isolation module for variable-frequency sound attenuation in shared occupancy environments.' },
];
---

<Layout
  title="Credentials & Compliance"
  description="ISO-certified, CAGE-registered, MBE-certified, and bonded — compliance standards and industry certifications for every project we deliver."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="cr-hero">
    <div class="cr-hero__content">
      <h1 class="cr-hero__h1">Architectural<br/>Authority.</h1>
      <p class="cr-hero__sub">
        Establishing the gold standard for modular industrial solutions through rigorous certification, proprietary technical innovation, and an unwavering commitment to safety.
      </p>
    </div>
  </section>

  <!-- ════════ 2. ISO CERTIFICATIONS ════════ -->
  <section class="cr-iso">
    <div class="mnc">
      <div class="cr-iso__head fade-up">
        <h2 class="cr-iso__title">ISO Certifications</h2>
        <p class="cr-iso__sub">
          Our operational governance is guided by globally recognized quality management systems, environmental protections, and rigorously maintained ISO standards to industrial precision.
        </p>
      </div>

      <div class="cr-iso__grid">
        {isoCards.map((card) => (
          <div class="cr-iso__card fade-up">
            <div class="cr-iso__card-icon" set:html={card.icon} />
            <h3 class="cr-iso__card-title">{card.title}</h3>
            <span class="cr-iso__card-sub">{card.subtitle}</span>
            <p class="cr-iso__card-desc">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ 3. ZERO-HARM INITIATIVE ════════ -->
  <section class="cr-safety">
    <div class="mnc">
      <div class="cr-safety__layout fade-up">
        <div class="cr-safety__left">
          <div class="cr-safety__img-wrap">
            <img src="/images/showcase/west-modules.jpg" alt="Safety protocol" loading="lazy" />
            <div class="cr-safety__img-overlay">
              <span class="cr-safety__img-label">Safety<br/>Protocol.</span>
            </div>
            <div class="cr-safety__img-badge">
              <span class="cr-safety__badge-num">0%</span>
            </div>
          </div>
        </div>

        <div class="cr-safety__right">
          <span class="cr-tag">Safety Protocols</span>
          <h2 class="cr-safety__title">Zero-Harm Initiative: Our Non-Negotiable Foundation.</h2>

          <div class="cr-safety__features">
            {safetyFeatures.map((f) => (
              <div class="cr-safety__feature">
                <h4 class="cr-safety__feature-title">{f.title}</h4>
                <p class="cr-safety__feature-desc">{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 4. ESG COMMITMENTS ════════ -->
  <section class="cr-esg">
    <div class="mnc">
      <div class="cr-esg__head fade-up">
        <h2 class="cr-esg__title">ESG Commitments</h2>
        <p class="cr-esg__sub">
          We define Architectural Authority not just by the strength of our structures, but by the integrity of our impact on the world.
        </p>
      </div>

      <div class="cr-esg__grid">
        {esgCards.map((card) => (
          <div class="cr-esg__card fade-up">
            <div class="cr-esg__card-img">
              {card.img ? (
                <img src={card.img} alt={card.title} loading="lazy" />
              ) : (
                <div class="cr-esg__card-placeholder">
                  <span>Governance<br/>Safe Work</span>
                </div>
              )}
            </div>
            <h3 class="cr-esg__card-title">{card.title}</h3>
            <p class="cr-esg__card-desc">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ 5. TECHNICAL PATENTS ════════ -->
  <section class="cr-patents">
    <div class="mnc">
      <div class="cr-patents__head fade-up">
        <h2 class="cr-patents__title">Technical Patents</h2>
        <span class="cr-patents__badge">Proprietary Innovations IP</span>
      </div>

      <div class="cr-patents__grid">
        {patents.map((p) => (
          <div class="cr-patent fade-up">
            <span class="cr-patent__id"># {p.id}</span>
            <div class="cr-patent__divider"></div>
            <h4 class="cr-patent__title">{p.title}</h4>
            <p class="cr-patent__desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }

  .cr-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .cr-tag::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* ═══ 1. HERO ═══ */
  .cr-hero {
    position: relative;
    height: 480px;
    overflow: hidden;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .cr-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .cr-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
  }

  .cr-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20,40,75,.4) 0%, rgba(20,40,75,.85) 100%);
    z-index: 1;
  }

  .cr-hero__lines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .cr-hero__lv {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: rgba(255,255,255,.05);
    transform: scaleY(0);
    transform-origin: top;
    animation: crLV 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .cr-hero__lv--1 { left: 55%; animation-delay: 0.1s; }
  .cr-hero__lv--2 { left: 72%; animation-delay: 0.4s; }
  .cr-hero__lv--3 { left: 90%; animation-delay: 0.7s; }
  .cr-hero__lh {
    position: absolute;
    height: 1px;
    left: 0; right: 0;
    background: rgba(255,255,255,.05);
    transform: scaleX(0);
    transform-origin: left;
    animation: crLH 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .cr-hero__lh--1 { top: 35%; animation-delay: 0.5s; }
  .cr-hero__lh--2 { top: 70%; animation-delay: 0.8s; }
  @keyframes crLV { to { transform: scaleY(1); } }
  @keyframes crLH { to { transform: scaleX(1); } }

  .cr-hero__content {
    position: relative;
    z-index: 3;
    max-width: 1240px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .cr-hero__tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--navy);
    background: var(--amber);
    padding: 6px 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    width: fit-content;
  }

  .cr-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: -2px;
    margin-bottom: 20px;
  }

  .cr-hero__sub {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255,255,255,.45);
    max-width: 480px;
    margin: 0;
  }

  /* ═══ 2. ISO ═══ */
  .cr-iso {
    background: var(--white);
    padding: 100px 0;
  }

  .cr-iso__head {
    margin-bottom: 48px;
  }

  .cr-iso__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--dark-text);
    margin-bottom: 12px;
  }

  .cr-iso__sub {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
    max-width: 640px;
    margin: 0;
  }

  .cr-iso__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .cr-iso__card {
    padding: 36px 32px;
    border: 1px solid rgba(0,0,0,.06);
    margin: -0.5px;
    transition: box-shadow 0.3s ease;
  }

  .cr-iso__card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,.06);
    z-index: 1;
    position: relative;
  }

  .cr-iso__card-icon {
    color: var(--amber-dark);
    margin-bottom: 16px;
  }

  .cr-iso__card-title {
    font-family: var(--font-secondary);
    font-size: 22px;
    font-weight: 900;
    color: var(--dark-text);
    margin-bottom: 4px;
  }

  .cr-iso__card-sub {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-gray);
    margin-bottom: 16px;
  }

  .cr-iso__card-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-gray);
    margin: 0;
  }

  /* ═══ 3. SAFETY ═══ */
  .cr-safety {
    background: var(--off-white);
    padding: 100px 0;
  }

  .cr-safety__layout {
    display: grid;
    grid-template-columns: 0.45fr 0.55fr;
    gap: 56px;
    align-items: center;
  }

  .cr-safety__img-wrap {
    position: relative;
    overflow: hidden;
  }

  .cr-safety__img-wrap img {
    width: 100%;
    display: block;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    filter: brightness(0.35);
  }

  .cr-safety__img-overlay {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 2;
  }

  .cr-safety__img-label {
    font-family: var(--font-secondary);
    font-size: 28px;
    font-weight: 900;
    color: var(--white);
    line-height: 1.1;
    text-transform: uppercase;
  }

  .cr-safety__img-badge {
    position: absolute;
    bottom: 24px;
    left: 24px;
    background: var(--amber);
    padding: 16px 24px;
    border-radius: 8px;
    z-index: 2;
  }

  .cr-safety__badge-num {
    font-family: var(--font-secondary);
    font-size: 32px;
    font-weight: 900;
    color: var(--navy);
    line-height: 1;
  }

  .cr-safety__title {
    font-family: var(--font-secondary);
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 800;
    color: var(--dark-text);
    line-height: 1.15;
    margin-bottom: 32px;
  }

  .cr-safety__features {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .cr-safety__feature {
    padding-left: 16px;
    border-left: 2px solid var(--amber);
  }

  .cr-safety__feature-title {
    font-family: var(--font-secondary);
    font-size: 15px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 4px;
  }

  .cr-safety__feature-desc {
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-gray);
    margin: 0;
  }

  /* ═══ 4. ESG ═══ */
  .cr-esg {
    background: var(--white);
    padding: 100px 0;
  }

  .cr-esg__head {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 48px;
  }

  .cr-esg__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--dark-text);
    margin-bottom: 12px;
  }

  .cr-esg__sub {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
    margin: 0;
  }

  .cr-esg__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .cr-esg__card {
    background: var(--off-white);
    overflow: hidden;
  }

  .cr-esg__card-img {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .cr-esg__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .cr-esg__card:hover .cr-esg__card-img img {
    transform: scale(1.04);
  }

  .cr-esg__card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--navy-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,.15);
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    line-height: 1.3;
  }

  .cr-esg__card-title {
    font-family: var(--font-secondary);
    font-size: 18px;
    font-weight: 700;
    color: var(--dark-text);
    padding: 20px 24px 0;
    margin-bottom: 8px;
  }

  .cr-esg__card-desc {
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-gray);
    padding: 0 24px 24px;
    margin: 0;
  }

  /* ═══ 5. PATENTS ═══ */
  .cr-patents {
    background: var(--off-white);
    padding: 100px 0;
  }

  .cr-patents__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(0,0,0,.08);
  }

  .cr-patents__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--dark-text);
    margin: 0;
  }

  .cr-patents__badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--amber);
  }

  .cr-patents__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .cr-patent {
    padding: 28px 24px;
    background: var(--white);
    border: 1px solid rgba(0,0,0,.06);
    transition: box-shadow 0.3s ease;
  }

  .cr-patent:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,.06);
  }

  .cr-patent__id {
    font-family: var(--font-secondary);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--amber);
    display: block;
  }

  .cr-patent__divider {
    width: 100%;
    height: 1px;
    background: rgba(0,0,0,.06);
    margin: 12px 0 16px;
  }

  .cr-patent__title {
    font-family: var(--font-secondary);
    font-size: 17px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 8px;
  }

  .cr-patent__desc {
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-gray);
    margin: 0;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .cr-safety__layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .cr-iso__grid { grid-template-columns: 1fr; }
    .cr-esg__grid { grid-template-columns: 1fr; }
    .cr-patents__head { flex-direction: column; align-items: flex-start; gap: 12px; }
  }

  @media (max-width: 768px) {
    .cr-hero { height: 380px; }

    .cr-iso,
    .cr-safety,
    .cr-esg,
    .cr-patents { padding: 64px 0; }

    .cr-patents__grid { grid-template-columns: 1fr; }
  }
</style>
