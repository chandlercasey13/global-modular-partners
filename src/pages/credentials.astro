---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const licenseStates = ['California', 'Hawaii', 'Louisiana', 'Nevada', 'Guam'];

const certifications = [
  {
    badge: 'CAGE',
    fullName: 'Commercial and Government Entity Code',
    description:
      'Registered CAGE code (1CHJ1) for SAM.gov visibility, contract vehicle eligibility, and standardized government entity identification.',
  },
  {
    badge: 'MBE',
    fullName: 'Minority-Owned Small Business Enterprise',
    description:
      'Certified Minority-Owned, Small Business Enterprise status supporting diversity-focused procurement, set-aside contracting, and subcontracting goals.',
  },
  {
    badge: 'BONDING',
    fullName: '$25M Single / $50M Aggregate Bonding',
    description:
      'Bonding capacity of $25M per single project and $50M aggregate through Marsh USA Inc., ensuring financial assurance for large-scale programs.',
  },
  {
    badge: 'CLASS A',
    fullName: 'General Engineering Contractor',
    description:
      'California Class A General Engineering Contractor license enabling infrastructure, site work, and heavy civil construction across the state.',
  },
];

---

<Layout
  title="Credentials & Licenses"
  description="CAGE-registered, MBE-certified, Class A licensed, and bonded up to $50M aggregate — multi-state contractor credentials for procurement and compliance teams."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb__sep">/</span>
          <span>Credentials</span>
        </nav>
        <h1 class="hero-title">Credentials &<br /><span class="hero-span">Licenses</span></h1>
        <p class="hero-sub">Verified credentials, compliance standards, and industry certifications that back every project we deliver.</p>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="cert-intro section-gap">
    <div class="mnc-container">
      <div class="cert-intro__head">
        <span class="section-tag">Commitment</span>
        <h2 class="section-title">Excellence you <span class="section-span">can verify with confidence</span></h2>
      </div>
      <div class="cert-intro__copy">
        <p>
          Global Modular Partners invests in certifications, registrations, and state licensing so
          procurement officers, compliance teams, and partners can move forward with confidence.
          Our documentation is maintained for audits, RFP responses, and prime-subcontractor
          workflows.
        </p>
        <p>
          From federal small-business programs to multi-state contractor authority and
          bonding capacity, we align operations with the standards your stakeholders expect.
        </p>
      </div>
    </div>
  </section>

  <!-- Credentials Grid -->
  <section id="credentials" class="cert-creds section-gap">
    <div class="mnc-container">
      <div class="cert-creds__head">
        <span class="section-tag">Credentials</span>
        <h2 class="section-title">Certifications & <span class="section-span">registrations we maintain</span></h2>
      </div>

      <div class="cert-creds__grid">
        {certifications.map((cert) => (
          <article class="cc">
            <span class="cc__badge">{cert.badge}</span>
            <h3 class="cc__name">{cert.fullName}</h3>
            <p class="cc__desc">{cert.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Licenses -->
  <section class="lic-section section-gap">
    <div class="mnc-container">
      <div class="lic-head">
        <span class="section-tag">Licenses</span>
        <h2 class="section-title">State contractor <span class="section-span">licenses across key markets</span></h2>
        <p class="lic-lede">
          Active licensing across key Western markets supports regional programs, public works, and
          cross-border logistics for modular deployment.
        </p>
      </div>
      <div class="lic-pills">
        {licenseStates.map((state) => (
          <span class="lic-pill">{state}</span>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Hero ── */
  .hero-wrap { padding: 0; }
  .hero-inner {
    height: 490px;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%);
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }
  .hero-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 20%, rgba(224,161,53,.08), transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(0,0,0,.15), transparent 60%);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 1; padding: 80px 1.5rem 36px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px)); width: 100%; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,.5);
    margin-bottom: 20px;
  }
  .breadcrumb a { color: rgba(255,255,255,.5); }
  .breadcrumb a:hover { color: var(--amber); }
  .breadcrumb__sep { color: rgba(255,255,255,.25); }
  .hero-title {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--white);
    max-width: 700px;
    margin-bottom: 16px;
  }
  .hero-span {
    color: rgba(255,255,255,.5);
  }
  .hero-sub {
    color: rgba(255,255,255,.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
  }
  /* ── MNC Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    font-family: var(--font-primary);
    font-size: 15px;
    font-weight: 600;
    border-radius: 4px;
    text-decoration: none;
    transition: all 200ms ease;
    cursor: pointer;
    border: 1px solid transparent;
    line-height: 1;
  }
  .mnc-btn__wrap {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .mnc-btn__icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
    transition: transform 200ms ease;
  }
  .mnc-btn__icon svg {
    width: 100%;
    height: 100%;
  }
  .mnc-btn:hover .mnc-btn__icon {
    transform: translateX(3px);
  }
  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border-color: var(--amber);
    font-weight: 700;
  }
  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }
  .mnc-btn--amber {
    background: var(--amber);
    color: var(--navy);
  }
  .mnc-btn--amber:hover {
    background: var(--amber-dark);
    color: #fff;
  }
  .mnc-btn--stroke {
    background: transparent;
    border-color: rgba(255,255,255,.3);
    color: #fff;
  }
  .mnc-btn--stroke:hover {
    border-color: var(--amber);
    color: var(--amber);
  }

  /* ── Container & Section ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .section-gap {
    padding: 100px 0;
  }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin-bottom: 0;
  }
  .section-span {
    color: var(--amber);
  }

  /* ── Intro ── */
  .cert-intro {
    background: #fff;
  }
  .cert-intro__head {
    text-align: center;
    margin-bottom: 40px;
  }
  .cert-intro__copy {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .cert-intro__copy p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-gray);
    margin-bottom: 16px;
  }
  .cert-intro__copy p:last-child {
    margin-bottom: 0;
  }

  /* ── Credentials ── */
  .cert-creds {
    background: var(--off-white);
  }
  .cert-creds__head {
    margin-bottom: 56px;
  }
  .cert-creds__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (max-width: 768px) {
    .hero-inner { height: 400px; }
    .hero-content { padding: 60px 1.5rem 24px; }
    .cert-creds__grid {
      grid-template-columns: 1fr;
    }
  }

  .cc {
    background: #fff;
    border-radius: 8px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cc__badge {
    display: inline-block;
    width: fit-content;
    padding: 6px 16px;
    background: var(--navy);
    color: #fff;
    border-radius: 4px;
    font-family: var(--font-secondary);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: .03em;
  }
  .cc__name {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--dark-text);
    margin: 0;
  }
  .cc__desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-gray);
    margin: 0;
  }

  /* ── Licenses ── */
  .lic-section {
    background: #fff;
  }
  .lic-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 48px;
  }
  .lic-lede {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
    margin-top: 16px;
  }
  .lic-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  .lic-pill {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    font-family: var(--font-secondary);
    font-weight: 600;
    font-size: 15px;
    color: var(--dark-text);
    background: var(--off-white);
    border: 1px solid #dedede;
    border-radius: 4px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .lic-pill:hover {
    border-color: var(--amber);
    box-shadow: 0 2px 8px rgba(224, 161, 53, 0.15);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .section-gap {
      padding: 64px 0;
    }
    .cert-creds__head,
    .cert-intro__head {
      text-align: left;
    }
    .cert-intro__copy {
      text-align: left;
    }
  }
</style>
