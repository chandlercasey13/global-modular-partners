---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageCTA from '../components/PageCTA.astro';

/**
 * Project spotlights delivered through Global Modular Partners' affiliated
 * entities — Hospitals Without Borders (hospitalswithoutborders.org) and
 * RI Group (rigroup.it). Card pattern mirrors the partners page (`pt-case`).
 */
const caseStudies = [
  {
    tag: 'HWB · Emergency Healthcare',
    title: 'Gaza Clinic — Type I',
    desc: 'Scalable modular field hospital delivering immediate clinical capacity where permanent infrastructure has been damaged or destroyed. The Type I configuration starts at 10 beds with a compact footprint that can be rapidly expanded, with integrated clinical and support spaces for emergency, inpatient, and outpatient care.',
    value: '10+ beds',
    location: 'Gaza, Palestine',
    img: '/images/showcase/hwb-field-hospital.webp',
  },
  {
    tag: 'HWB · Pediatric Infrastructure',
    title: "Sant'Anna Fuheis Children's Hospital",
    desc: 'Purpose-built pediatric medical center in the Al-Balqa governorate, designed as a permanent children\'s hospital with multi-level clinical wings, naturally lit double-height atriums, dedicated play and rehabilitation areas, and landscaped courtyards — creating a child-friendly healing environment for pediatric populations across the region.',
    value: 'Pediatric Permanent',
    location: 'Fuheis, Jordan',
    img: '/images/showcase/hwb-modular-pediatric.jpeg',
  },
  {
    tag: 'HWB · Genetics Research',
    title: "Genetics Laboratory · Bambino Gesù Di Cairo",
    desc: "Egypt's first specialized center for maternal and child genetic research and diagnosis, developed in partnership with Bambino Gesù Pediatric Hospital. Houses next-generation sequencing, a four-bed bone marrow transplant unit, and training programs — addressing high incidence of thalassemia, chromosomal syndromes, and hereditary metabolic disorders.",
    value: 'Sponsor: Fraternity For Humanity',
    location: 'Cairo, Egypt',
    img: '/images/showcase/hwb-pediatric-egypt.jpeg',
  },
  {
    tag: 'HWB · Tribal Healthcare',
    title: 'Project SAGE — Mobile Clinics for Tribal Communities',
    desc: 'A multi-site national initiative (Sovereignty, Access, Growth, Equity) strengthening healthcare delivery across Tribal-serving communities. Deploys mobile clinical units alongside primary care, chronic disease management, and behavioral health services — integrating Tribal-controlled data sovereignty, workforce pipelines, and secure digital infrastructure.',
    value: '6 initial sites',
    location: 'United States (Multi-Site)',
    img: '/images/showcase/hwb-teledoc.jpeg',
  },
  {
    tag: 'RI Group · Defence Medical',
    title: 'Field Hospital MTF ROLE 2B',
    desc: 'Patented field hospital designed for use in areas of ongoing military operations, proven highly effective for emergency interventions and national disaster relief. Delivered to the Italian Ministry of Defence as a rapidly deployable ISO-standard system with full surgical and triage capacity.',
    value: 'Italian Ministry of Defence',
    location: 'Italy',
    img: '/images/showcase/ri-medical-shelter.jpg',
  },
  {
    tag: 'RI Group · Biocontainment',
    title: 'Biocontainment Unit — Italian Ministry of Defence',
    desc: 'Patented, state-of-the-art container unit deployable as a stand-alone system or combined with other modular healthcare facilities to treat infectious diseases under full safety and containment protocols. Eight ISO 20-ft modules delivered with a three-day assembly envelope.',
    value: '8 × ISO 20′ · 3-day assembly',
    location: 'Italy',
    img: '/images/showcase/hwb-surgery-cutaway.png',
  },
  {
    tag: 'RI Group · Defence Compound',
    title: 'Forward Military Compound',
    desc: 'Full-scale modular military compound combining accommodation, offices, canteen, kitchen, laundry, ablution, armory, gate control, and technical plants. Integrates telescopic armored towers, Hesco bastion works, and surbunker shelters — engineered for rapid deployment in demanding operational environments.',
    value: 'Turn-key deployment',
    location: 'International Operations',
    img: '/images/showcase/ri-defense-base.png',
  },
  {
    tag: 'RI Group · Civil Infrastructure',
    title: 'Carabinieri Station & Police Infrastructure',
    desc: 'Permanent modular police stations and civil government facilities delivered across Italian and international sites. Buildings meet full seismic and permanent-use structural standards while compressing project timelines through factory-controlled production and pre-fitted MEP systems.',
    value: 'Permanent Structure',
    location: 'Italy',
    img: '/images/showcase/ri-carabinieri-station.png',
  },
  {
    tag: 'RI Group · Civil Compound',
    title: 'Civil Compound — Commercial & Government',
    desc: 'Multi-building modular compound delivering government administrative space, commercial floors, and support infrastructure within a single coordinated site. Steel-frame modular construction delivers permanent-grade aesthetics while cutting on-site construction time against conventional build.',
    value: 'Multi-block delivery',
    location: 'Mediterranean Basin',
    img: '/images/showcase/ri-civil-compound-aerial.png',
  },
  {
    tag: 'RI Group · Residential',
    title: 'Permanent Modular Residential Development',
    desc: 'Permanent residential buildings delivered through RI Group\'s modular building system — structurally engineered for long service life with full thermal, acoustic, and finish performance equivalent to conventional construction. Planned, fabricated, and delivered through a single coordinated program.',
    value: 'Permanent Residential',
    location: 'Italy',
    img: '/images/showcase/ri-permanent-building-wide.png',
  },
];

---

<Layout
  title="Projects"
  description="A comprehensive archive of modular delivery systems across international territories, emphasizing technical compliance and structural performance."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="pj-hero">
    <div class="pj-hero__panel">
      <canvas id="projects-hero-3d" class="pj-hero__canvas" aria-hidden="true"></canvas>
      <span class="pj-hero__canvas-tag" aria-hidden="true">Module in Transit</span>
      <div class="pj-hero__content">
        <h1 class="pj-hero__h1">Global Scale.<br/>Precision Delivery.</h1>
        <p class="pj-hero__sub">
          A comprehensive archive of modular delivery systems across international territories, emphasizing technical compliance and structural performance.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ 2. PROJECT SPOTLIGHTS (same card system as partners — pt-case) ════════ -->
  <section class="pt-cases">
    <div class="mnc-container">
      <div class="pt-cases__head fade-up">
        <span class="pt-tag">Portfolio</span>
        <h2 class="pt-cases__title">Project delivery through the GMP alliance</h2>
        <p class="pt-cases__sub">
          Selected projects delivered through Global Modular Partners' affiliated entities —
          Hospitals Without Borders and RI Group — spanning deployable healthcare,
          defence infrastructure, and permanent civil and residential construction.
        </p>
      </div>

      <div class="pt-cases__grid">
        {caseStudies.map((cs) => (
          <article class="pt-case fade-up">
            <div class="pt-case__img-wrap">
              <img src={cs.img} alt={cs.title} class="pt-case__img" loading="lazy" />
              <span class="pt-case__img-tag">{cs.tag}</span>
            </div>
            <h3 class="pt-case__title">{cs.title}</h3>
            <p class="pt-case__desc">{cs.desc}</p>
            {(cs.value || cs.location) && (
              <div class="pt-case__meta">
                {cs.value && <span class="pt-case__meta-item"><strong>Project Value:</strong> {cs.value}</span>}
                {cs.location && <span class="pt-case__meta-item"><strong>Location:</strong> {cs.location}</span>}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <PageCTA
    eyebrow="How it gets made"
    title="Curious how these projects<br/>actually come together?"
    image="/images/showcase/ri-factory-production.jpg"
    links={[
      { label: 'Our Services', href: '/services' },
      { label: 'About GMP', href: '/about' },
    ]}
  />

  <script>
    // ───────────────────────────────────────────────────────────────
    // PROJECTS — hero 3D: "Module in Transit"
    // A module suspended from a crane gantry by four cables, with a
    // slight pendulum sway. Reads as "precision delivery."
    // ───────────────────────────────────────────────────────────────
    import * as THREE from 'three';

    const canvas = document.getElementById('projects-hero-3d') as HTMLCanvasElement | null;
    if (canvas) {
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
      camera.position.set(8.4, 4.2, 10.6);
      camera.lookAt(0, 1.2, 0);

      // Shared wireframe materials (homepage style)
      const occluderMat = new THREE.MeshBasicMaterial({
        colorWrite: false,
        depthWrite: true,
        depthTest: true,
        side: THREE.DoubleSide,
        polygonOffset: true,
        polygonOffsetFactor: 1,
        polygonOffsetUnits: 1,
      });
      const lineMat = new THREE.LineBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0.92,
        depthTest: true,
        depthWrite: false,
        polygonOffset: true,
        polygonOffsetFactor: -1,
        polygonOffsetUnits: -1,
      });
      function wire(geometry: THREE.BufferGeometry): THREE.Group {
        const g = new THREE.Group();
        const shell = new THREE.Mesh(geometry, occluderMat);
        shell.renderOrder = 0;
        const edges = new THREE.LineSegments(
          new THREE.EdgesGeometry(geometry, 1),
          lineMat,
        );
        edges.renderOrder = 1;
        g.add(shell);
        g.add(edges);
        return g;
      }
      /** Bare white line (for cables — no depth occluder needed). */
      function wireLineCyl(radius: number, length: number, seg = 6): THREE.LineSegments {
        const geom = new THREE.CylinderGeometry(radius, radius, length, seg);
        return new THREE.LineSegments(new THREE.EdgesGeometry(geom, 1), lineMat);
      }

      // ── Gantry crane: two uprights + horizontal beam
      const gantry = new THREE.Group();
      const upL = wire(new THREE.BoxGeometry(0.28, 5.2, 0.28));
      upL.position.set(-3.2, 2.6, 0);
      gantry.add(upL);
      const upR = wire(new THREE.BoxGeometry(0.28, 5.2, 0.28));
      upR.position.set(3.2, 2.6, 0);
      gantry.add(upR);

      const beam = wire(new THREE.BoxGeometry(7.0, 0.32, 0.36));
      beam.position.set(0, 5.1, 0);
      gantry.add(beam);
      // Beam lower rail
      const beamRail = wire(new THREE.BoxGeometry(6.6, 0.06, 0.38));
      beamRail.position.set(0, 4.92, 0);
      gantry.add(beamRail);

      // Base feet
      const footL = wire(new THREE.BoxGeometry(0.9, 0.16, 0.9));
      footL.position.set(-3.2, 0.08, 0);
      gantry.add(footL);
      const footR = wire(new THREE.BoxGeometry(0.9, 0.16, 0.9));
      footR.position.set(3.2, 0.08, 0);
      gantry.add(footR);

      scene.add(gantry);

      // ── Module that swings
      const swing = new THREE.Group();
      scene.add(swing);

      const W = 3.2, H = 1.4, D = 1.7;
      const body = wire(new THREE.BoxGeometry(W, H, D));
      body.position.y = H / 2;
      swing.add(body);

      // Belt seam
      const belt = wire(new THREE.BoxGeometry(W + 0.02, 0.06, D + 0.02));
      belt.position.y = H * 0.62;
      swing.add(belt);

      // Top cap
      const cap = wire(new THREE.BoxGeometry(W + 0.04, 0.1, D + 0.04));
      cap.position.y = H + 0.01;
      swing.add(cap);

      // Corner posts
      [[-1, -1], [1, -1], [-1, 1], [1, 1]].forEach(([sx, sz]) => {
        const post = wire(new THREE.BoxGeometry(0.1, H + 0.12, 0.1));
        post.position.set(sx * (W / 2), H / 2, sz * (D / 2));
        swing.add(post);
      });

      // Vertical ribs on long faces
      for (let side = -1; side <= 1; side += 2) {
        for (let i = 1; i <= 4; i++) {
          const t = i / 5;
          const rib = wire(new THREE.BoxGeometry(0.02, H * 0.82, 0.03));
          rib.position.set(-W / 2 + t * W, H / 2, side * (D / 2 + 0.001));
          swing.add(rib);
        }
      }

      // Lift lugs
      const lugs: Array<[number, number]> = [
        [-W / 2 + 0.35,  D / 2 - 0.35],
        [ W / 2 - 0.35,  D / 2 - 0.35],
        [-W / 2 + 0.35, -D / 2 + 0.35],
        [ W / 2 - 0.35, -D / 2 + 0.35],
      ];
      lugs.forEach(([x, z]) => {
        const lug = wire(new THREE.BoxGeometry(0.14, 0.12, 0.14));
        lug.position.set(x, H + 0.12, z);
        swing.add(lug);
      });

      // ── Cables (thin white wireframe cylinders from beam down to lugs)
      const cables: THREE.LineSegments[] = [];
      lugs.forEach(() => {
        const cable = wireLineCyl(0.018, 1);
        scene.add(cable);
        cables.push(cable);
      });
      function positionCables(modulePos: THREE.Vector3, moduleRotZ: number) {
        const beamY = 5.1;
        const cosZ = Math.cos(moduleRotZ);
        const sinZ = Math.sin(moduleRotZ);
        for (let i = 0; i < lugs.length; i++) {
          const [lx, lz] = lugs[i];
          // Rotate lug's local (lx, H+0.12) around Z by moduleRotZ, then translate
          const localY = H + 0.12;
          const rx = lx * cosZ - localY * sinZ;
          const ry = lx * sinZ + localY * cosZ;
          const worldX = modulePos.x + rx;
          const worldY = modulePos.y + ry;
          const worldZ = modulePos.z + lz;
          // Beam attachment point directly above in world space
          const bx = worldX;
          const by = beamY;
          const bz = worldZ;
          const dx = bx - worldX;
          const dy = by - worldY;
          const dz = bz - worldZ;
          const len = Math.sqrt(dx * dx + dy * dy + dz * dz);
          const cable = cables[i];
          cable.position.set((worldX + bx) / 2, (worldY + by) / 2, (worldZ + bz) / 2);
          cable.scale.set(1, len, 1);
          // Align with direction
          const axis = new THREE.Vector3(dx, dy, dz).normalize();
          const up = new THREE.Vector3(0, 1, 0);
          const quat = new THREE.Quaternion().setFromUnitVectors(up, axis);
          cable.quaternion.copy(quat);
        }
      }


      function resize() {
        if (!canvas) return;
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;
        if (w === 0 || h === 0) return;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }
      resize();
      const ro = new ResizeObserver(resize);
      ro.observe(canvas);
      window.addEventListener('resize', resize);

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let paused = false;
      const io = new IntersectionObserver((entries) => {
        paused = !entries[0].isIntersecting;
      }, { threshold: 0.01 });
      io.observe(canvas);

      // Hover height (module floats up by this much)
      const hoverY = 2.0;
      const moduleWorldPos = new THREE.Vector3();

      let t0 = performance.now();
      function tick(now: number) {
        const dt = (now - t0) / 1000;
        t0 = now;
        if (!paused) {
          const sway = reduced ? 0 : Math.sin(now * 0.0011) * 0.06;
          const driftX = reduced ? 0 : Math.sin(now * 0.00055) * 0.35;
          swing.position.x = driftX;
          swing.position.y = hoverY;
          swing.position.z = 0;
          swing.rotation.z = sway;
          scene.rotation.y = reduced ? 0 : Math.sin(now * 0.0003) * 0.15;

          swing.getWorldPosition(moduleWorldPos);
          positionCables(moduleWorldPos, sway);

          renderer.render(scene, camera);
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  </script>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1440px; margin: 0 auto; padding: 0 1.5rem; }

  /* Headings use Barlow only on this page (no Sora) */
  h1, h2, h3, h4 {
    font-family: var(--font-primary);
  }

  .pt-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-bottom: 20px;
  }
  .pt-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ink);
    flex-shrink: 0;
  }

  /* ═══ 1. HERO ═══ */
  .pj-hero {
    position: relative;
    background: #fff;
    padding: 0;
  }

  .pj-hero__panel {
    position: relative;
    height: 480px;
    overflow: hidden;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .pj-hero__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .pj-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
  }

  .pj-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20,40,75,.4) 0%, rgba(20,40,75,.85) 100%);
    z-index: 1;
  }

  .pj-hero__lines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .pj-hero__lv {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: rgba(255,255,255,.05);
    transform: scaleY(0);
    transform-origin: top;
    animation: pjLineV 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .pj-hero__lv--1 { left: 55%; animation-delay: 0.1s; }
  .pj-hero__lv--2 { left: 72%; animation-delay: 0.4s; }
  .pj-hero__lv--3 { left: 90%; animation-delay: 0.7s; }
  .pj-hero__lh {
    position: absolute;
    height: 1px;
    left: 0; right: 0;
    background: rgba(255,255,255,.05);
    transform: scaleX(0);
    transform-origin: left;
    animation: pjLineH 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .pj-hero__lh--1 { top: 35%; animation-delay: 0.5s; }
  .pj-hero__lh--2 { top: 70%; animation-delay: 0.8s; }
  @keyframes pjLineV { to { transform: scaleY(1); } }
  @keyframes pjLineH { to { transform: scaleX(1); } }

  .pj-hero__content {
    position: relative;
    z-index: 3;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .pj-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: none;
    letter-spacing: -2px;
    margin-bottom: 20px;
  }

  .pj-hero__sub {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255,255,255,.45);
    max-width: 480px;
    margin: 0;
  }

  /* 3D hero accent — crane lifting a module */
  .pj-hero__canvas {
    position: absolute;
    top: 0;
    right: 0;
    width: clamp(360px, 58%, 780px);
    height: 100%;
    z-index: 2;
    pointer-events: none;
    display: block;
    touch-action: none;
    mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 100%);
  }
  .pj-hero__canvas-tag {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 4;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.55);
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(8, 16, 30, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  @media (max-width: 768px) {
    .pj-hero__canvas,
    .pj-hero__canvas-tag {
      display: none;
    }
  }

  /* ═══ 2. CASE STUDY CARDS — matches partners page (`.pt-case`) ═══ */
  .pt-cases {
    background: var(--paper-2);
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }

  .pt-cases__head {
    margin-bottom: 48px;
    max-width: 60rem;
  }

  .pt-cases__title {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-weight: 500;
    letter-spacing: var(--tracking-tighter);
    color: var(--ink);
    line-height: 1.05;
    margin: 0 0 18px;
  }

  .pt-cases__sub {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
    max-width: 48rem;
  }

  .pt-cases__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .pt-case {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .pt-case:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: #d6d6d1;
  }

  .pt-case__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    margin: 12px 12px 0;
    border-radius: var(--radius-lg);
  }

  .pt-case__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .pt-case:hover .pt-case__img { transform: scale(1.04); }

  .pt-case__img-tag {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(6px);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
  }

  .pt-case__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    padding: 24px 24px 8px;
  }

  .pt-case__desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--muted);
    padding: 0 24px;
    margin: 0 0 20px;
  }

  .pt-case__meta {
    display: flex;
    gap: 24px;
    padding: 16px 24px 24px;
    border-top: 1px solid var(--line);
    margin-top: 8px;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .pt-case__meta-item strong {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
    font-size: 0.68rem;
    color: var(--ink);
    display: block;
    margin-bottom: 2px;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .pt-cases__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .pj-hero__panel { height: 380px; }
    .pt-cases {
      padding: 40px 0;
    }
  }
</style>
