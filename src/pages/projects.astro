---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageCTA from '../components/PageCTA.astro';

const featured = {
  tag: 'Case Study 01',
  title: 'The Meridian Heights Assembly',
  location: 'Odessa, TX',
  duration: '18 Weeks',
  desc: 'A 120-unit residential modular tower utilizing our proprietary partnership framework — collaborating with 4 independent specialized contractors. Precision logistics integration reduced on-site waste by 45%. Achieving a 33% reduction in carbon footprint compared to traditional RC casting.',
};

const projects = [
  {
    tag: 'Project / Residential',
    title: 'West Modular Blvd Complex',
    desc: 'Modular-type scalable data center facility optimized for natural thermal regulation.',
    img: '/images/showcase/west-blvd-render.jpg',
  },
  {
    tag: 'Project / Defense',
    title: 'Forward Operations Compound',
    desc: 'Rapid deployment of 200,000 sf of facilities across demanding operational conditions.',
    img: '/images/showcase/ri-defense-base.png',
  },
  {
    tag: 'Project / Healthcare',
    title: 'St. Jude Medical Wing',
    desc: 'Integrated surgical-grade modular modules delivered within a live hospital operational environment.',
    img: '/images/showcase/hwb-clinic-interior.jpeg',
  },
];

---

<Layout
  title="Projects"
  description="A comprehensive archive of modular delivery systems across international territories, emphasizing technical compliance and structural performance."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="pj-hero">
    <div class="pj-hero__panel">
      <canvas id="projects-hero-3d" class="pj-hero__canvas" aria-hidden="true"></canvas>
      <span class="pj-hero__canvas-tag" aria-hidden="true">Module in Transit</span>
      <div class="pj-hero__content">
        <h1 class="pj-hero__h1">Global Scale.<br/>Precision Delivery.</h1>
        <p class="pj-hero__sub">
          A comprehensive archive of modular delivery systems across international territories, emphasizing technical compliance and structural performance.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ 2. CASE STUDY ════════ -->
  <section class="pj-case">
    <div class="mnc">
      <div class="pj-case__layout fade-up">
        <div class="pj-case__left">
          <span class="pj-tag">{featured.tag}</span>
          <h2 class="pj-case__title">{featured.title} · <span class="pj-case__location">{featured.location}</span></h2>
          <span class="pj-case__duration">{featured.duration}</span>
          <p class="pj-case__desc">{featured.desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 3. FEATURED IMAGE ════════ -->
  <section class="pj-featured-img">
    <div class="mnc">
      <div class="pj-featured-img__wrap fade-up">
        <img src="/images/showcase/ri-civil-compound-aerial.png" alt="Modular civil compound" loading="lazy" />
        <div class="pj-featured-img__card">
          <h4 class="pj-featured-img__card-title">■ Digital Archive</h4>
          <div class="pj-featured-img__card-rows">
            <div class="pj-featured-img__card-row">
              <span>Total Active Files</span>
              <span class="pj-featured-img__card-val">408</span>
            </div>
            <div class="pj-featured-img__card-row">
              <span>Compliance Level</span>
              <span class="pj-featured-img__card-val pj-featured-img__card-val--green">7,038 ↓</span>
            </div>
            <div class="pj-featured-img__card-row">
              <span>Energy Efficiency</span>
              <span class="pj-featured-img__card-val pj-featured-img__card-val--green">A+++</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 4. PROJECT GRID ════════ -->
  <section class="pj-grid-section">
    <div class="mnc">
      <div class="pj-grid">
        {projects.map((p) => (
          <article class="pj-card fade-up">
            <div class="pj-card__img-wrap">
              <img src={p.img} alt={p.title} loading="lazy" />
            </div>
            <div class="pj-card__body">
              <span class="pj-card__tag">{p.tag}</span>
              <h3 class="pj-card__title">{p.title}</h3>
              <p class="pj-card__desc">{p.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <PageCTA
    eyebrow="How it gets made"
    title="Curious how these projects<br/>actually come together?"
    image="/images/showcase/ri-factory-production.jpg"
    links={[
      { label: 'Our Services', href: '/services' },
      { label: 'About GMP', href: '/about' },
    ]}
  />

  <script>
    // ───────────────────────────────────────────────────────────────
    // PROJECTS — hero 3D: "Module in Transit"
    // A module suspended from a crane gantry by four cables, with a
    // slight pendulum sway. Reads as "precision delivery."
    // ───────────────────────────────────────────────────────────────
    import * as THREE from 'three';

    const canvas = document.getElementById('projects-hero-3d') as HTMLCanvasElement | null;
    if (canvas) {
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
      camera.position.set(8.4, 4.2, 10.6);
      camera.lookAt(0, 1.2, 0);

      // Shared wireframe materials (homepage style)
      const occluderMat = new THREE.MeshBasicMaterial({
        colorWrite: false,
        depthWrite: true,
        depthTest: true,
        side: THREE.DoubleSide,
        polygonOffset: true,
        polygonOffsetFactor: 1,
        polygonOffsetUnits: 1,
      });
      const lineMat = new THREE.LineBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0.92,
        depthTest: true,
        depthWrite: false,
        polygonOffset: true,
        polygonOffsetFactor: -1,
        polygonOffsetUnits: -1,
      });
      function wire(geometry: THREE.BufferGeometry): THREE.Group {
        const g = new THREE.Group();
        const shell = new THREE.Mesh(geometry, occluderMat);
        shell.renderOrder = 0;
        const edges = new THREE.LineSegments(
          new THREE.EdgesGeometry(geometry, 1),
          lineMat,
        );
        edges.renderOrder = 1;
        g.add(shell);
        g.add(edges);
        return g;
      }
      /** Bare white line (for cables — no depth occluder needed). */
      function wireLineCyl(radius: number, length: number, seg = 6): THREE.LineSegments {
        const geom = new THREE.CylinderGeometry(radius, radius, length, seg);
        return new THREE.LineSegments(new THREE.EdgesGeometry(geom, 1), lineMat);
      }

      // ── Gantry crane: two uprights + horizontal beam
      const gantry = new THREE.Group();
      const upL = wire(new THREE.BoxGeometry(0.28, 5.2, 0.28));
      upL.position.set(-3.2, 2.6, 0);
      gantry.add(upL);
      const upR = wire(new THREE.BoxGeometry(0.28, 5.2, 0.28));
      upR.position.set(3.2, 2.6, 0);
      gantry.add(upR);

      const beam = wire(new THREE.BoxGeometry(7.0, 0.32, 0.36));
      beam.position.set(0, 5.1, 0);
      gantry.add(beam);
      // Beam lower rail
      const beamRail = wire(new THREE.BoxGeometry(6.6, 0.06, 0.38));
      beamRail.position.set(0, 4.92, 0);
      gantry.add(beamRail);

      // Base feet
      const footL = wire(new THREE.BoxGeometry(0.9, 0.16, 0.9));
      footL.position.set(-3.2, 0.08, 0);
      gantry.add(footL);
      const footR = wire(new THREE.BoxGeometry(0.9, 0.16, 0.9));
      footR.position.set(3.2, 0.08, 0);
      gantry.add(footR);

      scene.add(gantry);

      // ── Module that swings
      const swing = new THREE.Group();
      scene.add(swing);

      const W = 3.2, H = 1.4, D = 1.7;
      const body = wire(new THREE.BoxGeometry(W, H, D));
      body.position.y = H / 2;
      swing.add(body);

      // Belt seam
      const belt = wire(new THREE.BoxGeometry(W + 0.02, 0.06, D + 0.02));
      belt.position.y = H * 0.62;
      swing.add(belt);

      // Top cap
      const cap = wire(new THREE.BoxGeometry(W + 0.04, 0.1, D + 0.04));
      cap.position.y = H + 0.01;
      swing.add(cap);

      // Corner posts
      [[-1, -1], [1, -1], [-1, 1], [1, 1]].forEach(([sx, sz]) => {
        const post = wire(new THREE.BoxGeometry(0.1, H + 0.12, 0.1));
        post.position.set(sx * (W / 2), H / 2, sz * (D / 2));
        swing.add(post);
      });

      // Vertical ribs on long faces
      for (let side = -1; side <= 1; side += 2) {
        for (let i = 1; i <= 4; i++) {
          const t = i / 5;
          const rib = wire(new THREE.BoxGeometry(0.02, H * 0.82, 0.03));
          rib.position.set(-W / 2 + t * W, H / 2, side * (D / 2 + 0.001));
          swing.add(rib);
        }
      }

      // Lift lugs
      const lugs: Array<[number, number]> = [
        [-W / 2 + 0.35,  D / 2 - 0.35],
        [ W / 2 - 0.35,  D / 2 - 0.35],
        [-W / 2 + 0.35, -D / 2 + 0.35],
        [ W / 2 - 0.35, -D / 2 + 0.35],
      ];
      lugs.forEach(([x, z]) => {
        const lug = wire(new THREE.BoxGeometry(0.14, 0.12, 0.14));
        lug.position.set(x, H + 0.12, z);
        swing.add(lug);
      });

      // ── Cables (thin white wireframe cylinders from beam down to lugs)
      const cables: THREE.LineSegments[] = [];
      lugs.forEach(() => {
        const cable = wireLineCyl(0.018, 1);
        scene.add(cable);
        cables.push(cable);
      });
      function positionCables(modulePos: THREE.Vector3, moduleRotZ: number) {
        const beamY = 5.1;
        const cosZ = Math.cos(moduleRotZ);
        const sinZ = Math.sin(moduleRotZ);
        for (let i = 0; i < lugs.length; i++) {
          const [lx, lz] = lugs[i];
          // Rotate lug's local (lx, H+0.12) around Z by moduleRotZ, then translate
          const localY = H + 0.12;
          const rx = lx * cosZ - localY * sinZ;
          const ry = lx * sinZ + localY * cosZ;
          const worldX = modulePos.x + rx;
          const worldY = modulePos.y + ry;
          const worldZ = modulePos.z + lz;
          // Beam attachment point directly above in world space
          const bx = worldX;
          const by = beamY;
          const bz = worldZ;
          const dx = bx - worldX;
          const dy = by - worldY;
          const dz = bz - worldZ;
          const len = Math.sqrt(dx * dx + dy * dy + dz * dz);
          const cable = cables[i];
          cable.position.set((worldX + bx) / 2, (worldY + by) / 2, (worldZ + bz) / 2);
          cable.scale.set(1, len, 1);
          // Align with direction
          const axis = new THREE.Vector3(dx, dy, dz).normalize();
          const up = new THREE.Vector3(0, 1, 0);
          const quat = new THREE.Quaternion().setFromUnitVectors(up, axis);
          cable.quaternion.copy(quat);
        }
      }


      function resize() {
        if (!canvas) return;
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;
        if (w === 0 || h === 0) return;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }
      resize();
      const ro = new ResizeObserver(resize);
      ro.observe(canvas);
      window.addEventListener('resize', resize);

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let paused = false;
      const io = new IntersectionObserver((entries) => {
        paused = !entries[0].isIntersecting;
      }, { threshold: 0.01 });
      io.observe(canvas);

      // Hover height (module floats up by this much)
      const hoverY = 2.0;
      const moduleWorldPos = new THREE.Vector3();

      let t0 = performance.now();
      function tick(now: number) {
        const dt = (now - t0) / 1000;
        t0 = now;
        if (!paused) {
          const sway = reduced ? 0 : Math.sin(now * 0.0011) * 0.06;
          const driftX = reduced ? 0 : Math.sin(now * 0.00055) * 0.35;
          swing.position.x = driftX;
          swing.position.y = hoverY;
          swing.position.z = 0;
          swing.rotation.z = sway;
          scene.rotation.y = reduced ? 0 : Math.sin(now * 0.0003) * 0.15;

          swing.getWorldPosition(moduleWorldPos);
          positionCables(moduleWorldPos, sway);

          renderer.render(scene, camera);
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  </script>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc { max-width: 1440px; margin: 0 auto; padding: 0 1.5rem; }

  /* Headings use Barlow only on this page (no Sora) */
  h1, h2, h3, h4 {
    font-family: var(--font-primary);
  }

  .pj-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-bottom: 20px;
  }
  .pj-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--ink);
    flex-shrink: 0;
  }
  .pj-tag--hero { color: rgba(255,255,255,.5); }
  .pj-tag--hero::before { background: var(--amber); }

  /* ═══ 1. HERO ═══ */
  .pj-hero {
    position: relative;
    background: #fff;
    padding: 0;
  }

  .pj-hero__panel {
    position: relative;
    height: 480px;
    overflow: hidden;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .pj-hero__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .pj-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
  }

  .pj-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20,40,75,.4) 0%, rgba(20,40,75,.85) 100%);
    z-index: 1;
  }

  .pj-hero__lines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .pj-hero__lv {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: rgba(255,255,255,.05);
    transform: scaleY(0);
    transform-origin: top;
    animation: pjLineV 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .pj-hero__lv--1 { left: 55%; animation-delay: 0.1s; }
  .pj-hero__lv--2 { left: 72%; animation-delay: 0.4s; }
  .pj-hero__lv--3 { left: 90%; animation-delay: 0.7s; }
  .pj-hero__lh {
    position: absolute;
    height: 1px;
    left: 0; right: 0;
    background: rgba(255,255,255,.05);
    transform: scaleX(0);
    transform-origin: left;
    animation: pjLineH 1.6s cubic-bezier(.22,.68,.36,1) forwards;
  }
  .pj-hero__lh--1 { top: 35%; animation-delay: 0.5s; }
  .pj-hero__lh--2 { top: 70%; animation-delay: 0.8s; }
  @keyframes pjLineV { to { transform: scaleY(1); } }
  @keyframes pjLineH { to { transform: scaleX(1); } }

  .pj-hero__content {
    position: relative;
    z-index: 3;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .pj-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    text-transform: none;
    letter-spacing: -2px;
    margin-bottom: 20px;
  }

  .pj-hero__sub {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255,255,255,.45);
    max-width: 480px;
    margin: 0;
  }

  /* 3D hero accent — crane lifting a module */
  .pj-hero__canvas {
    position: absolute;
    top: 0;
    right: 0;
    width: clamp(360px, 58%, 780px);
    height: 100%;
    z-index: 2;
    pointer-events: none;
    display: block;
    touch-action: none;
    mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 100%);
  }
  .pj-hero__canvas-tag {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 4;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.55);
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(8, 16, 30, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  @media (max-width: 768px) {
    .pj-hero__canvas,
    .pj-hero__canvas-tag {
      display: none;
    }
  }

  /* ═══ 2. CASE STUDY (aeline) ═══ */
  .pj-case {
    background: var(--paper);
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }

  .pj-case__layout {
    max-width: 52rem;
  }

  .pj-case__title {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-weight: 500;
    letter-spacing: var(--tracking-tighter);
    color: var(--ink);
    margin-bottom: 16px;
    line-height: 1.05;
  }

  .pj-case__location {
    color: var(--muted);
    font-weight: 400;
  }

  .pj-case__duration {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--ink);
    border: 1px solid var(--line);
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    margin-bottom: 20px;
  }

  .pj-case__desc {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  /* ═══ 3. FEATURED IMAGE (aeline) ═══ */
  .pj-featured-img {
    background: var(--paper);
    padding: 0 0 clamp(3.5rem, 7vw, 6rem);
  }

  .pj-featured-img__wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2xl);
  }

  .pj-featured-img__wrap img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    filter: brightness(0.5);
  }

  .pj-featured-img__card {
    position: absolute;
    top: 24px;
    right: 24px;
    background: var(--paper);
    padding: 24px;
    width: 260px;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--line);
  }

  .pj-featured-img__card-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .pj-featured-img__card-rows {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pj-featured-img__card-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .pj-featured-img__card-val {
    font-weight: 600;
    color: var(--ink);
  }

  .pj-featured-img__card-val--green {
    color: #2d9e5a;
  }

  /* ═══ 4. PROJECT GRID (aeline) ═══ */
  .pj-grid-section {
    background: var(--paper);
    padding: 0 0 clamp(3.5rem, 7vw, 6rem);
  }

  .pj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .pj-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .pj-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: #d6d6d1;
  }

  .pj-card__img-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin: 12px 12px 0;
    border-radius: var(--radius-lg);
  }

  .pj-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .pj-card:hover .pj-card__img-wrap img {
    transform: scale(1.04);
  }

  .pj-card__body {
    padding: 24px;
  }

  .pj-card__tag {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .pj-card__title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 10px;
  }

  .pj-card__desc {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 1024px) {
    .pj-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .pj-hero__panel { height: 380px; }
    .pj-case { padding: 64px 0; }
    .pj-grid { grid-template-columns: 1fr; }
    .pj-featured-img__card { display: none; }
  }
</style>
