---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const certifications = [
  {
    badge: 'SDVOSB',
    fullName: 'Service-Disabled Veteran-Owned Small Business',
    description:
      'Verified SDVOSB status supporting federal set-asides, sole-source pathways, and subcontracting goals for agencies and primes.',
  },
  {
    badge: '8(a)',
    fullName: 'SBA 8(a) Business Development Program',
    description:
      'Participation in the 8(a) program to accelerate capability reviews, mentor-protégé structures, and compliant teaming arrangements.',
  },
  {
    badge: 'ISO 9001',
    fullName: 'Quality Management System',
    description:
      'Certified QMS alignment for documented processes, audit readiness, and consistent quality across design, fabrication, and delivery.',
  },
  {
    badge: 'CAGE',
    fullName: 'Commercial and Government Entity Code',
    description:
      'Registered CAGE code for SAM.gov visibility, contract vehicle eligibility, and standardized government entity identification.',
  },
];

const licenseStates = ['California', 'Nevada', 'Arizona', 'Texas', 'Oregon'];

const partners = [
  {
    name: 'West Modular Manufacturing',
    type: 'Manufacturing',
    description:
      'Modular factory production and volumetric unit fabrication.',
  },
  {
    name: 'PROSET Construction',
    type: 'Construction',
    description:
      'General contracting and on-site modular assembly.',
  },
  {
    name: 'TRUE NORTH Compliance',
    type: 'Compliance',
    description:
      'Regulatory compliance, permitting, and code consulting.',
  },
  {
    name: 'EnTech Engineering',
    type: 'Engineering',
    description:
      'Structural, mechanical, and electrical engineering services.',
  },
  {
    name: 'Agbayani Construction Corporation',
    type: 'Construction',
    description:
      'Civil and modular general contracting.',
  },
  {
    name: 'STREAM Logistics',
    type: 'Logistics',
    description:
      'Module transportation, shipping, and delivery coordination.',
  },
  {
    name: 'ATCCO Construction',
    type: 'Construction',
    description:
      'Specialty construction and installation services.',
  },
  {
    name: 'Petra Air Conditioning',
    type: 'MEP',
    description:
      'HVAC systems design and installation for modular units.',
  },
  {
    name: 'Petra Aluminum',
    type: 'Materials',
    description:
      'Aluminum fabrication for facades and structural components.',
  },
  {
    name: 'Abstract Architecture',
    type: 'Architecture',
    description:
      'Architectural design and BIM coordination.',
  },
];
---

<Layout
  title="Partners & Alliance Network"
  description="Global Modular Partners' alliance network spans manufacturing, construction, healthcare, and emergency response."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero-wrap">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-breadcrumb">
          <a href="/">Home</a>
          <span class="hero-breadcrumb__sep">/</span>
          <span>Partners & Alliance Network</span>
        </div>
        <h1>Partners & Alliance<br /><span class="hero-span">Network</span></h1>
        <p class="hero-subtitle">
          Building together with industry leaders across manufacturing, construction, healthcare, and emergency response.
        </p>
        <div class="hero-actions">
          <a href="#network" class="mnc-btn mnc-btn--dark">
            <span class="mnc-btn__wrap">
              <span>Explore the network</span>
              <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
            </span>
          </a>
          <a href="#become-partner" class="mnc-btn mnc-btn--stroke">
            <span class="mnc-btn__wrap">
              <span>Become a partner</span>
              <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Alliance Intro -->
  <section id="network" class="alliance-section section-gap">
    <div class="mnc-container">
      <div class="alliance-center">
        <span class="section-tag">Alliance</span>
        <h2 class="section-title">A network built for <span class="section-span">complex programs</span></h2>
        <div class="alliance-copy">
          <p>
            Global Modular Partners curates an alliance network that unites manufacturing scale,
            construction execution, healthcare delivery, and emergency-response readiness. Together,
            we shorten procurement cycles, de-risk delivery, and align every stakeholder to a single
            program standard.
          </p>
          <p>
            Whether you are a public agency, a healthcare operator, or a commercial developer, our
            partners extend GMP's reach with specialized capabilities—without sacrificing compliance,
            safety, or schedule integrity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partners Grid -->
  <section class="partners-section section-gap">
    <div class="mnc-container">
      <span class="section-tag">Strategic Partners</span>
      <h2 class="section-title">Leaders across every <span class="section-span">critical vertical</span></h2>
      <p class="partners-lead">
        Each relationship is intentional: complementary strengths, shared accountability, and a
        commitment to modular excellence from factory floor to final inspection.
      </p>

      <div class="partners-grid">
        {partners.map((partner) => (
          <article class="partner-card">
            <div class="partner-card__top">
              <h3 class="partner-card__name">{partner.name}</h3>
              <span class="partner-card__pill">{partner.type}</span>
            </div>
            <p class="partner-card__desc">{partner.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Become a Partner -->
  <section id="become-partner" class="become-section section-gap">
    <div class="mnc-container">
      <div class="become-card">
        <div class="become-card__content">
          <span class="section-tag">Collaborate</span>
          <h2 class="section-title">Become a <span class="section-span">partner</span></h2>
          <p class="become-card__copy">
            We welcome organizations that share our standards for quality, transparency, and
            mission-driven delivery. Tell us about your capabilities—we'll explore alignment with
            active programs and future pipeline opportunities.
          </p>
          <a href="/contact" class="mnc-btn mnc-btn--dark">
            <span class="mnc-btn__wrap">
              <span>Start a conversation</span>
              <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
            </span>
          </a>
        </div>
        <div class="become-card__accent" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- Certifications & Licenses -->
  <section id="certifications" class="cert-section section-gap">
    <div class="mnc-container">
      <span class="section-tag">Certifications</span>
      <h2 class="section-title">Licenses & <span class="section-span">Certifications</span></h2>
      <p class="cert-lead">
        Global Modular Partners maintains federal certifications, ISO registrations, and multi-state
        contractor licenses so procurement officers and compliance teams can move forward with confidence.
      </p>

      <div class="cert-grid">
        {certifications.map((cert) => (
          <article class="cert-card">
            <span class="cert-card__badge">{cert.badge}</span>
            <h3 class="cert-card__name">{cert.fullName}</h3>
            <p class="cert-card__desc">{cert.description}</p>
          </article>
        ))}
      </div>

      <div class="cert-licenses">
        <h3 class="cert-licenses__title">State contractor <span class="section-span">licenses</span></h3>
        <p class="cert-licenses__lede">
          Active licensing across key Western markets supports regional programs, public works, and
          cross-border logistics for modular deployment.
        </p>
        <div class="cert-licenses__pills">
          {licenseStates.map((state) => (
            <span class="cert-licenses__pill">{state}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section section-gap">
    <div class="mnc-container">
      <div class="cta-inner">
        <h2 class="section-title cta-title">See our <span class="cta-span">delivery network</span></h2>
        <p class="cta-body">
          Explore how GMP's alliance of manufacturers, builders, and specialists supports modular programs end to end —
          from credentials and compliance through execution.
        </p>
        <div class="cta-actions">
          <a href="/services" class="mnc-btn mnc-btn--dark">
            <span class="mnc-btn__wrap">
              <span>View Our Work</span>
              <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
            </span>
          </a>
          <a href="#certifications" class="mnc-btn mnc-btn--stroke">
            <span class="mnc-btn__wrap">
              <span>View credentials</span>
              <span class="mnc-btn__icon"><svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg></span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ── Container & Spacing ── */
  .mnc-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-gap {
    padding: 100px 0;
  }

  /* ── Section Tag ── */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--amber);
    margin-bottom: 20px;
    padding: 0;
    border: none;
    border-radius: 0;
  }
  .section-tag::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* ── Section Title ── */
  .section-title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.2;
    font-weight: 500;
    color: var(--dark-text);
    margin-bottom: 24px;
  }

  .section-span {
    color: var(--amber);
  }

  /* ── Buttons ── */
  .mnc-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 500;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    cursor: pointer;
    line-height: 1;
  }

  .mnc-btn__wrap {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .mnc-btn__icon {
    display: inline-flex;
    align-items: center;
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .mnc-btn__icon svg {
    width: 100%;
    height: 100%;
  }

  .mnc-btn:hover .mnc-btn__icon {
    transform: translateX(3px);
  }

  .mnc-btn--dark {
    background: var(--amber);
    color: var(--navy);
    border-color: var(--amber);
    font-weight: 700;
  }

  .mnc-btn--dark:hover {
    background: var(--amber-dark);
    border-color: var(--amber-dark);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(224,161,53,.35);
  }

  .mnc-btn--outline {
    background: transparent;
    color: var(--navy);
    border-color: var(--navy);
  }

  .mnc-btn--outline:hover {
    background: var(--navy);
    color: #fff;
  }

  .mnc-btn--stroke {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .mnc-btn--stroke:hover {
    border-color: #fff;
    color: #fff;
  }

  /* ── Hero ── */
  .hero-wrap {
    padding: 16px;
  }

  .hero-inner {
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
    border-radius: 8px;
    height: 560px;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }

  .hero-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 120px 1.5rem 56px max(1.5rem, calc(50vw - 620px + 1.5rem - 16px));
    width: 100%;
  }

  .hero-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 24px;
  }

  .hero-breadcrumb a {
    color: rgba(255, 255, 255, 0.5);
  }

  .hero-breadcrumb a:hover {
    color: var(--amber);
  }

  .hero-breadcrumb__sep {
    color: rgba(255, 255, 255, 0.25);
  }

  .hero-content h1 {
    font-family: var(--font-secondary);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 600;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 20px;
    max-width: 680px;
  }

  .hero-span {
    color: rgba(255, 255, 255, 0.5);
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ── Alliance Section (white bg) ── */
  .alliance-section {
    background: #fff;
  }

  .alliance-center {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .alliance-center .section-title {
    margin-bottom: 32px;
  }

  .alliance-copy {
    text-align: left;
    max-width: 700px;
    margin: 0 auto;
  }

  .alliance-copy p {
    color: var(--text-gray);
    font-size: 17px;
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .alliance-copy p:last-child {
    margin-bottom: 0;
  }

  /* ── Partners Grid (off-white bg) ── */
  .partners-section {
    background: var(--off-white);
  }

  .partners-lead {
    color: var(--text-gray);
    font-size: 17px;
    line-height: 1.7;
    max-width: 620px;
    margin-bottom: 48px;
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .partner-card {
    background: #fff;
    border-radius: 8px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow 0.3s ease;
  }

  .partner-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .partner-card__top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .partner-card__name {
    font-family: var(--font-secondary);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 600;
    color: var(--dark-text);
    margin: 0;
    flex: 1;
    min-width: 180px;
  }

  .partner-card__pill {
    display: inline-block;
    border: 1px solid #8f8f8f;
    border-radius: 4px;
    padding: 4px 14px;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-gray);
    white-space: nowrap;
  }

  .partner-card__desc {
    margin: 0;
    color: var(--text-gray);
    font-size: 16px;
    line-height: 1.7;
  }

  /* ── Become a Partner (white bg) ── */
  .become-section {
    background: #fff;
  }

  .become-card {
    display: grid;
    grid-template-columns: 1fr minmax(140px, 300px);
    align-items: stretch;
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #dedede;
    max-width: 1000px;
  }

  .become-card__content {
    padding: 48px 40px;
  }

  .become-card__copy {
    color: var(--text-gray);
    font-size: 17px;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .become-card__accent {
    background: linear-gradient(145deg, var(--navy-dark) 0%, var(--navy) 45%, var(--navy-light) 100%);
    position: relative;
    min-height: 140px;
  }

  .become-card__accent::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 40%, rgba(224, 161, 53, 0.18), transparent 55%);
    pointer-events: none;
  }

  /* ── CTA Section (navy bg) ── */
  .cta-section {
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 100%);
  }

  .cta-inner {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .cta-title {
    color: #fff;
  }

  .cta-span {
    color: rgba(255, 255, 255, 0.5);
  }

  .cta-body {
    color: rgba(255, 255, 255, 0.65);
    font-size: 18px;
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  /* ── Certifications Section (off-white bg) ── */
  .cert-section {
    background: var(--off-white);
  }

  .cert-lead {
    color: var(--text-gray);
    font-size: 17px;
    line-height: 1.7;
    max-width: 680px;
    margin-bottom: 48px;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 72px;
  }

  .cert-card {
    background: #fff;
    border-radius: 8px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow 0.3s ease;
  }

  .cert-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .cert-card__badge {
    display: inline-block;
    width: fit-content;
    padding: 6px 16px;
    background: var(--navy);
    color: #fff;
    border-radius: 4px;
    font-family: var(--font-secondary);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.03em;
  }

  .cert-card__name {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--dark-text);
    margin: 0;
  }

  .cert-card__desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-gray);
    margin: 0;
  }

  .cert-licenses {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cert-licenses__title {
    font-family: var(--font-secondary);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 500;
    line-height: 1.2;
    color: var(--dark-text);
    margin-bottom: 16px;
  }

  .cert-licenses__lede {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-gray);
    margin-bottom: 32px;
  }

  .cert-licenses__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .cert-licenses__pill {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    font-family: var(--font-secondary);
    font-weight: 600;
    font-size: 15px;
    color: var(--dark-text);
    background: #fff;
    border: 1px solid #dedede;
    border-radius: 4px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .cert-licenses__pill:hover {
    border-color: var(--amber);
    box-shadow: 0 2px 8px rgba(224, 161, 53, 0.15);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .partners-grid {
      grid-template-columns: 1fr;
    }

    .cert-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .section-gap {
      padding: 64px 0;
    }

    .become-card {
      grid-template-columns: 1fr;
    }

    .become-card__content {
      padding: 32px 24px;
    }

    .hero-content {
      padding: 80px 1.5rem 40px;
    }

    .hero-inner {
      height: 480px;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .mnc-btn {
      width: 100%;
      justify-content: center;
    }

    .cta-actions {
      flex-direction: column;
      align-items: center;
    }

    .cta-actions .mnc-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
