---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const partners = [
  { name: 'West Modular', logo: '/images/partners/west-og.png' },
  { name: 'PROSET Construction', logo: '/images/partners/proset-footer.png' },
  { name: 'TRUE NORTH Compliance', logo: '/images/partners/true-north.svg' },
  { name: 'EnTech Engineering', logo: '/images/partners/entech.svg' },
  { name: 'Agbayani Construction', logo: '/images/partners/agbayani-real.png' },
  { name: 'STREAM Logistics', logo: '/images/partners/stream-dark.png' },
];

const caseStudies = [
  {
    tag: 'Multi-Unit Residential',
    title: 'The Meridian Heights Assembly',
    desc: 'Collaborating with 4 independent specialized contractors to deploy 120 modular units in 18 weeks. Precision logistics integration reduced on-site waste by 45%.',
    value: '$24M',
    location: 'Odessa, TX',
    img: '/images/showcase/ri-permanent-building-wide.png',
  },
  {
    tag: 'Healthcare Infrastructure',
    title: 'Surgical Excellence Clinic',
    desc: 'An end-to-end partnership with medical equipment manufacturers to pre-install Grade A clinical environments within modular frames, meeting all clinical compliance certifications.',
    value: '',
    location: '',
    img: '/images/showcase/hwb-modular-pediatric.jpeg',
  },
];

const affiliatedEntities = [
  {
    name: 'RI Group USA',
    logo: '/images/partners/ri-group.png',
    focus: 'Manufacturing & International Supply Chain',
    desc: 'International modular construction and manufacturing. Parent company based in Lecce, Italy with global project delivery capability across Europe, the Middle East, and North America.',
    link: '/partners',
  },
  {
    name: 'Hospitals Without Borders',
    logo: '/images/partners/hwb.svg',
    focus: 'Deployable Medical Infrastructure',
    desc: 'Deployable modular medical infrastructure for humanitarian and emergency response settings. Headquartered in Oakland, CA with active operations in Rome, Italy and Amman, Jordan.',
    link: '/partners',
  },
  {
    name: 'Agbayani Construction',
    logo: '/images/partners/agbayani-real.png',
    focus: 'Civil & Modular General Contracting',
    desc: 'Civil and modular general contracting services, headquartered in Daly City, CA with active operations across the Bay Area and Western United States.',
    link: '/partners',
  },
  {
    name: 'EDIS USA',
    logo: '/images/partners/edis.png',
    focus: 'Emergency Management & Preparedness',
    desc: 'Early warning systems and disaster preparedness technology for emergency management agencies. Supporting resilience infrastructure across government and civilian sectors.',
    link: '/partners',
  },
];

const protocols = [
  { num: '01', title: 'Centralized Command', desc: 'All partnership communications are routed through our Secure Portal. This creates a single source of truth for all schedule, financial, and change order management.' },
  { num: '02', title: 'Vetting Directory', desc: 'Potential partners must undergo the Pre-Qualification Audit covering financial stability, ethical compliance, and verifiable performance history.' },
  { num: '03', title: 'Transparent Inquiry', desc: 'We maintain a strict inquiry directory. Partners are assigned dedicated Liaison Officers to ensure clarity of deliverables and adherence to decision-making cycles.' },
];

const contacts = [
  { label: 'Alliance Partnerships', email: 'alliances@globalmodularpartners.com' },
  { label: 'Engineering Inquiries', email: 'engineering@globalmodularpartners.com' },
  { label: 'Procurement Office', email: 'procurement@globalmodularpartners.com' },
  { label: 'Corporate Affairs', email: 'governance@globalmodularpartners.com' },
];
---

<Layout
  title="Partners & Alliance Network"
  description="Global Modular Partners' alliance network spans manufacturing, construction, healthcare, and emergency response."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="pt-hero">
    <div class="pt-hero__inner">
      <div class="pt-hero__content">
        <h1 class="pt-hero__h1">A Network<br/>Built on Trust</h1>
        <p class="pt-hero__sub">
          Engineering excellence is not a solo endeavor. We curate a specialized ecosystem of global modular experts to deliver uncompromised architectural authority.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ 2. AFFILIATED ENTITIES ════════ -->
  <section class="pt-entities">
    <div class="mnc-container">
      <div class="pt-entities__head fade-up">
        <span class="pt-tag">Partner Network</span>
        <h2 class="pt-entities__title">Affiliated Entities</h2>
        <p class="pt-entities__sub">
          Global Modular Partners operates through a structured network of specialized affiliated entities — each bringing distinct expertise in manufacturing, civil contracting, healthcare infrastructure, and emergency management.
        </p>
      </div>
      <div class="pt-entities__grid">
        {affiliatedEntities.map((e) => (
          <div class="pt-entity fade-up">
            <div class="pt-entity__logo-wrap">
              <img src={e.logo} alt={e.name} class="pt-entity__logo" loading="lazy" />
            </div>
            <div class="pt-entity__body">
              <h3 class="pt-entity__name">{e.name}</h3>
              <span class="pt-entity__focus">{e.focus}</span>
              <p class="pt-entity__desc">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ 3. STRATEGIC ALLIANCES ════════ -->
  <section class="pt-alliances">
    <div class="mnc-container">
      <div class="pt-alliances__top fade-up">
        <h2 class="pt-alliances__title">Strategic<br/>Alliances</h2>
        <p class="pt-alliances__desc">
          Our trade partners are vetted through a rigorous proprietary multi-point qualification process. We maintain long-term relationships with leaders in steel fabrication, logistics, and precision interior finishing.
        </p>
      </div>

      <div class="pt-alliances__grid fade-up">
        {partners.map((p) => (
          <div class="pt-alliances__logo-card">
            <img src={p.logo} alt={p.name} title={p.name} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ 3. CASE STUDIES ════════ -->
  <section class="pt-cases">
    <div class="mnc-container">
      <div class="pt-cases__head fade-up">
        <span class="pt-tag">Proven Performance</span>
        <h2 class="pt-cases__title">Case Studies in Partnership</h2>
      </div>

      <div class="pt-cases__grid">
        {caseStudies.map((cs) => (
          <article class="pt-case fade-up">
            <div class="pt-case__img-wrap">
              <img src={cs.img} alt={cs.title} class="pt-case__img" loading="lazy" />
              <span class="pt-case__img-tag">{cs.tag}</span>
            </div>
            <h3 class="pt-case__title">{cs.title}</h3>
            <p class="pt-case__desc">{cs.desc}</p>
            {(cs.value || cs.location) && (
              <div class="pt-case__meta">
                {cs.value && <span class="pt-case__meta-item"><strong>Project Value:</strong> {cs.value}</span>}
                {cs.location && <span class="pt-case__meta-item"><strong>Location:</strong> {cs.location}</span>}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1440px; margin: 0 auto; padding: 0 1.5rem; }

  .pt-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--text-gray);
    margin-bottom: 16px;
  }
  .pt-tag::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* ═══ 1. HERO ═══ */
  .pt-hero {
    position: relative;
    background: #fff;
    padding: clamp(6px, 0.6vw, 10px);
  }

  .pt-hero__inner {
    position: relative;
    height: 480px;
    overflow: hidden;
    border-radius: clamp(14px, 1.6vw, 22px);
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .pt-hero__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
  }

  .pt-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
  }

  .pt-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(30,58,102,.5) 0%, rgba(30,58,102,.92) 100%);
    z-index: 1;
  }

  .pt-hero__content {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .pt-hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
    margin-bottom: 20px;
    width: fit-content;
  }

  .pt-hero__tag::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .pt-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    letter-spacing: -2px;
    text-transform: none;
    margin-bottom: 20px;
  }

  .pt-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,.5);
    max-width: 480px;
    margin: 0;
  }

  /* ═══ 2. ALLIANCES ═══ */
  .pt-alliances {
    background: var(--section-blue);
    padding: 56px 0;
  }

  .pt-alliances__top {
    display: grid;
    grid-template-columns: 0.4fr 0.6fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 64px;
  }

  .pt-alliances__title {
    font-family: var(--font-secondary);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    color: var(--dark-text);
    line-height: 1.1;
    margin: 0;
  }

  .pt-alliances__desc {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
  }

  .pt-alliances__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .pt-alliances__logo-card {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    border: 1px solid rgba(0,0,0,.06);
    margin: -0.5px;
    transition: background 0.2s ease;
  }

  .pt-alliances__logo-card:hover {
    background: var(--off-white);
  }

  .pt-alliances__logo-card img {
    height: 36px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(1) opacity(0.5);
    transition: filter 0.3s ease;
  }

  .pt-alliances__logo-card:hover img {
    filter: grayscale(0) opacity(1);
  }

  /* ═══ 3. CASE STUDIES ═══ */
  .pt-cases {
    background: var(--off-white);
    padding: 56px 0;
  }

  .pt-cases__head {
    margin-bottom: 48px;
  }

  .pt-cases__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    color: var(--dark-text);
    margin: 0;
  }

  .pt-cases__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .pt-case {
    background: var(--section-blue);
    border-radius: 0;
    overflow: hidden;
  }

  .pt-case__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .pt-case__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .pt-case:hover .pt-case__img {
    transform: scale(1.04);
  }

  .pt-case__img-tag {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--white);
    background: rgba(43,75,126,.85);
    backdrop-filter: blur(6px);
    padding: 6px 14px;
    border-radius: 4px;
  }

  .pt-case__title {
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 700;
    color: var(--dark-text);
    margin: 0;
    padding: 24px 24px 8px;
  }

  .pt-case__desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-gray);
    padding: 0 24px;
    margin: 0 0 16px;
  }

  .pt-case__meta {
    display: flex;
    gap: 24px;
    padding: 0 24px 24px;
    font-size: 12px;
    color: var(--text-gray);
  }

  .pt-case__meta-item strong {
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 10px;
    color: var(--dark-text);
    display: block;
    margin-bottom: 2px;
  }

  /* ═══ 2. AFFILIATED ENTITIES ═══ */
  .pt-entities {
    background: var(--section-blue);
    padding: 56px 0;
  }

  .pt-entities__head {
    margin-bottom: 56px;
    max-width: 720px;
  }

  .pt-entities__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 16px;
  }

  .pt-entities__sub {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-gray);
    margin: 0;
  }

  .pt-entities__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .pt-entity {
    background: var(--off-white);
    border: 1px solid rgba(0,0,0,.05);
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .pt-entity:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,.1);
    transform: translateY(-4px);
  }

  .pt-entity__logo-wrap {
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: var(--white);
    border-bottom: 1px solid rgba(0,0,0,.05);
  }

  .pt-entity__logo {
    max-width: 100%;
    max-height: 72px;
    object-fit: contain;
    filter: grayscale(1) brightness(0.8);
    transition: filter 0.3s ease;
  }

  .pt-entity:hover .pt-entity__logo {
    filter: grayscale(0) brightness(1);
  }

  .pt-entity__body {
    padding: 24px;
  }

  .pt-entity__name {
    font-family: var(--font-secondary);
    font-size: 16px;
    font-weight: 700;
    color: var(--dark-text);
    margin-bottom: 4px;
  }

  .pt-entity__focus {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--amber-dark);
    margin-bottom: 12px;
  }

  .pt-entity__desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-gray);
    margin: 0;
  }

  /* ═══ 3. ISO CERTIFICATIONS ═══ */
  .pt-iso {
    background: var(--off-white);
    padding: 56px 0;
  }

  .pt-iso__head {
    margin-bottom: 48px;
  }

  .pt-iso__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--dark-text);
    margin-bottom: 12px;
  }

  .pt-iso__sub {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
    max-width: 640px;
    margin: 0;
  }

  .pt-iso__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .pt-iso__card {
    padding: 36px 32px;
    background: var(--white);
    border: 1px solid rgba(0,0,0,.06);
    margin: -0.5px;
    transition: box-shadow 0.3s ease;
  }

  .pt-iso__card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,.06);
    z-index: 1;
    position: relative;
  }

  .pt-iso__card-icon {
    color: var(--amber-dark);
    margin-bottom: 16px;
  }

  .pt-iso__card-title {
    font-family: var(--font-secondary);
    font-size: 22px;
    font-weight: 900;
    color: var(--dark-text);
    margin-bottom: 4px;
  }

  .pt-iso__card-sub {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-gray);
    margin-bottom: 16px;
  }

  .pt-iso__card-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-gray);
    margin: 0;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .pt-alliances__top {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .pt-alliances__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .pt-cases__grid {
      grid-template-columns: 1fr;
    }

    .pt-iso__grid { grid-template-columns: 1fr; }
    .pt-entities__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .pt-hero__inner { height: 380px; }

    .pt-alliances,
    .pt-cases,
    .pt-iso,
    .pt-entities {
      padding: 40px 0;
    }

    .pt-iso__grid { grid-template-columns: 1fr; }
    .pt-entities__grid { grid-template-columns: 1fr; }
  }
</style>
