---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageCTA from '../components/PageCTA.astro';

const partners = [
  { name: 'West Modular', logo: '/images/partners/west-og.png', url: 'https://www.westmodular.com' },
  { name: 'PROSET Construction', logo: '/images/partners/proset-footer.png', url: 'https://www.prosetconstruction.com' },
  { name: 'TRUE NORTH Compliance', logo: '/images/partners/true-north.svg', url: 'https://truenorthcompliance.com' },
  { name: 'EnTech Engineering', logo: '/images/partners/entech.svg', url: 'https://entechengineers.com' },
  { name: 'Agbayani Construction', logo: '/images/partners/agbayani-real.png', url: 'https://agbayaniconstruction.com' },
  { name: 'STREAM Logistics', logo: '/images/partners/stream-dark.png', url: 'https://streamlogistics.com' },
];

const caseStudies = [
  {
    tag: 'Multi-Unit Residential',
    title: 'The Meridian Heights Assembly',
    desc: 'Collaborating with 4 independent specialized contractors to deploy 120 modular units in 18 weeks. Precision logistics integration reduced on-site waste by 45%.',
    value: '$24M',
    location: 'Odessa, TX',
    img: '/images/showcase/ri-permanent-building-wide.png',
  },
  {
    tag: 'Healthcare Infrastructure',
    title: 'Surgical Excellence Clinic',
    desc: 'An end-to-end partnership with medical equipment manufacturers to pre-install Grade A clinical environments within modular frames, meeting all clinical compliance certifications.',
    value: '',
    location: '',
    img: '/images/showcase/hwb-modular-pediatric.jpeg',
  },
];

const affiliatedEntities = [
  {
    name: 'RI Group USA',
    logo: '/images/partners/ri-group.png',
    focus: 'Manufacturing & International Supply Chain',
    desc: 'International modular construction and manufacturing. Parent company based in Lecce, Italy with global project delivery capability across Europe, the Middle East, and North America.',
    url: 'https://www.rigroup.it',
  },
  {
    name: 'Hospitals Without Borders',
    logo: '/images/partners/hwb.svg',
    focus: 'Deployable Medical Infrastructure',
    desc: 'Deployable modular medical infrastructure for humanitarian and emergency response settings. Headquartered in Oakland, CA with active operations in Rome, Italy and Amman, Jordan.',
    url: 'https://hospitalswithoutborders.org',
  },
  {
    name: 'Agbayani Construction',
    logo: '/images/partners/agbayani-real.png',
    focus: 'Civil & Modular General Contracting',
    desc: 'Civil and modular general contracting services, headquartered in Daly City, CA with active operations across the Bay Area and Western United States.',
    url: 'https://agbayaniconstruction.com',
  },
  {
    name: 'EDIS USA',
    logo: '/images/partners/edis.png',
    focus: 'Emergency Management & Preparedness',
    desc: 'Early warning systems and disaster preparedness technology for emergency management agencies. Supporting resilience infrastructure across government and civilian sectors.',
    url: 'https://www.edisgroup.com',
  },
];

const protocols = [
  { num: '01', title: 'Centralized Command', desc: 'All partnership communications are routed through our Secure Portal. This creates a single source of truth for all schedule, financial, and change order management.' },
  { num: '02', title: 'Vetting Directory', desc: 'Potential partners must undergo the Pre-Qualification Audit covering financial stability, ethical compliance, and verifiable performance history.' },
  { num: '03', title: 'Transparent Inquiry', desc: 'We maintain a strict inquiry directory. Partners are assigned dedicated Liaison Officers to ensure clarity of deliverables and adherence to decision-making cycles.' },
];

const contacts = [
  { label: 'Alliance Partnerships', email: 'alliances@globalmodularpartners.com' },
  { label: 'Engineering Inquiries', email: 'engineering@globalmodularpartners.com' },
  { label: 'Procurement Office', email: 'procurement@globalmodularpartners.com' },
  { label: 'Corporate Affairs', email: 'governance@globalmodularpartners.com' },
];
---

<Layout
  title="Partners & Alliance Network"
  description="Global Modular Partners' alliance network spans manufacturing, construction, healthcare, and emergency response."
>
  <Header slot="header" />

  <!-- ════════ 1. HERO ════════ -->
  <section class="pt-hero">
    <div class="pt-hero__inner">
      <div class="pt-hero__content">
        <h1 class="pt-hero__h1">A Network<br/><span class="pt-hero__h1-sub">Built on Trust</span></h1>
        <p class="pt-hero__sub">
          Engineering excellence is not a solo endeavor. We curate a specialized ecosystem of global modular experts to deliver uncompromised architectural authority.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ 2. AFFILIATED ENTITIES ════════ -->
  <section class="pt-entities">
    <div class="mnc-container">
      <div class="pt-entities__head fade-up">
        <span class="pt-tag">Partner Network</span>
        <h2 class="pt-entities__title">Affiliated Entities</h2>
        <p class="pt-entities__sub">
          Global Modular Partners operates through a structured network of specialized affiliated entities — each bringing distinct expertise in manufacturing, civil contracting, healthcare infrastructure, and emergency management.
        </p>
      </div>
      <div class="pt-entities__grid">
        {affiliatedEntities.map((e) => (
          <a
            class="pt-entity fade-up"
            href={e.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Visit ${e.name}`}
          >
            <div class="pt-entity__logo-wrap">
              <img src={e.logo} alt={e.name} class="pt-entity__logo" loading="lazy" />
            </div>
            <div class="pt-entity__body">
              <h3 class="pt-entity__name">
                {e.name}
                <span class="pt-entity__arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M9 7h8v8"/></svg>
                </span>
              </h3>
              <span class="pt-entity__focus">{e.focus}</span>
              <p class="pt-entity__desc">{e.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ 3. STRATEGIC ALLIANCES ════════ -->
  <section class="pt-alliances">
    <div class="mnc-container">
      <div class="pt-alliances__top fade-up">
        <h2 class="pt-alliances__title">Strategic<br/>Alliances</h2>
        <p class="pt-alliances__desc">
          Our trade partners are vetted through a rigorous proprietary multi-point qualification process. We maintain long-term relationships with leaders in steel fabrication, logistics, and precision interior finishing.
        </p>
      </div>

      <div class="pt-alliances__grid fade-up">
        {partners.map((p) => (
          <a
            class="pt-alliances__logo-card"
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Visit ${p.name}`}
            title={p.name}
          >
            <img src={p.logo} alt={p.name} loading="lazy" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ 3. CASE STUDIES ════════ -->
  <section class="pt-cases">
    <div class="mnc-container">
      <div class="pt-cases__head fade-up">
        <span class="pt-tag">Proven Performance</span>
        <h2 class="pt-cases__title">Case Studies in Partnership</h2>
      </div>

      <div class="pt-cases__grid">
        {caseStudies.map((cs) => (
          <article class="pt-case fade-up">
            <div class="pt-case__img-wrap">
              <img src={cs.img} alt={cs.title} class="pt-case__img" loading="lazy" />
              <span class="pt-case__img-tag">{cs.tag}</span>
            </div>
            <h3 class="pt-case__title">{cs.title}</h3>
            <p class="pt-case__desc">{cs.desc}</p>
            {(cs.value || cs.location) && (
              <div class="pt-case__meta">
                {cs.value && <span class="pt-case__meta-item"><strong>Project Value:</strong> {cs.value}</span>}
                {cs.location && <span class="pt-case__meta-item"><strong>Location:</strong> {cs.location}</span>}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <PageCTA
    eyebrow="The full picture"
    title="There's more to the network<br/>than the names on this page."
    image="/images/showcase/ri-civil-compound-aerial.png"
    links={[
      { label: 'About GMP', href: '/about' },
      { label: 'Our Services', href: '/services' },
    ]}
  />

  <Footer slot="footer" />
</Layout>

<style>
  .mnc-container { max-width: 1440px; margin: 0 auto; padding: 0 1.5rem; }

  .pt-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-bottom: 20px;
  }
  .pt-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ink);
    flex-shrink: 0;
  }

  /* ═══ 1. HERO ═══ */
  .pt-hero {
    position: relative;
    background: #fff;
    padding: 0;
  }

  .pt-hero__inner {
    position: relative;
    height: 480px;
    overflow: hidden;
    border-radius: 0;
    background: linear-gradient(165deg, var(--navy) 0%, var(--navy-dark) 50%, var(--navy-light) 100%);
  }

  .pt-hero__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 75% 20%, rgba(224, 161, 53, 0.07) 0%, transparent 55%);
    pointer-events: none;
  }

  .pt-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
  }

  .pt-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(30,58,102,.5) 0%, rgba(30,58,102,.92) 100%);
    z-index: 1;
  }

  .pt-hero__content {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 1.5rem 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .pt-hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
    margin-bottom: 20px;
    width: fit-content;
  }

  .pt-hero__tag::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .pt-hero__h1 {
    font-family: var(--font-primary);
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--white);
    letter-spacing: -2px;
    text-transform: none;
    margin-bottom: 20px;
  }

  .pt-hero__h1-sub {
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
  }

  .pt-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,.5);
    max-width: 480px;
    margin: 0;
  }

  /* ═══ 2. ALLIANCES (aeline) ═══ */
  .pt-alliances {
    background: var(--paper);
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }

  .pt-alliances__top {
    display: grid;
    grid-template-columns: 0.45fr 0.55fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 56px;
  }

  .pt-alliances__title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #0d1c33;
    line-height: 1.15;
    margin: 0;
  }

  .pt-alliances__desc {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
    max-width: 34rem;
  }

  .pt-alliances__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .pt-alliances__logo-card {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 36px 28px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--paper);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .pt-alliances__logo-card:hover {
    background: var(--paper-2);
    border-color: #d6d6d1;
    transform: translateY(-2px);
  }

  .pt-alliances__logo-card:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 3px;
  }

  .pt-alliances__logo-card img {
    height: 40px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.8;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .pt-alliances__logo-card:hover img {
    filter: grayscale(0);
    opacity: 1;
  }

  /* ═══ 3. CASE STUDIES (aeline) ═══ */
  .pt-cases {
    background: var(--paper-2);
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }

  .pt-cases__head {
    margin-bottom: 48px;
  }

  .pt-cases__title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #0d1c33;
    line-height: 1.15;
    margin: 0;
  }

  .pt-cases__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .pt-case {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .pt-case:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: #d6d6d1;
  }

  .pt-case__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    margin: 12px 12px 0;
    border-radius: var(--radius-lg);
  }

  .pt-case__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .pt-case:hover .pt-case__img { transform: scale(1.04); }

  .pt-case__img-tag {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(6px);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
  }

  .pt-case__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    padding: 24px 24px 8px;
  }

  .pt-case__desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--muted);
    padding: 0 24px;
    margin: 0 0 20px;
  }

  .pt-case__meta {
    display: flex;
    gap: 24px;
    padding: 16px 24px 24px;
    border-top: 1px solid var(--line);
    margin-top: 8px;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .pt-case__meta-item strong {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
    font-size: 0.68rem;
    color: var(--ink);
    display: block;
    margin-bottom: 2px;
  }

  /* ═══ 2. AFFILIATED ENTITIES (aeline) ═══ */
  .pt-entities {
    background: var(--paper-2);
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }

  .pt-entities__head {
    margin-bottom: 56px;
    max-width: 52rem;
  }

  .pt-entities__title {
    font-family: var(--font-secondary);
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #0d1c33;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .pt-entities__sub {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  .pt-entities__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .pt-entity {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .pt-entity:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: #d6d6d1;
  }

  .pt-entity:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 3px;
  }

  .pt-entity__logo-wrap {
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }

  .pt-entity__logo {
    max-width: 100%;
    max-height: 64px;
    object-fit: contain;
  }

  .pt-entity__body {
    padding: 24px;
  }

  .pt-entity__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 6px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .pt-entity__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: transform 0.25s ease, opacity 0.25s ease, color 0.25s ease;
  }
  .pt-entity:hover .pt-entity__arrow,
  .pt-entity:focus-visible .pt-entity__arrow {
    opacity: 1;
    transform: translate(0, 0);
    color: var(--ink);
  }

  .pt-entity__focus {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
  }

  .pt-entity__desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  /* ═══ 3. ISO CERTIFICATIONS ═══ */
  .pt-iso {
    background: var(--off-white);
    padding: 56px 0;
  }

  .pt-iso__head {
    margin-bottom: 48px;
  }

  .pt-iso__title {
    font-family: var(--font-secondary);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--dark-text);
    margin-bottom: 12px;
  }

  .pt-iso__sub {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-gray);
    max-width: 640px;
    margin: 0;
  }

  .pt-iso__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .pt-iso__card {
    padding: 36px 32px;
    background: var(--white);
    border: 1px solid rgba(0,0,0,.06);
    margin: -0.5px;
    transition: box-shadow 0.3s ease;
  }

  .pt-iso__card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,.06);
    z-index: 1;
    position: relative;
  }

  .pt-iso__card-icon {
    color: var(--amber-dark);
    margin-bottom: 16px;
  }

  .pt-iso__card-title {
    font-family: var(--font-secondary);
    font-size: 22px;
    font-weight: 900;
    color: var(--dark-text);
    margin-bottom: 4px;
  }

  .pt-iso__card-sub {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-gray);
    margin-bottom: 16px;
  }

  .pt-iso__card-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-gray);
    margin: 0;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .pt-alliances__top {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .pt-alliances__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .pt-cases__grid {
      grid-template-columns: 1fr;
    }

    .pt-iso__grid { grid-template-columns: 1fr; }
    .pt-entities__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .pt-hero__inner { height: 380px; }

    .pt-alliances,
    .pt-cases,
    .pt-iso,
    .pt-entities {
      padding: 40px 0;
    }

    .pt-iso__grid { grid-template-columns: 1fr; }
    .pt-entities__grid { grid-template-columns: 1fr; }
  }
</style>
