---
// Soft "while you're here, here's more of us" block that sits directly above
// the footer on every interior page. It mirrors the homepage CTA's treatment
// (image + navy overlay + centered copy) but leans on a friendlier tone —
// the goal isn't to push a conversion, it's to invite the reader deeper into
// the site.

export interface PageCTALink {
  label: string;
  href: string;
  variant?: 'primary' | 'ghost';
}

export interface Props {
  eyebrow?: string;
  title: string;
  image?: string;
  imageAlt?: string;
  links?: PageCTALink[];
}

const {
  eyebrow = 'More from GMP',
  title,
  image = '/images/showcase/west-crane.jpg',
  imageAlt = '',
  links = [],
} = Astro.props;
---

<section class="page-cta" aria-label={eyebrow}>
  <div class="page-cta__panel slide-in-up">
    <img
      src={image}
      alt={imageAlt}
      class="page-cta__img"
      loading="lazy"
      aria-hidden={imageAlt ? undefined : 'true'}
    />
    <div class="page-cta__overlay"></div>
    <div class="page-cta__inner">
      <h2 class="page-cta__title" set:html={title}></h2>
      {links.length > 0 && (
        <div class="page-cta__actions">
          {links.map((link) => (
            <a
              href={link.href}
              class={`page-cta__btn page-cta__btn--${link.variant ?? 'ghost'}`}
            >
              {link.label}
              {link.variant === 'primary' && (
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                  <path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .page-cta {
    position: relative;
    background: #fff;
    padding: clamp(6px, 0.6vw, 10px) clamp(6px, 0.6vw, 10px) 0;
  }

  .page-cta__panel {
    position: relative;
    overflow: hidden;
    min-height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 96px 1.5rem;
    isolation: isolate;
    border-radius: clamp(14px, 1.6vw, 22px) clamp(14px, 1.6vw, 22px) 0 0;
  }

  .page-cta__panel.slide-in-up {
    opacity: 0;
    transform: translateY(120px);
    transition:
      opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.35s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.05s;
  }
  .page-cta__panel.slide-in-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .page-cta__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .page-cta__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26, 42, 66, 0.78) 0%, rgba(17, 28, 48, 0.88) 100%);
    z-index: -1;
  }

  .page-cta__inner {
    position: relative;
    max-width: 840px;
    width: 100%;
    text-align: center;
    color: #fff;
  }

  .page-cta__tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 22px;
  }
  .page-cta__tag::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--amber, #f0c645);
  }

  .page-cta__title {
    font-family: var(--font-secondary);
    font-size: clamp(26px, 3.4vw, 44px);
    font-weight: 500;
    line-height: 1.25;
    color: #fff;
    margin: 0 0 32px;
    letter-spacing: -0.005em;
  }

  .page-cta__actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .page-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.25s, color 0.25s, border-color 0.25s, gap 0.25s;
  }

  .page-cta__btn--primary {
    background: var(--amber, #f0c645);
    color: #111;
    border: 1px solid var(--amber, #f0c645);
  }
  .page-cta__btn--primary:hover {
    background: #f7d06b;
    border-color: #f7d06b;
    gap: 12px;
  }

  .page-cta__btn--ghost {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.45);
  }
  .page-cta__btn--ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #fff;
  }

  @media (max-width: 640px) {
    .page-cta__panel {
      min-height: 320px;
      padding: 64px 1.25rem;
    }
    .page-cta__btn {
      padding: 12px 20px;
      font-size: 12px;
    }
  }
</style>
