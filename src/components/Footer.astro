---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/about', label: 'About Us' },
  { href: '/about#subsidiaries', label: 'Subsidiaries' },
  { href: '/about#leadership', label: 'Leadership' },
  { href: '/about#mission', label: 'Mission & Values' },
  { href: '/about#history', label: 'History' },
];

const departments = [
  { href: '/departments#modular', label: 'Modular' },
  { href: '/departments#project-management', label: 'Project Mgmt' },
  { href: '/departments#dod-military', label: 'DoD / Military' },
  { href: '/departments#healthcare', label: 'Healthcare' },
  { href: '/departments#civil', label: 'Civil' },
];

const resources = [
  { href: '/partners', label: 'Partner Network' },
  { href: '/about#leadership', label: 'Leadership' },
  { href: '/contact', label: 'Careers' },
  { href: '#', label: '28 Day ADU' },
  { href: '#', label: 'FAQs' },
];
---

<footer class="ftr">
  <div class="ftr__outer">
    <div class="ftr__card">
      <!-- Top: newsletter CTA + nav columns -->
      <div class="ftr__top">
        <div class="ftr__cta">
          <a href="/" class="ftr__logo-link" aria-label="Home">
            <img src="/images/logo/gmp-globe-white.svg" alt="Global Modular Partners" class="ftr__logo" />
            <span class="ftr__logo-word"><span>GLOBAL</span><span>MODULAR</span><span>PARTNERS</span></span>
          </a>
          <p class="ftr__lede">Field-tested perspective. Occasional updates on modular delivery, regulated sectors, and how we partner with owners and agencies — written by the team that executes the work.</p>
          <form class="ftr__form" onsubmit="event.preventDefault();">
            <input class="ftr__field" type="email" placeholder="Enter your email" required />
            <button class="ftr__btn" type="submit" aria-label="Subscribe">
              <span class="ftr__btn-text">Subscribe</span>
              <span class="ftr__btn-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
              </span>
            </button>
          </form>
        </div>

        <div class="ftr__nav-grid">
          <div class="ftr__nav">
            <div class="ftr__nav-title">Quick View</div>
            <div class="ftr__nav-links">
              {quickLinks.map((l) => (
                <a href={l.href} class="ftr__nav-link">{l.label}</a>
              ))}
            </div>
          </div>
          <div class="ftr__nav">
            <div class="ftr__nav-title">Departments</div>
            <div class="ftr__nav-links">
              {departments.map((d) => (
                <a href={d.href} class="ftr__nav-link">{d.label}</a>
              ))}
            </div>
          </div>
          <div class="ftr__nav">
            <div class="ftr__nav-title">Resources</div>
            <div class="ftr__nav-links">
              {resources.map((r) => (
                <a href={r.href} class="ftr__nav-link">{r.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Contact strip -->
      <div class="ftr__info">
        <a href="mailto:info@globalmodularpartners.com" class="ftr__info-item">
          <span class="ftr__info-label">Email</span>
          <span class="ftr__info-value">info@globalmodularpartners.com</span>
        </a>
        <a href="tel:+15105550199" class="ftr__info-item">
          <span class="ftr__info-label">Phone</span>
          <span class="ftr__info-value">(510) 555-0199</span>
        </a>
        <a href="/contact" class="ftr__info-item">
          <span class="ftr__info-label">Headquarters</span>
          <span class="ftr__info-value">Oakland, California</span>
        </a>
      </div>

      <!-- Base bar -->
      <div class="ftr__base">
        <div class="ftr__base-left">
          <span class="ftr__base-text">&copy; {currentYear} Global Modular Partners, LLC</span>
        </div>
        <div class="ftr__base-links">
          <a href="#" class="ftr__base-link">Privacy</a>
          <a href="#" class="ftr__base-link">Terms</a>
          <a href="#" class="ftr__base-link">Sitemap</a>
        </div>
        <a href="#" class="ftr__gotop" id="ftr-gotop" aria-label="Go to top">
          <span>Back to top</span>
          <span class="ftr__gotop-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</footer>

<script>
  const goTop = document.getElementById('ftr-gotop');
  goTop?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

<style>
  /* ════════════════════════════════════════════
     Aeline-style footer — rounded dark card
     ════════════════════════════════════════════ */
  .ftr {
    position: relative;
    z-index: 3;
    background-color: var(--paper, #fff);
    font-family: var(--font-primary);
  }

  .ftr__outer {
    max-width: none;
    margin: 0;
    padding: 0;
  }

  .ftr__card {
    background-color: var(--ink, #1d1d1d);
    color: var(--on-ink, #fff);
    border-radius: 0;
    padding: clamp(2.5rem, 5vw, 5rem) clamp(1.5rem, 4vw, 4rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  /* Top grid: CTA + nav columns */
  .ftr__top {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  /* Left: logo + lede + form */
  .ftr__logo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    margin-bottom: 1.5rem;
  }
  .ftr__logo {
    width: 44px;
    height: 44px;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,.3));
  }
  .ftr__logo-word {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 2.4px;
    line-height: 1.12;
    color: var(--on-ink);
  }
  .ftr__logo-word > span:nth-child(2) { color: var(--accent); }

  .ftr__lede {
    color: var(--on-ink-muted, rgba(255,255,255,.62));
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 26rem;
    margin-bottom: 1.75rem;
  }

  .ftr__form {
    display: flex;
    align-items: center;
    background-color: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: var(--radius-pill, 999px);
    padding: 0.35rem 0.35rem 0.35rem 1.25rem;
    max-width: 26rem;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }
  .ftr__form:focus-within {
    border-color: rgba(255,255,255,.3);
    background-color: rgba(255,255,255,.09);
  }
  .ftr__field {
    flex: 1;
    padding: 0;
    border: none;
    background: transparent;
    font-family: var(--font-primary);
    font-size: 0.95rem;
    color: var(--on-ink);
    outline: none;
    min-width: 0;
  }
  .ftr__field::placeholder { color: rgba(255,255,255,.4); }

  .ftr__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0.2rem 0.2rem 0.85rem;
    background-color: var(--on-ink, #fff);
    color: var(--ink, #1d1d1d);
    border: 0;
    border-radius: var(--radius-pill, 999px);
    font-family: var(--font-primary);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    flex: none;
    transition: background-color var(--transition-base);
  }
  .ftr__btn:hover { background-color: #f3f3f0; }
  .ftr__btn-text { padding-left: 0.1rem; }
  .ftr__btn-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background-color: var(--ink);
    color: var(--on-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
  }
  .ftr__btn-icon svg { width: 13px; height: 13px; }

  /* Right: nav columns */
  .ftr__nav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .ftr__nav { display: flex; flex-direction: column; gap: 1rem; }
  .ftr__nav-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
    font-weight: 500;
  }
  .ftr__nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ftr__nav-link {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--on-ink);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: opacity var(--transition-fast);
    opacity: 0.82;
  }
  .ftr__nav-link:hover { opacity: 1; color: var(--accent); }

  /* Contact strip — separated by hairline, 3 tiles */
  .ftr__info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid rgba(255,255,255,.08);
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .ftr__info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.5rem 0;
    padding-right: 1.5rem;
    color: var(--on-ink);
    text-decoration: none;
    border-right: 1px solid rgba(255,255,255,.08);
    transition: opacity var(--transition-fast);
  }
  .ftr__info-item:last-child { border-right: none; padding-right: 0; }
  .ftr__info-item + .ftr__info-item { padding-left: 1.5rem; }
  .ftr__info-item:hover { opacity: .75; }
  .ftr__info-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
    font-weight: 500;
  }
  .ftr__info-value {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--on-ink);
  }

  /* Base bar */
  .ftr__base {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,.45);
  }
  .ftr__base-text { color: rgba(255,255,255,.55); }
  .ftr__base-links { display: flex; gap: 1.5rem; }
  .ftr__base-link {
    color: rgba(255,255,255,.55);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .ftr__base-link:hover { color: var(--on-ink); }

  .ftr__gotop {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--on-ink);
    text-decoration: none;
    padding: 0.4rem 0.4rem 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    background-color: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    transition: background-color var(--transition-fast);
  }
  .ftr__gotop:hover { background-color: rgba(255,255,255,.12); }
  .ftr__gotop-icon {
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 999px;
    background-color: var(--on-ink);
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .ftr__gotop-icon svg { width: 12px; height: 12px; }

  /* Responsive */
  @media (max-width: 960px) {
    .ftr__top { grid-template-columns: 1fr; }
    .ftr__nav-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .ftr__outer { padding: 0; }
    .ftr__card { border-radius: 0; padding: 2rem 1.25rem; }
    .ftr__nav-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .ftr__info { grid-template-columns: 1fr; }
    .ftr__info-item {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,.08);
      padding: 1rem 0;
    }
    .ftr__info-item + .ftr__info-item { padding-left: 0; }
    .ftr__info-item:last-child { border-bottom: none; }
    .ftr__base { flex-direction: column; align-items: flex-start; }
  }
</style>
