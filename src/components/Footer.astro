---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/about', label: 'About Us' },
  { href: '/services', label: 'Services' },
  { href: '/partners', label: 'Partners' },
  { href: '/news', label: 'News' },
  { href: '/contact', label: 'Contact' },
];

const departments = [
  { href: '/departments/modular', label: 'Modular' },
  { href: '/departments/project-management', label: 'Project Mgmt' },
  { href: '/departments/dod-military', label: 'DoD / Military' },
  { href: '/departments/healthcare', label: 'Healthcare' },
  { href: '/departments/civil', label: 'Civil' },
];

const resources = [
  { href: '/news', label: 'News & Insights' },
  { href: '/partners', label: 'Partner Network' },
  { href: '/about', label: 'Leadership' },
  { href: '/contact', label: 'Careers' },
  { href: '#', label: 'FAQs' },
];
---

<footer class="ftr">
  <!-- ── Top bar: logo + go-to-top ── -->
  <div class="ftr__brand-wrap">
    <div class="ftr__container">
      <div class="ftr__brand-row">
        <a href="/" class="ftr__logo-link" aria-label="Home">
          <img src="/images/logo/gmp-logo-final.png" alt="GMP" style="height:36px;width:auto;" />
        </a>
        <a href="#" class="ftr__gotop" id="ftr-gotop">
          <div class="ftr__gotop-inner">
            <span class="ftr__gotop-label">Go To Top</span>
            <span class="ftr__gotop-icon">
              <svg fill="none" viewBox="0 0 25 25" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.4 11.76s-4.52-6.13-6.13-6.13S6.13 11.76 6.13 11.76" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/>
                <path d="M18.4 18.91s-4.52-6.13-6.13-6.13S6.13 18.91 6.13 18.91" opacity="0.4" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.67"/>
              </svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </div>

  <div class="ftr__line"></div>

  <!-- ── Main menu area: newsletter CTA + 3 nav columns ── -->
  <div class="ftr__menu-wrap">
    <div class="ftr__container">
      <div class="ftr__menu-row">
        <!-- Newsletter CTA -->
        <div class="ftr__cta">
          <h3 class="ftr__cta-title">Stay Informed. Stay Ahead.</h3>
          <p class="ftr__cta-text">Join our community and receive insights on innovation, industry trends, and corporate updates — delivered straight to your inbox.</p>
          <form class="ftr__cta-form" onsubmit="event.preventDefault();">
            <input class="ftr__cta-field" type="email" placeholder="Enter Your Email" required />
            <button class="ftr__cta-btn" type="submit">Subscribe</button>
          </form>
        </div>

        <!-- Nav columns -->
        <div class="ftr__nav-grid">
          <div class="ftr__nav">
            <div class="ftr__nav-title">Quick View</div>
            <div class="ftr__nav-links">
              {quickLinks.map((l) => (
                <a href={l.href} class="ftr__nav-link">{l.label}</a>
              ))}
            </div>
          </div>
          <div class="ftr__nav">
            <div class="ftr__nav-title">Departments</div>
            <div class="ftr__nav-links">
              {departments.map((d) => (
                <a href={d.href} class="ftr__nav-link">{d.label}</a>
              ))}
            </div>
          </div>
          <div class="ftr__nav">
            <div class="ftr__nav-title">Resources</div>
            <div class="ftr__nav-links">
              {resources.map((r) => (
                <a href={r.href} class="ftr__nav-link">{r.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="ftr__line"></div>

  <!-- ── Contact info strip: 3 columns ── -->
  <div class="ftr__info-wrap">
    <div class="ftr__container">
      <div class="ftr__info-row">
        <a href="mailto:info@globalmodularpartners.com" class="ftr__info">
          <div class="ftr__info-icon-wrap">
            <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="ftr__info-text">
            <span class="ftr__info-label">Email Address</span>
            <span class="ftr__info-value">info@globalmodularpartners.com</span>
          </div>
        </a>
        <a href="tel:+15105550199" class="ftr__info ftr__info--mid">
          <div class="ftr__info-icon-wrap">
            <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="ftr__info-text">
            <span class="ftr__info-label">Phone Number</span>
            <span class="ftr__info-value">(510) 555-0199</span>
          </div>
        </a>
        <a href="/contact" class="ftr__info ftr__info--last">
          <div class="ftr__info-icon-wrap">
            <svg fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="ftr__info-text">
            <span class="ftr__info-label">Headquarters</span>
            <span class="ftr__info-value">San Francisco Bay Area / Oakland, CA</span>
          </div>
        </a>
      </div>
    </div>
  </div>

  <div class="ftr__line"></div>

  <!-- ── Copyright bar ── -->
  <div class="ftr__copy-wrap">
    <div class="ftr__container">
      <div class="ftr__copy-row">
        <span class="ftr__copy-text">&copy; {currentYear} Global Modular Partners, LLC</span>
        <span class="ftr__copy-dot"></span>
        <a href="#" class="ftr__copy-link">Privacy Policy</a>
        <span class="ftr__copy-dot"></span>
        <a href="#" class="ftr__copy-link">Terms of Service</a>
        <span class="ftr__copy-dot"></span>
        <a href="#" class="ftr__copy-link">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const goTop = document.getElementById('ftr-gotop');
  if (goTop) {
    goTop.addEventListener('click', (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style>
  /* ════════════════════════════════════════════
     MNC-faithful Footer — GMP color scheme
     ════════════════════════════════════════════ */

  .ftr {
    background-color: var(--navy-dark, #1a2a42);
    font-family: var(--font-primary, 'Barlow', sans-serif);
    border-top: 3px solid var(--amber, #E0A135);
  }

  .ftr__container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ftr__line {
    height: 1px;
    width: 100%;
    background-color: rgba(255,255,255,.08);
  }


  /* ── Brand bar ── */
  .ftr__brand-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-left: 1px solid rgba(255,255,255,.08);
    border-right: 1px solid rgba(255,255,255,.08);
  }

  .ftr__logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 24px;
    border-right: 1px solid rgba(255,255,255,.08);
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .ftr__logo-link:hover {
    opacity: 0.8;
  }

  .ftr__gotop {
    display: flex;
    align-items: center;
    padding: 20px 24px;
    border-left: 1px solid rgba(255,255,255,.08);
    text-decoration: none;
    color: var(--white, #fff);
    transition: opacity 0.3s;
  }

  .ftr__gotop:hover {
    color: var(--amber, #E0A135);
  }
  .ftr__gotop:hover .ftr__gotop-label {
    color: var(--amber, #E0A135);
  }

  .ftr__gotop-inner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ftr__gotop-label {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--white, #fff);
  }

  .ftr__gotop-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
  }

  .ftr__gotop-icon svg {
    width: 100%;
    height: 100%;
  }


  /* ── Menu area ── */
  .ftr__menu-row {
    display: flex;
    gap: 48px;
    padding: 64px 24px;
    border-left: 1px solid rgba(255,255,255,.08);
    border-right: 1px solid rgba(255,255,255,.08);
    align-items: flex-start;
  }

  .ftr__cta {
    flex: none;
    width: 100%;
    max-width: 400px;
  }

  .ftr__cta-title {
    font-family: var(--font-secondary, 'Sora', sans-serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--white, #fff);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .ftr__cta-text {
    font-size: 14px;
    color: rgba(255,255,255,.45);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .ftr__cta-form {
    display: flex;
    height: 48px;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 4px;
    overflow: hidden;
    max-width: 340px;
    transition: border-color 0.3s;
  }
  .ftr__cta-form:focus-within {
    border-color: var(--amber, #E0A135);
  }

  .ftr__cta-field {
    flex: 1;
    padding: 0 16px;
    border: none;
    background: transparent;
    font-family: var(--font-primary, 'Barlow', sans-serif);
    font-size: 14px;
    color: var(--white, #fff);
    outline: none;
  }

  .ftr__cta-field::placeholder {
    color: rgba(255,255,255,.4);
  }

  .ftr__cta-btn {
    padding: 0 16px;
    background-color: var(--amber, #E0A135);
    border: none;
    font-family: var(--font-primary, 'Barlow', sans-serif);
    font-size: 14px;
    font-weight: 700;
    color: var(--navy-dark, #1a2a42);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: background-color 0.25s;
    white-space: nowrap;
  }

  .ftr__cta-btn:hover {
    background-color: var(--amber-dark, #c48b25);
  }


  /* ── Nav columns ── */
  .ftr__nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    flex: 1;
  }

  .ftr__nav {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ftr__nav-title {
    font-family: var(--font-secondary, 'Sora', sans-serif);
    font-size: 16px;
    font-weight: 600;
    color: var(--white, #fff);
    line-height: 1.4;
  }

  .ftr__nav-links {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ftr__nav-link {
    font-size: 14px;
    font-weight: 400;
    color: rgba(255,255,255,.4);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s, opacity 0.3s;
    opacity: 0.7;
  }

  .ftr__nav-link:hover {
    color: var(--amber, #E0A135);
    opacity: 1;
  }


  /* ── Contact info strip ── */
  .ftr__info-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border-left: 1px solid rgba(255,255,255,.08);
    border-right: 1px solid rgba(255,255,255,.08);
  }

  .ftr__info {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 24px 32px;
    border-right: 1px solid rgba(255,255,255,.08);
    text-decoration: none;
    transition: background-color 0.25s;
  }

  .ftr__info:hover {
    background-color: rgba(255,255,255,.03);
  }

  .ftr__info--last {
    border-right: none;
  }

  .ftr__info-icon-wrap {
    width: 40px;
    height: 40px;
    padding: 8px;
    border-radius: 6px;
    background-color: rgba(255,255,255,.06);
    color: rgba(255,255,255,.5);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ftr__info-icon-wrap svg {
    width: 100%;
    height: 100%;
  }

  .ftr__info-label {
    display: block;
    font-size: 12px;
    color: rgba(255,255,255,.35);
    font-weight: 300;
    letter-spacing: 0.3px;
    margin-bottom: 2px;
  }

  .ftr__info-value {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--white, #fff);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }


  /* ── Copyright bar ── */
  .ftr__copy-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    padding: 20px 24px 40px;
    border-left: 1px solid rgba(255,255,255,.08);
    border-right: 1px solid rgba(255,255,255,.08);
    font-size: 14px;
    color: rgba(255,255,255,.4);
  }

  .ftr__copy-text {
    display: inline;
  }

  .ftr__copy-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: rgba(255,255,255,.25);
    margin: 0 10px;
    vertical-align: middle;
  }

  .ftr__copy-link {
    color: rgba(255,255,255,.4);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    transition: color 0.3s, text-decoration-color 0.3s;
  }

  .ftr__copy-link:hover {
    color: var(--white, #fff);
    text-decoration-color: var(--white, #fff);
  }


  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .ftr__menu-row {
      flex-direction: column;
      gap: 40px;
    }

    .ftr__cta {
      max-width: 100%;
    }

    .ftr__cta-form {
      max-width: 100%;
    }

    .ftr__nav-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .ftr__nav-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .ftr__info-row {
      grid-template-columns: 1fr;
    }

    .ftr__info {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    .ftr__info--last {
      border-bottom: none;
    }

    .ftr__copy-row {
      flex-direction: column;
      gap: 8px;
    }

    .ftr__copy-dot {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .ftr__menu-row {
      padding: 40px 16px;
    }

    .ftr__nav-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ftr__brand-row {
      border-left: none;
      border-right: none;
    }
  }
</style>
