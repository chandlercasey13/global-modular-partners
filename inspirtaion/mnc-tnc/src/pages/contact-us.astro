  <script is:inline>
    (function() {
      var staggerMap = {};

      function isInViewport(el) {
        var rect = el.getBoundingClientRect();
        return rect.top < (window.innerHeight || document.documentElement.clientHeight) &&
               rect.bottom > 0 && rect.left < (window.innerWidth || document.documentElement.clientWidth) &&
               rect.right > 0;
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var parent = el.parentElement;
          var key = parent ? (parent.id || parent.className.split(" ")[0] || "r") : "r";
          if (!staggerMap[key]) staggerMap[key] = 0;
          var delay = staggerMap[key] * 100;
          staggerMap[key]++;
          setTimeout(function() { el.classList.add("wf-visible"); }, delay);
          observer.unobserve(el);
        });
      }, { threshold: 0.01, rootMargin: "50px 0px 50px 0px" });

      document.addEventListener("DOMContentLoaded", function() {
        var animEls = [];
        document.querySelectorAll("[data-w-id]").forEach(function(el) {
          if (el.closest(".w-nav, .header-wrapper, .navbar, nav, footer, .w-commerce-commercecartwrapper")) return;
          el.classList.add("wf-anim");
          animEls.push(el);
        });

        requestAnimationFrame(function() {
          animEls.forEach(function(el) {
            if (isInViewport(el)) {
              el.classList.add("wf-visible");
            } else {
              observer.observe(el);
            }
          });
        });

        document.querySelectorAll(".w-slider").forEach(function(slider) {
          var mask = slider.querySelector(".w-slider-mask");
          var slides = slider.querySelectorAll(".w-slide");
          var prev = slider.querySelector(".w-slider-arrow-left");
          var next = slider.querySelector(".w-slider-arrow-right");
          if (!mask || slides.length === 0) return;
          var cur = 0, total = slides.length;
          slides.forEach(function(s, i) {
            s.style.position = i === 0 ? "relative" : "absolute";
            s.style.top = "0"; s.style.left = "0"; s.style.width = "100%";
            s.style.opacity = i === 0 ? "1" : "0";
            s.style.transition = "opacity 0.5s ease";
            if (i !== 0) s.style.pointerEvents = "none";
          });
          mask.style.position = "relative"; mask.style.overflow = "hidden";
          function go(idx) {
            slides[cur].style.opacity = "0"; slides[cur].style.pointerEvents = "none"; slides[cur].style.position = "absolute";
            cur = ((idx % total) + total) % total;
            slides[cur].style.opacity = "1"; slides[cur].style.pointerEvents = ""; slides[cur].style.position = "relative";
          }
          if (prev) prev.addEventListener("click", function(e) { e.preventDefault(); go(cur - 1); });
          if (next) next.addEventListener("click", function(e) { e.preventDefault(); go(cur + 1); });
          var autoplay = slider.getAttribute("data-autoplay") === "true";
          var delay = parseInt(slider.getAttribute("data-delay")) || 4000;
          if (autoplay && delay > 0) setInterval(function() { go(cur + 1); }, delay);
        });

        document.querySelectorAll(".w-dropdown").forEach(function(dd) {
          var toggle = dd.querySelector(".w-dropdown-toggle");
          var list = dd.querySelector(".w-dropdown-list");
          if (!toggle || !list) return;
          var isHover = dd.getAttribute("data-hover") === "true";
          if (isHover) {
            dd.addEventListener("mouseenter", function() { list.style.display = "block"; dd.classList.add("w--open"); });
            dd.addEventListener("mouseleave", function() { list.style.display = ""; dd.classList.remove("w--open"); });
          } else {
            toggle.addEventListener("click", function(e) {
              e.preventDefault();
              var open = dd.classList.toggle("w--open");
              list.style.display = open ? "block" : "";
            });
          }
        });
      });
    })();
  </script>
